              icon: 'trash-2', iconBg: 'rgba(239,68,68,.12)', iconColor: '#f87171',
              confirmText: '<%= t.ticketsPanels.delete %>',
              confirmClass: 'btn-danger',
              onConfirm: async () => {
                try {
                  const r = await fetch('/dashboard/<%= guildId %>/tickets/panels/delete', {
                    method: 'DELETE', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ panelId }),
                  });
                  if (!r.ok) { const e = await r.json(); alert('Error: ' + (e.error || r.status)); return; }
                  const idx = _panelList.findIndex(p => p.id === panelId);
                  if (idx >= 0) _panelList.splice(idx, 1);
                  const opt = pSel.querySelector(`option[value="${panelId}"]`);
                  if (opt) opt.remove();
                  document.getElementById('panel-count-badge').textContent = _panelList.length + ' panel' + (_panelList.length !== 1 ? 's' : '');
                  if (_panelList.length > 0) {
                    const last = _panelList[_panelList.length - 1];
                    _pSelSet(last.id); loadPanelData(last); _updatePanelSendStatus(last.messageId || null);
                    document.getElementById('panel-delete-btn').style.display = '';

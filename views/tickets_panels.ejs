          // ── Banner upload helpers ───────────────────────────────────────────────
          function _showBanner(urlId, prevId, imgId, value) {
            const urlInp = document.getElementById(urlId);
            const prev = document.getElementById(prevId);
            const img = document.getElementById(imgId);
            if (!urlInp || !prev || !img) return;
            if (value) { urlInp.value = value; img.src = value; prev.style.display = ''; }
            else { urlInp.value = ''; img.src = ''; prev.style.display = 'none'; }
          }

          function _initBannerUpload(fileId, urlId, prevId, imgId, clearId, progId) {
            const fileInp = document.getElementById(fileId);
            const urlInp = document.getElementById(urlId);
            const prev = document.getElementById(prevId);
            const img = document.getElementById(imgId);
            const clearBtn = document.getElementById(clearId);
            const prog = document.getElementById(progId);
            if (!fileInp || !urlInp || !prev || !img || !clearBtn || !prog) return;
            function _show(url) {
              if (url) { img.src = url; prev.style.display = ''; }
              else { img.src = ''; prev.style.display = 'none'; }
            }
            urlInp.addEventListener('input', () => { _show(urlInp.value.trim()); markDirty(); });
            fileInp.addEventListener('change', async () => {
              const file = fileInp.files[0]; if (!file) return;
              const ok = ['image/png', 'image/jpeg', 'image/webp'];
              if (!ok.includes(file.type)) {
                alert('<%= t.ticketsPanels.onlyPNGJPGJPEGWEBPAllowed %>');
                fileInp.value = ''; return;
              }
              if (file.size > 20 * 1024 * 1024) {
                alert('<%= t.ticketsPanels.maxFileSizeIs20MB %>');
                fileInp.value = ''; return;
              }
              prog.style.display = '';
              const fd = new FormData(); fd.append('file', file);
              try {
                const r = await fetch('/dashboard/<%= guildId %>/tickets/upload-banner', { method: 'POST', body: fd });
                const d = await r.json();
                if (!r.ok) throw new Error(d.error || 'Upload failed');
                urlInp.value = d.url; _show(d.url); markDirty();
              } catch (err) { alert('Upload error: ' + err.message); }
              finally { prog.style.display = 'none'; fileInp.value = ''; }
            });
            clearBtn.addEventListener('click', () => { urlInp.value = ''; _show(''); markDirty(); });
          }

          // ── Send-status helpers ─────────────────────────────────────────────────
          function _updatePanelSendStatus(messageId) {
            const dot = document.getElementById('panel-send-dot');
            const txt = document.getElementById('panel-send-status');
            const editBtn = document.getElementById('panel-send-btn');
            const newBtn = document.getElementById('panel-resend-btn');
            const hidMsgId = document.getElementById('panel-message-id');
            if (hidMsgId) hidMsgId.value = messageId || '';
            if (!txt) return;
            const hasMsgId = !!messageId;
            const panelSel = !!document.getElementById('panel-id')?.value;
            if (dot) dot.className = 'send-dot ' + (hasMsgId ? 'sent' : 'unsent');
            txt.textContent = hasMsgId
              ? ('<%= t.ticketsPanels.sent %>')
              : ('<%= t.ticketsPanels.notSentYet %>');
            if (editBtn) editBtn.disabled = !hasMsgId || !panelSel;
            if (newBtn) newBtn.disabled = !panelSel;
          }
          function _updateMpSendStatus(messageId) {
            const dot = document.getElementById('mp-send-dot');
            const txt = document.getElementById('mp-send-status');
            const editBtn = document.getElementById('mp-send-btn');
            const newBtn = document.getElementById('mp-resend-btn');
            const hidMsgId = document.getElementById('mp-message-id');
            if (hidMsgId) hidMsgId.value = messageId || '';
            if (!txt) return;
            const hasMsgId = !!messageId;
            const mpSel = !!document.getElementById('mp-id')?.value;
            if (dot) dot.className = 'send-dot ' + (hasMsgId ? 'sent' : 'unsent');
            txt.textContent = hasMsgId
              ? ('<%= t.ticketsPanels.sent %>')
              : ('<%= t.ticketsPanels.notSentYet %>');
            if (editBtn) editBtn.disabled = !hasMsgId || !mpSel;

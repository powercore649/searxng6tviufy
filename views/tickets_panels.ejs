          const _guildRoles = JSON.parse(document.getElementById('guild-roles-data').textContent || '[]');

          function _loadPanelSupportRoles(roles) {
            const chips = document.getElementById('panel-support-roles-chips');
            if (!chips) return;
            chips.innerHTML = '';
            roles.forEach(id => _addSupportRoleChip(id));
          }

          function _addSupportRoleChip(roleId) {
            const chips = document.getElementById('panel-support-roles-chips');
            if (!chips) return;
            if (chips.querySelector(`[data-role-id="${roleId}"]`)) return;
            const roleName = (_guildRoles.find(r => r.id === roleId) || {}).name || roleId;
            const chip = document.createElement('span');
            chip.className = 'panel-support-role-pill selected';
            chip.dataset.roleId = roleId;
            chip.innerHTML = `@${roleName} <button type="button" style="background:none;border:none;color:inherit;cursor:pointer;padding:0 0 0 6px;font-size:1em;line-height:1" aria-label="remove">&times;</button>`;
            chip.querySelector('button').addEventListener('click', () => { chip.remove(); markDirty(); });
            chips.appendChild(chip);
          }

          const _AB_DEFAULTS = {
            close: { style: '4', labelMode: 'both' },
            claim: { style: '1', labelMode: 'both' },
            unclaim: { style: '2', labelMode: 'both' },
            add: { style: '2', labelMode: 'both' },
            remove: { style: '2', labelMode: 'both' },
          };

          function _loadActionBtns(p) {
            const mode = (p && p.actionBtnsMode) || 'buttons';
            const ab = (p && p.actionBtns) || {};
            const modeVal = document.getElementById('ab-mode-val');
            if (modeVal) modeVal.value = mode;
            document.querySelectorAll('.ab-mode-opt').forEach(b => b.classList.toggle('active', b.dataset.val === mode));
            const cfgWrap = document.getElementById('ab-btns-config');
            if (cfgWrap) cfgWrap.style.display = mode === 'select' ? 'none' : '';
            for (const key of Object.keys(_AB_DEFAULTS)) {
              const cfg = ab[key] || {};
              const emojiEl = document.getElementById(`ab-${key}-emoji`);
              const styleEl = document.getElementById(`ab-${key}-style-val`);
              const labelEl = document.getElementById(`ab-${key}-label-val`);
              if (emojiEl) emojiEl.value = cfg.emoji || '';
              const styleVal = String(cfg.style || _AB_DEFAULTS[key].style);
              if (styleEl) styleEl.value = styleVal;
              document.querySelectorAll(`#ab-${key}-style-group .ab-style-opt`).forEach(b => b.classList.toggle('active', b.dataset.val === styleVal));
              const labelMode = cfg.labelMode || _AB_DEFAULTS[key].labelMode;
              if (labelEl) labelEl.value = labelMode;
              document.querySelectorAll(`#ab-${key}-label-group .ab-label-opt`).forEach(b => b.classList.toggle('active', b.dataset.val === labelMode));
            }
          }

          function _getActionBtnsPayload() {
            const mode = document.getElementById('ab-mode-val')?.value || 'buttons';
            const btns = {};
            for (const key of Object.keys(_AB_DEFAULTS)) {
              btns[key] = {
                emoji: (document.getElementById(`ab-${key}-emoji`)?.value || '').trim(),
                style: parseInt(document.getElementById(`ab-${key}-style-val`)?.value, 10) || parseInt(_AB_DEFAULTS[key].style, 10),
                labelMode: document.getElementById(`ab-${key}-label-val`)?.value || 'both',
              };
            }
            return { actionBtnsMode: mode, actionBtns: btns };
          }


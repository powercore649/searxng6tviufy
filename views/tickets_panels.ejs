            { name: '😀 Smileys', emojis: ['😀', '😁', '😂', '🤣', '😊', '😇', '🙂', '😉', '🥰', '😍', '😎', '🤩', '🥳', '😋', '🤑', '🤗', '🤔', '🤫', '😐', '😏', '😒', '😞', '😔', '😕', '😢', '😭', '😤', '😡', '🤬', '🤯', '😳', '🥺', '😰', '😨', '😱', '🤪', '😵', '🥴', '🤒', '🤕', '😷', '🤧', '🤢', '🤮', '😴'] },
            { name: '👍 Hands', emojis: ['👍', '👎', '👌', '🤌', '✌️', '🤏', '🤞', '🤘', '👈', '👉', '👆', '👇', '☝️', '👏', '🖐️', '🖖', '💪', '🤜', '🤛', '🙌', '🫱', '🫲', '🤝', '🙏', '✍️', '👐', '🤲'] },
            { name: '❤️ Hearts', emojis: ['❤️', '🧡', '💛', '💚', '💙', '💜', '🖤', '🤍', '🤎', '💔', '❣️', '💕', '💞', '💓', '💗', '💖', '💘', '💝', '💟', '♥️'] },
            { name: '🎉 Events', emojis: ['🎉', '🎊', '🎈', '🎆', '🎇', '🥳', '🎂', '🎁', '🏆', '🥇', '🎖️', '🧨', '🍾', '🎶', '🎵', '🎤', '🔥', '✨', '💥', '🌟', '⭐', '🌈'] },
            { name: '✅ Symbols', emojis: ['✅', '❌', '❗', '❓', '💯', '🔝', '✔️', '❎', '🔴', '🟠', '🟡', '🟢', '🔵', '🟣', '⚫', '⚪', '🔶', '🔷', '🔸', '🔹', '💠', '🔮', '💎', '🔑', '🔒', '🔓', '⚡', '🌀', '♻️', '🔄'] },
            { name: '🌱 Nature', emojis: ['🌱', '🌲', '🌳', '🌴', '🌵', '🌷', '🌸', '🌹', '🌺', '🌻', '🌼', '🌿', '☘️', '🍀', '🍁', '🍂', '🍃', '🍄', '🦋', '🐢', '🐣', '🐱', '🐶', '🐼', '🦁', '🐯', '🦊', '🐺', '🦝'] },
            { name: '🎮 Fun', emojis: ['🎮', '👾', '🕹️', '🎲', '🧩', '🎯', '🎳', '🏓', '🛡️', '⚔️', '🎭', '🎪', '🎠', '🎡', '🎟️', '🎬', '📢', '📣', '🔔', '🔕', '📌', '📍', '🗂️', '📋', '📊', '💻', '🖥️', '🖨️'] },
          ];
          function _buildEmojiPicker() {
            const existing = document.getElementById('panel-ep');
            if (existing) { existing.remove(); return; }
            const anchor = document.getElementById('panel-emoji-anchor');
            if (!anchor) return;
            const picker = document.createElement('div');
            picker.id = 'panel-ep';
            picker.className = 'ep-panel';
            const hasSrv = _GUILD_EMOJIS.length > 0;
            picker.innerHTML = `
        <div class="ep-tabs">
          <button type="button" class="ep-tab active" data-ep="std">😀 Standard</button>
          ${hasSrv ? '<button type="button" class="ep-tab" data-ep="srv">🖥️ Server</button>' : ''}
        </div>
        <div class="ep-search"><input type="text" placeholder="<%= t.ticketsPanels.search %>" id="ep-q" autocomplete="off" /></div>
        <div class="ep-grid" id="ep-g"></div>`;
            anchor.appendChild(picker);
            let _tab = 'std';
            function renderEPGrid(q) {
              const grid = picker.querySelector('#ep-g');
              grid.innerHTML = '';
              q = (q || '').toLowerCase();
              if (_tab === 'std') {
                _EP_GROUPS.forEach(g => {
                  g.emojis.filter(e => !q || g.name.toLowerCase().includes(q)).forEach(em => {
                    const b = document.createElement('button');
                    b.type = 'button'; b.className = 'ep-btn'; b.textContent = em;
                    b.addEventListener('click', () => _pickPanelEmoji(em));
                    grid.appendChild(b);
                  });
                });
                if (!grid.children.length) grid.innerHTML = '<span class="ep-empty"><%= t.ticketsPanels.noResults %></span>';
              } else {
                const list = _GUILD_EMOJIS.filter(e => !q || e.name.toLowerCase().includes(q));
                if (!list.length) { grid.innerHTML = '<span class="ep-empty"><%= t.ticketsPanels.noServerEmojis %></span>'; return; }
                list.forEach(e => {
                  const b = document.createElement('button');
                  b.type = 'button'; b.className = 'ep-btn ep-custom'; b.title = ':' + e.name + ':';
                  b.innerHTML = `<img src="${e.url}" alt=":${e.name}:" loading="lazy" />`;
                  b.addEventListener('click', () => _pickPanelEmoji('<:' + e.name + ':' + e.id + '>'));
                  grid.appendChild(b);
                });
              }
            }
            picker.querySelectorAll('.ep-tab').forEach(tab => {
              tab.addEventListener('click', () => {
                picker.querySelectorAll('.ep-tab').forEach(t => t.classList.remove('active'));
                tab.classList.add('active');
                _tab = tab.dataset.ep;
                picker.querySelector('#ep-q').value = '';
                renderEPGrid('');
              });
            });
            picker.querySelector('#ep-q').addEventListener('input', ev => renderEPGrid(ev.target.value));
            picker.addEventListener('click', ev => ev.stopPropagation());
            renderEPGrid('');
          }
          function _pickPanelEmoji(val) {
            const inp = document.getElementById('panel-btn-emoji');
            if (inp) { inp.value = val; inp.dispatchEvent(new Event('input')); }
            const p = document.getElementById('panel-ep'); if (p) p.remove();
          }
          document.getElementById('panel-emoji-pick-btn').addEventListener('click', e => {
            e.stopPropagation();
            _buildEmojiPicker();
          });
          document.addEventListener('click', () => {
            const p = document.getElementById('panel-ep'); if (p) p.remove();
          });
          // ── End Emoji Picker ──────────────────────────────────────────────

          // Nav links
          document.querySelectorAll('.nav-link').forEach(a => {
            a.addEventListener('click', e => { e.preventDefault(); window.location.href = a.href; });
          });

          // Mobile menu
          const menuBtn = document.getElementById('menu-toggle');
          const sidebar = document.getElementById('mgmt-sidebar');
          const overlay = document.getElementById('nav-overlay');
          function openSidebar() { sidebar.classList.add('open'); overlay.classList.add('open'); document.body.style.overflow = 'hidden'; }
          function closeSidebar() {
            sidebar.classList.remove('open');
            const _nav = document.querySelector('.nav-sidebar');
            if (_nav) _nav.classList.remove('open');
            overlay.classList.remove('open');
            document.body.style.overflow = '';
          }
          if (menuBtn) menuBtn.addEventListener('click', () => sidebar.classList.contains('open') ? closeSidebar() : openSidebar());
          if (overlay) overlay.addEventListener('click', () => closeSidebar());

          // Section collapse
          document.querySelectorAll('.mgmt-section-btn').forEach(btn => {
            btn.addEventListener('click', () => {
              btn.classList.toggle('open');
              btn.nextElementSibling.classList.toggle('open');
            });
          });

          // Transcript enabled toggle → show/hide channel + DM rows
          document.getElementById('panel-transcript-enabled').addEventListener('change', function () {
            document.getElementById('panel-transcript-channel-row').style.display = this.checked ? '' : 'none';
            document.getElementById('panel-transcript-dm-row').style.display = this.checked ? '' : 'none';
          });

          // Feedback enabled toggle → show/hide rows, force DM on
          document.getElementById('panel-feedback-enabled').addEventListener('change', function () {
            const on = this.checked;
            const dmEl = document.getElementById('panel-feedback-dm');
            document.getElementById('panel-feedback-dm-row').style.display = on ? '' : 'none';
            document.getElementById('panel-feedback-channel-row').style.display = on ? '' : 'none';
            document.getElementById('panel-feedback-role-row').style.display = on ? '' : 'none';
            if (dmEl) { dmEl.checked = on; dmEl.disabled = on; }
          });

          // Thread mode toggle → show/hide thread notif row
          document.getElementById('panel-thread-mode').addEventListener('change', function () {
            document.getElementById('panel-thread-notif-row').style.display = this.checked ? '' : 'none';
          });

          // Naming mode → show/hide custom row
          document.getElementById('panel-naming-mode').addEventListener('change', function () {
            document.getElementById('panel-naming-custom-row').style.display = this.value === 'custom' ? '' : 'none';
          });

          // Naming chips
          document.querySelectorAll('#panel-naming-chips .var-chip').forEach(chip => {
            chip.addEventListener('click', () => {
              const input = document.getElementById('panel-naming-custom');
              const val = chip.dataset.val;
              const start = input.selectionStart ?? input.value.length;
              const end = input.selectionEnd ?? input.value.length;
              input.value = input.value.slice(0, start) + val + input.value.slice(end);
              input.focus();
              input.setSelectionRange(start + val.length, start + val.length);
              markDirty();
            });
          });

          // ─── Form question builder state ───
          let _formQuestions = [];

          function _loadFormQuestions(qs) {
            _formQuestions = qs.map(q => Object.assign({}, q));
            _renderFormQuestions();
          }

          function _renderFormQuestions() {
            const list = document.getElementById('form-q-list');
            if (!list) return;
            list.innerHTML = '';
            _formQuestions.forEach((q, i) => {
              const wrap = document.createElement('div');
              wrap.className = 'form-q-row';
              wrap.innerHTML = `
          <div class="form-q-num">${i + 1}</div>
          <div class="form-q-fields">
            <input type="text" class="form-input form-input-wide form-q-label-inp"
              placeholder="<%= t.ticketsPanels.questionTextMax45Chars %>"
              maxlength="45" />
            <input type="text" class="form-input form-input-wide form-q-ph-inp"
              placeholder="<%= t.ticketsPanels.placeholderHintOptionalMax100Chars %>"
              maxlength="100" />
            <div class="form-q-meta">
              <div class="form-q-style-group">
                <button type="button" class="form-q-style-opt" data-val="short">
                  <svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h10"/></svg>
                  <%= t.ticketsPanels.short %>
                </button>
                <button type="button" class="form-q-style-opt" data-val="paragraph">
                  <svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h12"/></svg>
                  <%= t.ticketsPanels.paragraph %>
                </button>
              </div>
              <button type="button" class="form-q-req-pill">
                <svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <input type="checkbox" class="form-q-req-chk" />
                <span><%= t.ticketsPanels.required %></span>
              </button>
              <button type="button" class="form-q-del" title="<%= t.ticketsPanels.remove2 %>">
                <svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.8" d="M18 6 6 18M6 6l12 12"/></svg>
              </button>
            </div>
          </div>`;
              // Set values safely (no HTML injection)
              wrap.querySelector('.form-q-label-inp').value = q.label || '';
              wrap.querySelector('.form-q-ph-inp').value = q.placeholder || '';
              // Style pill-group
              const curStyle = q.style || 'short';
              wrap.querySelectorAll('.form-q-style-opt').forEach(b => {
                b.classList.toggle('active', b.dataset.val === curStyle);
                b.addEventListener('click', () => {
                  _formQuestions[i].style = b.dataset.val;
                  wrap.querySelectorAll('.form-q-style-opt').forEach(x => x.classList.toggle('active', x.dataset.val === b.dataset.val));
                  markDirty();
                });
              });
              // Required pill
              const reqPill = wrap.querySelector('.form-q-req-pill');
              const reqChk = wrap.querySelector('.form-q-req-chk');
              reqChk.checked = !!q.required;
              reqPill.classList.toggle('active', !!q.required);
              reqPill.addEventListener('click', () => {
                const next = !reqChk.checked;
                reqChk.checked = next;
                _formQuestions[i].required = next;
                reqPill.classList.toggle('active', next);
                markDirty();
              });
              // Listeners
              wrap.querySelector('.form-q-label-inp').addEventListener('input', e => { _formQuestions[i].label = e.target.value; markDirty(); });
              wrap.querySelector('.form-q-ph-inp').addEventListener('input', e => { _formQuestions[i].placeholder = e.target.value; markDirty(); });
              wrap.querySelector('.form-q-del').addEventListener('click', () => { _formQuestions.splice(i, 1); _renderFormQuestions(); markDirty(); });
              list.appendChild(wrap);
            });
            const addBtn = document.getElementById('form-q-add');
            const counter = document.getElementById('form-q-counter');
            if (addBtn) addBtn.disabled = _formQuestions.length >= 5;
            if (counter) counter.textContent = `${_formQuestions.length} / 5`;
          }

          // ─── Access Control ───
          let aclRows = [];
          function renderAcl() {
            const list = document.getElementById('acl-list');
            list.innerHTML = '';
            aclRows.forEach((row, idx) => {
              const el = document.createElement('div');
              el.className = 'acl-row';
              el.innerHTML = `
          <i data-lucide="grip-vertical" class="acl-drag" style="width:14px;height:14px;stroke:currentColor;fill:none;"></i>
          <span class="acl-type">${row.type}</span>
          <select class="form-select acl-select" data-idx="${idx}" data-field="target">
            ${row.type === 'role'
                  ? `<option value="">— select role —</option>${(window._guildRoles || []).map(r => `<option value="${r.id}"${row.target === r.id ? ' selected' : ''}>${r.name}</option>`).join('')}`
                  : `<option value="${row.target || ''}">${row.target ? '@' + row.target : '— user id —'}</option>`
                }
          </select>
          <select class="form-select acl-action-select" data-idx="${idx}" data-field="action">
            <option value="allow"${row.action === 'allow' ? ' selected' : ''}>✅ Allow</option>
            <option value="deny"${row.action === 'deny' ? ' selected' : ''}>⛔ Deny</option>
          </select>
          <button class="acl-remove" data-idx="${idx}" title="Remove">
            <i data-lucide="x" style="width:14px;height:14px;stroke:currentColor;fill:none;"></i>
          </button>`;
              el.querySelectorAll('select').forEach(s => s.addEventListener('change', () => {
                aclRows[+s.dataset.idx][s.dataset.field] = s.value; markDirty();
              }));
              el.querySelector('.acl-remove').addEventListener('click', () => { aclRows.splice(idx, 1); renderAcl(); markDirty(); });
              list.appendChild(el);
            });
            lucide.createIcons();
          }
          window._guildRoles = JSON.parse(document.getElementById('guild-roles-data').textContent);
          const _panelList = JSON.parse(document.getElementById('panel-list-data').textContent);
          const _mpList = JSON.parse(document.getElementById('mp-list-data').textContent);

          // ── Panel display label helper ──────────────────────────────────────────
          // Shows emoji + button label. Falls back to panelTitle then id.
          function _panelLabel(p) {
            const e = (p.btnEmoji || '').trim();
            const t = (p.btnText || p.panelTitle || p.name || p.id || '').trim();
            return e ? `${e}  ${t}` : t;
          }
          // Update the selector option text for a given panelId in real time
          function _refreshPanelOption(panelId) {
            const entry = _panelList.find(x => x.id === panelId);
            if (!entry) return;
            const opt = document.querySelector(`#panel-selector option[value="${panelId}"]`);
            if (opt) opt.textContent = _panelLabel(entry);
            _syncPSelUI();
          }

          // ── Custom panel selector ──────────────────────────────────────────────
          function _renderSelItemHTML(entry) {
            const e = (entry.btnEmoji || '').trim();
            const t = (entry.btnText || entry.panelTitle || entry.name || entry.id || '').trim();
            const m = e.match(/^<a?:([^:]+):(\d+)>$/);
            if (m) {
              const ext = e.startsWith('<a:') ? 'gif' : 'webp';
              return `<img src="https://cdn.discordapp.com/emojis/${m[2]}.${ext}?size=32" alt=":${m[1]}:"><span>${t}</span>`;
            }
            return e ? `<span>${e} ${t}</span>` : `<span>${t}</span>`;
          }
          // Convert Discord emoji codes in a string to <img> tags
          function _emojiToHTML(str) {
            return String(str).replace(/<a?:([^:]+):([0-9]+)>/g, (_, name, id) => {
              const ext = _.startsWith('<a:') ? 'gif' : 'webp';
              return `<img src="https://cdn.discordapp.com/emojis/${id}.${ext}?size=32" alt=":${name}:" style="width:20px;height:20px;vertical-align:middle;border-radius:3px;">`;
            });
          }

          function _syncPSelUI() {
            const disp = document.getElementById('panel-sel-display');
            if (!disp) return;
            const pSel = document.getElementById('panel-selector');
            const val = pSel ? pSel.value : '';
            if (!val) {
              disp.innerHTML = '\u2726 <%= t.ticketsPanels.newPanel2 %>';
              return;
            }
            const entry = _panelList.find(p => p.id === val);
            disp.innerHTML = entry ? _renderSelItemHTML(entry) : `<span>${val}</span>`;
          }
          function _pSelSet(val) {
            const pSel = document.getElementById('panel-selector');
            if (pSel) pSel.value = val;
            _syncPSelUI();
          }
          function _buildPSelList() {
            const list = document.getElementById('panel-sel-list');
            if (!list) return;
            const pSel = document.getElementById('panel-selector');
            const curVal = pSel ? pSel.value : '';
            list.innerHTML = '';
            const ni = document.createElement('div');
            ni.className = 'csel-item' + (!curVal ? ' csel-active' : '');
            ni.innerHTML = '<span>\u2726 <%= t.ticketsPanels.newPanel2 %></span>';
            ni.addEventListener('click', () => _cselPick(''));
            list.appendChild(ni);
            _panelList.forEach(entry => {
              const item = document.createElement('div');
              item.className = 'csel-item' + (entry.id === curVal ? ' csel-active' : '');
              item.innerHTML = _renderSelItemHTML(entry);
              item.addEventListener('click', () => _cselPick(entry.id));
              list.appendChild(item);
            });
          }
          let _cselIsOpen = false;
          function _cselPick(val) {
            const pSel = document.getElementById('panel-selector');
            _pSelSet(val);
            if (pSel) pSel.dispatchEvent(new Event('change'));
            const list = document.getElementById('panel-sel-list');
            const wrap = document.getElementById('panel-sel-wrap');
            if (list) list.style.display = 'none';
            if (wrap) wrap.classList.remove('csel-open');
            _cselIsOpen = false;
          }
          (function _initPanelSelTrigger() {
            const trig = document.getElementById('panel-sel-trigger');
            const wrap = document.getElementById('panel-sel-wrap');
            if (!trig) return;
            trig.addEventListener('click', e => {
              e.stopPropagation();
              const list = document.getElementById('panel-sel-list');
              if (_cselIsOpen) { list.style.display = 'none'; wrap.classList.remove('csel-open'); _cselIsOpen = false; return; }
              _buildPSelList(); list.style.display = ''; wrap.classList.add('csel-open'); _cselIsOpen = true;
            });
            document.addEventListener('click', () => {
              if (!_cselIsOpen) return;
              const list = document.getElementById('panel-sel-list');
              if (list) list.style.display = 'none';
              if (wrap) wrap.classList.remove('csel-open');
              _cselIsOpen = false;
            });
          })();
          // ── End custom panel selector ──────────────────────────────────────────

          // ── Generic field helpers ───────────────────────────────────────────────
          function _setVal(id, val) { const el = document.getElementById(id); if (el) el.value = val ?? ''; }
          function _setChk(id, val) { const el = document.getElementById(id); if (el) el.checked = Boolean(val); }
          function _setSel(id, val) {
            const el = document.getElementById(id); if (!el) return;
            for (const o of el.options) if (o.value === String(val ?? '')) { o.selected = true; return; }
          }
          function _setColor(inpId, swatchId, hexId, val) {
            const inp = document.getElementById(inpId), sw = document.getElementById(swatchId), hex = document.getElementById(hexId);
            if (!inp) return; const v = val || '#7c3aed';
            inp.value = v; if (sw) sw.style.background = v; if (hex) hex.textContent = v;
          }

          // ── Load saved panel into Card 1 ────────────────────────────────────────
          function loadPanelData(p) {
            document.getElementById('panel-id').value = p ? (p.id || '') : '';
            document.getElementById('panel-message-id').value = p ? (p.messageId || '') : '';
            if (!p) { resetPanelForm(); return; }
            _setSel('panel-mention-role', p.mentionRole);
            _setChk('panel-transcript-enabled', p.transcriptEnabled);
            const trChRow = document.getElementById('panel-transcript-channel-row');
            const trDmRow = document.getElementById('panel-transcript-dm-row');
            if (trChRow) trChRow.style.display = p.transcriptEnabled ? '' : 'none';
            if (trDmRow) trDmRow.style.display = p.transcriptEnabled ? '' : 'none';
            _setSel('panel-transcript-channel', p.transcriptChannel ?? 'global');
            _setChk('panel-transcript-dm', p.transcriptDm);
            _setChk('panel-feedback-enabled', p.feedbackEnabled);
            const fbEnabled = !!p.feedbackEnabled;
            const fbDmRow = document.getElementById('panel-feedback-dm-row');
            const fbChRow = document.getElementById('panel-feedback-channel-row');
            const fbRoleRow = document.getElementById('panel-feedback-role-row');
            const fbDmEl = document.getElementById('panel-feedback-dm');
            if (fbDmRow) fbDmRow.style.display = fbEnabled ? '' : 'none';
            if (fbChRow) fbChRow.style.display = fbEnabled ? '' : 'none';
            if (fbRoleRow) fbRoleRow.style.display = fbEnabled ? '' : 'none';
            if (fbDmEl) { fbDmEl.checked = fbEnabled; fbDmEl.disabled = fbEnabled; }
            _setSel('panel-feedback-channel', p.feedbackChannel);
            _setSel('panel-feedback-role', p.feedbackRole);
            _setChk('panel-delete-mentions', p.deleteMentions);
            _setChk('panel-thread-mode', p.threadMode);
            _setSel('panel-thread-notif-channel', p.threadNotifChannel);
            const tRow = document.getElementById('panel-thread-notif-row');
            if (tRow) tRow.style.display = p.threadMode ? '' : 'none';
            _setVal('panel-cooldown', p.cooldown ?? 0);
            _setSel('panel-category', p.category);
            _setVal('panel-max-open', p.maxOpen ?? 0);
            _setChk('panel-hide-close', p.hideClose);
            _setChk('panel-hide-close-reason', p.hideCloseReason);
            _setChk('panel-hide-claim', p.hideClaim);
            // form builder
            _setChk('panel-form-enabled', p.formEnabled);
            const _fbWrap = document.getElementById('panel-form-builder');
            if (_fbWrap) _fbWrap.style.display = p.formEnabled ? '' : 'none';
            _loadFormQuestions(Array.isArray(p.formQuestions) ? p.formQuestions : []);
            _setSel('panel-awaiting-cat', p.awaitingCat);
            _setSel('panel-naming-mode', p.namingMode ?? 'global');
            _setVal('panel-naming-custom', p.namingCustom ?? 'ticket-{number}');
            const ncRow = document.getElementById('panel-naming-custom-row');
            if (ncRow) ncRow.style.display = (p.namingMode === 'custom') ? '' : 'none';
            _setVal('panel-title', p.panelTitle);
            _setSel('panel-channel', p.panelChannel);
            _setChk('panel-disabled', p.disabled);

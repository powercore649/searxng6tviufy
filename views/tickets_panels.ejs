          // ─── Confirm Modal helper ────────────────────────────────────────────────
          function _modal({ title, body, icon = 'triangle-alert', iconBg = 'rgba(239,68,68,.12)', iconColor = '#f87171', confirmText, confirmClass = 'btn-danger', requireInput = null, onConfirm }) {
            const backdrop = document.getElementById('confirm-modal');
            const titleEl = document.getElementById('cm-title');
            const bodyEl = document.getElementById('cm-body');
            const iconEl = document.getElementById('cm-icon');
            const iconWrap = document.getElementById('cm-icon-wrap');
            const inputWrap = document.getElementById('cm-input-wrap');
            const inputEl = document.getElementById('cm-input');
            const hintEl = document.getElementById('cm-input-hint');
            const confirmEl = document.getElementById('cm-confirm');
            const cancelEl = document.getElementById('cm-cancel');
            titleEl.textContent = title;
            bodyEl.innerHTML = body;
            iconEl.setAttribute('data-lucide', icon);
            iconWrap.style.background = iconBg;
            iconEl.style.stroke = iconColor; iconEl.style.fill = 'none';
            lucide.createIcons({ nodes: [iconWrap] });
            confirmEl.textContent = confirmText || ('<%= t.ticketsPanels.confirm %>');
            confirmEl.className = 'btn ' + confirmClass;
            inputWrap.style.display = requireInput ? '' : 'none';
            if (requireInput) {
              inputEl.value = ''; inputEl.placeholder = requireInput.placeholder || '';
              if (hintEl) hintEl.textContent = requireInput.hint || '';
            }
            backdrop.style.display = 'flex';
            function close() {
              backdrop.style.display = 'none';
              confirmEl.removeEventListener('click', onOk);
              cancelEl.removeEventListener('click', close);
              backdrop.removeEventListener('click', onBackdrop);
              document.removeEventListener('keydown', onEsc);
            }
            function onBackdrop(e) { if (e.target === backdrop) close(); }
            function onEsc(e) { if (e.key === 'Escape') close(); }
            function onOk() {
              if (requireInput) {
                if (inputEl.value.trim() !== requireInput.expected) {
                  inputEl.classList.remove('shake'); void inputEl.offsetWidth; inputEl.classList.add('shake');
                  return;
                }
              }
              close(); onConfirm();
            }
            confirmEl.addEventListener('click', onOk);
            cancelEl.addEventListener('click', close);
            backdrop.addEventListener('click', onBackdrop);
            document.addEventListener('keydown', onEsc);
          }

          // ─── Delete Panel ────────────────────────────────────────────────────────
          document.getElementById('panel-delete-btn').addEventListener('click', () => {
            const panelId = document.getElementById('panel-id').value;

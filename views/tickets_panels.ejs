          // ─── Multi-Panel: panels picker ───
          function _mpDispHTML(slot) {
            const matched = _panelList.find(p => p.id === slot.panelId || (p.panelTitle || p.name || '') === slot.name);
            if (matched) return _renderSelItemHTML(matched);
            const t = slot.name || slot.panelId || '?';
            return `<span>${t}</span>`;
          }

          function _buildMpPanelSelList() {
            const list = document.getElementById('mp-panel-sel-list');
            if (!list) return;
            list.innerHTML = '';
            const usedIds = new Set(mpPanels.map(p => p.panelId).filter(Boolean));
            const usedNames = new Set(mpPanels.map(p => (p.name || '').trim()).filter(Boolean));
            // placeholder
            const ni = document.createElement('div');
            ni.className = 'csel-item';
            ni.innerHTML = '<span><%= t.ticketsPanels.selectAPanel %></span>';
            ni.addEventListener('click', e => { e.stopPropagation(); _mpCselPick(''); });
            list.appendChild(ni);
            _panelList.forEach(entry => {
              const entryTitle = (entry.panelTitle || entry.name || '').trim();
              if (usedIds.has(entry.id) || usedNames.has(entryTitle)) return; // hide already-added
              const item = document.createElement('div');
              item.className = 'csel-item';
              item.innerHTML = _renderSelItemHTML(entry);
              item.addEventListener('click', e => { e.stopPropagation(); _mpCselPick(entry.id); });
              list.appendChild(item);
            });
            if (list.children.length === 1) {
              const empty = document.createElement('div');
              empty.className = 'csel-item'; empty.style.opacity = '.5'; empty.style.pointerEvents = 'none';
              empty.innerHTML = '<span><%= t.ticketsPanels.noPanelsAvailable %></span>';
              list.appendChild(empty);
            }
          }
          let _mpCselOpen = false;
          let _mpPanelSelVal = '';
          function _mpCselPick(val) {
            _mpPanelSelVal = val;
            const inp = document.getElementById('mp-panel-sel');
            const disp = document.getElementById('mp-panel-sel-display');
            const list = document.getElementById('mp-panel-sel-list');
            const wrap = document.getElementById('mp-panel-sel-wrap');
            if (inp) inp.value = val;
            if (disp) {
              if (!val) { disp.innerHTML = '<%= t.ticketsPanels.selectAPanel %>'; }
              else { const e = _panelList.find(p => p.id === val); disp.innerHTML = e ? _renderSelItemHTML(e) : `<span>${val}</span>`; }
            }
            if (list) list.style.display = 'none';
            if (wrap) wrap.classList.remove('csel-open');
            _mpCselOpen = false;
          }
          (function _initMpPanelSel() {
            const trig = document.getElementById('mp-panel-sel-trigger');
            const wrap = document.getElementById('mp-panel-sel-wrap');
            if (!trig) return;
            trig.addEventListener('click', e => {
              e.stopPropagation();
              const list = document.getElementById('mp-panel-sel-list');
              if (_mpCselOpen) { list.style.display = 'none'; wrap.classList.remove('csel-open'); _mpCselOpen = false; return; }
              _buildMpPanelSelList(); list.style.display = ''; wrap.classList.add('csel-open'); _mpCselOpen = true;
            });
            document.addEventListener('click', e => {
              if (!_mpCselOpen) return;
              const wrapEl = document.getElementById('mp-panel-sel-wrap');
              if (wrapEl && wrapEl.contains(e.target)) return;
              const list = document.getElementById('mp-panel-sel-list');
              if (list) list.style.display = 'none';
              if (wrapEl) wrapEl.classList.remove('csel-open');
              _mpCselOpen = false;
            });
          })();

          function _mpPanelDisplayName(slot) {
            const matched = _panelList.find(p => p.id === slot.panelId || (p.panelTitle || p.name || '') === slot.name);
            return matched ? _panelLabel(matched) : (slot.name || slot.panelId || '?');
          }

          function renderMpPanels() {
            const tags = document.getElementById('mp-panels-tags');
            tags.innerHTML = '';
            mpPanels.forEach((p, i) => {
              const tag = document.createElement('span');
              tag.className = 'mp-panel-tag';
              tag.innerHTML = `${_mpDispHTML(p)}<button type="button" aria-label="remove" data-i="${i}">&times;</button>`;
              tag.querySelector('button').addEventListener('click', () => { mpPanels.splice(i, 1); renderMpPanels(); renderMpCustomize(); markDirty(); });
              tags.appendChild(tag);
            });
            renderMpCustomize();
            _buildMpPanelSelList(); // always keep picker in sync with current mpPanels tags
          }
          document.getElementById('mp-panel-add-btn').addEventListener('click', e => {
            e.stopPropagation();
            const panelId = _mpPanelSelVal || document.getElementById('mp-panel-sel')?.value || '';
            if (!panelId) return;
            const entry = _panelList.find(p => p.id === panelId);
            if (!entry) return;
            const slotName = entry.panelTitle || entry.name || entry.id;
            if (mpPanels.find(p => p.panelId === panelId)) return; // dedupe by id only
            mpPanels.push({ name: slotName, panelId, overrideBtnText: '', overrideBtnEmoji: '', overrideBtnColor: '' });
            _mpCselPick(''); // reset
            _buildMpPanelSelList(); // refresh list (hides newly-added panel)
            renderMpPanels();
            markDirty();
          });

          // ─── Multi-Panel: per-panel customization ───
          function renderMpCustomize() {
            const list = document.getElementById('mp-customize-list');
            const empty = document.getElementById('mp-customize-empty');
            if (mpPanels.length === 0) { list.innerHTML = ''; list.appendChild(empty); empty.style.display = ''; return; }
            empty.style.display = 'none';
            // Remove stale rows
            const existing = Array.from(list.querySelectorAll('.mp-customize-row'));
            existing.forEach(el => { if (!mpPanels.find(p => p.panelId === el.dataset.panelId || p.name === el.dataset.panel)) el.remove(); })
            mpPanels.forEach((p, i) => {
              const rowKey = p.panelId || p.name;
              let row = list.querySelector(`.mp-customize-row[data-panel-id="${CSS.escape(rowKey)}"]`)
                || list.querySelector(`.mp-customize-row[data-panel="${CSS.escape(p.name)}"]`);
              if (!row) {
                row = document.createElement('div');
                row.className = 'mp-customize-row';
                row.dataset.panel = p.name;
                row.dataset.panelId = p.panelId || p.name;
                const _dispName = _mpDispHTML(p);
                row.innerHTML = `
            <div class="mp-customize-row-header">
              <span class="mp-customize-row-title">${_dispName}</span>
              <button type="button" class="mp-edit-panel-btn" data-pname="${p.name}"><%= t.ticketsPanels.edit %></button>
              <i data-lucide="chevron-down" style="width:13px;height:13px;stroke:var(--muted);fill:none;"></i>
            </div>
            <div class="mp-customize-body">
              <div class="mp-customize-inner-row">
                <label class="form-label" style="margin:0"><%= t.tickets.btnTextLabel %></label>
                <input type="text" class="form-input form-input-wide mp-btn-text" placeholder="<%= t.tickets.btnTextPlaceholder %>" value="${p.overrideBtnText || ''}" />
              </div>
              <div class="mp-customize-inner-row">
                <label class="form-label" style="margin:0"><%= t.tickets.btnEmojiLabel %></label>
                <input type="text" class="form-input form-input-wide mp-btn-emoji" placeholder="🎫" value="${p.overrideBtnEmoji || ''}" />
              </div>
              <div class="mp-customize-inner-row">
                <label class="form-label" style="margin:0"><%= t.tickets.btnColorLabel %></label>
                <div class="btn-color-group mp-btn-color-group">
                  ${['1:Blue:#5865f2', '3:Green:#57f287', '4:Red:#ed4245'].map(v => { const [val, label, col] = v.split(':'); return `<button type="button" class="btn-color-opt${(p.overrideBtnColor || '1') === val ? ' selected' : ''}" data-val="${val}"><span class="btn-color-dot" style="background:${col}"></span>${label}</button>`; }).join('')}
                  <input type="hidden" class="mp-btn-color-val" value="${p.overrideBtnColor || '1'}" />
                </div>
              </div>
            </div>`;
                row.querySelector('.mp-customize-row-header').addEventListener('click', (e) => {
                  if (e.target.closest('.mp-edit-panel-btn')) return; // let edit btn handle its own click
                  row.querySelector('.mp-customize-body').classList.toggle('open');
                });
                row.querySelector('.mp-edit-panel-btn').addEventListener('click', () => {
                  const found = _panelList.find(pl => (pl.panelTitle || pl.name || '') === p.name || pl.id === (p.panelId || ''));
                  if (!found) {
                    alert('<%= t.ticketsPanels.panelNotFoundMakeSureIt %>');
                    return;
                  }
                  const pSel = document.getElementById('panel-selector');
                  _pSelSet(found.id);
                  loadPanelData(found);
                  _updatePanelSendStatus(found.messageId || null);
                  document.getElementById('panel-delete-btn').style.display = '';
                  document.getElementById('panel-selector-bar').scrollIntoView({ behavior: 'smooth', block: 'start' });
                });
                row.querySelectorAll('.mp-btn-color-group .btn-color-opt').forEach(btn => {
                  btn.addEventListener('click', () => {
                    btn.closest('.mp-btn-color-group').querySelectorAll('.btn-color-opt').forEach(b => b.classList.remove('selected'));
                    btn.classList.add('selected');
                    btn.closest('.mp-customize-row').querySelector('.mp-btn-color-val').value = btn.dataset.val;
                    const idx = mpPanels.findIndex(pp => pp.name === btn.closest('.mp-customize-row').dataset.panel);
                    if (idx !== -1) { mpPanels[idx].overrideBtnColor = btn.dataset.val; markDirty(); }
                  });
                });
                row.querySelector('.mp-btn-text').addEventListener('input', e => { mpPanels[i].overrideBtnText = e.target.value; markDirty(); });
                row.querySelector('.mp-btn-emoji').addEventListener('input', e => { mpPanels[i].overrideBtnEmoji = e.target.value; markDirty(); });
                list.appendChild(row);
              }
            });
            lucide.createIcons();
          }
          renderMpPanels();

          // Watch all regular inputs
          const watchSels = ['panel-mention-role', 'panel-transcript-channel', 'panel-thread-notif-channel',
            'panel-category', 'panel-awaiting-cat', 'panel-naming-mode', 'panel-channel',
            'panel-feedback-channel', 'panel-feedback-role',
            'panel-timezone',
            'mp-channel'];
          const watchInps = ['panel-cooldown', 'panel-max-open', 'panel-naming-custom', 'panel-title',
            'panel-description', 'panel-btn-text', 'panel-btn-emoji', 'panel-select-desc', 'panel-select-placeholder',
            'mp-dropdown-placeholder', 'mp-refresh-btn-label'];
          const watchChecks = ['panel-delete-mentions', 'panel-thread-mode', 'panel-hide-close', 'panel-hide-close-reason',
            'panel-hide-claim', 'panel-disabled', 'panel-always-open',
            'panel-transcript-enabled', 'panel-transcript-dm',
            'panel-feedback-enabled', 'panel-feedback-dm',
            'panel-form-enabled',
            'mp-use-dropdown', 'mp-show-refresh-btn'];
          const watchColors = [];

          [...watchSels, ...watchInps, ...watchColors].forEach(id => {
            const el = document.getElementById(id);
            if (el) { el.addEventListener('change', markDirty); el.addEventListener('input', markDirty); }
          });
          watchChecks.forEach(id => {
            const el = document.getElementById(id);
            if (el) el.addEventListener('change', markDirty);
          });
          // Panel support role select — add chip on selection
          document.getElementById('panel-support-role-sel')?.addEventListener('change', e => {
            const val = e.target.value;
            if (!val) return;
            _addSupportRoleChip(val);
            e.target.value = '';
            markDirty();
          });

          // Action buttons mode toggle
          document.querySelectorAll('.ab-mode-opt').forEach(btn => {
            btn.addEventListener('click', () => {
              const val = btn.dataset.val;
              document.getElementById('ab-mode-val').value = val;
              document.querySelectorAll('.ab-mode-opt').forEach(b => b.classList.toggle('active', b.dataset.val === val));
              const wrap = document.getElementById('ab-btns-config');
              if (wrap) wrap.style.display = val === 'select' ? 'none' : '';
              markDirty();
            });
          });
          // Action button style pills
          document.querySelectorAll('.ab-style-opt').forEach(btn => {
            btn.addEventListener('click', () => {
              btn.closest('.ab-style-group').querySelectorAll('.ab-style-opt').forEach(b => b.classList.remove('active'));
              btn.classList.add('active');
              const key = btn.closest('.ab-config-row').dataset.key;
              document.getElementById(`ab-${key}-style-val`).value = btn.dataset.val;
              markDirty();
            });
          });
          // Action button label-mode pills
          document.querySelectorAll('.ab-label-opt').forEach(btn => {
            btn.addEventListener('click', () => {
              btn.closest('.ab-label-group').querySelectorAll('.ab-label-opt').forEach(b => b.classList.remove('active'));
              btn.classList.add('active');
              const key = btn.closest('.ab-config-row').dataset.key;
              document.getElementById(`ab-${key}-label-val`).value = btn.dataset.val;
              markDirty();
            });
          });
          // Action button emoji inputs
          document.querySelectorAll('.ab-emoji-inp').forEach(el => {
            el.addEventListener('input', markDirty);
          });

          saveBtn.addEventListener('click', async () => {
            saveBtn.disabled = true;
            const savingLabel = '<%= t.tickets.savingBtn %>';
            const savedLabel = '<%= t.tickets.savedBtn %>';
            const saveLabel = '<%= t.tickets.saveBtn %>';
            saveBtn.textContent = savingLabel;

            const payload = {
              panelId: document.getElementById('panel-id').value || null,
              mentionRole: document.getElementById('panel-mention-role').value || null,
              transcriptEnabled: document.getElementById('panel-transcript-enabled').checked,
              transcriptChannel: document.getElementById('panel-transcript-channel').value || null,
              transcriptDm: document.getElementById('panel-transcript-dm').checked,
              deleteMentions: document.getElementById('panel-delete-mentions').checked,
              threadMode: document.getElementById('panel-thread-mode').checked,
              threadNotifChannel: document.getElementById('panel-thread-notif-channel').value || null,
              cooldown: parseInt(document.getElementById('panel-cooldown').value, 10) || 0,
              category: document.getElementById('panel-category').value || null,
              maxOpen: parseInt(document.getElementById('panel-max-open').value, 10) || 0,
              hideClose: document.getElementById('panel-hide-close').checked,
              hideCloseReason: document.getElementById('panel-hide-close-reason').checked,
              hideClaim: document.getElementById('panel-hide-claim').checked,
              formEnabled: document.getElementById('panel-form-enabled').checked,
              formQuestions: _formQuestions.map(q => ({
                label: (q.label || '').trim(),
                placeholder: (q.placeholder || '').trim(),
                style: q.style || 'short',
                required: !!q.required,
              })).filter(q => q.label),
              feedbackEnabled: document.getElementById('panel-feedback-enabled').checked,
              feedbackDm: document.getElementById('panel-feedback-dm').checked,
              feedbackChannel: document.getElementById('panel-feedback-channel').value || null,
              feedbackRole: document.getElementById('panel-feedback-role').value || null,
              awaitingCat: document.getElementById('panel-awaiting-cat').value || null,
              namingMode: document.getElementById('panel-naming-mode').value,
              namingCustom: document.getElementById('panel-naming-custom').value,
              panelTitle: document.getElementById('panel-title').value,
              panelChannel: document.getElementById('panel-channel').value || null,
              disabled: document.getElementById('panel-disabled').checked,
              bannerImage: document.getElementById('panel-banner-url').value || '',
              description: document.getElementById('panel-description').value || '',
              accentColor: document.getElementById('panel-accent-color-val').value || null,
              btnText: document.getElementById('panel-btn-text').value || '',
              btnEmoji: document.getElementById('panel-btn-emoji').value || '',
              btnColor: parseInt(document.getElementById('panel-btn-color-val').value, 10) || 1,
              useSelectMenu: document.getElementById('panel-use-select-menu').value === 'true',
              selectMenuDesc: document.getElementById('panel-select-desc').value || '',
              selectMenuPlaceholder: document.getElementById('panel-select-placeholder').value || '',
              acl: aclRows,
              supportRoles: [...document.querySelectorAll('#panel-support-roles-chips [data-role-id]')].map(c => c.dataset.roleId),
              ...(_getActionBtnsPayload()),
              alwaysOpen: document.getElementById('panel-always-open').checked,
              timezone: document.getElementById('panel-timezone').value,
              hours: ['monday', 'tuesday', 'wednesday', 'thursday', 'friday', 'saturday', 'sunday'].reduce((acc, d) => {
                acc[d] = {
                  open: document.getElementById(`hours-open-${d}`).value,
                  close: document.getElementById(`hours-close-${d}`).value,
                };
                return acc;
              }, {}),
              multiPanel: {
                mpId: document.getElementById('mp-id').value || null,
                channel: document.getElementById('mp-channel').value || null,
                panels: mpPanels.map(slot => ({
                  ...slot,
                  panelId: slot.panelId || (_panelList.find(p => (p.panelTitle || p.name || '') === slot.name) || {}).id || null,
                })),
                useDropdown: document.getElementById('mp-use-dropdown').checked,
                showRefreshBtn: document.getElementById('mp-show-refresh-btn').checked,
                refreshBtnLabel: document.getElementById('mp-refresh-btn-label').value.trim() || null,
                placeholder: document.getElementById('mp-dropdown-placeholder').value,
                panelTitle: document.getElementById('mp-title').value.trim() || '',
                description: document.getElementById('mp-description').value.trim() || '',
                bannerImage: document.getElementById('mp-banner-url').value || '',
                accentColor: document.getElementById('mp-accent-color-val').value || null,
              },
            };

            try {
              const res = await fetch('/dashboard/<%= guildId %>/tickets/panels/save', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload),
              });
              if (!res.ok) throw new Error('Save failed');
              const data = await res.json();
              // Update hidden IDs with server-assigned values
              if (data.panelId) {
                const pId = document.getElementById('panel-id');
                const pSel = document.getElementById('panel-selector');
                const wasNew = !pId.value;
                pId.value = data.panelId;
                _updatePanelSendStatus(document.getElementById('panel-message-id').value || null);
                if (wasNew) {
                  const newEntry = _collectPanelState(data.panelId);
                  _panelList.push(newEntry);
                  const o = document.createElement('option'); o.value = data.panelId;
                  o.textContent = _panelLabel(newEntry);
                  pSel.appendChild(o); _pSelSet(data.panelId);
                  document.getElementById('panel-count-badge').textContent = _panelList.length + ' panel' + (_panelList.length !== 1 ? 's' : '');
                } else {
                  const entry = _panelList.find(p => p.id === data.panelId);
                  if (entry) {
                    Object.assign(entry, _collectPanelState(data.panelId));
                    _refreshPanelOption(data.panelId);
                  }
                }
              }
              if (data.mpId) {
                const mId = document.getElementById('mp-id');
                const mSel = document.getElementById('mp-selector');
                const wasNew = !mId.value;
                mId.value = data.mpId;
                document.getElementById('mp-send-btn').disabled = false;
                if (wasNew) {
                  const _mpTitle = document.getElementById('mp-title').value.trim();
                  const o = document.createElement('option'); o.value = data.mpId;
                  o.textContent = _mpTitle || data.mpId;
                  mSel.appendChild(o); mSel.value = data.mpId;
                  _mpList.push(_collectMpState(data.mpId));
                  document.getElementById('mp-count-badge').textContent = _mpList.length + ' multi-panel' + (_mpList.length !== 1 ? 's' : '');
                } else {
                  // Sync existing _mpList entry so switching away + back reloads current data
                  const _mpIdx = _mpList.findIndex(m => m.id === data.mpId);
                  if (_mpIdx !== -1) Object.assign(_mpList[_mpIdx], _collectMpState(data.mpId));
                }
              }
              saveBtn.textContent = savedLabel;
              saveBtn.classList.remove('btn-primary');
              saveBtn.classList.add('btn-success');
              setTimeout(() => {
                saveBar.classList.remove('visible');
                saveBtn.textContent = saveLabel;
                saveBtn.classList.remove('btn-success');
                saveBtn.classList.add('btn-primary');
                saveBtn.disabled = false;
              }, 1800);
            } catch (err) {
              console.error(err);
              saveBtn.textContent = saveLabel;
              saveBtn.disabled = false;
              alert('<%= t.ticketsPanels.saveFailedPleaseTryAgain %>');
            }
          });

          resetBtn.addEventListener('click', () => {
            saveBar.classList.remove('visible');
          });

          // ── Send Panel ────────────────────────────────────────────────────────
          document.getElementById('panel-send-btn').addEventListener('click', async () => {
            const panelId = document.getElementById('panel-id').value;
            const msgId = document.getElementById('panel-message-id').value;
            const channelId = document.getElementById('panel-channel').value || null;
            const sendBtn = document.getElementById('panel-send-btn');
            const dot = document.getElementById('panel-send-dot');
            const statusTx = document.getElementById('panel-send-status');
            if (!panelId) {
              alert('<%= t.ticketsPanels.saveThePanelFirstBeforeSending %>');
              return;
            }
            sendBtn.disabled = true;
            dot.className = 'send-dot sending';
            statusTx.textContent = '<%= t.ticketsPanels.sending2 %>';
            try {
              const res = await fetch('/dashboard/<%= guildId %>/tickets/panels/send', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ panelId, messageId: msgId || null, channelId }),
              });
              const data = await res.json();
              if (!res.ok || !data.success) throw new Error(data.error || 'Send failed');
              const entry = _panelList.find(p => p.id === panelId);
              if (entry) entry.messageId = data.messageId;
              _updatePanelSendStatus(data.messageId);
            } catch (err) {
              console.error('[Send Panel]', err);
              dot.className = 'send-dot unsent';
              statusTx.textContent = (err.message || '<%= t.ticketsPanels.sendFailed %>');
            } finally {
              sendBtn.disabled = false;
            }
          });

          // ── Send Multi-Panel ──────────────────────────────────────────────────
          document.getElementById('mp-send-btn').addEventListener('click', async () => {
            const mpId = document.getElementById('mp-id').value;
            const msgId = document.getElementById('mp-message-id').value;
            const sendBtn = document.getElementById('mp-send-btn');
            const dot = document.getElementById('mp-send-dot');
            const statusTx = document.getElementById('mp-send-status');
            const channelId = document.getElementById('mp-channel').value;
            if (!mpId) {
              alert('<%= t.ticketsPanels.saveTheMultiPanelFirstBefore %>');
              return;
            }
            if (!channelId) {
              alert('<%= t.ticketsPanels.pleaseChooseAChannelFirst %>');
              return;
            }
            if (!mpPanels || mpPanels.length === 0) {
              alert('<%= t.ticketsPanels.addAtLeastOnePanelFirst || "Add at least one panel to the multi-panel first." %>');
              return;
            }
            sendBtn.disabled = true;
            dot.className = 'send-dot sending';
            statusTx.textContent = '<%= t.ticketsPanels.sending2 %>';
            try {
              const res = await fetch('/dashboard/<%= guildId %>/tickets/multi-panels/send', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ mpId, channelId, messageId: msgId || null, panels: mpPanels }),
              });
              const data = await res.json();
              if (!res.ok || !data.success) throw new Error(data.error || 'Send failed');
              const entry = _mpList.find(m => m.id === mpId);
              if (entry) entry.messageId = data.messageId;
              _updateMpSendStatus(data.messageId);
            } catch (err) {
              console.error('[Send Multi-Panel]', err);
              dot.className = 'send-dot unsent';
              statusTx.textContent = (err.message || '<%= t.ticketsPanels.sendFailed %>');
            } finally {
              sendBtn.disabled = false;
            }
          });

          // Lang switcher
          document.getElementById('lang-select').addEventListener('change', function () {
            const url = new URL(window.location.href);
            url.searchParams.set('lang', this.value);
            window.location.href = url.toString();
          });

          // ── Profile sidebar ───────────────────────────────────────────────────
          const profSidebar = document.getElementById('prof-sidebar');
          const profBackdrop = document.getElementById('prof-backdrop');
          const openBtn = document.getElementById('open-profile');
          const closeBtn = document.getElementById('close-profile');
          const copyId = document.getElementById('prof-copy-id');

          function openProfile() { profSidebar.classList.add('open'); profBackdrop.classList.add('open'); profSidebar.setAttribute('aria-hidden', 'false'); document.body.style.overflow = 'hidden'; }
          function closeProfile() { profSidebar.classList.remove('open'); profBackdrop.classList.remove('open'); profSidebar.setAttribute('aria-hidden', 'true'); document.body.style.overflow = ''; }

          if (openBtn) openBtn.addEventListener('click', openProfile);
          document.querySelectorAll('.open-profile-btn').forEach(b => b.addEventListener('click', openProfile));
          if (closeBtn) closeBtn.addEventListener('click', closeProfile);
          profBackdrop.addEventListener('click', closeProfile);
          document.addEventListener('keydown', e => { if (e.key === 'Escape') closeProfile(); });

          if (copyId) {
            copyId.addEventListener('click', () => {
              navigator.clipboard.writeText(copyId.textContent.trim()).then(() => {
                const orig = copyId.textContent;
                copyId.textContent = '✓ Copied!';
                copyId.style.color = 'var(--cyan-l)';
                setTimeout(() => { copyId.textContent = orig; copyId.style.color = ''; }, 1500);
              });
            });
          }

          // bannerColor initialisation
          const bannerSolid = profSidebar.querySelector('.prof-banner-solid');
          if (bannerSolid && bannerSolid.dataset.bg) bannerSolid.style.background = bannerSolid.dataset.bg;

          // ── Sort button → toggle nav-sidebar ─────────────────────────────────
          const sortBtn = document.querySelector('.mgmt-sort-btn');
          const navSidebarEl = document.querySelector('.nav-sidebar');
          if (sortBtn) {
            sortBtn.addEventListener('click', () => {
              if (navSidebarEl && navSidebarEl.classList.contains('open')) {
                navSidebarEl.classList.remove('open');
                overlay.classList.remove('open');
                document.body.style.overflow = '';
              } else {
                closeSidebar();
                if (navSidebarEl) { navSidebarEl.classList.add('open'); overlay.classList.add('open'); document.body.style.overflow = 'hidden'; }
              }
            });
          }
        </script>
        <!-- ─── Confirm Modal ─── -->
        <div id="confirm-modal" class="cm-backdrop" style="display:none" aria-modal="true" role="dialog">
          <div class="cm-box">
            <div class="cm-icon-wrap" id="cm-icon-wrap">
              <i data-lucide="triangle-alert" id="cm-icon" style="width:28px;height:28px;"></i>
            </div>
            <h3 class="cm-title" id="cm-title"></h3>
            <p class="cm-body" id="cm-body"></p>
            <div id="cm-input-wrap" class="cm-input-wrap" style="display:none">
              <input type="text" id="cm-input" class="form-input cm-input" autocomplete="off" />
              <p id="cm-input-hint" class="cm-hint"></p>
            </div>
            <div class="cm-actions">
              <button type="button" id="cm-cancel" class="btn btn-surface">
                <%= t.ticketsPanels.cancel %>
              </button>
              <button type="button" id="cm-confirm" class="btn btn-danger">
                <%= t.ticketsPanels.confirm %>
              </button>
            </div>
          </div>
        </div>
        <script>lucide.createIcons();</script>

        <!-- Page transition overlay -->
        <div id="ov"
          style="position:fixed;inset:0;z-index:9999;background:#040010;animation:pIn .45s cubic-bezier(.4,0,.2,1) forwards;pointer-events:none;">
        </div>
        <style>
          @keyframes pIn {
            from {
              opacity: 1
            }

            to {
              opacity: 0
            }
          }

          @keyframes pOut {
            from {
              opacity: 0
            }

            to {
              opacity: 1
            }
          }

          #ov.leave {
            animation: pOut .35s cubic-bezier(.4, 0, .2, 1) forwards;
            pointer-events: all;
          }
        </style>
        <script>
          (function () {
            function fadeOut(href) { var ov = document.getElementById('ov'); ov.classList.add('leave'); setTimeout(function () { window.location.href = href; }, 360); }
            document.querySelectorAll('a.nav-link, a#logout-link').forEach(function (a) {
              a.addEventListener('click', function (e) { if (this.target === '_blank') return; e.preventDefault(); fadeOut(this.href); });
            });
          })();
        </script>
        <%- include('partials/promo_card') %>
        <%- include('partials/footer') %>
  </body>

  </html>


  <!-- Lucide -->
  <script src="/js/lucide.min.js"></script>
  <script>lucide.createIcons();</script>

  <%- include('partials/bg_stars') %>

  <script>
    /* ── XP & level helpers (mirrored from systems/levels.js) ── */
    function xpForLevel(n) { return 5*n*n + 50*n + 100; }
    function totalXpToLevel(n) { let t=0; for(let i=0;i<n;i++) t+=xpForLevel(i); return t; }
    const MSGS_PER_LVL = 50, MINS_PER_LVL = 30;

    function textHint(lvl) {
      const mode = document.querySelector('.choice-box[data-choice^="text-"].selected')?.dataset.choice;
      if (!lvl || lvl === 0) return 'Not required';
      if (mode === 'text-xp') {
        const msgs = Math.round(totalXpToLevel(lvl) / 20);
        return `Level ${lvl} · ~${msgs.toLocaleString()} messages`;
      } else {
        return `${(lvl * MSGS_PER_LVL).toLocaleString()} messages`;
      }
    }
    function voiceHint(lvl) {
      const mode = document.querySelector('.choice-box[data-choice^="voice-"].selected')?.dataset.choice;
      if (!lvl || lvl === 0) return 'Not required';
      if (mode === 'voice-xp') {
        const totalMins = Math.round(totalXpToLevel(lvl) / 10);
        const h = Math.floor(totalMins/60), m = totalMins % 60;
        return `Level ${lvl} · ${h>0?h+'h ':''}${m}min`;
      } else {
        const totalMins = lvl * MINS_PER_LVL;
        const h = Math.floor(totalMins/60), m = totalMins % 60;
        return `${h>0?h+'h ':''}${m} minutes`;
      }
    }

    function updateHints(row) {
      if (!row) return;
      const tIn  = row.querySelector('.text-level-input');
      const vIn  = row.querySelector('.voice-level-input');
      const tH   = row.querySelector('.text-hint');
      const vH   = row.querySelector('.voice-hint');
      if (tH && tIn) tH.textContent = textHint(parseInt(tIn.value)||0);
      if (vH && vIn) vH.textContent = voiceHint(parseInt(vIn.value)||0);
    }

    function spinChange(btn, dir) {
      const input = btn.parentElement.querySelector('.level-spinner-input');
      const val   = Math.max(0, (parseInt(input.value)||0) + dir);
      input.value = val;
      updateHints(btn.closest('tr'));
    }

    function deleteRoleRow(btn) {
      const row = btn.closest('tr');
      row.remove();
      updateCounter();
      if (!document.querySelector('#roles-tbody tr[data-role-id]')) {
        const empty = document.createElement('tr');
        empty.id = 'empty-row';
        empty.innerHTML = '<td colspan="5" class="table-empty">No reward roles configured</td>';
        document.getElementById('roles-tbody').appendChild(empty);
      }
      // Re-enable the role in the picker
      const roleId = row.dataset.roleId;
      const opt = document.querySelector(`.role-option[data-id="${roleId}"]`);
      if (opt) opt.classList.remove('is-added');
    }

    function updateCounter() { /* counter display removed */ }

    /* ── Role Picker ── */
    const GUILD_ROLES = JSON.parse(document.getElementById('guild-roles-data').textContent);
    let selectedRoleId = null;

    function buildPickerList(filter='') {
      const list = document.getElementById('role-picker-list');
      const addedIds = new Set(
        [...document.querySelectorAll('#roles-tbody tr[data-role-id]')].map(r=>r.dataset.roleId)
      );
      list.innerHTML = '';
      const fil = filter.toLowerCase();
      GUILD_ROLES
        .filter(r => !fil || r.name.toLowerCase().includes(fil))
        .forEach(role => {
          const el = document.createElement('div');
          el.className = 'role-option' + (addedIds.has(role.id) ? ' is-added' : '');
          el.dataset.id = role.id;
          const color = role.color || '#5865f2';
          const iconEl = role.icon
            ? `<img class="role-icon-sm" src="${role.icon}" alt="" onerror="this.style.display='none'" />`
            : `<span class="role-color-dot" style="background:${color}"></span>`;
          el.innerHTML = `${iconEl}<span class="role-name-text" style="color:${color !== '#000000' ? color : 'var(--white)'}">${role.name}</span>`;
          el.addEventListener('click', () => {
            if (el.classList.contains('is-added')) return;
            selectedRoleId = role.id;
            // Update picker button
            const dot  = document.getElementById('picker-dot');
            const lbl  = document.getElementById('picker-label');
            dot.style.background  = color !== '#000000' ? color : '#5865f2';
            dot.style.display     = role.icon ? 'none' : '';
            if (role.icon) {
              // show small icon in button
              let imgEl = document.getElementById('picker-icon-img');
              if (!imgEl) { imgEl = document.createElement('img'); imgEl.id='picker-icon-img'; imgEl.className='role-icon-sm'; lbl.before(imgEl); }
              imgEl.src = role.icon;
            }
            lbl.textContent = role.name;
            lbl.style.color = color !== '#000000' ? color : 'var(--white)';
            document.getElementById('add-role-btn').disabled = false;
            closePicker();
          });
          list.appendChild(el);
        });
      if (!list.children.length) {
        list.innerHTML = '<div style="padding:12px 14px;color:var(--muted);font-size:.82rem">No roles found</div>';
      }
    }

    function openPicker() {
      const dd = document.getElementById('role-picker-dropdown');
      const btn = document.getElementById('role-picker-btn');
      dd.style.display = 'flex';
      btn.classList.add('open');
      buildPickerList('');
      document.getElementById('role-search-input').value = '';
      document.getElementById('role-search-input').focus();
    }
    function closePicker() {
      document.getElementById('role-picker-dropdown').style.display = 'none';
      document.getElementById('role-picker-btn').classList.remove('open');
    }

    document.getElementById('role-picker-btn').addEventListener('click', (e) => {
      e.stopPropagation();
      const open = document.getElementById('role-picker-dropdown').style.display !== 'none';
      open ? closePicker() : openPicker();
    });
    document.getElementById('role-search-input').addEventListener('input', e => buildPickerList(e.target.value));
    document.addEventListener('click', e => {
      if (!document.getElementById('role-picker-wrap')?.contains(e.target)) closePicker();
      document.querySelectorAll('.cpicker-dropdown').forEach(dd => {
        if (dd.style.display !== 'none' && !dd.closest('.cpicker')?.contains(e.target)) {
          dd.style.display = 'none';
          dd.style.top = ''; dd.style.bottom = ''; dd.style.left = ''; dd.style.right = ''; dd.style.width = ''; dd.style.minWidth = '';
          dd.closest('.cpicker')?.querySelector('.cpicker-btn')?.classList.remove('open');
        }
      });
    });

    /* ── Add Role button ── */
    document.getElementById('add-role-btn').addEventListener('click', () => {
      if (!selectedRoleId) return;
      const alreadyAdded = document.querySelector(`#roles-tbody tr[data-role-id="${selectedRoleId}"]`);
      if (alreadyAdded) return;
      const count = document.querySelectorAll('#roles-tbody tr[data-role-id]').length;

      const role = GUILD_ROLES.find(r => r.id === selectedRoleId);
      if (!role) return;

      document.getElementById('empty-row')?.remove();

      const color = role.color || '#5865f2';
      const iconHtml = role.icon
        ? `<img class="role-icon-sm" src="${role.icon}" alt="" onerror="this.style.display='none'" />`
        : `<span class="role-color-dot" style="background:${color}"></span>`;

      const tr = document.createElement('tr');
      tr.dataset.roleId = role.id;
      tr.innerHTML = `
        <td><div class="role-cell-content">${iconHtml}<span class="role-name-text">${role.name}</span></div></td>
        <td><div class="spinner-cell">
          <div class="level-spinner">
            <button class="level-spinner-btn" type="button" onclick="spinChange(this,-1)">−</button>
            <input type="number" class="level-spinner-input text-level-input" min="0" max="999" value="1" onchange="updateHints(this.closest('tr'))" />
            <button class="level-spinner-btn" type="button" onclick="spinChange(this,1)">+</button>
          </div>
          <div class="spinner-hint text-hint"></div>
        </div></td>
        <td><div class="spinner-cell">
          <div class="level-spinner">
            <button class="level-spinner-btn" type="button" onclick="spinChange(this,-1)">−</button>
            <input type="number" class="level-spinner-input voice-level-input" min="0" max="999" value="0" onchange="updateHints(this.closest('tr'))" />
            <button class="level-spinner-btn" type="button" onclick="spinChange(this,1)">+</button>
          </div>
          <div class="spinner-hint voice-hint"></div>
        </div></td>
        <td><label class="toggle-switch"><input type="checkbox" class="either-level-toggle"><span class="toggle-slider"></span></label></td>
        <td><button class="btn-del-role" type="button" onclick="deleteRoleRow(this)" title="Remove">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="currentColor"><path opacity="0.4" d="M3.408 5L3.903 14.389C3.979 15.853 5.185 17 6.649 17H11.353C12.817 17 14.023 15.853 14.099 14.39L14.594 5H3.408Z"/><path d="M7.374 14C6.98 14 6.649 13.69 6.626 13.29L6.376 8.79C6.354 8.38 6.67 8.02 7.083 8C7.489 7.98 7.851 8.29 7.874 8.71L8.124 13.21C8.147 13.62 7.83 13.98 7.417 14H7.374Z"/><path d="M10.626 14H10.583C10.17 13.98 9.854 13.62 9.876 13.21L10.126 8.71C10.149 8.29 10.498 7.98 10.917 8C11.33 8.02 11.647 8.38 11.624 8.79L11.374 13.29C11.352 13.69 11.021 14 10.626 14Z"/><path d="M15.25 4H12V2.75C12 1.785 11.215 1 10.25 1H7.75C6.785 1 6 1.785 6 2.75V4H2.75C2.336 4 2 4.336 2 4.75C2 5.164 2.336 5.5 2.75 5.5H15.25C15.664 5.5 16 5.164 16 4.75C16 4.336 15.664 4 15.25 4ZM7.5 2.75C7.5 2.614 7.614 2.5 7.75 2.5H10.25C10.386 2.5 10.5 2.614 10.5 2.75V4H7.5V2.75Z"/></svg>
        </button></td>`;
      document.getElementById('roles-tbody').appendChild(tr);
      updateHints(tr);
      updateCounter();

      // Mark in picker list
      const opt = document.querySelector(`.role-option[data-id="${role.id}"]`);
      if (opt) opt.classList.add('is-added');

      // Reset picker
      selectedRoleId = null;
      document.getElementById('picker-label').textContent = 'Select a role to add...';
      document.getElementById('picker-label').style.color = 'var(--muted)';
      document.getElementById('picker-dot').style.display = 'none';
      const img = document.getElementById('picker-icon-img');
      if (img) img.remove();
      document.getElementById('add-role-btn').disabled = true;
    });

    /* ── Update hints on all rows at load & when mode changes ── */
    function refreshAllHints() {
      document.querySelectorAll('#roles-tbody tr[data-role-id]').forEach(updateHints);
    }
    document.querySelectorAll('.choice-box').forEach(box => {
      box.addEventListener('click', () => setTimeout(refreshAllHints, 10));
    });
    refreshAllHints();

    // ── Custom Picker (cpicker) factory ──────────────────────────
    function makeCPicker(wrapperId, hiddenId) {
      const wrap = document.getElementById(wrapperId);
      if (!wrap) return;
      const btn     = wrap.querySelector('.cpicker-btn');
      const dd      = wrap.querySelector('.cpicker-dropdown');
      const lbl     = btn.querySelector('.cpicker-label');
      const badge   = btn.querySelector('.cpicker-badge');
      const hidden  = document.getElementById(hiddenId);
      const isMulti = !!badge;
      const srch    = wrap.querySelector('.cpicker-search-wrap input');

      function getActive() { return [...dd.querySelectorAll('.cpicker-opt.active')]; }
      function syncHidden() {
        if (!hidden) return;
        if (isMulti) {
          const av = new Set(getActive().map(o => o.dataset.value));
          [...hidden.options].forEach(o => { o.selected = av.has(o.value); });
        } else {
          const a = dd.querySelector('.cpicker-opt.active');
          hidden.value = a ? a.dataset.value : '';
        }
      }
      function updateBadge() {
        if (!isMulti || !badge) return;
        const active = getActive();
        const ph = lbl.dataset.placeholder || 'None';
        if (!active.length) {
          lbl.textContent = ph; lbl.classList.add('cpicker-muted'); badge.style.display = 'none';
        } else {
          const names = active.map(o => o.textContent.trim().replace(/\s+/g,' ')).filter(Boolean);
          lbl.textContent = names.slice(0,2).join(', ') + (names.length > 2 ? ' +' + (names.length-2) : '');
          lbl.classList.remove('cpicker-muted');
          badge.textContent = active.length; badge.style.display = '';
        }
      }
      let rafId = null;
      function positionDd(immediate = false) {
        if (rafId) cancelAnimationFrame(rafId);
        const doPosition = () => {
          const rect = btn.getBoundingClientRect();
          const spaceBelow = window.innerHeight - rect.bottom - 6;
          const spaceAbove = rect.top - 6;
          const ddHeight = Math.min(300, dd.scrollHeight || 300);
          const showAbove = spaceBelow < ddHeight && spaceAbove > spaceBelow;
          // Remove inset property completely to avoid conflicts
          dd.style.removeProperty('inset');
          dd.style.setProperty('left', rect.left + 'px', 'important');
          dd.style.setProperty('width', rect.width + 'px', 'important');
          dd.style.setProperty('right', 'auto', 'important');
          dd.style.setProperty('min-width', rect.width + 'px', 'important');
          if (showAbove) {
            dd.style.setProperty('top', 'auto', 'important');
            dd.style.setProperty('bottom', (window.innerHeight - rect.top + 6) + 'px', 'important');
          } else {
            dd.style.setProperty('top', (rect.bottom + 6) + 'px', 'important');
            dd.style.setProperty('bottom', 'auto', 'important');
          }
        };
        if (immediate) {
          doPosition();
        } else {
          rafId = requestAnimationFrame(doPosition);
        }
      }
      function openDd() {
        // close all first
        document.querySelectorAll('.cpicker-dropdown').forEach(d => {
          d.style.display = 'none';
          d.style.removeProperty('visibility');
          d.style.removeProperty('inset');
          d.style.removeProperty('top');
          d.style.removeProperty('bottom');
          d.style.removeProperty('left');
          d.style.removeProperty('right');
          d.style.removeProperty('width');
          d.style.removeProperty('min-width');
          // move back to original parent if was detached to body
          const orig = d._origParent;
          if (orig && d.parentNode === document.body) orig.appendChild(d);
          d.closest('.cpicker')?.querySelector('.cpicker-btn')?.classList.remove('open');
        });
        closePicker();
        // Move to body to escape backdrop-filter stacking context
        if (!dd._origParent) dd._origParent = dd.parentNode;
        document.body.appendChild(dd);
        dd.style.visibility = 'hidden';
        dd.style.display = 'flex'; 
        dd.style.flexDirection = 'column';
        positionDd(true);
        requestAnimationFrame(() => { dd.style.visibility = 'visible'; });
        btn.classList.add('open');
        if (srch) { srch.value = ''; filterList(''); srch.focus(); }
      }
      function closeDd() {
        dd.style.display = 'none';
        dd.style.removeProperty('visibility');
        dd.style.removeProperty('inset');
        dd.style.removeProperty('top');
        dd.style.removeProperty('bottom');
        dd.style.removeProperty('left');
        dd.style.removeProperty('right');
        dd.style.removeProperty('width');
        dd.style.removeProperty('min-width');
        // Return dropdown to original parent
        if (dd._origParent && dd.parentNode === document.body) dd._origParent.appendChild(dd);
        btn.classList.remove('open');
        if (rafId) cancelAnimationFrame(rafId);
      }
      function filterList(q) {
        const ql = q.toLowerCase();
        dd.querySelectorAll('.cpicker-opt').forEach(o => {
          const t = o.textContent.toLowerCase();
          o.style.display = (!ql || t.includes(ql)) ? '' : 'none';
        });
      }
      btn.addEventListener('click', e => {
        e.stopPropagation();
        dd.style.display !== 'none' ? closeDd() : openDd();
      });
      let scrollTimeout = null;
      function onScrollResize() { 
        if (dd.style.display !== 'none') {
          if (scrollTimeout) clearTimeout(scrollTimeout);
          scrollTimeout = setTimeout(() => positionDd(false), 10);
        }
      }
      window.addEventListener('scroll', onScrollResize, true);
      window.addEventListener('resize', onScrollResize);
      if (srch) srch.addEventListener('input', e => filterList(e.target.value));
      wrap.querySelectorAll('.cpicker-opt').forEach(opt => {
        opt.addEventListener('click', e => {
          e.stopPropagation();
          if (isMulti) {
            opt.classList.toggle('active');
            syncHidden(); updateBadge();
          } else {
            dd.querySelectorAll('.cpicker-opt').forEach(o => o.classList.remove('active'));
            opt.classList.add('active');
            lbl.textContent = opt.textContent.trim().replace(/\s+/g,' ');
            lbl.classList.remove('cpicker-muted');
            syncHidden(); closeDd();
          }
          if (typeof markDirty === 'function') markDirty();
        });
      });
      // init
      if (!isMulti) {
        const a = dd.querySelector('.cpicker-opt.active');
        if (a) { lbl.textContent = a.textContent.trim().replace(/\s+/g,' '); lbl.classList.remove('cpicker-muted'); }
      } else { updateBadge(); }
      syncHidden();
    }
    makeCPicker('cpicker-reward-type', 'reward-type');
    makeCPicker('cpicker-disable-rewards', 'disable-rewards');
    makeCPicker('cpicker-levelup-channel', 'levelup-channel');
    makeCPicker('cpicker-ignore-channels', 'ignore-channels');
    makeCPicker('cpicker-ignore-roles', 'ignore-roles');
    makeCPicker('cpicker-reward-msg-channel', 'reward-msg-channel');
    makeCPicker('cpicker-text-msg-channel',   'text-msg-channel');
    makeCPicker('cpicker-voice-msg-channel',  'voice-msg-channel');

    // Close all cpickers when clicking outside
    document.addEventListener('click', e => {
      if (!e.target.closest('.cpicker')) {
        document.querySelectorAll('.cpicker-dropdown').forEach(dd => {
          if (dd.style.display !== 'none') {
            dd.style.display = 'none';
            dd.style.removeProperty('visibility');
            dd.style.removeProperty('inset');
            dd.style.removeProperty('top');
            dd.style.removeProperty('bottom');
            dd.style.removeProperty('left');
            dd.style.removeProperty('right');
            dd.style.removeProperty('width');
            dd.style.removeProperty('min-width');
            if (dd._origParent && dd.parentNode === document.body) dd._origParent.appendChild(dd);
            dd.closest('.cpicker')?.querySelector('.cpicker-btn')?.classList.remove('open');
          }
        });
      }
    });

    // ── Discord message preview ───────────────────────────────
    function dcParseMarkdown(text) {
      let html = text
        .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
        .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
        .replace(/\*(.+?)\*/g,    '<em>$1</em>')
        .replace(/`([^`]+)`/g,    '<code>$1</code>')
        .replace(/\[user\]/g,     '<span class="dc-mention">@User</span>')
        .replace(/\[userName\]/g, '<span class="dc-mention">Username</span>')
        .replace(/\[roleName\]/g, '<span class="dc-mention">@RoleName</span>')
        .replace(/\[oldLevel\]/g, '<strong>1</strong>')
        .replace(/\[newLevel\]/g, '<strong>2</strong>');
      return html;
    }
    function dcTimeNow() {
      const now = new Date();
      let h = now.getHours(), m = now.getMinutes();
      const ampm = h >= 12 ? 'PM' : 'AM';
      h = h % 12 || 12;
      return 'Today at ' + h + ':' + String(m).padStart(2,'0') + ' ' + ampm;
    }
    function initPreview(textareaId, previewId, timeId) {
      const ta = document.getElementById(textareaId);
      const pv = document.getElementById(previewId);
      const tm = timeId ? document.getElementById(timeId) : null;
      if (!ta || !pv) return;
      if (tm) tm.textContent = dcTimeNow();
      function update() { pv.innerHTML = dcParseMarkdown(ta.value); }
      ta.addEventListener('input', update);
      update();
    }
    initPreview('reward-msg-text', 'reward-preview', 'reward-preview-time');
    initPreview('text-msg-text',   'text-preview',   'text-preview-time');
    initPreview('voice-msg-text',  'voice-preview',  'voice-preview-time');

    // ── Variable tag click to insert ────────────────────────────
    document.querySelectorAll('.var-tag').forEach(tag => {
      tag.addEventListener('click', () => {
        const targetId = tag.closest('.vars-grid')?.dataset?.target;
        const ta = targetId ? document.getElementById(targetId) : null;
        if (!ta) return;
        const v = tag.dataset.var;
        const s = ta.selectionStart, e = ta.selectionEnd;
        ta.value = ta.value.slice(0, s) + v + ta.value.slice(e);
        ta.selectionStart = ta.selectionEnd = s + v.length;
        ta.focus();
        ta.dispatchEvent(new Event('input'));
      });
    });

    // ── Emoji Picker ────────────────────────────────────────
    const UNICODE_EMOJI_GROUPS = [
      { name: '😀 Smileys', emojis: ['😀','😁','😂','😃','😄','😅','😆','🤣','😇','😈','😉','😊','😋','😌','😍','🥰','😎','🤓','🤗','🤔','🤬','🤮','🤧','🤒','😑','😜','🤫','😞','😟','😢','😭','😔','😕','🤥','😖','😪','😫','🤤','😝','😤','😡','🤬','😠','😮','😯','😲','🤯','😳','🤰','😵','🤮','😶','😷','🤢','🤕','🤑','🤩','🥳','🥰','🤪','🤨'] },
      { name: '👍 Hands', emojis: ['👍','👎','👌','🤌','✌️','🤏','🤞','🤘','👈','👉','👆','👇','☝️','👏','🖐️','🖖','🫱','🫲','💪','🦵','🤎','🤟','🙏','🫰','👐','🤲','🤎','✍️','🤝'] },
      { name: '❤️ Hearts', emojis: ['❤️','🧡','💛','💚','💙','💜','🤎','💞','🖤','💔','❣️','💕','💖','💗','💘','💝','💟','♥️'] },
      { name: '🎉 Party', emojis: ['🎉','🎊','🎈','🎆','🎇','🥳','🎂','🎁','💝','🏆','🧨','🍾','🎶','🔥','✨','🟥','🟧','🟨','🟩','🟦','🟣','🟤'] },
      { name: '🔥 Symbols', emojis: ['✨','⭐','🔥','⚡','💫','✅','❌','❗','❓','💯','🔝','🔞','🔄','♻️','✔️','💠','💎','🔮','🌈','⚪','🟡','🟢','🔵','🟞'] },
      { name: '🌱 Nature', emojis: ['🌱','🌲','🌳','🌴','🌵','🌶️','🌷','🌸','🌹','🌺','🌻','🌼','🌿','☘️','🍀','🍁','🍂','🍃','🍄','🐢','🐣','🐱','🐶','🐼','🦋'] },
      { name: '👨‍💻 People', emojis: ['👨‍💻','👩','🧑','👴','👵','👶','🧒','👸','🤸','👻','💂','🕵️','👱','🦰','🦱','🦲','🦳','👷','👳','👨‍⚕️','👩‍⚕️'] },
    ];
    const CUSTOM_EMOJIS = JSON.parse(document.getElementById('guild-emojis-data')?.textContent || '[]');

    let _emojiPickerOpen = null; // current target textarea id

    function buildEmojiPicker(targetId) {
      const existing = document.getElementById('emoji-picker-global');
      if (existing) existing.remove();
      const ta = document.getElementById(targetId);
      if (!ta) return;
      const wrap = ta.closest('.msg-textarea-wrap');
      if (!wrap) return;
      wrap.style.position = 'relative';

      const picker = document.createElement('div');
      picker.id = 'emoji-picker-global';
      picker.className = 'emoji-picker-wrap';
      picker.innerHTML = `
        <div class="emoji-pick-tabs">
          <button class="emoji-pick-tab active" data-epanel="unicode">
            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
            Standard
          </button>
          <button class="emoji-pick-tab" data-epanel="custom">
            <svg viewBox="0 0 24 24"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
            Server
          </button>
        </div>
        <div class="emoji-pick-search"><input type="text" placeholder="Search emoji..." id="emoji-pick-q" /></div>
        <div class="emoji-pick-grid" id="ep-grid"></div>
      `;
      wrap.appendChild(picker);

      let activePanel = 'unicode';
      function renderGrid(q) {
        const grid = picker.querySelector('#ep-grid');
        grid.innerHTML = '';
        q = (q || '').toLowerCase();
        if (activePanel === 'unicode') {
          UNICODE_EMOJI_GROUPS.forEach(g => {
            g.emojis.filter(e => !q || g.name.toLowerCase().includes(q)).forEach(em => {
              const b = document.createElement('button');
              b.type = 'button'; b.className = 'emoji-pick-btn'; b.textContent = em;
              b.addEventListener('click', () => insertEmoji(em, targetId, picker));
              grid.appendChild(b);
            });
          });
          if (!grid.children.length) grid.innerHTML = '<span class="emoji-pick-empty">No emojis found</span>';
        } else {
          const list = CUSTOM_EMOJIS.filter(e => !q || e.name.toLowerCase().includes(q));
          if (!list.length) { grid.innerHTML = '<span class="emoji-pick-empty">No custom emojis</span>'; return; }
          list.forEach(e => {
            const b = document.createElement('button');
            b.type = 'button'; b.className = 'emoji-pick-btn custom-e'; b.title = e.name;
            b.innerHTML = `<img src="${e.url}" alt=":${e.name}:" />`;
            b.addEventListener('click', () => insertEmoji(':'+e.name+':', targetId, picker));
            grid.appendChild(b);
          });
        }
      }
      picker.querySelectorAll('.emoji-pick-tab').forEach(tab => {
        tab.addEventListener('click', () => {
          picker.querySelectorAll('.emoji-pick-tab').forEach(t => t.classList.remove('active'));
          tab.classList.add('active');
          activePanel = tab.dataset.epanel;
          picker.querySelector('#emoji-pick-q').value = '';
          renderGrid('');
        });
      });
      picker.querySelector('#emoji-pick-q').addEventListener('input', e => renderGrid(e.target.value));
      picker.addEventListener('click', e => e.stopPropagation());
      renderGrid('');
    }
    function insertEmoji(emoji, targetId, picker) {
      const ta = document.getElementById(targetId);
      if (!ta) return;
      const s = ta.selectionStart, e2 = ta.selectionEnd;
      ta.value = ta.value.slice(0, s) + emoji + ta.value.slice(e2);
      ta.selectionStart = ta.selectionEnd = s + emoji.length;
      ta.focus(); ta.dispatchEvent(new Event('input'));
      picker.remove(); _emojiPickerOpen = null;
    }
    document.querySelectorAll('.msg-emoji-btn').forEach(btn => {
      btn.addEventListener('click', e => {
        e.stopPropagation();
        const targetId = btn.dataset.target;
        const existing = document.getElementById('emoji-picker-global');
        if (existing && _emojiPickerOpen === targetId) { existing.remove(); _emojiPickerOpen = null; return; }
        if (existing) existing.remove();
        _emojiPickerOpen = targetId;
        buildEmojiPicker(targetId);
      });
    });
    document.addEventListener('click', () => {
      const ep = document.getElementById('emoji-picker-global');
      if (ep) { ep.remove(); _emojiPickerOpen = null; }
    });

    // Apply role-color-dot background from data attribute
    document.querySelectorAll('.role-color-dot[data-color]').forEach(el => {
      el.style.background = el.dataset.color;
    });

    // Tab switching
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById('tab-' + btn.dataset.tab).classList.add('active');
      });
    });

    // Choice boxes
    document.querySelectorAll('.choice-box').forEach(box => {
      box.addEventListener('click', () => {
        const group = box.dataset.choice.split('-')[0];
        document.querySelectorAll(`.choice-box[data-choice^="${group}-"]`).forEach(b => b.classList.remove('selected'));
        box.classList.add('selected');
        markDirty();
      });
    });

    // ── Dirty tracking ────────────────────────────────────────────────────────
    const _saveBar = document.getElementById('save-bar');
    function markDirty() { _saveBar?.classList.add('visible'); }
    function markClean() { _saveBar?.classList.remove('visible'); }
    document.addEventListener('change', e => {
      if (!e.target.closest('#emoji-picker-global')) markDirty();
    });
    document.addEventListener('input', e => {
      if (e.target.matches('textarea, input[type="text"], input[type="number"]') &&
          !e.target.closest('#emoji-picker-global')) markDirty();
    });

    // Save settings
    document.getElementById('save-btn')?.addEventListener('click', async () => {
      // Collect reward roles
      const rewardRoles = [];
      document.querySelectorAll('#roles-tbody tr[data-role-id]').forEach(row => {
        rewardRoles.push({
          ROLE_ID:      row.dataset.roleId,
          TEXT_LEVEL:   parseInt(row.querySelector('.text-level-input')?.value)  || 0,
          VOICE_LEVEL:  parseInt(row.querySelector('.voice-level-input')?.value) || 0,
          EITHER_LEVEL: row.querySelector('.either-level-toggle')?.checked || false
        });
      });

      const data = {
        ENABLE: document.getElementById('level-enable').checked,
        TEXT_ACTIVITY: {
          ENABLE: true,
          TRACK_MODE:          document.querySelector('.choice-box[data-choice^="text-"].selected')?.dataset.choice === 'text-xp' ? 'XP' : 'MESSAGES',
          XP_PER_MESSAGE_MIN:  15,
          XP_PER_MESSAGE_MAX:  25,
          COOLDOWN_SECONDS:    60,
          IGNORE_ROLES:        Array.from(document.getElementById('ignore-roles')?.selectedOptions || []).map(o => o.value),
          IGNORE_CHANNELS:     Array.from(document.getElementById('ignore-channels')?.selectedOptions || []).map(o => o.value)
        },
        VOICE_ACTIVITY: {
          ENABLE: true,
          TRACK_MODE:      document.querySelector('.choice-box[data-choice^="voice-"].selected')?.dataset.choice === 'voice-xp' ? 'XP' : 'MINUTES',
          XP_PER_MINUTE:   10,
          IGNORE_MUTED:    document.getElementById('ignore-muted')?.checked,
          IGNORE_DEAFENED: document.getElementById('ignore-deafened')?.checked
        },
        REWARD_ROLES: rewardRoles,
        REWARD_SETTINGS: {
          REMOVE_PREVIOUS_ROLES: document.getElementById('reward-type')?.value === 'REMOVE_PREVIOUS',
          DISABLE_REWARDS:       document.getElementById('disable-rewards')?.value === 'true',
          REMOVE_ON_RESET:       document.getElementById('remove-on-reset')?.checked,
          GIVE_HIGHEST_ROLE_ONLY:document.getElementById('highest-only')?.checked
        },
        LEVELUP_CHANNEL:         document.getElementById('levelup-channel')?.value || '',
        LEVELUP_MESSAGE_ENABLED: document.getElementById('levelup-enabled')?.checked ?? true,
        MESSAGES: {
          REWARD_ROLE: {
            CHANNEL: document.getElementById('reward-msg-channel')?.value || '',
            TEXT:    document.getElementById('reward-msg-text')?.value || '',
            DM:      document.getElementById('reward-msg-dm')?.checked || false
          },
          TEXT_LEVELUP: {
            CHANNEL: document.getElementById('text-msg-channel')?.value || '',
            TEXT:    document.getElementById('text-msg-text')?.value || ''
          },
          VOICE_LEVELUP: {
            CHANNEL: document.getElementById('voice-msg-channel')?.value || '',
            TEXT:    document.getElementById('voice-msg-text')?.value || ''
          }
        }
      };

      const btn = document.getElementById('save-btn');
      const lbl = document.getElementById('save-label');
      const hint = document.getElementById('save-hint');
      btn.disabled = true;
      lbl.textContent = btn.dataset.savingText || 'Saving...';
      try {
        const res = await fetch(window.location.pathname + '/save', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        if (res.ok) {
          lbl.textContent = btn.dataset.savedText || '✓ Saved!';
          btn.style.background = 'var(--green)';
          hint.textContent = new Date().toLocaleTimeString();
          hint.classList.add('show');
          setTimeout(() => {
            markClean();
            lbl.textContent = btn.dataset.saveText || 'Save Settings';
            btn.style.background = ''; btn.disabled = false;
            setTimeout(() => hint.classList.remove('show'), 3000);
          }, 2000);
        } else {
          lbl.textContent = btn.dataset.saveText || 'Save Settings';
          btn.disabled = false;
          hint.textContent = 'Failed to save'; hint.classList.add('show');
        }
      } catch (err) {
        console.error(err);
        lbl.textContent = btn.dataset.saveText || 'Save Settings';
        btn.disabled = false;
        hint.textContent = 'Network error'; hint.classList.add('show');
      }
    });
  </script>

  <!-- Page in overlay -->
  <div id="ov" style="position:fixed;inset:0;z-index:9999;background:#040010;animation:pIn .45s cubic-bezier(.4,0,.2,1) forwards;pointer-events:none;"></div>

  <script>
    /* ── Banner solid color ── */
    const bannerSolid = document.querySelector('.prof-banner-solid');
    if (bannerSolid && bannerSolid.dataset.bg) bannerSolid.style.background = bannerSolid.dataset.bg;

    /* ── Profile sidebar ── */
    const profSidebar = document.getElementById('prof-sidebar');
    const profBackdrop = document.getElementById('prof-backdrop');
    const openBtn = document.getElementById('open-profile');
    const closeBtn = document.getElementById('close-profile');
    const copyId = document.getElementById('prof-copy-id');

    function openProfile() { profSidebar.classList.add('open'); profBackdrop.classList.add('open'); profSidebar.setAttribute('aria-hidden','false'); document.body.style.overflow='hidden'; }
    function closeProfile() { profSidebar.classList.remove('open'); profBackdrop.classList.remove('open'); profSidebar.setAttribute('aria-hidden','true'); document.body.style.overflow=''; }

    openBtn.addEventListener('click', openProfile);
    document.querySelectorAll('.open-profile-btn').forEach(b => b.addEventListener('click', openProfile));
    if (closeBtn) closeBtn.addEventListener('click', closeProfile);
    profBackdrop.addEventListener('click', closeProfile);
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeProfile(); });

    if (copyId) {
      copyId.addEventListener('click', () => {
        navigator.clipboard.writeText(copyId.textContent.trim()).then(() => {
          const orig = copyId.textContent;
          copyId.textContent = '✓ Copied!';
          copyId.style.color = 'var(--cyan-l)';
          setTimeout(() => { copyId.textContent = orig; copyId.style.color = ''; }, 1500);
        });
      });
    }

    /* ── Language select ── */
    const langSelectEl = document.getElementById('lang-select');
    if (langSelectEl) {
      langSelectEl.addEventListener('change', function () {
        const u = new URL(window.location.href);
        u.searchParams.set('lang', this.value);
        window.location.href = u.toString();
      });
    }

    /* ── Mobile nav toggle ── */
    const menuToggle  = document.getElementById('menu-toggle');
    const mgmtSidebar = document.getElementById('mgmt-sidebar');
    const navSidebar  = document.querySelector('.nav-sidebar');
    const navOverlay  = document.getElementById('nav-overlay');

    function openMgmt()  { mgmtSidebar.classList.add('open'); navOverlay.classList.add('open'); document.body.style.overflow='hidden'; }
    function closeMgmt() { mgmtSidebar.classList.remove('open'); navOverlay.classList.remove('open'); document.body.style.overflow=''; }
    function openNav()   { if (navSidebar) { navSidebar.classList.add('open'); navOverlay.classList.add('open'); document.body.style.overflow='hidden'; } }
    function closeNav()  { if (navSidebar) { navSidebar.classList.remove('open'); navOverlay.classList.remove('open'); document.body.style.overflow=''; } }

    if (menuToggle) menuToggle.addEventListener('click', () => mgmtSidebar.classList.contains('open') ? closeMgmt() : openMgmt());
    if (navOverlay) navOverlay.addEventListener('click', () => { closeMgmt(); closeNav(); });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') { closeMgmt(); closeNav(); closeProfile(); } });

    const sortBtn = document.querySelector('.mgmt-sort-btn');
    if (sortBtn) {
      sortBtn.addEventListener('click', function () {
        if (navSidebar && navSidebar.classList.contains('open')) { closeNav(); } else { closeMgmt(); openNav(); }
      });
    }

    /* ── Mgmt section collapse ── */
    document.querySelectorAll('.mgmt-section-btn').forEach(btn => {
      btn.addEventListener('click', function () {
        const body = this.nextElementSibling;
        const isOpen = body.classList.contains('open');
        body.classList.toggle('open', !isOpen);
        this.classList.toggle('open', !isOpen);
      });
    });

    /* ── Page transitions ── */
    function fadeOut(href) {
      const ov = document.getElementById('ov');
      ov.classList.add('leave');
      setTimeout(() => { window.location.href = href; }, 360);
    }
    document.querySelectorAll('a.nav-link, a#logout-link').forEach(a => {
      a.addEventListener('click', function (e) {
        if (this.target === '_blank') return;
        e.preventDefault(); fadeOut(this.href);
      });
    });
  </script>
</body>
</html>


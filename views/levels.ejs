              <span class="cpicker-label <%= !_vmc ? 'cpicker-muted' : '' %>"><%= _vmc ? '#'+_vmc.name : (t.levels.eventChannelDefault) %></span>
              <svg class="cpicker-chevron" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
            </button>
            <div class="cpicker-dropdown" style="display:none">
              <div class="cpicker-search-wrap"><input type="text" placeholder="<%= t.levels.searchChannels %>" /></div>
              <div class="cpicker-list">
                <div class="cpicker-opt <%= !_vmc ? 'active' : '' %>" data-value=""><%= t.levels.eventChannelDefault %></div>
                <% guildChannels.forEach(ch => { %>
                  <div class="cpicker-opt <%= (levelSettings.MESSAGES && levelSettings.MESSAGES.VOICE_LEVELUP && levelSettings.MESSAGES.VOICE_LEVELUP.CHANNEL === ch.id) ? 'active' : '' %>" data-value="<%= ch.id %>">#<%= ch.name %></div>
                <% }) %>
              </div>
            </div>
          </div>
          <input type="hidden" id="voice-msg-channel" value="<%= (levelSettings.MESSAGES && levelSettings.MESSAGES.VOICE_LEVELUP && levelSettings.MESSAGES.VOICE_LEVELUP.CHANNEL) || '' %>">
        </div>
        <div class="form-row">
          <label class="form-label"><%= t.levels.messageText %></label>
          <div class="msg-textarea-wrap" style="position:relative">
            <textarea class="msg-textarea" id="voice-msg-text" maxlength="1000" data-preview="voice-preview"><%= (levelSettings.MESSAGES && levelSettings.MESSAGES.VOICE_LEVELUP && levelSettings.MESSAGES.VOICE_LEVELUP.TEXT) || "**🎙️ Congrats, [user]!** You've leveled up in voice from `[oldLevel]` to `[newLevel]`!" %></textarea>
            <button class="msg-emoji-btn" type="button" data-target="voice-msg-text" title="<%= t.levels.insertEmoji %>">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 18 18" fill="currentColor"><path opacity=".4" d="M9 17C4.589 17 1 13.411 1 9S4.589 1 9 1s8 3.589 8 8-3.589 8-8 8Z"/><circle cx="6" cy="8" r="1"/><circle cx="12" cy="8" r="1"/><path d="M11.897 10.758c-.154-.155-.366-.22-.583-.188-1.532.239-3.112.238-4.638-.001-.214-.031-.421.036-.573.186-.154.153-.227.376-.191.598.23 1.511 1.558 2.651 3.089 2.651 1.531 0 2.86-1.14 3.089-2.648.033-.216-.039-.437-.193-.598Z"/></svg>
            </button>
          </div>
          <div class="dc-preview-wrap">
            <div class="dc-preview-label"><%= t.levels.messagePreview %></div>
            <div class="dc-preview">
              <div class="dc-msg-row">
                <% if (botUser.avatar) { %>
                  <img class="dc-avatar" src="<%= botUser.avatar %>" alt="bot" />
                <% } else { %>
                  <div class="dc-avatar dc-avatar-fallback" style="background:var(--purple)"><%= botUser.name.charAt(0) %></div>
                <% } %>
                <div class="dc-body">
                  <div class="dc-header">
                    <span class="dc-botname"><%= botUser.name %></span>
                    <span class="dc-app-badge"><% if (botUser.isVerified) { %><svg viewBox="0 0 16 16" fill="currentColor"><path d="M7.4 1.93 6 3H4a1 1 0 0 0-1 1v2L1.93 7.4a1 1 0 0 0 0 1.2L3 10v2a1 1 0 0 0 1 1h2l1.4 1.07a1 1 0 0 0 1.2 0L10 13h2a1 1 0 0 0 1-1v-2l1.07-1.4a1 1 0 0 0 0-1.2L13 6V4a1 1 0 0 0-1-1h-2L8.6 1.93a1 1 0 0 1-1.2 0ZM11 6.5 7.5 10 5 7.5l1-1 1.5 1.5 3.5-3.5 1 1Z"/></svg><% } %>APP</span>
                    <span class="dc-time" id="voice-preview-time"></span>
                  </div>
                  <div class="dc-v2-container">
                    <div class="dc-v2-text" id="voice-preview"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="vars-box">
            <div class="vars-title"><%= t.levels.availableVariablesClickToInsert2 %></div>
            <div class="vars-grid" data-target="voice-msg-text">
              <div class="var-item"><span class="var-tag" data-var="[user]">[user]</span><span class="var-desc"><%= t.levels.userMention %></span></div>
              <div class="var-item"><span class="var-tag" data-var="[userName]">[userName]</span><span class="var-desc"><%= t.levels.username %></span></div>
              <div class="var-item"><span class="var-tag" data-var="[oldLevel]">[oldLevel]</span><span class="var-desc"><%= t.levels.previousLevel %></span></div>
              <div class="var-item"><span class="var-tag" data-var="[newLevel]">[newLevel]</span><span class="var-desc"><%= t.levels.newLevel %></span></div>
            </div>
          </div>
        </div>
      </div>

      <!-- hidden guild emojis data -->
      <script id="guild-emojis-data" type="application/json"><%- JSON.stringify(guildEmojis) %></script>

    </div>

  <!-- Sticky Save Bar -->
  <div class="save-bar" id="save-bar">
    <span class="save-bar-hint" id="save-hint"></span>
    <button class="btn btn-primary" id="save-btn"
      data-save-text="<%= t.levels.saveSettings %>"
      data-saving-text="<%= t.levels.saving %>"
      data-saved-text="<%= t.levels.saved %>">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 10v4a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-4M12 7l-3-3-3 3M9 4v9"/></svg>
      <span id="save-label"><%= t.levels.saveSettings %></span>
    </button>
  </div>


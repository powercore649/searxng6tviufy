            if (e.target.classList.contains('wj-bld-btn-pill-del')) return;
            var bi = parseInt(this.dataset.bi);
            if (isNaN(bi) || !row.buttons[bi]) return;
            var b = row.buttons[bi];
            var newLbl = prompt(bAR ? 'نص الزر:' : 'Button label:', b.label || '');
            if (newLbl === null) return;
            b.label = newLbl.slice(0, 80);
            var styles = ['Primary','Secondary','Success','Danger','Link'];
            var newStyle = prompt(bAR ? 'النمط (Primary/Secondary/Success/Danger/Link):' : 'Style (Primary/Secondary/Success/Danger/Link):', b.style || 'Primary');
            if (newStyle !== null && styles.includes(newStyle)) b.style = newStyle;
            if (b.style === 'Link') {
              var newUrl = prompt(bAR ? 'الرابط:' : 'URL:', b.url || 'https://');
              if (newUrl !== null) b.url = newUrl;
              b.customId = '';
            }
            _wjRenderRows();
          });
        });
      }
      if (row.type === 'select') {
        var sPh = wrap.querySelector('._wj-sel-ph');
        if (sPh) sPh.addEventListener('input', function() { if (row.select) row.select.placeholder = this.value; _updatePreview(); });
        wrap.querySelectorAll('._wj-del-opt').forEach(function(btn) {
          btn.addEventListener('click', function(e) {
            e.stopPropagation();
            if (row.select && row.select.options) row.select.options.splice(parseInt(this.dataset.oi), 1);
            _wjRenderRows();
          });
        });
        var aOpt = wrap.querySelector('._wj-add-opt');
        if (aOpt) aOpt.addEventListener('click', function() {
          if (!row.select) row.select = { customId: _wjUid(), placeholder: '', minValues: 1, maxValues: 1, disabled: false, options: [] };
          if (!row.select.options) row.select.options = [];
          if (row.select.options.length >= 25) return;
          row.select.options.push({ label: bAR ? 'خيار' : 'Option', value: _wjUid(), description: '', emoji: '', default: false });
          _wjRenderRows();
        });
      }
      if (row.type === 'container') {
        if (!row.children) row.children = [];
        var cCol = wrap.querySelector('._wj-cnt-color');
        if (cCol) cCol.addEventListener('input', function() {
          row.accentColor = this.value;
          var card = wrap.querySelector('.wj-bld-cnt-card');
          if (card) card.style.borderLeftColor = this.value;
          _updatePreview();
        });
        var cClr = wrap.querySelector('._wj-cnt-clear');
        if (cClr) cClr.addEventListener('click', function() { row.accentColor = ''; _wjRenderRows(); });
        wrap.querySelectorAll('._wj-del-child').forEach(function(btn) {
          btn.addEventListener('click', function(e) {
            e.stopPropagation();
            row.children.splice(parseInt(this.dataset.ci), 1);
            _wjRenderRows();
          });
        });
        wrap.querySelectorAll('._wj-child-td').forEach(function(ta) {
          ta.addEventListener('input', function() {
            var ci = parseInt(this.dataset.ci);
            if (row.children[ci]) { row.children[ci].text = this.value; _updatePreview(); }
          });
        });
        wrap.querySelectorAll('._wj-child-sep-div').forEach(function(chk) {
          chk.addEventListener('change', function() {
            var ci = parseInt(this.dataset.ci);
            if (row.children[ci]) { row.children[ci].divider = this.checked; _wjRenderRows(); }
          });
        });
        wrap.querySelectorAll('._wj-child-sep-sp').forEach(function(sel) {
          sel.addEventListener('change', function() {
            var ci = parseInt(this.dataset.ci);
            if (row.children[ci]) { row.children[ci].spacing = this.value; _wjRenderRows(); }
          });
        });
        wrap.querySelectorAll('._wj-child-img-url').forEach(function(inp) {
          inp.addEventListener('change', function() {
            var ci = parseInt(this.dataset.ci);
            if (row.children[ci]) { row.children[ci].url = this.value; _wjRenderRows(); }
          });
        });
        wrap.querySelectorAll('._wj-child-img-desc').forEach(function(inp) {
          inp.addEventListener('input', function() {
            var ci = parseInt(this.dataset.ci);
            if (row.children[ci]) { row.children[ci].description = this.value; _updatePreview(); }
          });
        });
        wrap.querySelectorAll('._wj-child-sel-ph').forEach(function(inp) {
          inp.addEventListener('input', function() {
            var ci = parseInt(this.dataset.ci);
            if (row.children[ci] && row.children[ci].select) { row.children[ci].select.placeholder = this.value; _updatePreview(); }
          });
        });
        var acBtn = wrap.querySelector('._wj-add-child-btn');
        var acMenu = wrap.querySelector('._wj-add-child-menu');
        if (acBtn && acMenu) {
          acBtn.addEventListener('click', function(e) { e.stopPropagation(); acMenu.classList.toggle('open'); });
          document.addEventListener('click', function() { acMenu.classList.remove('open'); });
          function _wjAddChild(type) {
            acMenu.classList.remove('open');
            if (row.children.length >= 10) { _toast(bAR ? 'الحد الأقصى ١٠ عناصر' : 'Max 10 items per container', 'error'); return; }
            var ch = { id: 'c_' + _wjUid(), type: type };
            if (type === 'text_display') ch.text = '';
            else if (type === 'separator') { ch.divider = true; ch.spacing = 'Small'; }
            else if (type === 'image') { ch.url = ''; ch.description = ''; }
            else if (type === 'buttons') ch.buttons = [{ customId: _wjUid(), label: bAR ? 'زر' : 'Button', style: 'Primary', emoji: '', url: '', disabled: false }];
            else if (type === 'select') ch.select = { customId: _wjUid(), placeholder: bAR ? 'اختر...' : 'Select\u2026', minValues: 1, maxValues: 1, disabled: false, options: [{ label: bAR ? 'خيار 1' : 'Option 1', value: _wjUid(), description: '', emoji: '', default: false }] };
            row.children.push(ch);
            _wjRenderRows();
          }
          wrap.querySelector('._wj-child-text').addEventListener('click', function() { _wjAddChild('text_display'); });
          wrap.querySelector('._wj-child-sep').addEventListener('click',  function() { _wjAddChild('separator'); });
          wrap.querySelector('._wj-child-img').addEventListener('click',  function() { _wjAddChild('image'); });
          wrap.querySelector('._wj-child-btn').addEventListener('click',  function() { _wjAddChild('buttons'); });
          wrap.querySelector('._wj-child-sel').addEventListener('click',  function() { _wjAddChild('select'); });
        }
      }
    }

    // ── Add component menu ──────────────────────────
    (function() {
      var aBtn  = document.getElementById('wjAddCompBtn');
      var aMenu = document.getElementById('wjAddCompMenu');
      if (!aBtn || !aMenu) return;
      var mAR = '<%= lang %>' === 'ar';
      aBtn.addEventListener('click', function(e) { e.stopPropagation(); aMenu.classList.toggle('open'); });
      document.addEventListener('click', function() { if (aMenu) aMenu.classList.remove('open'); });
      function _wjPushRow(type) {
        aMenu.classList.remove('open');
        var id = _wjUid();
        if (type === 'text_display') _wjCompRows.push({ id: id, type: 'text_display', text: '' });
        else if (type === 'separator') _wjCompRows.push({ id: id, type: 'separator', divider: true, spacing: 'Small' });
        else if (type === 'buttons') _wjCompRows.push({ id: id, type: 'buttons', buttons: [{ customId: _wjUid(), label: mAR ? 'زر' : 'Button', style: 'Primary', emoji: '', url: '', disabled: false }] });
        else if (type === 'select') _wjCompRows.push({ id: id, type: 'select', select: { customId: _wjUid(), placeholder: mAR ? 'اختر خياراً...' : 'Select an option\u2026', minValues: 1, maxValues: 1, disabled: false, options: [{ label: mAR ? 'خيار 1' : 'Option 1', value: _wjUid(), description: '', emoji: '', default: false }] } });
        else if (type === 'image') _wjCompRows.push({ id: id, type: 'image', url: '', description: '' });
        else if (type === 'container') _wjCompRows.push({ id: id, type: 'container', accentColor: '', children: [] });
        _wjRenderRows();
      }
      document.getElementById('wjMenuText').addEventListener('click', function() { _wjPushRow('text_display'); });
      document.getElementById('wjMenuSep').addEventListener('click',  function() { _wjPushRow('separator'); });
      document.getElementById('wjMenuBtn').addEventListener('click',  function() { _wjPushRow('buttons'); });
      document.getElementById('wjMenuSel').addEventListener('click',  function() { _wjPushRow('select'); });
      document.getElementById('wjMenuImg').addEventListener('click',  function() { _wjPushRow('image'); });
      document.getElementById('wjMenuCnt').addEventListener('click',  function() { _wjPushRow('container'); });
    })();

    // ── Serialize / Load ────────────────────────────
    function _wjSerialize() { return JSON.stringify({ components: _wjCompRows }); }

    function _wjLoad(json) {
      try {
        var d = JSON.parse(json || '{}');
        _wjCompRows = Array.isArray(d.components) ? d.components : [];
        _wjCompRows.forEach(function(r) { if (!r.id) r.id = _wjUid(); });
      } catch(e) { _wjCompRows = []; }
      _wjRenderRows();
    }

    // ── Discord component v2 preview renderers ──────
    function _wjDcMd(raw) {
      if (!raw) return '';
      var s = raw.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
      s = s.replace(/\*\*\*(.+?)\*\*\*/g,'<strong><em>$1</em></strong>');
      s = s.replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>');
      s = s.replace(/__(.+?)__/g,'<u>$1</u>');
      s = s.replace(/\*(.+?)\*/g,'<em>$1</em>');
      s = s.replace(/_([^_]+)_/g,'<em>$1</em>');
      s = s.replace(/~~(.+?)~~/g,'<del>$1</del>');
      s = s.replace(/`([^`]+)`/g,'<code>$1</code>');
      s = s.replace(/\n/g,'<br>');
      return s;
    }

    function _wjRenderDcRow(row) {
      if (!row) return '';
      if (row.type === 'text_display') return '<div class="wj-dc-text-display">' + _wjDcMd(row.text || '') + '</div>';
      if (row.type === 'separator') {
        var sc = row.spacing === 'Large' ? 'wj-dc-separator-l' : 'wj-dc-separator-s';
        return row.divider !== false ? '<div class="' + sc + '"><hr class="wj-dc-hr"></div>' : '<div class="' + sc + '"></div>';
      }
      if (row.type === 'container') {
        var ac = row.accentColor || '#5865f2';
        var inner = (row.children || []).map(_wjRenderDcRow).join('') || '<div style="color:#949ba4;font-size:.8rem;font-style:italic;padding:4px 0;">(empty)</div>';
        return '<div class="wj-dc-container" style="border-left-color:' + _esc(ac) + ';">' + inner + '</div>';
      }
      if (row.type === 'image') {
        if (!row.url) return '<div class="wj-dc-image-placeholder">\uD83D\uDDBC Image URL not set</div>';
        return '<div class="wj-dc-image-wrap"><img src="' + _esc(row.url) + '" class="wj-dc-image" alt="' + _esc(row.description || '') + '" onerror="this.style.display=\'none\'"></div>';
      }
      if (row.type === 'buttons') {
        var bmap = { Primary:'wj-dc-btn-primary', Secondary:'wj-dc-btn-secondary', Success:'wj-dc-btn-success', Danger:'wj-dc-btn-danger', Link:'wj-dc-btn-link' };
        var btns = (row.buttons || []).map(function(b) {
          return '<button class="wj-dc-btn ' + (bmap[b.style] || 'wj-dc-btn-secondary') + '"' + (b.disabled ? ' disabled' : '') + '>' + (b.emoji ? _esc(b.emoji) + ' ' : '') + _esc(b.label || 'Button') + '</button>';
        }).join('');
        return '<div class="wj-dc-action-row">' + btns + '</div>';
      }
      if (row.type === 'select') {
        var sp = (row.select && row.select.placeholder) ? row.select.placeholder : 'Select an option\u2026';
        return '<div class="wj-dc-select-wrap"><div class="wj-dc-select"><span>' + _esc(sp) + '</span><svg viewBox="0 0 24 24" width="16" height="16" fill="#949ba4"><path d="M16.59 8.59L12 13.17 7.41 8.59 6 10l6 6 6-6z"/></svg></div></div>';
      }
      return '';
    }

    // ── Tabs ───────────────────────────────────────
    document.querySelectorAll('.wj-tab').forEach(tab => {
      tab.addEventListener('click', function() {
        const target = this.dataset.tab;
        document.querySelectorAll('.wj-tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.wj-tab-content').forEach(c => c.classList.remove('active'));
        this.classList.add('active');
        const el = document.getElementById('tab-' + target);
        if (el) el.classList.add('active');
        if (target === 'log') _loadLogs();
      });
    });

    // ── DM toggle ─────────────────────────────────
    const _dmToggle = document.getElementById('dmWelcome');
    const _dmBox    = document.getElementById('dmSettings');
    function _syncDm() { if (_dmBox) _dmBox.style.display = _dmToggle && _dmToggle.checked ? 'block' : 'none'; }
    if (_dmToggle) { _dmToggle.addEventListener('change', _syncDm); _syncDm(); }
    const _dmTA = document.getElementById('dmMessage');
    const _dmCC = document.getElementById('dmCharCount');
    if (_dmTA && _dmCC) _dmTA.addEventListener('input', function() { _dmCC.textContent = this.value.length; });

    // ── Helpers ────────────────────────────────────
    function _esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
    function _chName(id) {
      if (id === 'dm') return 'DM';
      const c = _guildChannels.find(c => c.id === id);
      return c ? '#' + c.name : (id || '—');
    }

    // ── Global member filter radio group ───────────
    document.querySelectorAll('#memberFilterGroup .wj-filter-opt').forEach(opt => {
      opt.addEventListener('click', function() {
        document.querySelectorAll('#memberFilterGroup .wj-filter-opt').forEach(o => o.classList.remove('selected'));
        this.classList.add('selected');
        const radio = this.querySelector('input[type="radio"]');
        if (radio) radio.checked = true;
        const v = this.dataset.filter;
        document.getElementById('ignoreBots').value  = v === 'nobots'   ? '1' : '';
        document.getElementById('ignoreUsers').value = v === 'nohumans' ? '1' : '';
        _autoSave();
      });
    });

    // ── Auto-save on global settings changes ───────────────
    // Debounce helper: waits 800 ms after last input before saving
    let _autoSaveTimer = null;
    function _debouncedAutoSave() {
      clearTimeout(_autoSaveTimer);
      _autoSaveTimer = setTimeout(_autoSave, 800);
    }

    // Checkboxes / toggles — save immediately on toggle
    ['moduleEnabled', 'welcomeText', 'dmWelcome', 'waitRules'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.addEventListener('change', _autoSave);
    });
    // Number inputs — use `input` event + debounce so every keystroke / arrow press is caught
    // (the `change` event only fires on blur, missing saves when user refreshes mid-edit)
    ['sendDelay', 'deleteDelay'].forEach(id => {
      const el = document.getElementById(id);
      if (el) {
        el.addEventListener('input',  _debouncedAutoSave);
        el.addEventListener('change', _autoSave); // also fire on blur/enter as a safety net
      }
    });
    // DM textarea — debounced so we don't save on every keystroke
    const _dmMsgField = document.getElementById('dmMessage');
    if (_dmMsgField) {
      _dmMsgField.addEventListener('input',  _debouncedAutoSave);
      _dmMsgField.addEventListener('change', _autoSave);
    }

    // ── Per-template member filter radio group ─────────
    function _syncTplFilterGroup(ignoreBots, ignoreUsers) {
      const group = document.getElementById('tplMemberFilterGroup');
      if (!group) return;
      let val = 'all';
      if (ignoreBots)  val = 'nobots';
      if (ignoreUsers) val = 'nohumans';
      group.querySelectorAll('.wj-filter-opt').forEach(opt => {
        const match = opt.dataset.filter === val;
        opt.classList.toggle('selected', match);
        const radio = opt.querySelector('input[type="radio"]');
        if (radio) radio.checked = match;
      });
      document.getElementById('tplIgnoreBots').value  = ignoreBots  ? '1' : '';
      document.getElementById('tplIgnoreUsers').value = ignoreUsers ? '1' : '';
    }
    document.querySelectorAll('#tplMemberFilterGroup .wj-filter-opt').forEach(opt => {
      opt.addEventListener('click', function() {
        document.querySelectorAll('#tplMemberFilterGroup .wj-filter-opt').forEach(o => o.classList.remove('selected'));
        this.classList.add('selected');
        const radio = this.querySelector('input[type="radio"]');
        if (radio) radio.checked = true;
        const v = this.dataset.filter;
        document.getElementById('tplIgnoreBots').value  = v === 'nobots'   ? '1' : '';
        document.getElementById('tplIgnoreUsers').value = v === 'nohumans' ? '1' : '';
      });
    });

    // ── Activity Log ───────────────────────────────
    let _wjLogs = [];
    let _wjLogsLoaded = false;

    async function _loadLogs() {
      if (_wjLogsLoaded) { _renderLogs(); return; }
      const spinner = document.getElementById('wjLogSpinner');
      const list    = document.getElementById('wjLogList');
      const empty   = document.getElementById('wjLogEmpty');
      const bar     = document.getElementById('wjLogBar');
      const footer  = document.getElementById('wjLogFooter');
      if (spinner) spinner.style.display = 'flex';
      if (list)    list.style.display    = 'none';
      if (empty)   empty.style.display   = 'none';
      if (bar)     bar.style.display     = 'none';
      if (footer)  footer.style.display  = 'none';
      try {
        const r = await fetch('/dashboard/<%= guildId %>/welcome/join/logs');
        if (!r.ok) throw new Error('HTTP ' + r.status);
        const d = await r.json();
        _wjLogs = d.logs || [];
        _wjLogsLoaded = true;
      } catch (e) {
        _wjLogs = [];
        _wjLogsLoaded = false;
      }
      if (spinner) spinner.style.display = 'none';
      _renderLogs();
    }

    function _renderLogs() {
      const list   = document.getElementById('wjLogList');
      const empty  = document.getElementById('wjLogEmpty');
      const bar    = document.getElementById('wjLogBar');
      const footer = document.getElementById('wjLogFooter');
      const typeF  = (document.getElementById('wjLogTypeFilter')   || {}).value || '';
      const statF  = (document.getElementById('wjLogStatusFilter') || {}).value || '';
      const dateF  = (document.getElementById('wjLogDateFilter')   || {}).value || '';
      if (!list || !empty) return;
      if (bar) bar.style.display = _wjLogs.length ? 'flex' : 'none';
      let logs = _wjLogs.slice();
      if (typeF) logs = logs.filter(function(l) { return l.type === typeF; });
      if (statF) logs = logs.filter(function(l) { return l.status === statF; });
      if (dateF) {
        const d = new Date(dateF);
        const next = new Date(d); next.setDate(next.getDate() + 1);
        logs = logs.filter(function(l) { const t = new Date(l.sentAt); return t >= d && t < next; });
      }
      if (!logs.length) {
        list.style.display  = 'none';
        empty.style.display = 'flex';
        if (footer) footer.style.display = 'none';
        return;
      }
      empty.style.display = 'none';
      list.style.display  = 'flex';
      if (footer) {
        footer.style.display  = 'block';
        footer.textContent = '<%= lang === "ar" ? "يُعرض" : "Showing" %> ' + logs.length + ' / ' + _wjLogs.length;
      }
      list.innerHTML = logs.map(function(log, i) {
        const time    = log.sentAt ? new Date(log.sentAt).toLocaleString() : '';
        const avatar  = log.avatarUrl
          ? '<img class="wj-log-avatar" src="' + _esc(log.avatarUrl) + '" alt="" loading="lazy" onerror="this.style.opacity=0">'
          : '<div class="wj-log-avatar"></div>';
        const name    = _esc(log.displayName || log.username || 'Unknown');
        const tplName = _esc(log.templateName || '\u2014');
        const chLabel = log.channelId === 'dm' ? 'DM' : _esc(_chName(log.channelId));
        const typeB   = '<span class="wj-log-badge ' + _esc(log.type || 'text') + '">' + _esc(log.type || 'text') + '</span>';
        const statB   = log.status === 'error'
          ? '<span class="wj-log-badge error" title="' + _esc(log.errorMsg || '') + '">\u2717 error</span>'
          : '<span class="wj-log-badge ok">\u2713 ok</span>';
        return '<div class="wj-log-entry">'
          + avatar
          + '<div class="wj-log-info"><div class="wj-log-name">' + name + '</div>'
          + '<div class="wj-log-meta">' + tplName + ' \u00b7 ' + chLabel + '</div></div>'
          + typeB + statB
          + '<span class="wj-log-time">' + _esc(time) + '</span>'
          + '<button class="wj-log-resend" data-idx="' + i + '"><%= lang === "ar" ? "إعادة إرسال" : "Resend" %></button>'
          + '</div>';
      }).join('');
      list.querySelectorAll('.wj-log-resend').forEach(function(btn) {
        btn.addEventListener('click', async function() {
          const log = logs[parseInt(this.dataset.idx)];
          const tpl = _templates.find(function(t) { return t.name === log.templateName; });
          if (!tpl) { _toast('<%= lang === "ar" ? "القالب غير موجود في القائمة الحالية" : "Template not found in current list" %>', 'error'); return; }
          this.disabled = true;
          try {
            const r = await fetch('/dashboard/<%= guildId %>/welcome/join/test-send', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ template: tpl, targetChannelId: log.channelId })
            });
            const d = await r.json();
            if (d.success) _toast('<%= lang === "ar" ? "تم الإرسال بنجاح" : "Sent successfully" %>', 'success');
            else _toast(d.error || 'Error', 'error');
          } catch (e) { _toast('Error', 'error'); }
          finally { this.disabled = false; }
        });
      });
    }

    document.getElementById('wjLogRefresh') && document.getElementById('wjLogRefresh').addEventListener('click', function() {
      _wjLogsLoaded = false; _loadLogs();
    });
    ['wjLogTypeFilter', 'wjLogStatusFilter', 'wjLogDateFilter'].forEach(function(id) {
      const el = document.getElementById(id);
      if (el) el.addEventListener('change', _renderLogs);
    });

    // ── Confirm Dialog ────────────────────────────
    let _confirmCb = null;
    function _confirm(title, msg, cb) {
      const ov = document.getElementById('wjConfirmOverlay');
      if (!ov) { if (cb) cb(); return; }
      document.getElementById('wjConfirmTitle').textContent = title;
      document.getElementById('wjConfirmMsg').textContent   = msg;
      _confirmCb = cb;
      ov.classList.add('open');
    }
    document.getElementById('wjConfirmOk').addEventListener('click', function() {
      document.getElementById('wjConfirmOverlay').classList.remove('open');
      if (_confirmCb) { _confirmCb(); _confirmCb = null; }
    });
    document.getElementById('wjConfirmCancel').addEventListener('click', function() {
      document.getElementById('wjConfirmOverlay').classList.remove('open');
      _confirmCb = null;
    });
    document.getElementById('wjConfirmOverlay').addEventListener('click', function(e) {
      if (e.target === this) { this.classList.remove('open'); _confirmCb = null; }
    });

    // ── Searchable Channel Select ─────────────────
    function _chSelectSet(val) {
      const hidden   = document.getElementById('tplChannel');
      const trigText = document.getElementById('tplChLabel');
      const list     = document.getElementById('tplChList');
      if (!hidden || !trigText || !list) return;
      hidden.value = val;
      const opt = list.querySelector('.wj-ch-opt[data-val="' + val + '"]');
      trigText.textContent = opt ? opt.textContent.trim() : '— <%= t.welcomeJoin.channelPlaceholder || "Select channel" %> —';
      trigText.classList.toggle('has-val', !!val);
      list.querySelectorAll('.wj-ch-opt').forEach(function(o) { o.classList.toggle('selected', o.dataset.val === val); });
    }
    (function _initChSelect() {
      var container = document.getElementById('tplChannelSelect');
      var trigger   = document.getElementById('tplChTrigger');
      var search    = document.getElementById('tplChSearch');
      var list      = document.getElementById('tplChList');
      if (!container || !trigger) return;
      trigger.addEventListener('click', function(e) { e.stopPropagation(); container.classList.toggle('open'); });
      document.addEventListener('click', function(e) {
        if (container && !container.contains(e.target)) {
          container.classList.remove('open');
          if (search) { search.value = ''; list.querySelectorAll('.wj-ch-opt').forEach(function(o) { o.classList.remove('hidden'); }); }
        }
      });
      if (search && list) {
        search.addEventListener('input', function() {
          var q = this.value.toLowerCase();
          list.querySelectorAll('.wj-ch-opt').forEach(function(opt) {
            opt.classList.toggle('hidden', !!q && !opt.textContent.toLowerCase().includes(q));
          });
        });
      }
      if (list) {
        list.querySelectorAll('.wj-ch-opt').forEach(function(opt) {
          opt.addEventListener('click', function() {
            _chSelectSet(opt.dataset.val || '');
            container.classList.remove('open');
            if (search) { search.value = ''; list.querySelectorAll('.wj-ch-opt').forEach(function(o) { o.classList.remove('hidden'); }); }
          });
        });
      }
    })();

    // ── Live Preview ──────────────────────────────
    function _updatePreview() {
      var body = document.getElementById('wjLivePreview');
      if (!body) return;
      var type = (document.querySelector('.wj-msg-type-btn.active') || {dataset:{}}).dataset.type || 'text';
      var html = '';
      if (type === 'embed') {
        var etitle  = ((document.getElementById('embedTitle')  || {}).value || '').trim();
        var edesc   = ((document.getElementById('embedDesc')   || {}).value || '').trim();
        var efooter = ((document.getElementById('embedFooter') || {}).value || '').trim();
        var ethumb  = ((document.getElementById('embedThumb')  || {}).value || '').trim();
        var ecolor  =  (document.getElementById('embedColor')  || {value:'#7c3aed'}).value || '#7c3aed';
        if (!etitle && !edesc) {
          html = '<div class="wj-dc-plain-empty"><%= lang === "ar" ? "أضف عنواناً أو وصفاً لرؤية المعاينة" : "Add a title or description to preview" %></div>';
        } else {
          html = '<div class="wj-dc-msg">' +
                 '<div class="wj-dc-avatar"></div>' +
                 '<div class="wj-dc-bubble">' +
                   '<div class="wj-dc-username">Bot <span class="wj-dc-bot-tag">BOT</span></div>' +
                   '<div class="wj-dc-embed">' +
                     '<div class="wj-dc-embed-bar" style="background:' + _esc(ecolor) + '"></div>' +
                     '<div class="wj-dc-embed-body">' +
                       '<div class="wj-dc-embed-top">' +
                         '<div class="wj-dc-embed-main">' +
                           (etitle ? '<div class="wj-dc-embed-title">' + _applyVars(etitle) + '</div>' : '') +
                           (edesc  ? '<div class="wj-dc-embed-desc">'  + _applyVars(edesc).replace(/\n/g,'<br>') + '</div>' : '') +
                         '</div>' +
                         (ethumb ? '<img class="wj-dc-embed-thumb" src="' + _esc(ethumb) + '" onerror="this.style.display=\'none\'" alt="">' : '') +
                       '</div>' +
                       (efooter ? '<div class="wj-dc-embed-footer">' + _applyVars(efooter) + '</div>' : '') +
                     '</div>' +
                   '</div>' +
                 '</div></div>';
        }
      } else if (type === 'text') {
        var tcontent = ((document.getElementById('tplContent') || {}).value || '').trim();
        if (!tcontent) {
          html = '<div class="wj-dc-plain-empty"><%= lang === "ar" ? "ابدأ بالكتابة لرؤية المعاينة" : "Start typing to see preview" %></div>';
        } else {
          html = '<div class="wj-dc-msg">' +
                 '<div class="wj-dc-avatar"></div>' +
                 '<div class="wj-dc-bubble">' +
                   '<div class="wj-dc-username">Bot <span class="wj-dc-bot-tag">BOT</span></div>' +
                   '<div class="wj-dc-text">' + _applyVars(tcontent).replace(/\n/g, '<br>') + '</div>' +
                 '</div></div>';
        }
      } else {
        var _cpHtml = _wjCompRows.map(_wjRenderDcRow).join('');
        if (!_cpHtml) {
          html = '<div class="wj-dc-plain-empty"><%= lang === "ar" ? "أضف عنصراً لرؤية المعاينة" : "Add a component to preview" %></div>';
        } else {
          html = '<div class="wj-dc-msg"><div class="wj-dc-avatar"></div><div class="wj-dc-bubble"><div class="wj-dc-username">Bot <span class="wj-dc-bot-tag">BOT</span></div><div class="wj-dc-comp-preview">' + _cpHtml + '</div></div></div>';
        }
      }
      body.innerHTML = html;
      // If this template is linked to the dynamic image, append the canvas thumbnail
      if (_editIdx >= 0 && _templates[_editIdx]) {
        const _linked = (document.getElementById('imgLinkedTemplate')?.value || '').trim();
        if (_linked && _templates[_editIdx].name === _linked) {
          const _thumbSrc = document.getElementById('imgPreviewThumb')?.src || '';
          if (_thumbSrc.startsWith('data:')) {
            const _imgRow = document.createElement('div');
            _imgRow.className = 'wj-dc-msg';
            _imgRow.innerHTML =
              '<div class="wj-dc-avatar"></div>' +
              '<div class="wj-dc-bubble">' +
                '<div class="wj-dc-username">Bot <span class="wj-dc-bot-tag">BOT</span></div>' +
                '<img src="' + _esc(_thumbSrc) + '" style="max-width:100%;border-radius:8px;margin-top:4px;" alt="">' +
              '</div>';
            body.appendChild(_imgRow);
          }
        }
      }
    }
    function _renderTemplates() {
      const list  = document.getElementById('templateList');
      const empty = document.getElementById('tplEmpty');
      const cEl   = document.getElementById('tpl-count');
      const tEl   = document.getElementById('tpl-total');
      list.querySelectorAll('.wj-template-item').forEach(el => el.remove());
      const n = _templates.length;
      if (cEl) cEl.textContent = String(n).padStart(2, '0');
      if (tEl) tEl.textContent = String(n).padStart(2, '0');
      if (n === 0) { if (empty) empty.style.display = 'flex'; return; }
      if (empty) empty.style.display = 'none';
      _templates.forEach((tpl, idx) => {
        const enabled = tpl.enabled !== false;
        const item = document.createElement('div');
        item.className = 'wj-template-item' + (enabled ? '' : ' tpl-disabled');
        item.innerHTML =
          '<label class="wj-tpl-toggle" data-toggle="' + idx + '" title="' + (enabled ? '<%= lang === "ar" ? "تعطيل" : "Disable" %>' : '<%= lang === "ar" ? "تفعيل" : "Enable" %>') + '">' +
            '<input type="checkbox"' + (enabled ? ' checked' : '') + '>' +
            '<span class="wj-tpl-toggle-track"></span>' +
          '</label>' +
          '<div class="wj-template-icon"><i data-lucide="message-square" style="width:16px;height:16px;stroke:currentColor;fill:none;"></i></div>' +
          '<div class="wj-template-info">' +
            '<div class="wj-template-name">' + _esc(tpl.name || 'Template ' + (idx + 1)) + '</div>' +
            '<div class="wj-template-meta">' +
              '<span class="wj-template-ch">' + _esc(_chName(tpl.channelId)) + '</span>' +
              '<span class="wj-template-type ' + _esc(tpl.type || 'text') + '">' + _esc(tpl.type || 'text') + '</span>' +
            '</div>' +
          '</div>' +
          '<div class="wj-template-actions">' +
            '<button class="wj-btn-icon success" data-send="' + idx + '" title="<%= lang === "ar" ? "إرسال تجريبي" : "Test Send" %>"><i data-lucide="send" style="width:13px;height:13px;stroke:currentColor;fill:none;"></i></button>' +
            '<button class="wj-btn-icon dup" data-dup="' + idx + '" title="<%= lang === "ar" ? "نسخ" : "Duplicate" %>"><i data-lucide="copy-plus" style="width:13px;height:13px;stroke:currentColor;fill:none;"></i></button>' +
            '<button class="wj-btn-icon" data-edit="' + idx + '" title="<%= lang === "ar" ? "تعديل" : "Edit" %>"><i data-lucide="pencil" style="width:14px;height:14px;stroke:currentColor;fill:none;"></i></button>' +
            '<button class="wj-btn-icon danger" data-del="' + idx + '" title="<%= lang === "ar" ? "حذف" : "Delete" %>"><i data-lucide="trash-2" style="width:14px;height:14px;stroke:currentColor;fill:none;"></i></button>' +
          '</div>';
        list.appendChild(item);
      });
      lucide.createIcons();
      list.querySelectorAll('[data-toggle]').forEach(lbl => lbl.addEventListener('click', function(e) {
        e.preventDefault();
        const idx = parseInt(this.dataset.toggle);
        if (!_templates[idx]) return;
        _templates[idx].enabled = _templates[idx].enabled === false ? true : false;
        _renderTemplates();
        _autoSave();
      }));
      list.querySelectorAll('[data-send]').forEach(btn => btn.addEventListener('click', () => _openTestSend(parseInt(btn.dataset.send))));
      list.querySelectorAll('[data-dup]').forEach(btn => btn.addEventListener('click', () => _duplicateTemplate(parseInt(btn.dataset.dup))));
      list.querySelectorAll('[data-edit]').forEach(btn => btn.addEventListener('click', () => _openModal(parseInt(btn.dataset.edit))));
      list.querySelectorAll('[data-del]').forEach(btn => btn.addEventListener('click', () => {
        const idx  = parseInt(btn.dataset.del);
        const name = _templates[idx]?.name || 'Template';
        _confirm(
          '<%= lang === "ar" ? "حذف القالب؟" : "Delete Template?" %>',
          '"' + _esc(name) + '" — <%= lang === "ar" ? "هل أنت متأكد؟ لا يمكن التراجع." : "Are you sure? This cannot be undone." %>',
          () => { _templates.splice(idx, 1); _renderTemplates(); _autoSave(); }
        );
      }));
      _refreshImgTemplateSelector();
    }

    // ── Randomized Groups ───────────────────
    let _groupEditId = null; // id of group being edited, null = new

    function _renderGroups() {
      const list  = document.getElementById('groupList');
      const empty = document.getElementById('groupEmpty');
      if (!list || !empty) return;
      list.innerHTML = '';
      if (_groups.length === 0) {
        empty.style.display = 'flex';
        list.style.display  = 'none';
        return;
      }
      empty.style.display = 'none';
      list.style.display  = 'flex';
      _groups.forEach((grp, idx) => {
        const enabled = grp.enabled !== false;
        const item = document.createElement('div');
        item.className = 'wj-group-item';
        const chips = (grp.templateNames || []).length
          ? grp.templateNames.map(n => '<span class="wj-group-chip">'+_esc(n)+'</span>').join('')
          : '<span class="wj-group-chip empty"><%= lang === "ar" ? "لا قوالب" : "no templates" %></span>';
        item.innerHTML =
          '<div class="wj-group-header">'+
            '<label class="wj-tpl-toggle">'+
              '<input type="checkbox"'+(enabled?' checked':'')+' data-grp-toggle="'+idx+'">'+
              '<span class="wj-tpl-toggle-track"></span>'+
            '</label>'+
            '<div class="wj-group-name">'+_esc(grp.name || 'Group')+'</div>'+
            '<div class="wj-group-actions">'+
              '<button class="wj-btn-icon" data-grp-edit="'+idx+'" title="<%= lang === "ar" ? "تعديل" : "Edit" %>"><i data-lucide="pencil" style="width:14px;height:14px;stroke:currentColor;fill:none;"></i></button>'+
              '<button class="wj-btn-icon danger" data-grp-del="'+idx+'" title="<%= lang === "ar" ? "حذف" : "Delete" %>"><i data-lucide="trash-2" style="width:14px;height:14px;stroke:currentColor;fill:none;"></i></button>'+
            '</div>'+
          '</div>'+
          '<div class="wj-group-chips">'+chips+'</div>';
        list.appendChild(item);
      });
      lucide.createIcons();
      list.querySelectorAll('[data-grp-toggle]').forEach(inp => inp.addEventListener('change', function() {
        const idx = parseInt(this.dataset.grpToggle);
        if (_groups[idx]) { _groups[idx].enabled = this.checked; _renderGroups(); _autoSave(); }
      }));
      list.querySelectorAll('[data-grp-edit]').forEach(btn => btn.addEventListener('click', () => _openGroupModal(parseInt(btn.dataset.grpEdit))));
      list.querySelectorAll('[data-grp-del]').forEach(btn => btn.addEventListener('click', () => {
        const idx  = parseInt(btn.dataset.grpDel);
        const name = _groups[idx]?.name || 'Group';
        _confirm(
          '<%= lang === "ar" ? "حذف المجموعة؟" : "Delete Group?" %>',
          '"'+_esc(name)+'" — <%= lang === "ar" ? "هل أنت متأكد؟ لا يمكن التراجع." : "Are you sure? This cannot be undone." %>',
          () => { _groups.splice(idx, 1); _renderGroups(); _autoSave(); }
        );
      }));
    }

    function _openGroupModal(editIdx) {
      _groupEditId = (editIdx >= 0) ? _groups[editIdx]?.id : null;
      const grp = editIdx >= 0 ? _groups[editIdx] : null;
      const titleEl = document.getElementById('groupModalTitle');
      if (titleEl) titleEl.textContent = grp
        ? '<%= lang === "ar" ? "تعديل المجموعة" : "Edit Group" %>'
        : '<%= lang === "ar" ? "مجموعة جديدة" : "New Group" %>';
      const nameInput = document.getElementById('groupNameInput');
      if (nameInput) nameInput.value = grp?.name || '';
      const tplList  = document.getElementById('groupTplList');
      const tplEmpty = document.getElementById('groupTplEmpty');
      if (tplList) {
        tplList.innerHTML = '';
        if (_templates.length === 0) {
          if (tplEmpty) tplEmpty.style.display = 'flex';
          tplList.style.display = 'none';
        } else {
          if (tplEmpty) tplEmpty.style.display = 'none';
          tplList.style.display = 'flex';
          _templates.forEach(tpl => {
            const checked = grp?.templateNames?.includes(tpl.name) || false;
            const row = document.createElement('label');
            row.className = 'wj-group-tpl-item';
            row.innerHTML = '<input type="checkbox" name="grpTpl" value="'+_esc(tpl.name)+'"'+(checked?' checked':'')+'>'+
              '<span>'+_esc(tpl.name || 'Template')+'<span class="wj-template-type '+_esc(tpl.type||'text')+'" style="margin-left:6px;">'+_esc(tpl.type||'text')+'</span></span>';
            tplList.appendChild(row);
          });
        }
      }
      document.getElementById('groupModal')?.classList.add('open');
      lucide.createIcons();
    }
    function _closeGroupModal() {
      document.getElementById('groupModal')?.classList.remove('open');
    }
    document.getElementById('groupModalClose')?.addEventListener('click', _closeGroupModal);
    document.getElementById('groupModalCancel')?.addEventListener('click', _closeGroupModal);
    document.getElementById('groupModal')?.addEventListener('click', function(e) { if (e.target === this) _closeGroupModal(); });
    document.getElementById('groupModalSave')?.addEventListener('click', function() {
      const name = (document.getElementById('groupNameInput')?.value || '').trim();
      if (!name) { _toast('<%= lang === "ar" ? "أدخل اسم المجموعة" : "Enter a group name" %>', 'error'); return; }
      const selected = [...document.querySelectorAll('#groupTplList input[name=grpTpl]:checked')].map(i => i.value);
      const existingIdx = _groupEditId ? _groups.findIndex(g => g.id === _groupEditId) : -1;
      if (existingIdx >= 0) {
        _groups[existingIdx].name = name;
        _groups[existingIdx].templateNames = selected;
      } else {
        _groups.push({ id: Math.random().toString(36).slice(2,10), name, enabled: true, templateNames: selected });
      }
      _renderGroups();
      _autoSave();
      _closeGroupModal();
    });

    // ── Randomized / Dynamic (placeholders) ───────────
    document.getElementById('newGroupBtn').addEventListener('click', () => _openGroupModal(-1));
    document.getElementById('openImageEditor')?.addEventListener('click', () => window._wiOpen && window._wiOpen());
    const _modalTit = document.getElementById('modalTitle');
    const CREATE_LABEL = '<%= t.welcomeJoin.tplModalCreate %>';
    const EDIT_LABEL   = '<%= t.welcomeJoin.tplModalEdit %>';
    function _openModal(editIdx) {
      _editIdx = (editIdx >= 0) ? editIdx : -1;
      const tpl = _editIdx >= 0 ? _templates[_editIdx] : null;
      if (_modalTit) _modalTit.textContent = _editIdx >= 0 ? EDIT_LABEL : CREATE_LABEL;
      document.getElementById('tplName').value           = tpl?.name            || '';
      document.getElementById('tplChannel').value        = tpl?.channelId       || '';
      _chSelectSet(tpl?.channelId || '');
      document.getElementById('tplContent').value        = tpl?.content         || '';
      document.getElementById('tplCharCount').textContent= (tpl?.content        || '').length;
      document.getElementById('embedTitle').value        = tpl?.embed?.title    || '';
      document.getElementById('embedDesc').value         = tpl?.embed?.description || '';
      document.getElementById('embedThumb').value        = tpl?.embed?.thumbnail  || '';
      const col = tpl?.embed?.color || '#7c3aed';
      document.getElementById('embedColor').value        = col;
      document.getElementById('embedColorHex').value     = col;
      document.getElementById('embedColorBar').style.background = col;
      document.getElementById('embedFooter').value       = tpl?.embed?.footer   || '';
      document.getElementById('tplComponentJson').value  = tpl?.componentJson   || '';
      _wjLoad(tpl?.componentJson || '{}');
      document.getElementById('tplWaitRules').checked    = tpl?.waitRules       || false;
      _syncTplFilterGroup(tpl?.ignoreBots || false, tpl?.ignoreUsers || false);
      document.getElementById('tplSendDelay').value      = tpl?.sendDelay       || 0;
      document.getElementById('tplDeleteDelay').value    = tpl?.deleteDelay     || 0;
      _setMsgType(tpl?.type || 'text');
      const ob = document.getElementById('msgOptsBody');
      const ob_btn = document.getElementById('msgOptsToggle');
      if (ob) ob.style.display = 'none';
      if (ob_btn) ob_btn.classList.remove('open');
      _updatePreview();
      _modal.classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function _closeModal() { _modal.classList.remove('open'); document.body.style.overflow = ''; }
    document.getElementById('modalClose').addEventListener('click', _closeModal);
    document.getElementById('modalCancelBtn').addEventListener('click', _closeModal);
    _modal.addEventListener('click', e => { if (e.target === _modal) _closeModal(); });
    document.getElementById('createTemplateBtn').addEventListener('click', () => {
      const def = document.getElementById('defaultChannel')?.value || '';
      _openModal(-1);
      _chSelectSet(def);
    });

    // ── Msg type switch ────────────────────────────
    function _setMsgType(type) {
      document.querySelectorAll('.wj-msg-type-btn').forEach(b => b.classList.toggle('active', b.dataset.type === type));
      document.getElementById('editorText').style.display      = type === 'text'      ? 'block' : 'none';
      document.getElementById('editorEmbed').style.display     = type === 'embed'     ? 'block' : 'none';
      document.getElementById('editorComponent').style.display = type === 'component' ? 'block' : 'none';
    }
    document.querySelectorAll('.wj-msg-type-btn').forEach(btn => btn.addEventListener('click', () => { _setMsgType(btn.dataset.type); _updatePreview(); }));

    // ── Char counters ─────────────────────────────
    const _tplTA = document.getElementById('tplContent');
    const _tplCC = document.getElementById('tplCharCount');
    if (_tplTA && _tplCC) _tplTA.addEventListener('input', function() { _tplCC.textContent = this.value.length; _updatePreview(); });

    // ── Color sync ────────────────────────────────
    const _cIn  = document.getElementById('embedColor');
    const _cHex = document.getElementById('embedColorHex');
    const _cBar = document.getElementById('embedColorBar');
    if (_cIn && _cHex) {
      _cIn.addEventListener('input', function() { _cHex.value = this.value; if (_cBar) _cBar.style.background = this.value; _updatePreview(); });
      _cHex.addEventListener('input', function() { if (/^#[0-9a-fA-F]{6}$/.test(this.value)) { _cIn.value = this.value; if (_cBar) _cBar.style.background = this.value; _updatePreview(); } });
    }
    // ── Embed fields preview wiring ───────────────
    ['embedTitle','embedDesc','embedFooter','embedThumb'].forEach(function(id) {
      var el = document.getElementById(id); if (el) el.addEventListener('input', _updatePreview);
    });


    // ── Collapse ──────────────────────────────────
    const _optBtn  = document.getElementById('msgOptsToggle');
    const _optBody = document.getElementById('msgOptsBody');
    if (_optBtn) _optBtn.addEventListener('click', function() {
      const open = this.classList.toggle('open');
      if (_optBody) _optBody.style.display = open ? 'flex' : 'none';
    });

    // ── Save template ─────────────────────────────
    document.getElementById('modalSaveBtn').addEventListener('click', () => {
      const name      = document.getElementById('tplName').value.trim();
      const channelId = document.getElementById('tplChannel').value;
      const type      = document.querySelector('.wj-msg-type-btn.active')?.dataset.type || 'text';
      if (!name)      { _toast('<%= lang === "ar" ? "يرجى إدخال اسم القالب" : "Please enter a template name" %>', 'error'); return; }
      if (!channelId) { _toast('<%= lang === "ar" ? "يرجى اختيار قناة" : "Please select a channel" %>', 'error'); return; }
      const prevEnabled = _editIdx >= 0 ? (_templates[_editIdx]?.enabled !== false) : true;
      const tpl = {
        name, channelId, type,
        enabled: prevEnabled,
        content: document.getElementById('tplContent').value,
        embed: {
          title: document.getElementById('embedTitle').value,
          description: document.getElementById('embedDesc').value,
          thumbnail: document.getElementById('embedThumb').value,
          color: document.getElementById('embedColor').value,
          footer: document.getElementById('embedFooter').value
        },
        componentJson: _wjSerialize(),
        waitRules:     document.getElementById('tplWaitRules').checked,
        ignoreBots:    !!document.getElementById('tplIgnoreBots').value,
        ignoreUsers:   !!document.getElementById('tplIgnoreUsers').value,
        sendDelay:     parseInt(document.getElementById('tplSendDelay').value)   || 0,
        deleteDelay:   parseInt(document.getElementById('tplDeleteDelay').value) || 0
      };
      if (_editIdx >= 0) { _templates[_editIdx] = tpl; } else { _templates.push(tpl); }
      _renderTemplates();
      _closeModal();
      _autoSave();
    });

    // ── Duplicate Template ──────────────────────────
    function _duplicateTemplate(idx) {
      const tpl = _templates[idx];
      if (!tpl) return;
      const copy = JSON.parse(JSON.stringify(tpl));
      copy.name = copy.name + ' (<%= lang === "ar" ? "نسخة" : "Copy" %>)';
      copy.enabled = true;
      _templates.splice(idx + 1, 0, copy);
      _renderTemplates();
      _autoSave();
    }

    // ── Export Templates ────────────────────────────
    document.getElementById('exportTemplatesBtn')?.addEventListener('click', function() {
      if (_templates.length === 0) { _toast('<%= lang === "ar" ? "لا توجد قوالب للتصدير" : "No templates to export" %>', 'error'); return; }
      const data = JSON.stringify({ version: 1, templates: _templates }, null, 2);
      const blob = new Blob([data], { type: 'application/json' });
      const url  = URL.createObjectURL(blob);
      const a    = Object.assign(document.createElement('a'), { href: url, download: 'welcome-templates.json' });
      document.body.appendChild(a); a.click(); a.remove(); URL.revokeObjectURL(url);
      _toast('<%= lang === "ar" ? "تم تصدير القوالب" : "Templates exported" %>', 'success');
    });

    // ── Import Templates ────────────────────────────
    document.getElementById('importTemplatesBtn')?.addEventListener('click', function() {
      document.getElementById('importTemplateFile')?.click();
    });
    document.getElementById('importTemplateFile')?.addEventListener('change', function() {
      const file = this.files[0]; if (!file) return;
      const reader = new FileReader();
      reader.onload = function(e) {
        try {
          const parsed   = JSON.parse(e.target.result);
          const imported = Array.isArray(parsed) ? parsed : (Array.isArray(parsed.templates) ? parsed.templates : null);
          if (!imported || imported.length === 0) { _toast('<%= lang === "ar" ? "لم يتم العثور على قوالب في الملف" : "No templates found in file" %>', 'error'); return; }
          imported.forEach(t => { if (t.enabled === undefined) t.enabled = true; });
          _templates.push(...imported);
          _renderTemplates();
          _autoSave();
        } catch (err) { _toast('<%= lang === "ar" ? "فشل في قراءة الملف" : "Failed to parse JSON" %>', 'error'); }
      };
      reader.readAsText(file);
      this.value = '';
    });

    // ── Test Send ────────────────────────────────────
    let _testSendTpl = null;
    function _openTestSend(idx) {
      _testSendTpl = _templates[idx];
      if (!_testSendTpl) return;
      const nameEl = document.getElementById('testSendName');
      if (nameEl) nameEl.textContent = _testSendTpl.name || 'Template';
      const chEl = document.getElementById('testTargetCh');
      if (chEl) chEl.value = _testSendTpl.channelId || 'dm';
      document.getElementById('wjTestOverlay')?.classList.add('open');
    }
    document.getElementById('wjTestOverlay')?.addEventListener('click', function(e) {
      if (e.target === this) { this.classList.remove('open'); _testSendTpl = null; }
    });
    document.getElementById('testSendCancel')?.addEventListener('click', function() {
      document.getElementById('wjTestOverlay')?.classList.remove('open'); _testSendTpl = null;
    });
    document.getElementById('testSendConfirm')?.addEventListener('click', async function() {
      if (!_testSendTpl) return;
      const targetChannelId = document.getElementById('testTargetCh')?.value || 'dm';
      this.disabled = true;
      const btnEl = this;
      try {
        const r = await fetch('/dashboard/<%= guildId %>/welcome/join/test-send', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ template: _testSendTpl, targetChannelId })
        });
        const d = await r.json();
        if (d.success) {
          _toast('<%= lang === "ar" ? "تم الإرسال بنجاح!" : "Test message sent!" %>', 'success');
          document.getElementById('wjTestOverlay')?.classList.remove('open');
          _testSendTpl = null;
        } else { _toast(d.error || '<%= lang === "ar" ? "فشل الإرسال" : "Send failed" %>', 'error'); }
      } catch { _toast('<%= lang === "ar" ? "خطأ في الشبكة" : "Network error" %>', 'error'); }
      finally { btnEl.disabled = false; }
    });

    // ── Randomized / Dynamic ───────

    /* ══════════════════════════════════════════════════════════════
       IMAGE EDITOR  (fabric.js)
       ══════════════════════════════════════════════════════════════ */
    (function() {
      const GUILD_ID = '<%= guildId %>';
      let _wiCanvas = null;    // fabric.Canvas instance
      let _wiHistory = [];     // undo stack
      let _wiRedo = [];        // redo stack
      let _wiLoaded = false;
      let _wiDesignW = 500, _wiDesignH = 350; // logical design size
      let _wiLastRatio = 1;

      // ── helpers ────────────────────────────────────────
      function uid() { return Math.random().toString(36).slice(2,10); }
      function _esc(s) { return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

      function _syncBgColor() {
        const col = document.getElementById('wiBgColor')?.value || '#060018';
        if (_wiCanvas) { _wiCanvas.backgroundColor = col; _wiCanvas.renderAll(); }
      }
      document.getElementById('wiBgColor')?.addEventListener('input', _syncBgColor);

      // ── Open / close ─────────────────────────────────────
      window._wiOpen = function _wiOpen() {
        const overlay = document.getElementById('imgEditorOverlay');
        overlay.classList.add('open');
        document.body.style.overflow = 'hidden';
        if (!_wiLoaded) { _initFabric(); _loadFromServer(); _wiLoaded = true; }
        if (typeof lucide !== 'undefined') lucide.createIcons();
        // Double-rAF: wait for two frames so the overlay flex layout is fully painted
        requestAnimationFrame(() => requestAnimationFrame(_wiScaleCanvas));
      };
      function _wiClose() {
        document.getElementById('imgEditorOverlay').classList.remove('open');
        document.body.style.overflow = '';
      }
      document.getElementById('wiCloseBtn')?.addEventListener('click', _wiClose);

      // ── Mobile tab switching ──────────────────────────────
      (function() {
        function _mobTab(which) {
          const layersPanel = document.getElementById('wiLayersPanel');
          const propsPanel  = document.getElementById('wiPropsPanel');
          const tabL = document.getElementById('wiTabLayers');
          const tabP = document.getElementById('wiTabProps');
          if (which === 'layers') {
            layersPanel?.classList.add('mob-active');    propsPanel?.classList.remove('mob-active');
            tabL?.classList.add('active');               tabP?.classList.remove('active');
          } else {
            propsPanel?.classList.add('mob-active');     layersPanel?.classList.remove('mob-active');
            tabP?.classList.add('active');               tabL?.classList.remove('active');
          }
        }
        document.getElementById('wiTabLayers')?.addEventListener('click', () => _mobTab('layers'));
        document.getElementById('wiTabProps') ?.addEventListener('click', () => _mobTab('props'));
        window._wiMobTab = _mobTab;
      })();

      // ── Canvas responsive scaling ─────────────────────────
      function _wiScaleCanvas() {
        if (!_wiCanvas) return;
        const area = document.querySelector('.wi-canvas-area');
        if (!area) return;
        const aw = area.clientWidth  - 48;   // 24px padding × 2
        const ah = area.clientHeight - 48;  // 24px padding × 2
        if (aw <= 0 || ah <= 0) return;
        const ratio = Math.min(aw / _wiDesignW, ah / _wiDesignH, 1);
        if (Math.abs(ratio - _wiLastRatio) < 0.005) return;
        _wiLastRatio = ratio;
        _wiCanvas.setDimensions({ width: _wiDesignW * ratio, height: _wiDesignH * ratio });
        _wiCanvas.setZoom(ratio);
        _wiCanvas.renderAll();
      }
      window.addEventListener('resize', _wiScaleCanvas);

      // ── Init fabric canvas ────────────────────────────────
      function _initFabric() {
        if (_wiCanvas) return;
        _wiCanvas = new fabric.Canvas('wiCanvas', {
          width: _wiDesignW,
          height: _wiDesignH,
          backgroundColor: '#060018',
          selection: true,
          preserveObjectStacking: true,
          enableRetinaScaling: false,
        });

        // Scale to fit immediately (double-rAF ensures layout is committed)
        requestAnimationFrame(() => requestAnimationFrame(_wiScaleCanvas));

        // Watch canvas-area for size changes (e.g. panel open/close)
        if (typeof ResizeObserver !== 'undefined') {
          const _ro = new ResizeObserver(() => _wiScaleCanvas());
          const _area = document.querySelector('.wi-canvas-area');
          if (_area) _ro.observe(_area);
        }

        // Selection events → update props panel + layers
        _wiCanvas.on('selection:created',  _onSelChange);
        _wiCanvas.on('selection:updated',  _onSelChange);
        _wiCanvas.on('selection:cleared',  () => { _renderPropsPanel(null); _renderLayersList(); });
        _wiCanvas.on('object:modified',    () => { _pushHistory(); _renderLayersList(); _renderPropsPanel(_wiCanvas.getActiveObject()); });
        _wiCanvas.on('object:moving',      () => { _renderPropsPanel(_wiCanvas.getActiveObject()); });
        _wiCanvas.on('object:scaling',     () => { _renderPropsPanel(_wiCanvas.getActiveObject()); });
        _wiCanvas.on('object:rotating',    () => { _renderPropsPanel(_wiCanvas.getActiveObject()); });
      }

      function _onSelChange() {
        _renderLayersList();
        _renderPropsPanel(_wiCanvas.getActiveObject());
        // On mobile: auto-switch to Properties tab when an element is selected
        if (window.innerWidth <= 640 && window._wiMobTab) window._wiMobTab('props');
      }

      // ── History ───────────────────────────────────────────
      function _pushHistory() {
        _wiHistory.push(JSON.stringify(_wiCanvas));
        if (_wiHistory.length > 50) _wiHistory.shift();
        _wiRedo = [];
      }
      document.getElementById('wiUndo')?.addEventListener('click', () => {
        if (!_wiCanvas || _wiHistory.length < 2) return;
        _wiRedo.push(_wiHistory.pop());
        _wiCanvas.loadFromJSON(_wiHistory[_wiHistory.length - 1], () => {
          _wiCanvas.renderAll(); _renderLayersList(); _renderPropsPanel(null);
        });
      });
      document.getElementById('wiRedo')?.addEventListener('click', () => {
        if (!_wiCanvas || !_wiRedo.length) return;
        const state = _wiRedo.pop();
        _wiHistory.push(state);
        _wiCanvas.loadFromJSON(state, () => {
          _wiCanvas.renderAll(); _renderLayersList(); _renderPropsPanel(null);
        });
      });

      // ── Add elements ──────────────────────────────────────
      document.getElementById('wiAddText')?.addEventListener('click', () => {
        if (!_wiCanvas) return;
        const t = new fabric.IText('[userName]', {
          left: 100, top: 140, fontSize: 28, fontFamily: 'Inter',
          fill: '#ffffff', textAlign: 'center', originX: 'left', originY: 'top',
          fontWeight: 'bold', shadow: new fabric.Shadow({ color:'rgba(0,0,0,0.6)', blur:8, offsetX:2, offsetY:2 }),
        });
        t._wiType = 'text';
        t._wiId = uid();
        _wiCanvas.add(t);
        _wiCanvas.setActiveObject(t);
        _wiCanvas.renderAll();
        _pushHistory(); _renderLayersList();
      });

      document.getElementById('wiAddBg')?.addEventListener('click', () => {
        _openWiBgModal();
      });

      function _openWiBgModal() {
        const ov = document.getElementById('wiBgModal');
        if (!ov) return;
        document.getElementById('wiBgUrlInput').value = '';
        document.getElementById('wiBgUploadPreview').style.display = 'none';
        document.getElementById('wiBgUploadApply').disabled = true;
        _wiBgFile = null;
        ov.classList.add('open');
      }

      let _wiBgFile = null;

      // Tab switching
      document.querySelectorAll('#wiBgModal .wi-bg-tab').forEach(tab => {
        tab.addEventListener('click', function() {
          document.querySelectorAll('#wiBgModal .wi-bg-tab').forEach(t => t.classList.remove('active'));
          document.querySelectorAll('#wiBgModal .wi-bg-tab-pane').forEach(t => t.classList.remove('active'));
          this.classList.add('active');
          const pane = document.getElementById('wiBgTab' + this.dataset.tab.charAt(0).toUpperCase() + this.dataset.tab.slice(1));
          if (pane) pane.classList.add('active');
        });
      });

      // Close
      ['wiBgModalClose','wiBgModalCancel','wiBgUploadCancel'].forEach(id => {
        document.getElementById(id)?.addEventListener('click', () => {
          document.getElementById('wiBgModal').classList.remove('open');
        });
      });

      // URL Apply
      document.getElementById('wiBgUrlApply')?.addEventListener('click', () => {
        const url = (document.getElementById('wiBgUrlInput')?.value || '').trim();
        if (!url) return _toast('<%= lang === "ar" ? "أدخل رابطاً صالحاً" : "Please enter a valid URL" %>', 'error');
        document.getElementById('wiBgModal').classList.remove('open');
        _addFabricImage(url, { left:0, top:0, scaleX:1, scaleY:1 }, 'background', true);
      });
      document.getElementById('wiBgUrlInput')?.addEventListener('keydown', e => {
        if (e.key === 'Enter') document.getElementById('wiBgUrlApply')?.click();
      });

      // Drop zone
      const _bgDrop = document.getElementById('wiBgDropZone');
      const _bgFile = document.getElementById('wiBgFileInput');
      if (_bgDrop) {
        _bgDrop.addEventListener('click', () => _bgFile?.click());
        _bgDrop.addEventListener('dragover', e => { e.preventDefault(); _bgDrop.classList.add('drag'); });
        _bgDrop.addEventListener('dragleave', () => _bgDrop.classList.remove('drag'));
        _bgDrop.addEventListener('drop', e => {
          e.preventDefault(); _bgDrop.classList.remove('drag');
          const f = e.dataTransfer?.files?.[0];
          if (f) _handleBgFileSelect(f);
        });
      }
      _bgFile?.addEventListener('change', function() {
        if (this.files?.[0]) _handleBgFileSelect(this.files[0]);
        this.value = '';
      });

      function _handleBgFileSelect(file) {
        if (!file.type.startsWith('image/')) return _toast('<%= lang === "ar" ? "يجب أن يكون ملف صورة" : "File must be an image" %>', 'error');
        if (file.size > 8 * 1024 * 1024) return _toast('<%= lang === "ar" ? "الحجم الأقصى 8MB" : "Max size is 8MB" %>', 'error');
        _wiBgFile = file;
        const reader = new FileReader();
        reader.onload = e => {
          const prev = document.getElementById('wiBgUploadPreview');
          const img  = document.getElementById('wiBgUploadPreviewImg');
          if (prev && img) { img.src = e.target.result; prev.style.display = 'block'; }
        };
        reader.readAsDataURL(file);
        document.getElementById('wiBgUploadApply').disabled = false;
      }

      // Upload Apply
      document.getElementById('wiBgUploadApply')?.addEventListener('click', async function() {
        if (!_wiBgFile) return;
        const btn = this; btn.disabled = true;
        const origText = btn.innerHTML;
        btn.innerHTML = '<i data-lucide="loader-circle" style="stroke:currentColor;fill:none;width:13px;height:13px;animation:spin 1s linear infinite;"></i> <%= lang === "ar" ? "جارٍ الرفع…" : "Uploading…" %>';
        try {
          const fd = new FormData();
          fd.append('file', _wiBgFile);
          const r = await fetch('/dashboard/' + GUILD_ID + '/welcome/join/image/upload-bg', { method:'POST', body:fd });
          const d = await r.json();
          if (!d.url) throw new Error(d.error || 'Upload failed');
          document.getElementById('wiBgModal').classList.remove('open');
          _addFabricImage(d.url, { left:0, top:0, scaleX:1, scaleY:1 }, 'background', true);
          _toast('<%= lang === "ar" ? "تم رفع الصورة وتطبيقها" : "Image uploaded and applied" %>', 'success');
        } catch(err) {
          _toast(err.message || 'Upload failed', 'error');
          btn.disabled = false;
          btn.innerHTML = origText;
        }
      });

      document.getElementById('wiAddImg')?.addEventListener('click', () => {
        const url = prompt('<%= lang === "ar" ? "رابط الصورة:" : "Image URL:" %>');
        if (!url) return;
        _addFabricImage(url, { left:50, top:50, scaleX:.5, scaleY:.5 }, 'image');
      });

      document.getElementById('wiAddAvatar')?.addEventListener('click', () => {
        if (!_wiCanvas) return;
        const rect = new fabric.Rect({
          left:200, top:100, width:100, height:100, rx:50, ry:50,
          fill:'rgba(124,58,237,0.4)', stroke:'rgba(167,139,250,0.6)', strokeWidth:2,
        });
        const label = new fabric.Text('👤 Avatar', {
          left:250, top:150, fontSize:13, fill:'#a78bfa',
          originX:'center', originY:'center', selectable:false, evented:false,
        });
        const grp = new fabric.Group([rect, label], { left:200, top:100 });
        grp._wiType = 'avatar';
        grp._wiId   = uid();
        grp._wiSrc  = 'dynamic:avatar';
        _wiCanvas.add(grp);
        _wiCanvas.setActiveObject(grp);
        _wiCanvas.renderAll();
        _pushHistory(); _renderLayersList();
      });

      function _wiProxyUrl(url) {
        return /^https?:\/\//i.test(url)
          ? '/dashboard/proxy-image?url=' + encodeURIComponent(url)
          : url;
      }

      function _addFabricImage(url, opts, wiType, sendToBack) {
        if (!_wiCanvas) return;
        fabric.Image.fromURL(_wiProxyUrl(url), (img) => {
          if (!img) { _toast('<%= lang === "ar" ? "فشل تحميل الصورة" : "Failed to load image" %>', 'error'); return; }
          img.set({ left: opts.left||0, top: opts.top||0, scaleX: opts.scaleX||1, scaleY: opts.scaleY||1 });
          img._wiType = wiType || 'image';
          img._wiId   = uid();
          img._wiSrc  = url;  // preserve original URL for layer serialization
          _wiCanvas.add(img);
          if (sendToBack) _wiCanvas.sendToBack(img);
          _wiCanvas.setActiveObject(img);
          _wiCanvas.renderAll();
          _pushHistory(); _renderLayersList();
        }, {});
      }

      // ── Layers panel ──────────────────────────────────────
      function _renderLayersList() {
        if (!_wiCanvas) return;
        const list = document.getElementById('wiLayersList');
        if (!list) return;
        list.innerHTML = '';
        const objs = [..._wiCanvas.getObjects()].reverse();
        const active = _wiCanvas.getActiveObject();
        objs.forEach((obj) => {
          const isActive = obj === active;
          const type = obj._wiType || (obj.type === 'i-text' || obj.type === 'text' ? 'text' : 'image');
          const name = type === 'text' ? (obj.text||'text').slice(0,18) : (obj._wiSrc||type).slice(0,18);
          const icon = type === 'text' ? 'type' : type === 'avatar' ? 'user-circle-2' : 'image';

          const row = document.createElement('div');
          row.className = 'wi-layer-item' + (isActive ? ' active' : '');
          row.innerHTML =
            '<i data-lucide="' + icon + '" style="stroke:currentColor;fill:none;width:11px;height:11px;flex-shrink:0;"></i>' +
            '<span class="wi-layer-name">' + _esc(name) + '</span>' +
            '<div class="wi-layer-move">' +
              '<button type="button" class="wi-layer-up" title="Up">▲</button>' +
              '<button type="button" class="wi-layer-dn" title="Down">▼</button>' +
            '</div>' +
            '<button type="button" class="wi-layer-vis" title="Toggle vis"><i data-lucide="' + (obj.visible===false?'eye-off':'eye') + '" style="stroke:currentColor;fill:none;width:10px;height:10px;"></i></button>' +
            '<button type="button" class="wi-layer-del" title="Delete"><i data-lucide="x" style="stroke:currentColor;fill:none;width:10px;height:10px;"></i></button>';

          row.addEventListener('click', (e) => {
            if (e.target.closest('.wi-layer-move') || e.target.closest('.wi-layer-vis') || e.target.closest('.wi-layer-del')) return;
            _wiCanvas.setActiveObject(obj);
            _wiCanvas.renderAll();
            _renderLayersList();
            _renderPropsPanel(obj);
          });
          row.querySelector('.wi-layer-up')?.addEventListener('click', () => {
            _wiCanvas.bringForward(obj); _pushHistory(); _renderLayersList();
          });
          row.querySelector('.wi-layer-dn')?.addEventListener('click', () => {
            _wiCanvas.sendBackwards(obj); _pushHistory(); _renderLayersList();
          });
          row.querySelector('.wi-layer-vis')?.addEventListener('click', () => {
            obj.set('visible', obj.visible === false);
            _wiCanvas.renderAll(); _renderLayersList();
          });
          row.querySelector('.wi-layer-del')?.addEventListener('click', () => {
            _wiCanvas.remove(obj); _pushHistory();
            _renderLayersList(); _renderPropsPanel(null);
          });
          list.appendChild(row);
        });
        if (typeof lucide !== 'undefined') lucide.createIcons();
      }

      // ── Properties panel ──────────────────────────────────
      function _renderPropsPanel(obj) {
        const el = document.getElementById('wiPropsContent');
        if (!el) return;
        if (!obj) {
          el.innerHTML = '<div class="wi-no-sel" style="text-align:center;color:var(--muted);padding:24px 8px;font-size:.75rem;"><%= lang === "ar" ? "حدد عنصراً" : "Select an element to edit its properties" %></div>';
          return;
        }
        const type = obj._wiType || (obj.type === 'i-text' || obj.type === 'text' ? 'text' : 'image');
        const x   = Math.round(obj.left || 0);
        const y   = Math.round(obj.top  || 0);
        const w   = Math.round((obj.width  || 0) * (obj.scaleX || 1));
        const h   = Math.round((obj.height || 0) * (obj.scaleY || 1));
        const rot = Math.round(obj.angle || 0);
        const opac= Math.round(((obj.opacity !== undefined ? obj.opacity : 1)) * 100);

        let html = '<div class="wi-prop-group">'
          + '<div class="wi-prop-label"><%= lang === "ar" ? "الموضع / الحجم" : "Transform" %></div>'
          + '<div class="wi-prop-row"><span class="wi-prop-lbl">X</span><input type="number" class="wi-prop-num" id="wp-x" value="'+x+'">'
          + '<span class="wi-prop-lbl">Y</span><input type="number" class="wi-prop-num" id="wp-y" value="'+y+'"></div>'
          + '<div class="wi-prop-row"><span class="wi-prop-lbl">W</span><input type="number" class="wi-prop-num" id="wp-w" value="'+w+'">'
          + '<span class="wi-prop-lbl">H</span><input type="number" class="wi-prop-num" id="wp-h" value="'+h+'"></div>'
          + '<div class="wi-prop-row"><span class="wi-prop-lbl">°</span><input type="number" class="wi-prop-num" id="wp-rot" value="'+rot+'" style="width:55px;">'
          + '<span class="wi-prop-lbl" style="margin-left:8px;"><%= lang==="ar"?"ش":"Op"%>%</span><input type="number" class="wi-prop-num" id="wp-op" value="'+opac+'" min="0" max="100" style="width:50px;"></div>'
          + '</div><div class="wi-prop-divider"></div>';

        if (type === 'text') {
          const txt = obj.text || '';
          const fs  = Math.round(obj.fontSize || 24);
          const fw  = obj.fontWeight || 'normal';
          const col = obj.fill || '#ffffff';
          const aln = obj.textAlign || 'left';
          const shadow = !!(obj.shadow && obj.shadow.blur > 0);
          html += '<div class="wi-prop-group">'
            + '<div class="wi-prop-label"><%= lang === "ar" ? "المحتوى" : "Content" %></div>'
            + '<textarea id="wp-txt" class="wi-prop-input" rows="3">' + _esc(txt) + '</textarea>'
            + '<div class="wi-var-chips">'
            + ['[userName]','[serverName]','[memberCount]','[userCreatedDays]','[inviter]','[inviteCode]']
                .map(v => '<button type="button" class="wi-var-chip" data-var="'+v+'">'+v+'</button>').join('')
            + '</div></div><div class="wi-prop-divider"></div>'
            + '<div class="wi-prop-group"><div class="wi-prop-label"><%= lang === "ar" ? "الخط" : "Font" %></div>'
            + '<div class="wi-prop-row"><span class="wi-prop-lbl">Sz</span><input type="number" class="wi-prop-num" id="wp-fs" value="'+fs+'" min="6" max="200" style="width:55px;">'
            + '<select class="wi-prop-select" id="wp-fw"><option value="normal"'+(fw==='normal'?' selected':'')+'>Normal</option><option value="bold"'+(fw==='bold'?' selected':'')+'>Bold</option><option value="300"'+(fw==='300'?' selected':'')+'>300</option><option value="600"'+(fw==='600'?' selected':'')+'>600</option><option value="900"'+(fw==='900'?' selected':'')+'>900</option></select></div>'
            + '<div class="wi-prop-row"><span class="wi-prop-lbl">Col</span><input type="color" class="wi-prop-color" id="wp-col" value="'+col+'">'
            + '<select class="wi-prop-select" id="wp-aln"><option value="left"'+(aln==='left'?' selected':'')+'>Left</option><option value="center"'+(aln==='center'?' selected':'')+'>Center</option><option value="right"'+(aln==='right'?' selected':'')+'>Right</option></select></div>'
            + '<div class="wi-prop-check-row"><span class="wi-prop-check-label">Shadow</span><label class="wj-switch wj-switch-sm"><input type="checkbox" id="wp-shadow"'+(shadow?' checked':'')+'><span class="wj-switch-track"><span class="wj-switch-thumb"></span></span></label></div>'
            + '</div>';
        }

        if (type === 'image' || type === 'avatar' || type === 'background') {
          const srcVal = obj._wiSrc || '';
          const br     = obj._wiBorderRadius || 0;
          html += '<div class="wi-prop-group"><div class="wi-prop-label">Source</div>';
          if (type === 'avatar') {
            html += '<select class="wi-prop-select" id="wp-src" style="width:100%;">'
              + '<option value="dynamic:avatar"'+(srcVal==='dynamic:avatar'?' selected':'')+'>dynamic:avatar</option>'
              + '<option value="dynamic:guild_icon"'+(srcVal==='dynamic:guild_icon'?' selected':'')+'>dynamic:guild_icon</option>'
              + '</select>';
          } else {
            html += '<input type="text" class="wi-prop-input" id="wp-src" value="'+_esc(srcVal)+'" placeholder="https://...">';
          }
          const shape = obj._wiShape || (br >= 50 ? 'circle' : br === 0 ? 'square' : 'custom');
          html += '</div><div class="wi-prop-group"><div class="wi-prop-label">Shape</div>'
            + '<div class="wi-shape-btns">'
            + '<button type="button" class="wi-shape-btn'+(shape==='square'?' active':'')+'" id="wp-shape-sq"><svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/></svg> Square</button>'
            + '<button type="button" class="wi-shape-btn'+(shape==='circle'?' active':'')+'" id="wp-shape-ci"><svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/></svg> Circle</button>'
            + '</div></div>'
            + '<div class="wi-prop-group"><div class="wi-prop-label">Border Radius %</div>'
            + '<div class="wi-prop-row"><input type="range" class="wi-slider" id="wp-br" min="0" max="50" value="'+br+'">'
            + '<span id="wp-br-v" style="font-size:.7rem;color:var(--muted);width:30px;text-align:right;">'+br+'%</span></div></div>';
        }

        el.innerHTML = html;

        // Wire transform inputs
        function _applyTransform() {
          if (!obj) return;
          const nx = parseInt(document.getElementById('wp-x')?.value)||0;
          const ny = parseInt(document.getElementById('wp-y')?.value)||0;
          const nw = parseInt(document.getElementById('wp-w')?.value)||1;
          const nh = parseInt(document.getElementById('wp-h')?.value)||1;
          const nr = parseFloat(document.getElementById('wp-rot')?.value)||0;
          const no = (parseInt(document.getElementById('wp-op')?.value)||100)/100;
          obj.set({ left:nx, top:ny, angle:nr, opacity:no });
          if (type !== 'text') {
            obj.set({ scaleX: nw/(obj.width||nw), scaleY: nh/(obj.height||nh) });
          } else {
            obj.set({ width: nw });
          }
          obj.setCoords();
          _wiCanvas.renderAll();
        }
        ['wp-x','wp-y','wp-w','wp-h','wp-rot','wp-op'].forEach(id => {
          document.getElementById(id)?.addEventListener('change', _applyTransform);
        });

        if (type === 'text') {
          document.getElementById('wp-txt')?.addEventListener('input', function() {
            obj.set('text', this.value); _wiCanvas.renderAll();
          });
          document.getElementById('wp-fs')?.addEventListener('input', function() {
            obj.set('fontSize', parseInt(this.value)||24); _wiCanvas.renderAll();
          });
          document.getElementById('wp-fw')?.addEventListener('change', function() {
            obj.set('fontWeight', this.value); _wiCanvas.renderAll();
          });
          document.getElementById('wp-col')?.addEventListener('input', function() {
            obj.set('fill', this.value); _wiCanvas.renderAll();
          });
          document.getElementById('wp-aln')?.addEventListener('change', function() {
            obj.set('textAlign', this.value); _wiCanvas.renderAll();
          });
          document.getElementById('wp-shadow')?.addEventListener('change', function() {
            obj.set('shadow', this.checked
              ? new fabric.Shadow({ color:'rgba(0,0,0,0.6)', blur:8, offsetX:2, offsetY:2 })
              : null);
            _wiCanvas.renderAll();
          });
          el.querySelectorAll('.wi-var-chip').forEach(chip => {
            chip.addEventListener('click', () => {
              const ta = document.getElementById('wp-txt');
              if (!ta) return;
              const s = ta.selectionStart, e2 = ta.selectionEnd;
              const newVal = ta.value.slice(0,s) + chip.dataset.var + ta.value.slice(e2);
              ta.value = newVal;
              obj.set('text', newVal);
              _wiCanvas.renderAll();
            });
          });
        }

        if (type === 'image' || type === 'avatar' || type === 'background') {
          document.getElementById('wp-src')?.addEventListener('change', function() {
            const newSrc = this.value.trim();
            obj._wiSrc = newSrc;
            if (/^https?:\/\//i.test(newSrc)) {
              fabric.Image.fromURL(_wiProxyUrl(newSrc), (img) => {
                if (img) { obj.setElement(img.getElement()); obj.dirty=true; _wiCanvas.renderAll(); }
              }, {});
            }
          });
          const brSlider = document.getElementById('wp-br');
          const brValEl  = document.getElementById('wp-br-v');
          function _applyBR(v) {
            obj._wiBorderRadius = v;
            if (brValEl) brValEl.textContent = v+'%';
            if (brSlider) brSlider.value = v;
            if (v > 0) {
              const minSide = Math.min((obj.width||100)*(obj.scaleX||1),(obj.height||100)*(obj.scaleY||1));
              const r = (v/100)*minSide/(obj.scaleX||1);
              obj.clipPath = new fabric.Rect({ width:obj.width||100, height:obj.height||100, rx:r, ry:r, originX:'center', originY:'center' });
            } else {
              obj.clipPath = null;
            }
            obj.dirty = true;
            obj.setCoords();
            _wiCanvas.requestRenderAll();
          }
          document.getElementById('wp-shape-sq')?.addEventListener('click', function() {
            obj._wiShape = 'square';
            _applyBR(0);
            this.classList.add('active');
            document.getElementById('wp-shape-ci')?.classList.remove('active');
            _pushHistory();
          });
          document.getElementById('wp-shape-ci')?.addEventListener('click', function() {
            obj._wiShape = 'circle';
            _applyBR(50);
            this.classList.add('active');
            document.getElementById('wp-shape-sq')?.classList.remove('active');
            _pushHistory();
          });
          brSlider?.addEventListener('input', function() {
            const v = parseInt(this.value)||0;
            obj._wiShape = v >= 50 ? 'circle' : v === 0 ? 'square' : 'custom';
            document.getElementById('wp-shape-sq')?.classList.toggle('active', v === 0);
            document.getElementById('wp-shape-ci')?.classList.toggle('active', v >= 50);
            _applyBR(v);
          });
        }
      }

      // ── Serialize layers ──────────────────────────────────
      function _extractLayers() {
        if (!_wiCanvas) return [];
        return _wiCanvas.getObjects().map(obj => {
          const rawType = obj._wiType || (obj.type==='i-text'||obj.type==='text' ? 'text' : 'image');
          // Normalize 'avatar' → 'image' (dynamic source kept in src field)
          const type = rawType === 'avatar' ? 'image' : rawType;
          const base = {
            id:       obj._wiId || uid(),
            type,
            name:     type==='text' ? (obj.text||'').slice(0,20) : type,
            visible:  obj.visible !== false,
            x:        Math.round(obj.left||0),
            y:        Math.round(obj.top||0),
            width:    Math.round((obj.width||100)*(obj.scaleX||1)),
            height:   Math.round((obj.height||100)*(obj.scaleY||1)),
            rotation: Math.round(obj.angle||0),
            opacity:  +((obj.opacity!==undefined?obj.opacity:1)).toFixed(2),
          };
          if (type === 'text') {
            Object.assign(base, {
              content:    obj.text||'',
              fontSize:   obj.fontSize||24,
              fontFamily: obj.fontFamily||'Inter',
              fontWeight: obj.fontWeight||'normal',
              fontStyle:  obj.fontStyle||'normal',
              color:      obj.fill||'#ffffff',
              align:      obj.textAlign||'left',
              shadow:     !!(obj.shadow&&obj.shadow.blur>0),
              shadowColor:obj.shadow?.color||'rgba(0,0,0,0.6)',
            });
          } else {
            Object.assign(base, {
              src:          obj._wiSrc||'',
              borderRadius: obj._wiBorderRadius||0,
              shape:        obj._wiShape||'square',
            });
          }
          return base;
        });
      }

      // ── Load config from server ───────────────────────────
      async function _loadFromServer() {
        if (!_wiCanvas) return;
        try {
          const r = await fetch('/dashboard/' + GUILD_ID + '/welcome/join/image');
          if (!r.ok) return;
          const cfg = await r.json();
          const bgInput = document.getElementById('wiBgColor');
          if (bgInput && cfg.bgColor) bgInput.value = cfg.bgColor;
          _wiCanvas.backgroundColor = cfg.bgColor || '#060018';
          // Populate card fields
          const fields = {
            imgSendMode:       cfg.sendMode,
            imgAttachmentText: cfg.attachmentText,
            imgChannel:        cfg.channelId,
          };
          Object.entries(fields).forEach(([id, val]) => {
            const el2 = document.getElementById(id);
            if (el2 && val !== undefined && val !== null) el2.value = val;
          });
          // Restore linked template (options already populated by _refreshImgTemplateSelector at init)
          const _linkedSel = document.getElementById('imgLinkedTemplate');
          if (_linkedSel && cfg.linkedTemplateId) _linkedSel.value = cfg.linkedTemplateId;
          const ei = document.getElementById('imgEnabled');
          if (ei) ei.checked = !!cfg.enabled;
          // Show/hide mode-specific panels
          const sendModeEl   = document.getElementById('imgSendMode');
          const linkDiv      = document.getElementById('imgTemplateLinkOpts');
          const channelField = document.getElementById('imgChannelField');
          const attOpts      = document.getElementById('imgAttachmentOpts');
          const mode = sendModeEl ? sendModeEl.value : 'embed';
          const _isLinked = mode === 'embed' || mode === 'component';
          if (linkDiv)      linkDiv.style.display      = _isLinked            ? 'block' : 'none';
          if (channelField) channelField.style.display = mode === 'attachment' ? 'flex'  : 'none';
          if (attOpts)      attOpts.style.display      = mode === 'attachment' ? 'block' : 'none';
          const _linkActions = document.getElementById('imgLinkActions');
          if (_linkActions) _linkActions.style.display = (_isLinked && cfg.linkedTemplateId) ? 'block' : 'none';
          if (_isLinked && cfg.linkedTemplateId) {
            const _linkedTpl = _templates.find(t => t.name === cfg.linkedTemplateId);
            const _chLbl = document.getElementById('imgLinkedChannelLabel');
            if (_chLbl) _chLbl.textContent = _linkedTpl ? _chName(_linkedTpl.channelId) : '—';
          }
          if (Array.isArray(cfg.layers) && cfg.layers.length) {
            _restoreLayers(cfg.layers, cfg.width||500, cfg.height||350);
          } else {
            _pushHistory();
            _wiCanvas.renderAll();
          }
        } catch(e) { /* silent */ }
      }

      function _restoreLayers(layers, cw, ch) {
        if (!_wiCanvas) return;
        _wiDesignW = cw; _wiDesignH = ch;
        _wiLastRatio = 1;
        _wiCanvas.setZoom(1);
        _wiCanvas.setDimensions({ width: cw, height: ch });
        requestAnimationFrame(() => requestAnimationFrame(_wiScaleCanvas));
        let loaded = 0;
        const total = layers.length;
        function _done() {
          loaded++;
          if (loaded >= total) {
            _wiCanvas.renderAll();
            _renderLayersList();
            _pushHistory();
            requestAnimationFrame(_updatePreviewThumb);
          }
        }
        if (!total) { _pushHistory(); _wiCanvas.renderAll(); return; }
        layers.forEach(layer => {
          if (layer.type === 'text') {
            const t = new fabric.IText(layer.content||'', {
              left:layer.x, top:layer.y,
              fontSize:layer.fontSize||24, fontFamily:layer.fontFamily||'Inter',
              fontWeight:layer.fontWeight||'normal', fontStyle:layer.fontStyle||'normal',
              fill:layer.color||'#ffffff', textAlign:layer.align||'left',
              angle:layer.rotation||0,
              opacity:layer.opacity!==undefined?layer.opacity:1,
              visible:layer.visible!==false,
            });
            if (layer.shadow) t.set('shadow', new fabric.Shadow({ color:layer.shadowColor||'rgba(0,0,0,0.6)', blur:8, offsetX:2, offsetY:2 }));
            t._wiType='text'; t._wiId=layer.id||uid();
            _wiCanvas.add(t); _done();
          } else {
            const src = layer.src;
            const _isFetchable = src && (/^https?:\/\//i.test(src) || /^\//.test(src));
            if (!_isFetchable) {
              const rect = new fabric.Rect({
                left:layer.x, top:layer.y, width:layer.width||100, height:layer.height||100,
                fill:'rgba(124,58,237,0.3)', stroke:'rgba(167,139,250,0.5)', strokeWidth:2,
                rx:layer.borderRadius||0, ry:layer.borderRadius||0,
                angle:layer.rotation||0, opacity:layer.opacity!==undefined?layer.opacity:1,
                visible:layer.visible!==false,
              });
              rect._wiType=layer.type; rect._wiId=layer.id||uid(); rect._wiSrc=src; rect._wiBorderRadius=layer.borderRadius||0; rect._wiShape=layer.shape||'square';
              _wiCanvas.add(rect); _done();
            } else {
              // Use proxy only for external http(s) URLs; relative paths are same-origin and load directly
              const _proxySrc = /^https?:\/\//i.test(src) ? _wiProxyUrl(src) : src;
              fabric.Image.fromURL(_proxySrc, (img) => {
                if (!img) { _done(); return; }
                img.set({
                  left:layer.x, top:layer.y,
                  scaleX:layer.width/(img.width||1), scaleY:layer.height/(img.height||1),
                  angle:layer.rotation||0,
                  opacity:layer.opacity!==undefined?layer.opacity:1,
                  visible:layer.visible!==false,
                });
                img._wiType=layer.type; img._wiId=layer.id||uid(); img._wiSrc=src; img._wiBorderRadius=layer.borderRadius||0; img._wiShape=layer.shape||'square';
                if (layer.borderRadius>0) {
                  const minSide=Math.min(layer.width,layer.height);
                  const r=(layer.borderRadius/100)*minSide/(img.scaleX||1);
                  img.clipPath=new fabric.Rect({ width:img.width||100, height:img.height||100, rx:r, ry:r, originX:'center', originY:'center' });
                }
                _wiCanvas.add(img);
                if (layer.type==='background') _wiCanvas.sendToBack(img);
                _done();
              }, {});
            }
          }
        });
      }

      // ── Save ──────────────────────────────────────────────
      document.getElementById('wiSaveBtn')?.addEventListener('click', async () => {
        if (!_wiCanvas) return;
        const btn = document.getElementById('wiSaveBtn');
        btn.disabled = true;
        const payload = {
          enabled:          document.getElementById('imgEnabled')?.checked        || false,
          channelId:        document.getElementById('imgChannel')?.value          || '',
          width:            _wiDesignW || 500,
          height:           _wiDesignH || 350,
          bgColor:          document.getElementById('wiBgColor')?.value           || '#060018',
          sendMode:         document.getElementById('imgSendMode')?.value         || 'embed',
          linkedTemplateId: document.getElementById('imgLinkedTemplate')?.value   || '',
          attachmentText:   document.getElementById('imgAttachmentText')?.value   || '',
          layers:           _extractLayers(),
        };
        try {
          const r = await fetch('/dashboard/' + GUILD_ID + '/welcome/join/image/save', {
            method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(payload)
          });
          const d = await r.json();
          if (d.success) {
            _toast('<%= lang === "ar" ? "تم حفظ إعدادات الصورة" : "Image config saved" %>', 'success');
            _updatePreviewThumb();
          } else {
            _toast(d.error || 'Error', 'error');
          }
        } catch(e) { _toast('Save failed', 'error'); }
        btn.disabled = false;
      });

      // ── Preview helpers ────────────────────────────────────
      let _previewVisible = true;
      function _updatePreviewThumb() {
        if (!_wiCanvas) return;
        const wrap = document.getElementById('imgPreviewWrap');
        const img  = document.getElementById('imgPreviewThumb');
        if (!wrap || !img) return;
        try {
          img.src = _wiCanvas.toDataURL({ format: 'png', multiplier: 1 });
          wrap.style.display = 'block';
          const body = document.getElementById('imgPreviewBody');
          if (body) body.style.display = _previewVisible ? 'block' : 'none';
        } catch(e) { /* canvas not ready yet */ }
      }

      document.getElementById('imgPreviewToggle')?.addEventListener('click', function() {
        const body  = document.getElementById('imgPreviewBody');
        const icon  = document.getElementById('imgPreviewToggleIcon');
        const label = document.getElementById('imgPreviewToggleLabel');
        if (!body) return;
        _previewVisible = !_previewVisible;
        body.style.display = _previewVisible ? 'block' : 'none';
        if (icon)  { icon.setAttribute('data-lucide', _previewVisible ? 'eye-off' : 'eye'); if (typeof lucide !== 'undefined') lucide.createIcons({ nodes: [icon] }); }
        if (label) label.textContent = _previewVisible ? '<%= lang === "ar" ? "إخفاء" : "Hide" %>' : '<%= lang === "ar" ? "إظهار" : "Show" %>';
      });

      document.getElementById('wiPreviewBtn')?.addEventListener('click', () => {
        _updatePreviewThumb();
        _wiClose();
      });

      document.getElementById('imgSendMode')?.addEventListener('change', function() {
        const linkDiv      = document.getElementById('imgTemplateLinkOpts');
        const channelField = document.getElementById('imgChannelField');
        const attOpts      = document.getElementById('imgAttachmentOpts');
        const linkActions  = document.getElementById('imgLinkActions');
        const isLinked = this.value === 'embed' || this.value === 'component';
        if (linkDiv)      linkDiv.style.display      = isLinked            ? 'block' : 'none';
        if (channelField) channelField.style.display = this.value === 'attachment' ? 'flex'  : 'none';
        if (attOpts)      attOpts.style.display      = this.value === 'attachment' ? 'block' : 'none';
        if (linkActions)  linkActions.style.display  = 'none';
        const linkedSel = document.getElementById('imgLinkedTemplate');
        if (linkedSel) linkedSel.value = '';
        _refreshImgTemplateSelector();
      });

    })(); /* end image editor IIFE */

    // ── Image card: populate fields from server on page load ──
    (function _initImgCardFields() {
      const _icRaw = document.getElementById('_imgConfigInit');
      const _ic = _icRaw ? JSON.parse(_icRaw.textContent) : {};
      const _smEl = document.getElementById('imgSendMode');
      if (_smEl && _ic.sendMode) {
        _smEl.value = _ic.sendMode;
        // Fire display-toggle
        const linkDiv      = document.getElementById('imgTemplateLinkOpts');
        const channelField = document.getElementById('imgChannelField');
        const attOpts      = document.getElementById('imgAttachmentOpts');
        const isLinked = _ic.sendMode === 'embed' || _ic.sendMode === 'component';
        if (linkDiv)      linkDiv.style.display      = isLinked                  ? 'block' : 'none';
        if (channelField) channelField.style.display = _ic.sendMode==='attachment' ? 'flex'  : 'none';
        if (attOpts)      attOpts.style.display      = _ic.sendMode==='attachment' ? 'block' : 'none';
      }
      const _atEl = document.getElementById('imgAttachmentText');
      if (_atEl && _ic.attachmentText) _atEl.value = _ic.attachmentText;
      // Channel and linked-template selects depend on dynamic options — set after options are populated
      if (_ic.channelId || _ic.linkedTemplateId) {
        const _setSelects = () => {
          const chEl = document.getElementById('imgChannel');
          if (chEl && _ic.channelId) chEl.value = _ic.channelId;
          const ltEl = document.getElementById('imgLinkedTemplate');
          if (ltEl && _ic.linkedTemplateId) {
            ltEl.value = _ic.linkedTemplateId;
            const la = document.getElementById('imgLinkActions');
            if (la && _ic.linkedTemplateId) la.style.display = 'block';
          }
        };
        // Options may not be populated yet — retry once after a tick
        setTimeout(_setSelects, 0);
        setTimeout(_setSelects, 300);
      }
    })();

    // ── Image card field auto-save listeners ──────────────
    document.getElementById('imgEnabled')?.addEventListener('change', _imgAutoSave);
    document.getElementById('imgSendMode')?.addEventListener('change', _imgAutoSave);
    document.getElementById('imgChannel')?.addEventListener('change', _imgAutoSave);
    document.getElementById('imgLinkedTemplate')?.addEventListener('change', _imgAutoSave);
    document.getElementById('imgLinkedTemplate')?.addEventListener('change', function() {
      const la      = document.getElementById('imgLinkActions');
      const panel   = document.getElementById('imgActionsPanel');
      const chevron = document.getElementById('imgActionsChevron');
      if (la)      la.style.display        = this.value ? 'block' : 'none';
      if (panel)   panel.style.display     = 'none';
      if (chevron) chevron.style.transform = '';
      if (this.value) {
        const tpl = _templates.find(t => t.name === this.value);
        const lbl = document.getElementById('imgLinkedChannelLabel');
        if (lbl) lbl.textContent = tpl ? _chName(tpl.channelId) : '—';
      }
    });

    document.getElementById('imgTestSendBtn')?.addEventListener('click', async function() {
      const templateName = document.getElementById('imgLinkedTemplate')?.value;
      if (!templateName) return _toast('<%= lang === "ar" ? "اختر قالباً أولاً" : "Select a template first" %>', 'error');
      const btn = this; btn.disabled = true;
      try {
        const r = await fetch('/dashboard/<%= guildId %>/welcome/join/image/test-send', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ linkedTemplateName: templateName })
        });
        const d = await r.json();
        if (d.success) _toast('<%= lang === "ar" ? "تم الإرسال التجريبي بنجاح" : "Test sent successfully" %>', 'success');
        else           _toast(d.error || 'Error', 'error');
      } catch(e) { _toast('Request failed', 'error'); }
      btn.disabled = false;
    });

    document.getElementById('imgSetupNowBtn')?.addEventListener('click', async function() {
      const btn = this; btn.disabled = true;
      // Ensure image is enabled
      const enabledEl = document.getElementById('imgEnabled');
      if (enabledEl && !enabledEl.checked) enabledEl.checked = true;
      // Save image settings (enabled flag + all card fields)
      await _imgAutoSave();
      btn.disabled = false;
      _toast('<%= lang === "ar" ? "تم تفعيل وحفظ إعدادات الصورة الديناميكية" : "Dynamic image enabled and saved" %>', 'success');
    });

    document.getElementById('imgActionsToggle')?.addEventListener('click', function() {
      const panel   = document.getElementById('imgActionsPanel');
      const chevron = document.getElementById('imgActionsChevron');
      if (!panel) return;
      const open = panel.style.display === 'none';
      panel.style.display = open ? 'block' : 'none';
      if (chevron) chevron.style.transform = open ? 'rotate(180deg)' : '';
    });

    const _attTextEl = document.getElementById('imgAttachmentText');
    if (_attTextEl) {
      _attTextEl.addEventListener('input',  _debouncedImgAutoSave);
      _attTextEl.addEventListener('change', _imgAutoSave);
    }

    // ── Image template selector refresh ──────────────────
    function _refreshImgTemplateSelector() {
      const sel  = document.getElementById('imgLinkedTemplate');
      if (!sel) return;
      const mode    = document.getElementById('imgSendMode')?.value || 'embed';
      const current = sel.value;
      sel.options.length = 0;
      const ph = document.createElement('option');
      ph.value = '';
      ph.textContent = '<%= lang === "ar" ? "— اختر قالباً —" : "— Select a template —" %>';
      sel.appendChild(ph);
      _templates.forEach(function(tpl) {
        if (!tpl.name) return;
        if (mode === 'embed'     && tpl.type !== 'embed')     return;
        if (mode === 'component' && tpl.type !== 'component') return;
        const opt = document.createElement('option');
        opt.value = tpl.name;
        opt.textContent = tpl.name + ' (' + _chName(tpl.channelId) + ')';
        sel.appendChild(opt);
      });
      if (current) sel.value = current;
    }

    // ── Payload builder ────────────────────────────────────
    function _buildPayload() {
      return {
        enabled:       document.getElementById('moduleEnabled')?.checked  || false,
        welcomeText:   document.getElementById('welcomeText')?.checked    || false,
        dmWelcome:     document.getElementById('dmWelcome')?.checked      || false,
        dmMessage:     document.getElementById('dmMessage')?.value        || '',
        sendDelay:     parseInt(document.getElementById('sendDelay')?.value)   || 0,
        deleteDelay:   parseInt(document.getElementById('deleteDelay')?.value) || 0,
        waitRules:     document.getElementById('waitRules')?.checked      || false,
        ignoreBots:    !!(document.getElementById('ignoreBots')?.value),
        ignoreUsers:   !!(document.getElementById('ignoreUsers')?.value),
        templates:     _templates,
        groups:        _groups
      };
    }

    // ── Auto-save after template mutations ────────────────
    async function _autoSave() {
      try {
        const r = await fetch('/dashboard/<%= guildId %>/welcome/join/save', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(_buildPayload())
        });
        const d = await r.json();
        if (d.success) { _toast('<%= t.welcomeJoin.savedToast %>', 'success'); }
        else           { _toast(d.error || '<%= t.welcomeJoin.errorToast %>', 'error'); }
      } catch (e) { _toast('<%= t.welcomeJoin.errorToast %>', 'error'); }
    }

    // ── Image card auto-save ──────────────────────────────
    async function _imgAutoSave() {
      try {
        const payload = {
          enabled:          document.getElementById('imgEnabled')?.checked          || false,
          sendMode:         document.getElementById('imgSendMode')?.value           || 'embed',
          linkedTemplateId: document.getElementById('imgLinkedTemplate')?.value     || '',
          channelId:        document.getElementById('imgChannel')?.value            || '',
          attachmentText:   document.getElementById('imgAttachmentText')?.value     || '',
        };
        const r = await fetch('/dashboard/<%= guildId %>/welcome/join/image/save', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
        const d = await r.json();
        if (d.success) { _toast('<%= lang === "ar" ? "تم حفظ إعدادات الصورة" : "Image settings saved" %>', 'success'); }
        else           { _toast(d.error || '<%= t.welcomeJoin.errorToast %>', 'error'); }
      } catch (e) { _toast('<%= t.welcomeJoin.errorToast %>', 'error'); }
    }

    // ── Image card debounce ───────────────────────────────
    let _imgAutoSaveTimer = null;
    function _debouncedImgAutoSave() {
      clearTimeout(_imgAutoSaveTimer);
      _imgAutoSaveTimer = setTimeout(_imgAutoSave, 800);
    }

    // ── Save all ───────────────────────────────────────────
    const _saveBtn = document.getElementById('saveBtn');
    if (_saveBtn) _saveBtn.addEventListener('click', async () => {
      _saveBtn.disabled = true;
      try {
        const r = await fetch('/dashboard/<%= guildId %>/welcome/join/save', {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(_buildPayload())
        });
        const d = await r.json();
        if (d.success) { _toast('<%= t.welcomeJoin.savedToast %>', 'success'); }
        else           { _toast(d.error || '<%= t.welcomeJoin.errorToast %>', 'error'); }
      } catch (e)      { _toast('<%= t.welcomeJoin.errorToast %>', 'error'); }
      finally          { _saveBtn.disabled = false; }
    });

    // ── Toast ──────────────────────────────────────
    function _toast(msg, type) {
      const el = document.getElementById('wjToast');
      if (!el) return;
      el.textContent = msg;
      el.className = 'wj-toast ' + type;
      clearTimeout(el._t);
      setTimeout(() => el.classList.add('show'), 10);
      el._t = setTimeout(() => el.classList.remove('show'), 3500);
    }

    // ── Init ───────────────────────────────────────
    _renderTemplates();
    _renderGroups();
  </script>
</body>
</html>

    /* Module toggle */
    .wj-module-toggle { display:flex; align-items:center; gap:10px; cursor:pointer; padding:8px 14px; border-radius:12px; background:var(--surface); border:1px solid var(--border); transition:background .18s,border-color .18s; user-select:none; }
    .wj-module-toggle:hover { background:rgba(124,58,237,.1); border-color:var(--border-h); }
    .wj-module-toggle input { display:none; }
    .wj-toggle-label { font-size:.82rem; font-weight:600; }
    .wj-toggle-track { width:42px; height:24px; border-radius:99px; background:rgba(255,255,255,.12); position:relative; transition:background .22s; flex-shrink:0; }
    .wj-module-toggle input:checked ~ .wj-toggle-track { background:var(--purple); }
    .wj-toggle-thumb { position:absolute; top:3px; left:3px; width:18px; height:18px; border-radius:50%; background:#fff; transition:left .22s; box-shadow:0 1px 4px rgba(0,0,0,.35); }
    .wj-module-toggle input:checked ~ .wj-toggle-track .wj-toggle-thumb { left:21px; }
    /* Tabs */

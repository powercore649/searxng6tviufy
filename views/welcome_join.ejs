      .mgmt-sidebar { left: 0 !important; right: auto !important; transform: translateX(-100%); width: 260px !important; z-index: 92; }
      [dir="rtl"] .mgmt-sidebar { left: auto !important; right: 0 !important; transform: translateX(100%); }
      .mgmt-sidebar.open { transform: translateX(0) !important; }
      .main { margin-left: var(--nav-w); margin-right: 0; padding: 24px 16px 48px; max-width: 100%; }
      [dir="rtl"] .main { margin-left: 0; margin-right: var(--nav-w); }
      .topbar { padding: 0 12px; gap: 8px; }
      .topbar-brand { display: none; }
      .guild-meta-id { display: none !important; }
      .guild-meta-name { max-width: 90px; }
      .user-chip span { display: none; }
      .user-chip { padding: 4px 7px; }
      .topbar-sep { display: none; }
    }
    @media (max-width: 600px) {

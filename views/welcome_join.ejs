    .wj-tab { display:flex; align-items:center; gap:7px; padding:9px 20px; border-radius:9px; font-size:.82rem; font-weight:600; color:var(--muted); background:none; border:1px solid transparent; cursor:pointer; font-family:inherit; transition:background .18s,color .18s,border-color .18s; white-space:nowrap; }
    .wj-tab:hover { color:var(--white); background:rgba(255,255,255,.05); }
    .wj-tab.active { background:rgba(124,58,237,.2); color:var(--purple-l); border-color:rgba(124,58,237,.3); }
    .wj-tab i { width:15px; height:15px; flex-shrink:0; }
    .wj-tab-content { display:none; flex-direction:column; gap:20px; }
    .wj-tab-content.active { display:flex; }
    /* Card */
    .wj-card { background:var(--card); border:1px solid var(--border); border-radius:18px; overflow:hidden; backdrop-filter:blur(20px); }
    .wj-card-header { display:flex; align-items:center; justify-content:space-between; padding:18px 22px 14px; border-bottom:1px solid rgba(255,255,255,.05); gap:12px; flex-wrap:wrap; }

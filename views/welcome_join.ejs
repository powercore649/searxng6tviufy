    .wj-btn-outline { display:flex; align-items:center; gap:7px; padding:8px 16px; border-radius:10px; background:transparent; color:var(--purple-l); border:1px solid rgba(124,58,237,.35); font-size:.82rem; font-weight:600; cursor:pointer; font-family:inherit; transition:background .18s,border-color .18s; flex-shrink:0; }
    .wj-btn-outline:hover { background:rgba(124,58,237,.1); border-color:rgba(124,58,237,.6); }

      .nav-sidebar.open .nav-back .nav-label { opacity: 1; visibility: visible; pointer-events: auto; }
      .nav-sidebar.open .nav-item { width: 100%; gap: 10px; padding: 0 12px 0 8px; justify-content: flex-start; border-radius: 10px; }
      .nav-sidebar.open .nav-item-label { opacity: 1; visibility: visible; pointer-events: auto; }
      .nav-sidebar.open .nav-status { opacity: 0; }
      .nav-sidebar.open .nav-divider { width: calc(100% - 24px); }
      .main { margin-left: 0 !important; margin-right: 0 !important; }
    }
    @media (max-width: 480px) {
      .main { padding: 18px 12px 40px; }
    }
    /* ── Welcome Join UI ─────────────────────────────── */
    .page-header-right { display:flex; align-items:center; gap:12px; }
    .wj-breadcrumb { display:flex; align-items:center; gap:6px; font-size:.68rem; font-weight:700; color:var(--muted); text-transform:uppercase; letter-spacing:.08em; margin-bottom:4px; }

    .wj-group-item { padding:13px 16px; border-radius:12px; background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.07); transition:background .15s,border-color .15s; }
    .wj-group-item:hover { background:rgba(124,58,237,.06); border-color:rgba(124,58,237,.18); }
    .wj-group-header { display:flex; align-items:center; gap:10px; }
    .wj-group-name { flex:1; font-size:.85rem; font-weight:700; color:var(--white); min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .wj-group-actions { display:flex; align-items:center; gap:6px; flex-shrink:0; }
    .wj-group-chips { display:flex; flex-wrap:wrap; gap:6px; margin-top:10px; }
    .wj-group-chip { font-size:.7rem; font-weight:600; padding:3px 9px; border-radius:99px; background:rgba(124,58,237,.1); border:1px solid rgba(124,58,237,.25); color:var(--purple-l); white-space:nowrap; }
    .wj-group-chip.empty { background:rgba(255,255,255,.04); border-color:rgba(255,255,255,.1); color:var(--muted); font-style:italic; }
    /* Group template picker inside modal */
    .wj-group-tpl-list { display:flex; flex-direction:column; gap:6px; max-height:220px; overflow-y:auto; padding-right:2px; scrollbar-width:thin; scrollbar-color:rgba(124,58,237,.3) transparent; }
    .wj-group-tpl-item { display:flex; align-items:center; gap:10px; padding:8px 10px; border-radius:9px; background:rgba(255,255,255,.03); border:1px solid rgba(255,255,255,.06); cursor:pointer; transition:background .12s,border-color .12s; }
    .wj-group-tpl-item:hover { background:rgba(124,58,237,.08); border-color:rgba(124,58,237,.2); }
    .wj-group-tpl-item input[type=checkbox] { accent-color:var(--purple); width:14px; height:14px; flex-shrink:0; cursor:pointer; }
    .wj-group-tpl-item label { flex:1; font-size:.82rem; color:var(--white); cursor:pointer; }
    /* Modal */
    .wj-modal-overlay { position:fixed; inset:0; z-index:500; background:rgba(0,0,0,.72); backdrop-filter:blur(8px); display:flex; align-items:center; justify-content:center; padding:20px; opacity:0; pointer-events:none; transition:opacity .22s; }
    .wj-modal-overlay.open { opacity:1; pointer-events:all; }
    .wj-modal { background:rgba(8,2,25,.98); border:1px solid rgba(124,58,237,.3); border-radius:20px; width:100%; max-width:560px; max-height:90vh; overflow-y:auto; box-shadow:0 20px 80px rgba(0,0,0,.7); display:flex; flex-direction:column; scrollbar-width:thin; scrollbar-color:rgba(124,58,237,.3) transparent; }
    .wj-modal::-webkit-scrollbar { width:4px; }
    .wj-modal::-webkit-scrollbar-thumb { background:rgba(124,58,237,.3); border-radius:4px; }
    .wj-modal-header { display:flex; align-items:center; justify-content:space-between; padding:18px 20px 14px; border-bottom:1px solid rgba(255,255,255,.06); flex-shrink:0; }
    .wj-modal-title { font-size:.95rem; font-weight:700; color:var(--white); }
    .wj-modal-close { display:flex; align-items:center; justify-content:center; width:32px; height:32px; border-radius:8px; background:rgba(255,255,255,.06); border:none; color:var(--muted); cursor:pointer; transition:background .15s,color .15s; }
    .wj-modal-close:hover { background:rgba(220,38,38,.2); color:#fca5a5; }
    .wj-modal-body { flex:1; padding:18px 20px; display:flex; flex-direction:column; gap:16px; }
    .wj-modal-footer { display:flex; align-items:center; justify-content:flex-end; gap:10px; padding:14px 20px; border-top:1px solid rgba(255,255,255,.06); flex-shrink:0; }
    /* Message type selector */
    .wj-msg-type-group { display:flex; gap:8px; flex-wrap:wrap; }
    .wj-msg-type-btn { display:flex; align-items:center; gap:7px; padding:9px 16px; border-radius:10px; background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.1); color:var(--muted); font-size:.81rem; font-weight:600; cursor:pointer; font-family:inherit; transition:background .15s,border-color .15s,color .15s; }
    .wj-msg-type-btn:hover { background:rgba(124,58,237,.1); border-color:rgba(124,58,237,.35); color:var(--purple-l); }
    .wj-msg-type-btn.active { background:rgba(124,58,237,.18); border-color:rgba(124,58,237,.5); color:var(--purple-l); }
    .wj-msg-type-btn i { width:14px; height:14px; }
    /* Embed editor */
    .wj-embed-preview { border-radius:12px; overflow:hidden; border:1px solid rgba(255,255,255,.1); background:rgba(255,255,255,.03); }
    .wj-embed-bar { height:5px; background:#7c3aed; }
    .wj-embed-inner { padding:14px; display:flex; flex-direction:column; gap:12px; }
    .wj-color-picker-wrap { display:flex; align-items:center; gap:8px; }
    .wj-color-input { width:40px; height:36px; border:none; background:none; cursor:pointer; border-radius:8px; padding:2px; flex-shrink:0; }
    .wj-color-hex { flex:1; }
    /* ── Live Preview Panel ── */
    .wj-modal-with-preview { max-width:900px !important; flex-direction:row !important; overflow:hidden !important; max-height:88vh; }
    .wj-modal-with-preview .wj-modal-form { flex:1; min-width:0; overflow-y:auto; display:flex; flex-direction:column; scrollbar-width:thin; scrollbar-color:rgba(124,58,237,.3) transparent; }
    .wj-modal-with-preview .wj-modal-form::-webkit-scrollbar { width:4px; }
    .wj-modal-with-preview .wj-modal-form::-webkit-scrollbar-thumb { background:rgba(124,58,237,.3); border-radius:4px; }
    .wj-preview-panel { width:300px; flex-shrink:0; background:rgba(4,1,17,.95); border-left:1px solid rgba(255,255,255,.07); display:flex; flex-direction:column; }
    .wj-preview-header { padding:12px 14px 8px; font-size:.65rem; font-weight:700; letter-spacing:.08em; text-transform:uppercase; color:rgba(203,194,255,.4); border-bottom:1px solid rgba(255,255,255,.06); flex-shrink:0; display:flex; align-items:center; gap:6px; cursor:pointer; }
    .wj-preview-header i { width:13px; height:13px; flex-shrink:0; }
    .wj-preview-body { flex:1; overflow-y:auto; padding:12px; display:flex; flex-direction:column; gap:8px; }
    /* Responsive: stack preview below form on narrow screens */
    @media (max-width:700px) {
      .wj-modal-with-preview { flex-direction:column !important; max-height:95vh; }
      .wj-preview-panel { width:100%; border-left:none; border-top:1px solid rgba(255,255,255,.07); max-height:220px; }
      .wj-preview-body { max-height:180px; }
    }
    /* Large screen: give the modal and preview more room */
    @media (min-width:960px) {
      .wj-modal-with-preview { max-width:min(90vw,1100px) !important; }
      .wj-preview-panel { width:360px; }
    }
    /* Discord-like message preview */
    .wj-dc-msg { display:flex; gap:10px; }
    .wj-dc-avatar { width:36px; height:36px; border-radius:50%; background:linear-gradient(135deg,#7c3aed,#4338ca); flex-shrink:0; overflow:hidden; }
    .wj-dc-avatar img { width:100%; height:100%; object-fit:cover; }
    .wj-dc-bubble { flex:1; min-width:0; }
    .wj-dc-username { font-size:.78rem; font-weight:700; color:#a78bfa; margin-bottom:2px; display:flex; align-items:center; gap:5px; }
    .wj-dc-bot-tag { background:#5865f2; color:#fff; font-size:.6rem; font-weight:700; padding:1px 5px; border-radius:3px; letter-spacing:.02em; }
    .wj-dc-text { font-size:.8rem; color:#dcddde; line-height:1.5; word-break:break-word; white-space:pre-wrap; }
    /* Discord embed */
    .wj-dc-embed { margin-top:6px; border-radius:4px; overflow:hidden; background:#2b2d31; border:1px solid rgba(255,255,255,.06); max-width:100%; display:flex; }
    .wj-dc-embed-bar { width:4px; min-width:4px; flex-shrink:0; background:#7c3aed; }
    .wj-dc-embed-body { flex:1; min-width:0; padding:10px 12px 10px 10px; display:flex; flex-direction:column; gap:2px; }
    .wj-dc-embed-top { display:flex; justify-content:space-between; align-items:flex-start; gap:8px; }
    .wj-dc-embed-main { flex:1; min-width:0; }
    .wj-dc-embed-title { font-size:.82rem; font-weight:700; color:#ffffff; margin-bottom:4px; }
    .wj-dc-embed-desc { font-size:.77rem; color:#dbdee1; white-space:pre-wrap; word-break:break-word; line-height:1.45; }
    .wj-dc-embed-thumb { width:52px; height:52px; border-radius:4px; object-fit:cover; flex-shrink:0; }
    .wj-dc-embed-footer { font-size:.69rem; color:rgba(185,187,190,.7); margin-top:8px; padding-top:6px; border-top:1px solid rgba(255,255,255,.07); }
    .wj-dc-plain-empty { font-size:.74rem; color:rgba(185,187,190,.35); text-align:center; padding:24px 8px; }
    .wj-dc-label { font-size:.68rem; font-weight:600; color:rgba(185,187,190,.4); letter-spacing:.06em; text-transform:uppercase; margin-bottom:4px; }
    /* Variable pills in live preview */
    .wj-pv-var { display:inline; background:rgba(88,101,242,.25); color:#bac0f7; border-radius:3px; padding:0 3px; font-size:.9em; white-space:nowrap; }
    .wj-pv-mention { background:rgba(88,101,242,.25); color:#bac0f7; border-radius:3px; padding:0 3px; font-size:.9em; }
    /* ── Component v2 builder ── */
    .wj-bld-rows-wrap { display:flex; flex-direction:column; gap:5px; min-height:4px; }
    .wj-bld-comp-row { display:flex; gap:6px; align-items:flex-start; }
    .wj-bld-comp-row-grip { display:flex; align-items:center; justify-content:center; width:20px; min-height:34px; color:rgba(185,187,190,.3); cursor:grab; flex-shrink:0; padding-top:5px; }
    .wj-bld-comp-row-grip:active { cursor:grabbing; }
    .wj-bld-comp-row-main { flex:1; min-width:0; }
    .wj-bld-comp-row-aside { display:flex; flex-direction:column; gap:3px; flex-shrink:0; }
    .wj-bld-comp-row-aside-btn { display:flex; align-items:center; justify-content:center; width:26px; height:26px; border-radius:6px; border:1px solid rgba(255,255,255,.08); background:rgba(255,255,255,.04); color:var(--muted); cursor:pointer; font-size:.8rem; transition:background .12s,color .12s; padding:0; }
    .wj-bld-comp-row-aside-btn.red { border-color:rgba(220,38,38,.2); }
    .wj-bld-comp-row-aside-btn:hover { background:rgba(255,255,255,.1); color:var(--white); }
    .wj-bld-comp-row-aside-btn.red:hover { background:rgba(220,38,38,.15); color:#ef4444; border-color:rgba(220,38,38,.4); }
    .wj-bld-text-card,.wj-bld-btn-card,.wj-bld-sep-card,.wj-bld-img-card,.wj-bld-cnt-card,.wj-bld-sel-card { background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.09); border-radius:10px; padding:10px 12px; }
    .wj-bld-cnt-card { border-left:3px solid rgba(88,101,242,.45); }
    .wj-bld-row-header { display:flex; align-items:center; gap:8px; margin-bottom:7px; flex-wrap:wrap; }
    .wj-bld-row-title { font-size:.6rem; font-weight:700; letter-spacing:.07em; color:rgba(185,187,190,.45); text-transform:uppercase; }
    .wj-bld-input { width:100%; background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.1); border-radius:7px; color:var(--white); font-size:.8rem; padding:6px 9px; font-family:inherit; outline:none; box-sizing:border-box; transition:border-color .15s; }
    .wj-bld-input:focus { border-color:rgba(124,58,237,.5); }
    .wj-bld-textarea { width:100%; background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.1); border-radius:7px; color:var(--white); font-size:.8rem; padding:7px 9px; font-family:inherit; outline:none; box-sizing:border-box; resize:vertical; transition:border-color .15s; }
    .wj-bld-textarea:focus { border-color:rgba(124,58,237,.5); }
    .wj-bld-select { background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.1); border-radius:7px; color:var(--white); font-size:.78rem; padding:4px 8px; font-family:inherit; outline:none; cursor:pointer; }
    .wj-bld-select:focus { border-color:rgba(124,58,237,.5); }
    .wj-bld-btn-pill { display:inline-flex; align-items:center; gap:4px; padding:3px 9px; border-radius:4px; font-size:.75rem; font-weight:600; cursor:pointer; border:none; color:#fff; }
    .wj-bld-btn-pill.Primary { background:#5865f2; }
    .wj-bld-btn-pill.Secondary { background:#4e5058; }
    .wj-bld-btn-pill.Success { background:#248046; }
    .wj-bld-btn-pill.Danger { background:#da373c; }
    .wj-bld-btn-pill.Link { background:transparent; color:#00aff4; text-decoration:underline; }
    .wj-bld-btn-pill-del { background:none; border:none; color:inherit; font-size:.85rem; cursor:pointer; padding:0 0 0 2px; opacity:.6; line-height:1; }
    .wj-bld-btn-pill-del:hover { opacity:1; }
    .wj-bld-opt-chip { display:inline-flex; align-items:center; gap:4px; padding:3px 8px; border-radius:5px; font-size:.74rem; background:rgba(255,255,255,.07); color:var(--muted); cursor:default; border:1px solid rgba(255,255,255,.1); }
    .wj-bld-opt-chip-del { background:none; border:none; color:inherit; font-size:.85rem; cursor:pointer; padding:0 0 0 2px; opacity:.6; line-height:1; }
    .wj-bld-opt-chip-del:hover { opacity:1; }
    .wj-bld-add-btn { width:100%; display:flex; align-items:center; justify-content:center; gap:6px; padding:9px; border-radius:9px; border:1px dashed rgba(255,255,255,.14); background:rgba(255,255,255,.02); color:var(--muted); font-size:.8rem; font-weight:600; cursor:pointer; font-family:inherit; transition:background .15s,border-color .15s,color .15s; margin-top:6px; }
    .wj-bld-add-btn:hover { background:rgba(124,58,237,.08); border-color:rgba(124,58,237,.3); color:#c4b5fd; }
    .wj-bld-add-wrap { position:relative; }
    .wj-bld-add-menu { position:absolute; bottom:calc(100% + 4px); left:0; right:0; z-index:900; background:rgba(8,2,26,.98); border:1px solid rgba(124,58,237,.3); border-radius:12px; box-shadow:0 12px 40px rgba(0,0,0,.7); display:none; flex-direction:column; padding:4px; }
    .wj-bld-add-menu.open { display:flex; }
    .wj-bld-add-menu-item { background:none; border:none; color:var(--muted); font-size:.82rem; font-weight:600; padding:8px 12px; border-radius:7px; cursor:pointer; font-family:inherit; text-align:left; transition:background .12s,color .12s; }
    .wj-bld-add-menu-item:hover { background:rgba(124,58,237,.15); color:var(--white); }
    .wj-bld-cnt-children { display:flex; flex-direction:column; gap:4px; margin:6px 0; }
    .wj-bld-child-row { display:flex; align-items:flex-start; gap:5px; background:rgba(255,255,255,.03); border:1px solid rgba(255,255,255,.07); border-radius:7px; padding:7px 8px; }
    .wj-bld-child-main { flex:1; min-width:0; display:flex; flex-direction:column; gap:5px; }
    .wj-bld-child-title { font-size:.6rem; font-weight:700; letter-spacing:.06em; color:rgba(185,187,190,.4); text-transform:uppercase; }
    .wj-bld-child-del { background:none; border:none; color:rgba(220,38,38,.5); font-size:1.1rem; cursor:pointer; line-height:1; padding:0; flex-shrink:0; transition:color .12s; }
    .wj-bld-child-del:hover { color:#ef4444; }
    .wj-bld-add-child-wrap { position:relative; margin-top:5px; }
    .wj-bld-add-child-btn { width:100%; display:flex; align-items:center; justify-content:center; gap:5px; padding:6px; border-radius:7px; border:1px dashed rgba(255,255,255,.1); background:rgba(255,255,255,.02); color:rgba(185,187,190,.5); font-size:.75rem; font-weight:600; cursor:pointer; font-family:inherit; transition:background .15s,border-color .15s,color .15s; }
    .wj-bld-add-child-btn:hover { background:rgba(124,58,237,.07); border-color:rgba(124,58,237,.25); color:#c4b5fd; }
    .wj-bld-add-child-menu { position:absolute; bottom:calc(100% + 3px); left:0; right:0; z-index:901; background:rgba(8,2,26,.98); border:1px solid rgba(124,58,237,.3); border-radius:10px; box-shadow:0 10px 30px rgba(0,0,0,.6); display:none; flex-direction:column; padding:3px; }
    .wj-bld-add-child-menu.open { display:flex; }
    .wj-bld-add-child-menu-item { background:none; border:none; color:var(--muted); font-size:.79rem; font-weight:600; padding:7px 11px; border-radius:6px; cursor:pointer; font-family:inherit; text-align:left; transition:background .12s,color .12s; }
    .wj-bld-add-child-menu-item:hover { background:rgba(124,58,237,.15); color:var(--white); }
    .wj-bld-img-preview { max-width:100%; max-height:120px; border-radius:6px; margin-top:6px; object-fit:cover; display:block; }
    .wj-bld-ghost-btn { background:none; border:1px solid rgba(255,255,255,.1); border-radius:6px; color:var(--muted); font-size:.72rem; font-weight:600; padding:3px 8px; cursor:pointer; font-family:inherit; transition:background .12s,color .12s; }
    .wj-bld-ghost-btn:hover { background:rgba(255,255,255,.07); color:var(--white); }
    /* Discord component v2 preview styles */
    .wj-dc-comp-preview { display:flex; flex-direction:column; gap:2px; }
    .wj-dc-text-display { color:#dbdee1; font-size:.8rem; line-height:1.55; white-space:pre-wrap; word-break:break-word; padding:2px 0; }
    .wj-dc-separator-s { height:8px; }
    .wj-dc-separator-l { height:20px; }
    .wj-dc-hr { border:none; border-top:1px solid rgba(79,84,92,.48); margin:0; }
    .wj-dc-container { border-left:4px solid #5865f2; padding:8px 12px; background:rgba(79,84,92,.1); border-radius:0 4px 4px 0; display:flex; flex-direction:column; gap:2px; margin:1px 0; }
    .wj-dc-action-row { display:flex; flex-wrap:wrap; gap:4px; padding:2px 0; }
    .wj-dc-btn { font-size:.76rem; font-weight:500; padding:5px 14px; border-radius:4px; border:none; cursor:default; }
    .wj-dc-btn-primary { background:#5865f2; color:#fff; }
    .wj-dc-btn-secondary { background:#4e5058; color:#fff; }
    .wj-dc-btn-success { background:#248046; color:#fff; }
    .wj-dc-btn-danger { background:#da373c; color:#fff; }
    .wj-dc-btn-link { background:transparent; color:#00aff4; text-decoration:underline; }
    .wj-dc-select-wrap { padding:2px 0; }
    .wj-dc-select { display:flex; align-items:center; justify-content:space-between; padding:7px 12px; background:rgba(32,34,37,.9); border:1px solid rgba(79,84,92,.6); border-radius:4px; color:#949ba4; font-size:.78rem; max-width:260px; }
    .wj-dc-image-wrap { padding:2px 0; }
    .wj-dc-image { max-width:100%; border-radius:4px; display:block; }
    .wj-dc-image-placeholder { color:rgba(185,187,190,.35); font-size:.74rem; font-style:italic; padding:4px 0; }
    /* ── Searchable channel select ── */
    .wj-ch-select { position:relative; }
    .wj-ch-trigger { display:flex; align-items:center; justify-content:space-between; gap:8px; padding:8px 12px; background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.1); border-radius:10px; cursor:pointer; font-size:.82rem; color:var(--white); min-height:40px; transition:border-color .15s; user-select:none; }
    .wj-ch-trigger:hover, .wj-ch-select.open .wj-ch-trigger { border-color:rgba(124,58,237,.5); }
    .wj-ch-trigger-text { flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; color:var(--muted); }
    .wj-ch-trigger-text.has-val { color:var(--white); }
    .wj-ch-trigger i { width:14px; height:14px; flex-shrink:0; color:var(--muted); transition:transform .15s; }
    .wj-ch-select.open .wj-ch-trigger i { transform:rotate(180deg); }
    .wj-ch-dropdown { position:absolute; top:calc(100% + 4px); left:0; right:0; z-index:600; background:rgba(8,2,26,.98); border:1px solid rgba(124,58,237,.3); border-radius:12px; box-shadow:0 12px 40px rgba(0,0,0,.7); overflow:hidden; display:none; flex-direction:column; }
    .wj-ch-select.open .wj-ch-dropdown { display:flex; }
    .wj-ch-search-wrap { padding:8px; border-bottom:1px solid rgba(255,255,255,.06); display:flex; align-items:center; gap:6px; }
    .wj-ch-search { flex:1; background:rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.08); border-radius:7px; color:var(--white); font-size:.8rem; padding:5px 8px; font-family:inherit; outline:none; }
    .wj-ch-search:focus { border-color:rgba(124,58,237,.4); }
    .wj-ch-search-wrap i { width:13px; height:13px; color:var(--muted); flex-shrink:0; }
    .wj-ch-list { max-height:200px; overflow-y:auto; padding:4px; scrollbar-width:thin; scrollbar-color:rgba(124,58,237,.25) transparent; }
    .wj-ch-opt { padding:7px 10px; border-radius:7px; cursor:pointer; font-size:.81rem; color:var(--muted); transition:background .12s,color .12s; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .wj-ch-opt:hover { background:rgba(124,58,237,.15); color:var(--white); }
    .wj-ch-opt.selected { background:rgba(124,58,237,.2); color:var(--purple-l); font-weight:600; }
    .wj-ch-opt.hidden { display:none; }
    /* ── Confirm Dialog ── */
    .wj-confirm-overlay { position:fixed; inset:0; z-index:5000; background:rgba(0,0,0,.78); backdrop-filter:blur(6px); display:flex; align-items:center; justify-content:center; padding:20px; opacity:0; pointer-events:none; transition:opacity .18s; }
    .wj-confirm-overlay.open { opacity:1; pointer-events:all; }
    .wj-confirm-box { background:rgba(10,2,30,.98); border:1px solid rgba(220,38,38,.3); border-radius:16px; padding:24px 22px; width:100%; max-width:340px; box-shadow:0 16px 60px rgba(0,0,0,.7); display:flex; flex-direction:column; gap:14px; }
    .wj-confirm-icon { width:40px; height:40px; border-radius:50%; background:rgba(220,38,38,.1); border:1px solid rgba(220,38,38,.2); display:flex; align-items:center; justify-content:center; color:#ef4444; }
    .wj-confirm-icon i { width:20px; height:20px; }
    .wj-confirm-title { font-size:.95rem; font-weight:700; color:var(--white); }
    .wj-confirm-msg { font-size:.82rem; color:var(--muted); line-height:1.55; }
    .wj-confirm-actions { display:flex; gap:10px; justify-content:flex-end; margin-top:4px; }
    .wj-confirm-cancel { padding:8px 18px; border-radius:9px; background:rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.1); color:var(--white); font-size:.82rem; font-weight:600; cursor:pointer; font-family:inherit; transition:background .15s; }
    .wj-confirm-cancel:hover { background:rgba(255,255,255,.12); }
    .wj-confirm-ok { padding:8px 18px; border-radius:9px; background:#dc2626; border:none; color:#fff; font-size:.82rem; font-weight:700; cursor:pointer; font-family:inherit; transition:background .15s; }
    .wj-confirm-ok:hover { background:#ef4444; }
    /* ── Member filter radio group ── */
    .wj-filter-group { display:flex; flex-direction:column; gap:6px; margin-top:4px; }
    .wj-filter-opt { display:flex; align-items:center; gap:10px; padding:8px 12px; border-radius:9px; border:1px solid rgba(255,255,255,.07); background:rgba(255,255,255,.03); cursor:pointer; transition:background .15s,border-color .15s; user-select:none; }
    .wj-filter-opt:hover { background:rgba(124,58,237,.07); border-color:rgba(124,58,237,.2); }
    .wj-filter-opt input[type="radio"] { display:none; }
    .wj-filter-opt.selected { background:rgba(124,58,237,.12); border-color:rgba(124,58,237,.3); }
    .wj-filter-opt-dot { width:14px; height:14px; border-radius:50%; border:2px solid rgba(255,255,255,.25); flex-shrink:0; transition:border-color .15s,background .15s; }
    .wj-filter-opt.selected .wj-filter-opt-dot { border-color:#c4b5fd; background:#7c3aed; box-shadow:0 0 0 3px rgba(124,58,237,.25); }
    .wj-filter-opt-text { font-size:.82rem; font-weight:600; color:var(--muted); }
    .wj-filter-opt.selected .wj-filter-opt-text { color:var(--purple-l); }
    /* ── Activity Log ── */
    .wj-log-bar { display:flex; align-items:center; gap:10px; flex-wrap:wrap; margin-bottom:16px; }
    .wj-log-filter-sel,.wj-log-input { padding:6px 10px; border-radius:8px; border:1px solid rgba(255,255,255,.1); background:rgba(255,255,255,.04); color:var(--white); font-size:.8rem; font-family:inherit; cursor:pointer; }
    .wj-log-filter-sel:focus,.wj-log-input:focus { outline:none; border-color:rgba(124,58,237,.4); }
    .wj-log-list { display:flex; flex-direction:column; gap:6px; }
    .wj-log-entry { display:flex; align-items:center; gap:12px; padding:10px 14px; border-radius:10px; background:rgba(255,255,255,.03); border:1px solid rgba(255,255,255,.06); flex-wrap:wrap; }
    .wj-log-avatar { width:34px; height:34px; border-radius:50%; object-fit:cover; flex-shrink:0; background:rgba(255,255,255,.08); }
    .wj-log-info { flex:1; min-width:120px; }
    .wj-log-name { font-size:.84rem; font-weight:700; color:var(--white); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .wj-log-meta { font-size:.75rem; color:var(--muted); margin-top:2px; }
    .wj-log-badge { font-size:.7rem; font-weight:700; padding:2px 7px; border-radius:6px; flex-shrink:0; }
    .wj-log-badge.text    { background:rgba(99,102,241,.12); color:#a5b4fc; border:1px solid rgba(99,102,241,.2); }
    .wj-log-badge.embed   { background:rgba(124,58,237,.12); color:#c4b5fd; border:1px solid rgba(124,58,237,.2); }
    .wj-log-badge.component { background:rgba(16,185,129,.1); color:#6ee7b7; border:1px solid rgba(16,185,129,.2); }
    .wj-log-badge.ok      { background:rgba(34,197,94,.1);  color:#86efac;  border:1px solid rgba(34,197,94,.2); }
    .wj-log-badge.error   { background:rgba(220,38,38,.1);  color:#fca5a5;  border:1px solid rgba(220,38,38,.2); }
    .wj-log-time { font-size:.73rem; color:var(--muted); white-space:nowrap; flex-shrink:0; }
    .wj-log-resend { padding:5px 10px; border-radius:7px; border:1px solid rgba(124,58,237,.25); background:rgba(124,58,237,.08); color:#c4b5fd; font-size:.75rem; font-weight:600; cursor:pointer; font-family:inherit; transition:background .15s; flex-shrink:0; }
    .wj-log-resend:hover { background:rgba(124,58,237,.18); }
    .wj-log-spin { display:flex; align-items:center; justify-content:center; padding:32px 0; }
    .wj-log-spin::after { content:''; width:22px; height:22px; border-radius:50%; border:3px solid rgba(124,58,237,.2); border-top-color:#7c3aed; animation:wj-spin .6s linear infinite; }
    @keyframes wj-spin { to{ transform:rotate(360deg); } }
    .wj-log-footer { text-align:center; margin-top:10px; font-size:.78rem; color:var(--muted); }
    /* Collapse */
    .wj-collapse-section { border-top:1px solid rgba(255,255,255,.06); padding-top:12px; }
    .wj-collapse-btn { display:flex; align-items:center; gap:8px; background:none; border:none; color:var(--muted); font-size:.82rem; font-weight:600; cursor:pointer; font-family:inherit; padding:0; transition:color .15s; }
    .wj-collapse-btn:hover { color:var(--white); }
    .wj-collapse-btn i { width:14px; height:14px; transition:transform .18s; }
    .wj-collapse-btn.open i { transform:rotate(90deg); }
    .wj-collapse-body { padding-top:10px; display:flex; flex-direction:column; gap:0; }
    /* Toast */
    .wj-toast { position:fixed; bottom:28px; right:28px; z-index:9000; padding:12px 20px; border-radius:12px; font-size:.84rem; font-weight:600; opacity:0; transform:translateY(8px); transition:opacity .25s,transform .25s; pointer-events:none; display:flex; align-items:center; gap:8px; }
    [dir="rtl"] .wj-toast { right:auto; left:28px; }
    .wj-toast.show { opacity:1; transform:translateY(0); }
    .wj-toast.success { background:rgba(34,197,94,.15); border:1px solid rgba(34,197,94,.3); color:#86efac; }
    .wj-toast.error { background:rgba(220,38,38,.15); border:1px solid rgba(220,38,38,.3); color:#fca5a5; }
    @media (max-width:640px) {
      .wj-var-grid { grid-template-columns:1fr; }
      .wj-field-row-2 { grid-template-columns:1fr; }
      .wj-modal { max-height:92vh; }
      .wj-modal-with-preview { flex-direction:column !important; max-width:100% !important; }
      .wj-preview-panel { width:100% !important; border-left:none; border-top:1px solid rgba(255,255,255,.07); max-height:240px; }
      .wj-msg-type-group { flex-direction:column; }
      .wj-save-row { justify-content:stretch; }
      .wj-btn-save { width:100%; padding:13px 20px; }
      .wj-tabs { width:100%; }
      .wj-tab { flex:1; justify-content:center; }
      .page-header { flex-direction:column; align-items:flex-start; }
      .wj-template-item { flex-wrap:wrap; }
      .wj-template-actions { width:100%; justify-content:flex-end; border-top:1px solid rgba(255,255,255,.05); padding-top:8px; margin-top:2px; }
    }

    /* ═══════════════════════════════════════════════
       IMAGE EDITOR MODAL  (.wi-*)
       ═══════════════════════════════════════════════ */
    .wi-overlay { position:fixed; inset:0; z-index:10000; background:rgba(4,0,16,.96); backdrop-filter:blur(18px); display:none; flex-direction:column; }
    .wi-overlay.open { display:flex; }
    .wi-shell { display:flex; flex-direction:column; width:100%; height:100%; overflow:hidden; }

    /* Top bar */
    .wi-topbar { display:flex; align-items:center; justify-content:space-between; gap:12px; padding:0 16px; height:54px; flex-shrink:0; background:rgba(6,2,20,.95); border-bottom:1px solid rgba(255,255,255,.06); }
    .wi-topbar-left { display:flex; align-items:center; gap:10px; flex-shrink:0; }
    .wi-topbar-center { display:flex; align-items:center; gap:4px; flex:1; justify-content:center; flex-wrap:wrap; }
    .wi-topbar-right { display:flex; align-items:center; gap:8px; flex-shrink:0; }
    .wi-close-btn { background:rgba(255,255,255,.07); border:1px solid rgba(255,255,255,.1); border-radius:8px; color:var(--white); cursor:pointer; display:flex; align-items:center; justify-content:center; width:32px; height:32px; transition:background .15s; flex-shrink:0; }
    .wi-close-btn:hover { background:rgba(220,38,38,.25); }
    .wi-topbar-title { font-size:.82rem; font-weight:700; letter-spacing:.03em; display:flex; align-items:center; gap:6px; color:var(--purple-l); }
    .wi-tool-btn { display:flex; align-items:center; gap:5px; background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.08); border-radius:8px; color:var(--white); font-size:.75rem; font-weight:600; cursor:pointer; padding:5px 9px; transition:background .15s,border-color .15s; height:30px; font-family:inherit; white-space:nowrap; }
    .wi-tool-btn:hover { background:rgba(124,58,237,.18); border-color:rgba(124,58,237,.4); color:var(--purple-l); }
    .wi-tool-btn i { width:14px; height:14px; }
    .wi-sep { width:1px; height:20px; background:rgba(255,255,255,.1); margin:0 4px; flex-shrink:0; }
    .wi-tool-label { font-size:.7rem; color:var(--muted); font-weight:600; }
    .wi-bg-color { width:30px; height:30px; border-radius:7px; border:1px solid rgba(255,255,255,.15); cursor:pointer; padding:2px; background:none; }
    .wi-btn-preview { display:flex; align-items:center; gap:6px; padding:6px 14px; border-radius:9px; border:1px solid var(--border); background:var(--surface); color:var(--white); font-size:.78rem; font-weight:600; cursor:pointer; font-family:inherit; transition:background .15s,border-color .15s; }
    .wi-btn-preview:hover { border-color:var(--border-h); background:rgba(124,58,237,.1); }
    .wi-btn-save { display:flex; align-items:center; gap:6px; padding:6px 14px; border-radius:9px; border:none; background:var(--purple); color:#fff; font-size:.78rem; font-weight:700; cursor:pointer; font-family:inherit; transition:background .15s; }
    .wi-btn-save:hover { background:#8b5cf6; }
    .wi-btn-save:disabled { opacity:.5; cursor:not-allowed; }
    /* Bg Modal */
    .wi-bg-modal-overlay { position:fixed; inset:0; z-index:10100; background:rgba(0,0,0,.78); backdrop-filter:blur(10px); display:flex; align-items:center; justify-content:center; padding:20px; opacity:0; pointer-events:none; transition:opacity .22s; }
    .wi-bg-modal-overlay.open { opacity:1; pointer-events:all; }
    .wi-bg-modal { background:rgba(8,2,25,.98); border:1px solid rgba(124,58,237,.32); border-radius:18px; width:100%; max-width:440px; box-shadow:0 24px 80px rgba(0,0,0,.75); }
    .wi-bg-modal-header { display:flex; align-items:center; justify-content:space-between; padding:16px 18px 12px; border-bottom:1px solid rgba(255,255,255,.06); }
    .wi-bg-modal-title { font-size:.9rem; font-weight:700; color:var(--white); display:flex; align-items:center; gap:8px; }
    .wi-bg-tabs { display:flex; gap:6px; padding:14px 18px 0; }
    .wi-bg-tab { flex:1; padding:7px 0; border-radius:8px 8px 0 0; background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.07); border-bottom:none; color:var(--muted); font-size:.78rem; font-weight:600; cursor:pointer; font-family:inherit; transition:background .15s,color .15s; display:flex; align-items:center; justify-content:center; gap:5px; }
    .wi-bg-tab.active { background:rgba(124,58,237,.18); border-color:rgba(124,58,237,.35); color:var(--purple-l); }
    .wi-bg-tab-body { padding:16px 18px 18px; border-top:1px solid rgba(124,58,237,.18); }
    .wi-bg-tab-pane { display:none; } .wi-bg-tab-pane.active { display:block; }
    .wi-upload-drop { border:2px dashed rgba(124,58,237,.3); border-radius:12px; padding:28px 20px; text-align:center; cursor:pointer; transition:border-color .18s,background .18s; background:rgba(124,58,237,.04); }
    .wi-upload-drop:hover,.wi-upload-drop.drag { border-color:rgba(124,58,237,.7); background:rgba(124,58,237,.1); }
    .wi-upload-drop-icon { margin-bottom:8px; color:var(--purple-l); opacity:.7; }
    .wi-upload-drop-text { font-size:.8rem; color:var(--muted); }
    .wi-upload-drop-text strong { color:var(--white); }
    .wi-upload-preview { margin-top:12px; border-radius:10px; overflow:hidden; max-height:140px; display:none; }
    .wi-upload-preview img { width:100%; height:140px; object-fit:cover; border-radius:10px; }

    /* Editor body (fills remaining height, panels + canvas in a row) */
    .wi-body { display:flex; flex:1; min-height:0; overflow:hidden; }

    /* Panels */
    .wi-panel { background:rgba(6,2,20,.95); border-right:1px solid rgba(255,255,255,.06); display:flex; flex-direction:column; flex-shrink:0; }
    .wi-props-panel { border-right:none; border-left:1px solid rgba(255,255,255,.06); }
    .wi-layers-panel { width:190px; }
    .wi-props-panel { width:220px; }
    .wi-panel-header { padding:10px 12px 8px; font-size:.7rem; font-weight:700; letter-spacing:.08em; color:var(--muted); text-transform:uppercase; border-bottom:1px solid rgba(255,255,255,.05); flex-shrink:0; display:flex; align-items:center; gap:6px; }
    .wi-layers-list { flex:1; overflow-y:auto; padding:6px; display:flex; flex-direction:column; gap:2px; scrollbar-width:thin; scrollbar-color:rgba(124,58,237,.25) transparent; }
    .wi-layer-item { display:flex; align-items:center; gap:6px; padding:6px 8px; border-radius:7px; cursor:pointer; font-size:.76rem; font-weight:600; color:var(--muted); transition:background .12s,color .12s; user-select:none; border:1px solid transparent; }
    .wi-layer-item:hover { background:rgba(255,255,255,.04); color:var(--white); }
    .wi-layer-item.active { background:rgba(124,58,237,.15); border-color:rgba(124,58,237,.35); color:var(--purple-l); }
    .wi-layer-item i { width:12px; height:12px; flex-shrink:0; }
    .wi-layer-name { flex:1; min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .wi-layer-vis { background:none; border:none; color:var(--muted); cursor:pointer; padding:0; display:flex; align-items:center; width:16px; height:16px; flex-shrink:0; opacity:.6; }
    .wi-layer-vis:hover { opacity:1; color:var(--white); }
    .wi-layer-del { background:none; border:none; color:var(--muted); cursor:pointer; padding:0; display:flex; align-items:center; width:16px; height:16px; flex-shrink:0; opacity:.5; }
    .wi-layer-del:hover { opacity:1; color:#ef4444; }
    .wi-layer-move { display:flex; flex-direction:column; gap:1px; flex-shrink:0; }
    .wi-layer-move button { background:none; border:none; color:var(--muted); cursor:pointer; padding:0; display:flex; align-items:center; width:12px; height:10px; font-size:.55rem; line-height:1; }
    .wi-layer-move button:hover { color:var(--white); }

    /* Canvas area */
    .wi-canvas-area { flex:1; overflow:auto; display:flex; align-items:center; justify-content:center; background:rgba(0,0,0,.3); padding:24px; }
    .wi-canvas-wrap { position:relative; box-shadow:0 8px 60px rgba(0,0,0,.7); border-radius:4px; overflow:hidden; }
    .wi-canvas-wrap canvas { display:block; }

    /* Properties */
    #wiPropsContent { flex:1; overflow-y:auto; padding:10px 10px 16px; display:flex; flex-direction:column; gap:10px; scrollbar-width:thin; scrollbar-color:rgba(124,58,237,.2) transparent; }
    .wi-no-sel { display:flex; flex-direction:column; align-items:center; justify-content:center; gap:8px; color:var(--muted); font-size:.78rem; text-align:center; padding:24px 12px; }
    .wi-prop-group { display:flex; flex-direction:column; gap:6px; }
    .wi-prop-label { font-size:.62rem; font-weight:700; letter-spacing:.07em; color:rgba(203,194,255,.4); text-transform:uppercase; }
    .wi-prop-lbl { font-size:.65rem; color:var(--muted); width:20px; flex-shrink:0; text-align:center; }
    .wi-prop-row { display:flex; align-items:center; gap:6px; }
    .wi-prop-input { flex:1; background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.1); border-radius:7px; color:var(--white); font-size:.76rem; padding:5px 8px; font-family:inherit; outline:none; min-width:0; }
    .wi-prop-input:focus { border-color:rgba(124,58,237,.5); }
    .wi-prop-num { width:60px; flex-shrink:0; background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.1); border-radius:7px; color:var(--white); font-size:.76rem; padding:5px 6px; font-family:inherit; outline:none; text-align:center; }
    .wi-prop-num:focus { border-color:rgba(124,58,237,.5); }
    .wi-prop-select { flex:1; background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.1); border-radius:7px; color:var(--white); font-size:.76rem; padding:5px 8px; font-family:inherit; outline:none; -webkit-appearance:none; }
    .wi-prop-select option { background:#0a0022; }
    .wi-prop-color { width:30px; height:28px; border-radius:6px; border:1px solid rgba(255,255,255,.15); cursor:pointer; padding:2px; background:none; flex-shrink:0; }
    .wi-prop-check-row { display:flex; align-items:center; justify-content:space-between; }
    .wi-prop-check-label { font-size:.76rem; color:var(--muted); }
    .wi-slider { width:100%; accent-color:var(--purple); }
    .wi-shape-btns { display:flex; gap:6px; }
    .wi-shape-btn { flex:1; padding:5px 0; border:1px solid rgba(255,255,255,.1); border-radius:7px; background:var(--surface); color:var(--muted); font-size:.72rem; cursor:pointer; transition:all .15s; display:flex; align-items:center; justify-content:center; gap:4px; }
    .wi-shape-btn.active { border-color:var(--purple); background:rgba(124,58,237,.18); color:#a78bfa; }
    .wi-var-chips { display:flex; flex-wrap:wrap; gap:4px; }
    .wi-var-chip { font-size:.65rem; padding:3px 7px; border-radius:99px; background:rgba(124,58,237,.12); border:1px solid rgba(124,58,237,.25); color:var(--purple-l); cursor:pointer; font-weight:600; transition:background .12s; }
    .wi-var-chip:hover { background:rgba(124,58,237,.25); }
    .wi-prop-divider { height:1px; background:rgba(255,255,255,.05); margin:4px 0; }

    /* ── Tablet (≤900px) ── */
    @media (max-width:900px) {
      .wi-layers-panel { width:160px; }
      .wi-props-panel  { width:200px; }
      .wi-tool-btn span { display:none; }
      .wi-tool-btn { padding:5px 7px; }
    }

    /* ── Mobile (≤640px) ── */
    @media (max-width:640px) {
      /* Topbar → 2 rows */
      .wi-topbar { flex-wrap:wrap; height:auto; padding:8px 12px 4px; gap:6px 8px; }
      .wi-topbar-left  { order:1; flex:1; min-width:0; }
      .wi-topbar-right { order:2; flex-shrink:0; }
      .wi-topbar-center {
        order:3; width:100%;
        overflow-x:auto; -webkit-overflow-scrolling:touch;
        flex-wrap:nowrap; justify-content:flex-start;
        padding-bottom:6px; gap:4px;
        scrollbar-width:none;
      }
      .wi-topbar-center::-webkit-scrollbar { display:none; }
      .wi-tool-btn span { display:none; }
      .wi-tool-btn { padding:6px 9px; height:32px; flex-shrink:0; }
      .wi-sep { height:16px; margin:0 2px; flex-shrink:0; }
      .wi-btn-preview span, .wi-btn-save span { display:none; }
      .wi-btn-preview, .wi-btn-save { padding:6px 10px; }

      /* Body → canvas on top, tabs + panel below */
      .wi-body { flex-direction:column; }
      .wi-canvas-area { order:1; flex:1; min-height:0; padding:10px; }

      /* Mobile tab bar */
      .wi-mob-tabs { display:flex !important; order:2; flex-shrink:0; background:rgba(6,2,20,.97); border-top:1px solid rgba(255,255,255,.07); }
      .wi-mob-tab { flex:1; display:flex; align-items:center; justify-content:center; gap:6px; padding:9px 4px; font-size:.74rem; font-weight:600; color:var(--muted); cursor:pointer; border:none; background:none; font-family:inherit; transition:color .15s,background .15s; border-top:2px solid transparent; }
      .wi-mob-tab i { width:14px; height:14px; flex-shrink:0; }
      .wi-mob-tab.active { color:var(--purple-l); border-top-color:var(--purple); background:rgba(124,58,237,.08); }

      /* Panels */
      .wi-layers-panel,
      .wi-props-panel  { display:none; order:3; width:100%; height:200px; max-height:45vh; border-right:none; border-left:none; border-top:1px solid rgba(255,255,255,.06); flex-shrink:0; }
      .wi-layers-panel.mob-active,
      .wi-props-panel.mob-active { display:flex; }
    }

    /* Hide mob-tabs on desktop */
    .wi-mob-tabs { display:none; }
  </style>
</head>
<body>
  <canvas id="c"></canvas>
  <div class="glow glow-a"></div>
  <div class="glow glow-b"></div>

  <%- include('partials/layout', { activePage: 'welcome-join' }) %>

  <main class="main">
    <!-- Page Header -->
    <div class="page-header">
      <div class="page-header-left">
        <div class="wj-breadcrumb">
          <i data-lucide="message-square-heart" style="stroke:currentColor;fill:none;"></i>
          <%= lang === 'ar' ? 'رسائل الترحيب' : 'Welcome Messages' %>
        </div>
        <h2><%= t.welcomeJoin.pageTitle %></h2>
        <p><%= t.welcomeJoin.pageDesc %></p>
      </div>
      <div class="page-header-right">
        <label class="wj-module-toggle">
          <input type="checkbox" id="moduleEnabled" <%= welcomeConfig.enabled ? 'checked' : '' %>>
          <span class="wj-toggle-track"><span class="wj-toggle-thumb"></span></span>
          <span class="wj-toggle-label"><%= t.welcomeJoin.moduleEnabled %></span>
        </label>
      </div>
    </div>

    <!-- Tabs -->
    <div class="wj-tabs">
      <button class="wj-tab active" data-tab="settings">
        <i data-lucide="settings-2" style="stroke:currentColor;fill:none;"></i>
        <%= t.welcomeJoin.tabSettings %>
      </button>
      <button class="wj-tab" data-tab="log">
        <i data-lucide="scroll-text" style="stroke:currentColor;fill:none;"></i>
        <%= t.welcomeJoin.tabLog %>
      </button>
    </div>

    <!-- ─── Settings Tab ─────────────────────────── -->
    <div class="wj-tab-content active" id="tab-settings">

      <!-- Templates Card -->
      <div class="wj-card">
        <div class="wj-card-header">
          <div class="wj-card-title-wrap">
            <div class="wj-card-icon wj-icon-purple"><i data-lucide="layout-template" style="stroke:currentColor;fill:none;"></i></div>
            <div>
              <div class="wj-card-title"><%= t.welcomeJoin.templatesTitle %></div>
              <div class="wj-card-desc"><%= t.welcomeJoin.templatesDesc %></div>
            </div>
          </div>
          <span class="wj-counter"><span id="tpl-count">00</span>&thinsp;/&thinsp;<span id="tpl-total">00</span></span>
        </div>
        <div class="wj-card-body">
          <div class="wj-field">
            <label class="wj-label"><i data-lucide="hash" style="stroke:currentColor;fill:none;"></i> <%= t.welcomeJoin.channelLabel %></label>
            <div class="wj-select-wrap">
              <select id="defaultChannel" class="wj-select">
                <option value="">— <%= t.welcomeJoin.channelPlaceholder %> —</option>
                <option value="dm"><%= t.welcomeJoin.dmOption %></option>
                <% (guildChannels || []).forEach(function(ch){ %><option value="<%= ch.id %>">#<%= ch.name %></option><% }); %>
              </select>
            </div>
          </div>
          <div class="wj-ie-bar" style="margin-top:4px;">
            <button class="wj-btn-primary" id="createTemplateBtn">
              <i data-lucide="plus" style="width:15px;height:15px;stroke:currentColor;fill:none;"></i>
              <%= t.welcomeJoin.createTemplateBtn %>
            </button>
            <button class="wj-btn-ghost" id="exportTemplatesBtn" title="<%= lang === 'ar' ? 'تصدير القوالب' : 'Export Templates' %>">
              <i data-lucide="download" style="width:14px;height:14px;stroke:currentColor;fill:none;"></i>
              <%= lang === 'ar' ? 'تصدير' : 'Export' %>
            </button>
            <button class="wj-btn-ghost" id="importTemplatesBtn" title="<%= lang === 'ar' ? 'استيراد القوالب' : 'Import Templates' %>">
              <i data-lucide="upload" style="width:14px;height:14px;stroke:currentColor;fill:none;"></i>
              <%= lang === 'ar' ? 'استيراد' : 'Import' %>
            </button>
            <input type="file" id="importTemplateFile" accept=".json" style="display:none;">
          </div>
          <div class="wj-template-list" id="templateList">
            <div class="wj-empty-state" id="tplEmpty">
              <i data-lucide="inbox" style="stroke:currentColor;fill:none;"></i>
              <span><%= t.welcomeJoin.noTemplates %></span>
            </div>
          </div>
        </div>
      </div>

      <!-- Additional Welcome Settings -->
      <div class="wj-card">
        <div class="wj-card-header">
          <div class="wj-card-title-wrap">
            <div class="wj-card-icon wj-icon-cyan"><i data-lucide="sliders-horizontal" style="stroke:currentColor;fill:none;"></i></div>
            <div><div class="wj-card-title"><%= t.welcomeJoin.additionalSettingsTitle %></div></div>
          </div>
        </div>
        <div class="wj-card-body">
          <div class="wj-toggle-row">
            <div class="wj-toggle-info">
              <div class="wj-toggle-name"><%= t.welcomeJoin.welcomeTextLabel %></div>
              <div class="wj-toggle-help"><%= t.welcomeJoin.welcomeTextHelp %></div>
            </div>
            <label class="wj-switch"><input type="checkbox" id="welcomeText" <%= welcomeConfig.welcomeText ? 'checked' : '' %>><span class="wj-switch-track"><span class="wj-switch-thumb"></span></span></label>
          </div>
          <div class="wj-toggle-row">
            <div class="wj-toggle-info">
              <div class="wj-toggle-name"><%= t.welcomeJoin.dmWelcomeLabel %></div>
              <div class="wj-toggle-help"><%= t.welcomeJoin.dmWelcomeHelp %></div>
            </div>
            <label class="wj-switch"><input type="checkbox" id="dmWelcome" <%= welcomeConfig.dmWelcome ? 'checked' : '' %>><span class="wj-switch-track"><span class="wj-switch-thumb"></span></span></label>
          </div>
          <div class="wj-dm-settings" id="dmSettings" style="display:none;">
            <div class="wj-textarea-wrap">
              <textarea id="dmMessage" class="wj-textarea" maxlength="1024" rows="4" placeholder="<%= t.welcomeJoin.dmPlaceholder %>"><%= welcomeConfig.dmMessage || '' %></textarea>
              <div class="wj-char-counter"><span id="dmCharCount"><%= (welcomeConfig.dmMessage || '').length %></span>/1024</div>
            </div>
          </div>
          <!-- Variables -->
          <div class="wj-variables">
            <div class="wj-variables-title"><%= t.welcomeJoin.variablesTitle %></div>
            <div class="wj-var-grid">
              <div class="wj-var-item"><code>[user]</code><span><%= t.welcomeJoin.varUser %></span></div>
              <div class="wj-var-item"><code>[userName]</code><span><%= t.welcomeJoin.varUserName %></span></div>
              <div class="wj-var-item"><code>[userCreatedDate]</code><span><%= t.welcomeJoin.varUserCreatedDate %></span></div>
              <div class="wj-var-item"><code>[userCreatedDays]</code><span><%= t.welcomeJoin.varUserCreatedDays %></span></div>
              <div class="wj-var-item"><code>[serverName]</code><span><%= t.welcomeJoin.varServerName %></span></div>
              <div class="wj-var-item"><code>[memberCount]</code><span><%= t.welcomeJoin.varMemberCount %></span></div>
              <div class="wj-var-item"><code>[inviter]</code><span><%= t.welcomeJoin.varInviter %></span></div>
              <div class="wj-var-item"><code>[inviterName]</code><span><%= t.welcomeJoin.varInviterName %></span></div>
              <div class="wj-var-item"><code>[invitesCount]</code><span><%= t.welcomeJoin.varInvitesCount %></span></div>
              <div class="wj-var-item"><code>[inviteCode]</code><span><%= t.welcomeJoin.varInviteCode %></span></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Message Settings Card -->
      <div class="wj-card">
        <div class="wj-card-header">
          <div class="wj-card-title-wrap">
            <div class="wj-card-icon wj-icon-gold"><i data-lucide="settings" style="stroke:currentColor;fill:none;"></i></div>
            <div><div class="wj-card-title"><%= t.welcomeJoin.msgSettingsTitle %></div></div>
          </div>
        </div>
        <div class="wj-card-body">
          <div class="wj-field-row">
            <div class="wj-field-info">
              <div class="wj-field-name"><%= t.welcomeJoin.msgDelayLabel %></div>
              <div class="wj-field-help"><%= t.welcomeJoin.msgDelayHelp %></div>
            </div>
            <input type="number" class="wj-input-number" id="sendDelay" min="0" max="300" value="<%= welcomeConfig.sendDelay || 0 %>">
          </div>
          <div class="wj-field-row">
            <div class="wj-field-info">
              <div class="wj-field-name"><%= t.welcomeJoin.msgDeleteDelayLabel %></div>
              <div class="wj-field-help"><%= t.welcomeJoin.msgDeleteDelayHelp %></div>
            </div>
            <input type="number" class="wj-input-number" id="deleteDelay" min="0" max="3600" value="<%= welcomeConfig.deleteDelay || 0 %>">
          </div>
          <div class="wj-toggle-row">
            <div class="wj-toggle-info">
              <div class="wj-toggle-name"><%= t.welcomeJoin.msgRulesLabel %></div>
              <div class="wj-toggle-help"><%= t.welcomeJoin.msgRulesHelp %></div>
            </div>
            <label class="wj-switch"><input type="checkbox" id="waitRules" <%= welcomeConfig.waitRules ? 'checked' : '' %>><span class="wj-switch-track"><span class="wj-switch-thumb"></span></span></label>
          </div>
          <div class="wj-field" style="padding:2px 0;">
            <label class="wj-label"><i data-lucide="filter" style="stroke:currentColor;fill:none;"></i> <%= lang === 'ar' ? 'تصفية الأعضاء' : 'Member Filter' %></label>
            <div class="wj-filter-group" id="memberFilterGroup">
              <label class="wj-filter-opt<%= !welcomeConfig.ignoreBots && !welcomeConfig.ignoreUsers ? ' selected' : '' %>" data-filter="all">
                <input type="radio" name="memberFilter" value="all" <%= !welcomeConfig.ignoreBots && !welcomeConfig.ignoreUsers ? 'checked' : '' %>>
                <span class="wj-filter-opt-dot"></span>
                <span class="wj-filter-opt-text"><%= lang === 'ar' ? 'إرسال للجميع (بشر + بوتات)' : 'Send to everyone (humans + bots)' %></span>
              </label>
              <label class="wj-filter-opt<%= welcomeConfig.ignoreBots ? ' selected' : '' %>" data-filter="nobots">
                <input type="radio" name="memberFilter" value="nobots" <%= welcomeConfig.ignoreBots ? 'checked' : '' %>>
                <span class="wj-filter-opt-dot"></span>
                <span class="wj-filter-opt-text"><%= lang === 'ar' ? 'تجاهل البوتات (البشر فقط)' : 'Ignore bots (humans only)' %></span>
              </label>
              <label class="wj-filter-opt<%= welcomeConfig.ignoreUsers ? ' selected' : '' %>" data-filter="nohumans">
                <input type="radio" name="memberFilter" value="nohumans" <%= welcomeConfig.ignoreUsers ? 'checked' : '' %>>
                <span class="wj-filter-opt-dot"></span>
                <span class="wj-filter-opt-text"><%= lang === 'ar' ? 'تجاهل البشر (البوتات فقط)' : 'Ignore humans (bots only)' %></span>
              </label>
            </div>
            <input type="hidden" id="ignoreBots"  value="<%= welcomeConfig.ignoreBots  ? '1' : '' %>">
            <input type="hidden" id="ignoreUsers" value="<%= welcomeConfig.ignoreUsers ? '1' : '' %>">
          </div>
        </div>
      </div>

      <!-- Randomized Groups Card -->
      <div class="wj-card">
        <div class="wj-card-header">
          <div class="wj-card-title-wrap">
            <div class="wj-card-icon wj-icon-green"><i data-lucide="shuffle" style="stroke:currentColor;fill:none;"></i></div>
            <div>
              <div class="wj-card-title"><%= t.welcomeJoin.randomizedGroupsTitle %></div>
              <div class="wj-card-desc"><%= t.welcomeJoin.randomizedGroupsDesc %></div>
            </div>
          </div>
          <button class="wj-btn-outline" id="newGroupBtn">
            <i data-lucide="plus" style="width:14px;height:14px;stroke:currentColor;fill:none;"></i>
            <%= t.welcomeJoin.newGroupBtn %>
          </button>
        </div>
        <div class="wj-card-body">
          <div class="wj-empty-state" id="groupEmpty">
            <i data-lucide="layers" style="stroke:currentColor;fill:none;"></i>
            <span><%= t.welcomeJoin.noGroups %></span>
          </div>
          <div class="wj-group-list" id="groupList" style="display:none;"></div>
        </div>
      </div>

      <!-- Dynamic Images Card -->
      <div class="wj-card">
        <div class="wj-card-header">
          <div class="wj-card-title-wrap">
            <div class="wj-card-icon wj-icon-cyan"><i data-lucide="image" style="stroke:currentColor;fill:none;"></i></div>
            <div>
              <div class="wj-card-title"><%= t.welcomeJoin.dynamicImagesTitle %></div>
              <div class="wj-card-desc"><%= t.welcomeJoin.dynamicImagesDesc %></div>
            </div>
          </div>
          <div style="display:flex;align-items:center;gap:8px;">
            <label class="wj-switch wj-switch-sm" title="Enable dynamic image">
              <input type="checkbox" id="imgEnabled"<%= imgConfig && imgConfig.enabled ? ' checked' : '' %>>
              <span class="wj-switch-track"><span class="wj-switch-thumb"></span></span>
            </label>
            <button class="wj-btn-outline" id="openImageEditor">
              <i data-lucide="pencil-ruler" style="width:14px;height:14px;stroke:currentColor;fill:none;"></i>
              <%= lang === 'ar' ? 'فتح المحرر' : 'Open Editor' %>
            </button>
          </div>
        </div>
        <div class="wj-card-body">
          <!-- Send mode + channel (attachment only) -->
          <div class="wj-field-row" style="margin-bottom:10px;">
            <div class="wj-field" style="flex:1;">
              <label class="wj-label"><i data-lucide="send" style="stroke:currentColor;fill:none;"></i> <%= lang === 'ar' ? 'طريقة الإرسال' : 'Send Mode' %></label>
              <div class="wj-select-wrap">
                <select id="imgSendMode" class="wj-select">
                  <option value="embed"><%= lang === 'ar' ? 'داخل Embed' : 'Inside Embed' %></option>
                  <option value="component"><%= lang === 'ar' ? 'Component v2' : 'Component v2' %></option>
                  <option value="attachment"><%= lang === 'ar' ? 'مرفق مستقل' : 'Standalone Attachment' %></option>
                </select>
              </div>
            </div>
            <div class="wj-field" id="imgChannelField" style="flex:1;display:none;">
              <label class="wj-label"><i data-lucide="hash" style="stroke:currentColor;fill:none;"></i> <%= lang === 'ar' ? 'قناة الإرسال' : 'Send Channel' %></label>
              <div class="wj-select-wrap">
                <select id="imgChannel" class="wj-select">
                  <option value="">— <%= lang === 'ar' ? 'اختر قناة' : 'Select channel' %> —</option>
                  <% (guildChannels || []).forEach(function(ch){ %><option value="<%= ch.id %>">#<%= ch.name %></option><% }); %>
                </select>
              </div>
            </div>
          </div>
          <!-- Template link (embed / component mode) -->
          <div id="imgTemplateLinkOpts">
            <div class="wj-field">
              <label class="wj-label"><i data-lucide="link" style="stroke:currentColor;fill:none;"></i> <%= lang === 'ar' ? 'اربط مع قالب' : 'Link to Template' %></label>
              <div class="wj-select-wrap">
                <select id="imgLinkedTemplate" class="wj-select">
                  <option value="">— <%= lang === 'ar' ? 'اختر قالباً' : 'Select a template' %> —</option>
                </select>
              </div>
              <div style="font-size:.72rem;color:rgba(203,194,255,.45);margin-top:5px;">
                <%= lang === 'ar' ? 'ستُضاف الصورة الديناميكية تلقائياً لرسالة القالب المحدد عند انضمام عضو' : "The dynamic image will be injected into the selected template's message when a member joins" %>
              </div>
            </div>
            <!-- Action panel: visible when a template is linked -->
            <div id="imgLinkActions" style="display:none;margin-top:10px;">
              <button id="imgActionsToggle" class="wj-btn-ghost" style="width:100%;justify-content:center;gap:6px;">
                <i data-lucide="zap" style="stroke:currentColor;fill:none;width:14px;height:14px;"></i>
                <%= lang === 'ar' ? 'إعداد الإرسال' : 'Configure & Send' %>
                <i data-lucide="chevron-down" id="imgActionsChevron" style="stroke:currentColor;fill:none;width:14px;height:14px;margin-left:auto;transition:transform .2s;"></i>
              </button>
              <div id="imgActionsPanel" style="display:none;margin-top:6px;padding:12px 14px;background:rgba(124,58,237,.05);border-radius:10px;border:1px solid rgba(124,58,237,.18);">
                <div style="font-size:.78rem;color:rgba(203,194,255,.55);margin-bottom:10px;display:flex;align-items:center;gap:5px;">
                  <i data-lucide="hash" style="width:12px;height:12px;stroke:currentColor;fill:none;"></i>
                  <%= lang === 'ar' ? 'القناة:' : 'Channel:' %> <span id="imgLinkedChannelLabel" style="color:rgba(203,194,255,.85);">—</span>
                </div>
                <div style="display:flex;gap:8px;flex-wrap:wrap;">
                  <button id="imgTestSendBtn" class="wj-btn-outline" style="flex:1;min-width:120px;justify-content:center;">
                    <i data-lucide="send" style="stroke:currentColor;fill:none;width:13px;height:13px;"></i>
                    <%= lang === 'ar' ? 'إرسال تجريبي' : 'Test Send' %>
                  </button>
                  <button id="imgSetupNowBtn" class="wj-btn-primary" style="flex:1;min-width:120px;width:auto;">
                    <i data-lucide="check-circle" style="stroke:currentColor;fill:none;width:13px;height:13px;"></i>
                    <%= lang === 'ar' ? 'حفظ وتفعيل' : 'Setup Now' %>
                  </button>
                </div>
              </div>
            </div>
          </div>
          <!-- Standalone attachment options -->
          <div id="imgAttachmentOpts" style="display:none;">
            <div class="wj-field">
              <label class="wj-label"><i data-lucide="message-square" style="stroke:currentColor;fill:none;"></i> <%= lang === 'ar' ? 'نص الرسالة (اختياري)' : 'Message Text (optional)' %></label>
              <input type="text" class="wj-input" id="imgAttachmentText" placeholder="<%= lang === 'ar' ? 'نص يُرسل مع الصورة كمرفق — يدعم المتغيرات' : 'Text sent with the image as attachment — supports variables' %>">
            </div>
          </div>
          <!-- Mini preview thumbnail -->
          <div id="imgPreviewWrap" style="margin-top:12px;display:none;">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">
              <div class="wj-label"><i data-lucide="eye" style="stroke:currentColor;fill:none;"></i> <%= lang === 'ar' ? 'معاينة الصورة' : 'Image Preview' %></div>
              <button id="imgPreviewToggle" class="wj-btn wj-btn-ghost" style="font-size:.75rem;padding:2px 10px;height:26px;" title="<%= lang === 'ar' ? 'إخفاء / إظهار' : 'Toggle preview' %>">
                <i data-lucide="eye-off" id="imgPreviewToggleIcon" style="stroke:currentColor;fill:none;width:13px;height:13px;"></i>
                <span id="imgPreviewToggleLabel"><%= lang === 'ar' ? 'إخفاء' : 'Hide' %></span>
              </button>
            </div>
            <div id="imgPreviewBody">
              <img id="imgPreviewThumb" src="" alt="preview" style="max-width:100%;border-radius:12px;border:1px solid var(--border);">
            </div>
          </div>
        </div>
      </div>

      <!-- Save Row -->
      <div class="wj-save-row">
        <button class="wj-btn-save" id="saveBtn">
          <i data-lucide="save" style="width:16px;height:16px;stroke:currentColor;fill:none;"></i>
          <%= t.welcomeJoin.saveBtn %>
        </button>
      </div>
    </div>

    <!-- ─── Log Tab ───────────────────────────────── -->
    <div class="wj-tab-content" id="tab-log">
      <div class="wj-card">
        <div class="wj-card-header">
          <div class="wj-card-title-wrap">
            <div class="wj-card-icon"><i data-lucide="scroll-text" style="stroke:currentColor;fill:none;"></i></div>
            <div>
              <div class="wj-card-title"><%= lang === 'ar' ? 'سجل النشاط' : 'Activity Log' %></div>
              <div class="wj-card-subtitle"><%= lang === 'ar' ? 'آخر 100 رسالة ترحيب أُرسلت' : 'Last 100 welcome messages sent' %></div>
            </div>
          </div>
          <button class="wj-btn-ghost" id="wjLogRefresh" style="padding:6px 14px;display:flex;align-items:center;gap:6px;">
            <i data-lucide="refresh-cw" style="stroke:currentColor;fill:none;width:14px;height:14px;"></i>
            <%= lang === 'ar' ? 'تحديث' : 'Refresh' %>
          </button>
        </div>
        <div class="wj-card-body">
          <!-- Filter bar (shown only when logs are loaded) -->
          <div class="wj-log-bar" id="wjLogBar" style="display:none;">
            <select class="wj-log-filter-sel" id="wjLogTypeFilter">
              <option value=""><%= lang === 'ar' ? 'كل الأنواع' : 'All types' %></option>
              <option value="text"><%= lang === 'ar' ? 'نص' : 'Text' %></option>
              <option value="embed">Embed</option>
              <option value="component">Component</option>
            </select>
            <select class="wj-log-filter-sel" id="wjLogStatusFilter">
              <option value=""><%= lang === 'ar' ? 'كل الحالات' : 'All statuses' %></option>
              <option value="ok"><%= lang === 'ar' ? 'نجح' : 'Success' %></option>
              <option value="error"><%= lang === 'ar' ? 'خطأ' : 'Error' %></option>
            </select>
            <input type="date" class="wj-log-input" id="wjLogDateFilter" title="<%= lang === 'ar' ? 'فلتر بالتاريخ' : 'Filter by date' %>">
          </div>
          <!-- Loading spinner -->
          <div class="wj-log-spin" id="wjLogSpinner"></div>
          <!-- Log entries -->
          <div class="wj-log-list" id="wjLogList" style="display:none;"></div>
          <!-- Empty state -->
          <div class="wj-empty-state" id="wjLogEmpty" style="display:none;">
            <i data-lucide="scroll-text" style="stroke:currentColor;fill:none;"></i>
            <span><%= t.welcomeJoin.noActivityLog %></span>
          </div>
          <div class="wj-log-footer" id="wjLogFooter" style="display:none;"></div>
        </div>
      </div>
    </div>

    <!-- ─── Group Modal ──────────────────────────── -->
    <div class="wj-modal-overlay" id="groupModal">
      <div class="wj-modal" style="max-width:460px;">
        <div class="wj-modal-header">
          <div class="wj-modal-title" id="groupModalTitle"><%= lang === 'ar' ? 'مجموعة جديدة' : 'New Group' %></div>
          <button class="wj-modal-close" id="groupModalClose"><i data-lucide="x" style="width:16px;height:16px;stroke:currentColor;fill:none;"></i></button>
        </div>
        <div class="wj-modal-body">
          <div class="wj-form-group">
            <label class="wj-form-label"><%= lang === 'ar' ? 'اسم المجموعة' : 'Group Name' %></label>
            <input type="text" class="wj-input" id="groupNameInput" maxlength="100" placeholder="<%= lang === 'ar' ? 'مثال: رسائل ترحيب' : 'e.g. welcome-messages' %>">
          </div>
          <div class="wj-form-group">
            <label class="wj-form-label" style="margin-bottom:8px;display:block;"><%= lang === 'ar' ? 'القوالب (اختر واحداً أو أكثر)' : 'Templates (pick one or more)' %></label>
            <div class="wj-group-tpl-list" id="groupTplList"></div>
            <div class="wj-empty-state" id="groupTplEmpty" style="padding:18px 0;display:none;">
              <i data-lucide="alert-circle" style="stroke:currentColor;fill:none;"></i>
              <span style="font-size:.78rem;"><%= lang === 'ar' ? 'لا توجد قوالب. أنشئ قالباً أولاً.' : 'No templates yet. Create a template first.' %></span>
            </div>
          </div>
        </div>
        <div class="wj-modal-footer">

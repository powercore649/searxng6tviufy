    .wj-card-icon { width:38px; height:38px; border-radius:10px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .wj-card-icon i { width:18px; height:18px; }
    .wj-icon-purple { background:rgba(124,58,237,.15); color:var(--purple-l); border:1px solid rgba(124,58,237,.2); }
    .wj-icon-cyan { background:rgba(6,182,212,.12); color:var(--cyan-l); border:1px solid rgba(6,182,212,.15); }
    .wj-icon-gold { background:rgba(217,119,6,.12); color:var(--gold-l); border:1px solid rgba(217,119,6,.15); }
    .wj-icon-green { background:rgba(34,197,94,.1); color:#86efac; border:1px solid rgba(34,197,94,.15); }
    .wj-icon-red { background:rgba(239,68,68,.1); color:#fca5a5; border:1px solid rgba(239,68,68,.15); }
    .wj-card-title { font-size:.9rem; font-weight:700; color:var(--white); }
    .wj-card-desc { font-size:.76rem; color:var(--muted); margin-top:2px; }
    .wj-card-subtitle { font-size:.76rem; color:var(--muted); margin-top:2px; }
    .wj-card-body { padding:20px 22px; display:flex; flex-direction:column; gap:16px; }
    .wj-counter { display:inline-flex; align-items:center; gap:2px; font-size:.78rem; font-weight:700; padding:4px 12px; border-radius:99px; background:rgba(124,58,237,.12); color:var(--purple-l); border:1px solid rgba(124,58,237,.2); font-family:'Orbitron',monospace; letter-spacing:.04em; flex-shrink:0; }
    /* Fields */

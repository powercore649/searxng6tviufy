    .wj-input { width:100%; padding:10px 12px; border-radius:10px; background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.1); color:var(--white); font-size:.84rem; font-family:inherit; outline:none; transition:border-color .18s,background-color .18s; }

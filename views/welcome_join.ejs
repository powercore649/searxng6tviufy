    .wj-btn-icon { display:flex; align-items:center; justify-content:center; width:32px; height:32px; border-radius:8px; background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.08); color:var(--muted); cursor:pointer; transition:background .15s,color .15s,border-color .15s; }
    .wj-btn-icon:hover { background:rgba(124,58,237,.12); color:var(--purple-l); border-color:rgba(124,58,237,.3); }
    .wj-btn-icon.danger:hover { background:rgba(239,68,68,.12); color:#fca5a5; border-color:rgba(239,68,68,.3); }
    .wj-btn-icon.success:hover { background:rgba(34,197,94,.12); color:#86efac; border-color:rgba(34,197,94,.3); }

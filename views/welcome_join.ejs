    .wj-toggle-row:last-of-type { border-bottom:none; }
    .wj-toggle-info { flex:1; min-width:0; }
    .wj-toggle-name { font-size:.84rem; font-weight:600; color:var(--white); }
    .wj-toggle-help { font-size:.74rem; color:var(--muted); margin-top:2px; }
    /* Switch */
    .wj-switch { position:relative; display:inline-flex; flex-shrink:0; cursor:pointer; }
    .wj-switch input { display:none; }
    .wj-switch-track { width:44px; height:24px; border-radius:99px; background:rgba(255,255,255,.12); position:relative; transition:background .22s; }
    .wj-switch input:checked + .wj-switch-track { background:var(--purple); }
    .wj-switch-thumb { position:absolute; top:3px; left:3px; width:18px; height:18px; border-radius:50%; background:#fff; transition:left .22s; box-shadow:0 1px 4px rgba(0,0,0,.4); }
    .wj-switch input:checked + .wj-switch-track .wj-switch-thumb { left:23px; }
    .wj-switch-sm .wj-switch-track { width:36px; height:20px; }

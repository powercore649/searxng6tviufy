        wrap.querySelectorAll('._wj-del-btn').forEach(function(btn) {
          btn.addEventListener('click', function(e) {
            e.stopPropagation();
            row.buttons.splice(parseInt(this.dataset.bi), 1);
            _wjRenderRows();
          });

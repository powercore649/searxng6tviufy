      .nav-sidebar { transform: translateX(-100%); width: 220px !important; align-items: stretch; overflow-x: unset; z-index: 95; transition: transform 350ms cubic-bezier(0.4,0,0.2,1); }
      [dir="rtl"] .nav-sidebar { transform: translateX(100%); }
      .nav-sidebar.open { transform: translateX(0) !important; }

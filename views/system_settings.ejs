      } else {
        document.getElementById('geo-fields').innerHTML = `<div class="geo-field full"><div class="geo-field-label">IP</div><div class="geo-field-value mono">${entry.ip || '—'}</div></div><div class="geo-field full" style="color:var(--muted);font-size:.78rem;">${_sys_t.noIpRecorded}</div>`;
        lucide.createIcons();

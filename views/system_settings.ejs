    function closeGeoModal() {
      document.getElementById('geo-modal-backdrop').classList.remove('open');
      document.body.style.overflow = '';
    }
    document.getElementById('geo-close-btn').addEventListener('click', closeGeoModal);
    document.getElementById('geo-modal-backdrop').addEventListener('click', e => { if (e.target === e.currentTarget) closeGeoModal(); });

    /* ═══════════════════════════════════════════════════════════════════════
       Auto Backup MongoDB
       ═══════════════════════════════════════════════════════════════════════ */
    (function () {
      const _t = _sys_t;
      let _bkpTargets        = [];
      let _bkpEditId         = null;
      let _bkpModalWebhooks  = []; // {masked, isNew, rawUrl?}

      const MODE_LABELS = {
        changestream: _t.autoBackupModeCS     || 'Change Stream',
        queue:        _t.autoBackupModeQ      || 'Queue',
        schedule:     _t.autoBackupModeSched  || 'Scheduled',
      };

      function _esc(s) {
        return String(s||'')
          .replace(/&/g,'&amp;').replace(/</g,'&lt;')
          .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
      }

      function _tf(tpl, vars) {
        if (!tpl) return '';
        return tpl.replace(/\{(\w+)\}/g, (_,k) => vars[k] ?? '');
      }

      function _msToLabel(ms) {
        if (!ms) return '—';
        const m = Math.round(ms / 60000);
        if (m < 60)   return `${m} ${_t.autoBackupMin || 'min'}`;
        const h = Math.round(m / 60);
        if (h < 24)   return `${h} ${h === 1 ? (_t.autoBackupHour||'hr') : (_t.autoBackupHours||'hrs')}`;
        const d = Math.round(h / 24);
        if (d < 30)   return `${d} ${d === 1 ? (_t.autoBackupDay||'day') : (_t.autoBackupDays||'days')}`;
        return `${Math.round(d/30)} ${_t.autoBackupMonth||'mo'}`;
      }

      function _timeAgo(iso) {
        try {
          const diff = Date.now() - new Date(iso).getTime();
          if (diff < 60000)  return '<1m';
          if (diff < 3600000) return `${Math.floor(diff/60000)}m`;
          if (diff < 86400000) return `${Math.floor(diff/3600000)}h`;
          return `${Math.floor(diff/86400000)}d`;
        } catch { return iso; }
      }

      /* ── Render target list ── */
      function _renderList(targets) {
        const loading = document.getElementById('bkp-loading');
        const empty   = document.getElementById('bkp-empty');
        const list    = document.getElementById('bkp-list');
        if (!loading || !empty || !list) return;
        loading.style.display = 'none';
        if (!targets.length) {
          empty.style.display = '';
          list.innerHTML = '';
          return;
        }
        empty.style.display = 'none';
        list.innerHTML = targets.map(t => {
          const dotClass = !t.enabled
            ? 'off'
            : (t.lastStatus === 'success' ? 'ok' : t.lastStatus === 'failed' ? 'fail' : '');
          const modeLabel = MODE_LABELS[t.mode] || t.mode;
          const modeBadge = t.mode === 'changestream'
            ? `<span class="bkp-badge bkp-badge-cs"><i data-lucide="zap" style="width:10px;height:10px;stroke:currentColor;"></i> ${_esc(modeLabel)}</span>`
            : t.mode === 'queue'
            ? `<span class="bkp-badge bkp-badge-q"><i data-lucide="layers" style="width:10px;height:10px;stroke:currentColor;"></i> ${_esc(modeLabel)}</span>`
            : `<span class="bkp-badge bkp-badge-s"><i data-lucide="clock" style="width:10px;height:10px;stroke:currentColor;"></i> ${_esc(modeLabel)}${t.scheduleMs ? ` (${_msToLabel(t.scheduleMs)})` : ''}</span>`;
          const disabledBadge = !t.enabled
            ? `<span class="bkp-badge bkp-badge-off">${_t.autoBackupDisabled||'Disabled'}</span>` : '';
          const lastRun = t.lastRun ? _timeAgo(t.lastRun) : (_t.autoBackupNeverRun||'Never');
          const diff = t.nextAt ? (t.nextAt - Date.now()) : 0;
          const nextSched = (t.mode === 'schedule' && t.nextAt && t.enabled && diff > 0)
            ? `<span><i data-lucide="chevrons-right" style="width:10px;height:10px;stroke:currentColor;vertical-align:middle;"></i> ${_t.autoBackupIn||'in'} ${_msToLabel(diff)}</span>` : '';
          const stats = t.stats || { success: 0, failed: 0, totalDocs: 0 };
          return `<div class="bkp-row" data-id="${_esc(t.id)}">
            <div class="bkp-status-dot ${dotClass}" title="${_esc(t.lastStatus||'')}"></div>
            <div class="bkp-info">
              <div class="bkp-name">${_esc(t.name)} ${modeBadge}${disabledBadge}</div>
              <div class="bkp-uri">${_esc(t.uriMasked||'')}</div>
              <div class="bkp-meta">
                <span><i data-lucide="history" style="width:10px;height:10px;stroke:currentColor;vertical-align:middle;"></i> ${_esc(lastRun)}</span>
                <span><i data-lucide="check-circle" style="width:10px;height:10px;stroke:#86efac;vertical-align:middle;"></i> ${stats.success} <i data-lucide="x-circle" style="width:10px;height:10px;stroke:#fca5a5;vertical-align:middle;"></i> ${stats.failed}</span>
                <span><i data-lucide="file-text" style="width:10px;height:10px;stroke:currentColor;vertical-align:middle;"></i> ${Number(stats.totalDocs).toLocaleString()}</span>
                ${nextSched}
              </div>
            </div>
            <div class="bkp-actions">
              <button class="bkp-icon-btn run" data-action="run" data-id="${_esc(t.id)}" title="${_t.autoBackupRunNow||'Run Now'}"><i data-lucide="play" style="width:13px;height:13px;stroke:currentColor;"></i></button>
              <button class="bkp-icon-btn" data-action="edit" data-id="${_esc(t.id)}" title="${_t.autoBackupEdit||'Edit'}"><i data-lucide="pencil" style="width:13px;height:13px;stroke:currentColor;"></i></button>
              <button class="bkp-icon-btn del" data-action="del" data-id="${_esc(t.id)}" title="${_t.autoBackupDelete||'Delete'}"><i data-lucide="trash-2" style="width:13px;height:13px;stroke:currentColor;"></i></button>
            </div>
          </div>`;
        }).join('');

        list.querySelectorAll('[data-action]').forEach(btn => {
          btn.addEventListener('click', async () => {
            const id     = btn.dataset.id;
            const action = btn.dataset.action;
            if (action === 'run') {
              if (!confirm(_t.autoBackupRunConfirm || 'Start a full backup now?')) return;
              btn.disabled = true;
              try {
                const r = await fetch(`/settings/backup/${encodeURIComponent(id)}/run`, { method: 'POST' });
                const d = await r.json();
                if (!r.ok) throw new Error(d.error || 'Failed');
                showSysToast(
                  `${_t.autoBackupRunDone||'Done'} — ${(d.duration/1000).toFixed(1)}s, ${Number(d.totalDocs||0).toLocaleString()} docs`,
                  'success'
                );
                _loadBackups();
              } catch (e) { showSysToast(e.message, 'error'); btn.disabled = false; }
            } else if (action === 'edit') {
              const tgt = _bkpTargets.find(x => x.id === id);
              if (tgt) _openModal(tgt);
            } else if (action === 'del') {
              if (!confirm(_t.autoBackupDeleteConfirm || 'Delete this backup target?')) return;
              btn.disabled = true;
              try {
                const r = await fetch(`/settings/backup/${encodeURIComponent(id)}`, { method: 'DELETE' });
                const d = await r.json();
                if (!r.ok) throw new Error(d.error || 'Failed');
                showSysToast(_t.autoBackupDeleted||'Deleted', 'success');
                _loadBackups();
              } catch (e) { showSysToast(e.message, 'error'); btn.disabled = false; }
            }
          });
        });
      }

      /* ── Webhook list inside modal ── */
      function _renderModalWebhooks() {
        const list = document.getElementById('bkp-wh-list');
        if (!list) return;
        if (!_bkpModalWebhooks.length) {
          list.innerHTML = `<p style="font-size:.72rem;color:var(--muted,#888);">${_t.autoBackupWebhookNone||'No webhooks added'}</p>`;
          return;
        }
        list.innerHTML = _bkpModalWebhooks.map((w, i) =>
          `<div class="bkp-wh-item">
            <span class="bkp-wh-url">${_esc(w.masked)}</span>
            <button type="button" class="bkp-wh-del" data-wi="${i}" title="Remove">✕</button>
          </div>`
        ).join('');
        list.querySelectorAll('.bkp-wh-del').forEach(b => {
          b.addEventListener('click', () => {
            _bkpModalWebhooks.splice(+b.dataset.wi, 1);
            _renderModalWebhooks();
          });
        });
      }

      /* ── Modal: open ── */
      function _openModal(target) {
        _bkpEditId = target ? target.id : null;
        const titleEl = document.getElementById('bkp-modal-title');
        if (titleEl) titleEl.textContent = target
          ? (_t.autoBackupEditTitle||'Edit Backup Target')
          : (_t.autoBackupAddTitle||'Add Backup Target');

        document.getElementById('bkp-name-inp').value = target?.name || '';
        document.getElementById('bkp-uri-inp').value  = '';
        const uriInp = document.getElementById('bkp-uri-inp');
        uriInp.type        = 'password';
        uriInp.placeholder = target
          ? (_t.autoBackupUriEditHint || 'Leave blank to keep current URI')
          : 'mongodb+srv://user:pass@host/db';
        const revIcon = document.querySelector('#bkp-uri-reveal i');
        if (revIcon) { revIcon.setAttribute('data-lucide','eye'); lucide.createIcons({nodes:[revIcon]}); }

        document.getElementById('bkp-enabled-toggle').checked = target?.enabled !== false;

        // Mode
        const modeVal = target?.mode || 'changestream';
        document.querySelectorAll('input[name="bkp-mode"]').forEach(r => { r.checked = r.value === modeVal; });
        _toggleIntervalField(modeVal);

        // Schedule preset
        const sel = document.getElementById('bkp-interval-preset');
        const cusRow = document.getElementById('bkp-custom-row');
        if (target?.scheduleMs) {
          const presets = ['60000','300000','900000','1800000','3600000','21600000','43200000','86400000','604800000','2592000000'];
          if (presets.includes(String(target.scheduleMs))) {
            sel.value = String(target.scheduleMs);
            cusRow.style.display = 'none';
          } else {
            sel.value = 'custom';
            cusRow.style.display = '';
            document.getElementById('bkp-custom-min').value = Math.round(target.scheduleMs / 60000);
          }
        } else {
          sel.value = '3600000';
          cusRow.style.display = 'none';
        }

        // Webhooks
        _bkpModalWebhooks = (target?.notifyWebhooks || []).map(w => ({
          masked: w,
          isNew: false,
        }));
        _renderModalWebhooks();
        document.getElementById('bkp-wh-inp').value = '';

        // Test result
        const tRes = document.getElementById('bkp-test-result');
        if (tRes) tRes.style.display = 'none';

        // Show
        document.getElementById('bkp-modal-backdrop').classList.add('open');
        document.body.style.overflow = 'hidden';
        document.getElementById('bkp-name-inp').focus();
      }

      function _closeModal() {
        const bd = document.getElementById('bkp-modal-backdrop');
        if (bd) bd.classList.remove('open');
        document.body.style.overflow = '';
        _bkpEditId = null;
        _bkpModalWebhooks = [];
      }

      function _toggleIntervalField(mode) {
        const field = document.getElementById('bkp-interval-field');
        if (field) field.style.display = mode === 'schedule' ? '' : 'none';
      }

      function _getScheduleMs() {
        const preset = document.getElementById('bkp-interval-preset').value;
        if (preset === 'custom') {
          const mins = parseInt(document.getElementById('bkp-custom-min').value, 10);
          if (isNaN(mins) || mins < 1 || mins > 43200) return null;
          return mins * 60000;
        }
        return parseInt(preset, 10) || null;
      }

      /* ── Save target ── */
      async function _saveModal() {
        const name    = document.getElementById('bkp-name-inp').value.trim();
        const uri     = document.getElementById('bkp-uri-inp').value.trim();
        const mode    = document.querySelector('input[name="bkp-mode"]:checked')?.value || 'changestream';
        const enabled = document.getElementById('bkp-enabled-toggle').checked;

        if (!name) { showSysToast(_t.autoBackupNameRequired||'Name required', 'error'); return; }
        if (!_bkpEditId && !uri) { showSysToast(_t.autoBackupUriRequired||'URI required', 'error'); return; }
        if (uri && !/^mongodb(\+srv)?:\/\//i.test(uri)) {
          showSysToast(_t.autoBackupUriInvalid||'Invalid MongoDB URI', 'error'); return;
        }

        let scheduleMs = null;
        if (mode === 'schedule') {
          scheduleMs = _getScheduleMs();
          if (!scheduleMs) { showSysToast(_t.autoBackupIntervalInvalid||'Invalid interval', 'error'); return; }
        }

        const newWebhooks = _bkpModalWebhooks.filter(w => w.isNew).map(w => w.rawUrl);

        const saveBtn  = document.getElementById('bkp-modal-save');
        const saveTxt  = document.getElementById('bkp-modal-save-text');
        const origTxt  = saveTxt?.textContent;
        saveBtn.disabled = true;
        if (saveTxt) saveTxt.textContent = _t.saving || 'Saving…';

        try {
          let url, method, body;
          if (_bkpEditId) {
            url    = `/settings/backup/${encodeURIComponent(_bkpEditId)}`;
            method = 'PUT';
            body   = { name, mode, enabled, scheduleMs };
            if (uri) body.uri = uri;

            // Compute webhook changes
            const tgt = _bkpTargets.find(x => x.id === _bkpEditId);
            const existingCount = (tgt?.notifyWebhooks || []).length;
            const keptIndices   = _bkpModalWebhooks.filter(w => !w.isNew).map((_, i) => i); // 0-based in original array
            const removedIdxs   = [];
            for (let i = 0; i < existingCount; i++) {
              if (!keptIndices.includes(i)) removedIdxs.push(i);
            }
            if (removedIdxs.length) body.webhooksRemove  = removedIdxs;
            if (newWebhooks.length) body.webhooksAppend  = newWebhooks;
          } else {
            url    = '/settings/backup';
            method = 'POST';
            body   = { name, uri, mode, enabled, scheduleMs, notifyWebhooks: newWebhooks };
          }

          const r = await fetch(url, {
            method,
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
          });
          const d = await r.json();
          if (!r.ok) throw new Error(d.error || 'Failed');
          showSysToast(_t.autoBackupSaved||'Saved', 'success');
          _closeModal();
          _loadBackups();
        } catch (e) { showSysToast(e.message, 'error'); }

        saveBtn.disabled = false;
        if (saveTxt) saveTxt.textContent = origTxt;
      }

      /* ── Load from server ── */
      async function _loadBackups() {
        const loading = document.getElementById('bkp-loading');
        const empty   = document.getElementById('bkp-empty');
        if (loading) loading.style.display = '';
        if (empty)   empty.style.display   = 'none';
        try {
          const r = await fetch('/settings/backup');
          const d = await r.json();
          if (!r.ok) throw new Error(d.error || 'Failed');
          _bkpTargets = d.targets || [];
          _renderList(_bkpTargets);
        } catch (e) {
          if (loading) loading.style.display = 'none';
          if (empty) { empty.textContent = e.message; empty.style.display = ''; }
        }
      }

      /* ── Wire events ── */
      (function _wireBackupEvents() {
        const addBtn = document.getElementById('bkp-add-btn');
        if (addBtn) addBtn.addEventListener('click', () => _openModal(null));

        const cancelBtn = document.getElementById('bkp-modal-cancel');
        if (cancelBtn) cancelBtn.addEventListener('click', _closeModal);

        const backdrop = document.getElementById('bkp-modal-backdrop');
        if (backdrop) backdrop.addEventListener('click', e => { if (e.target === e.currentTarget) _closeModal(); });

        const saveBtn = document.getElementById('bkp-modal-save');
        if (saveBtn) saveBtn.addEventListener('click', _saveModal);

        document.addEventListener('keydown', e => {
          if (e.key === 'Escape') {
            const bd = document.getElementById('bkp-modal-backdrop');
            if (bd && bd.classList.contains('open')) _closeModal();
          }
        });

        // URI reveal
        const revBtn = document.getElementById('bkp-uri-reveal');
        if (revBtn) revBtn.addEventListener('click', () => {
          const inp = document.getElementById('bkp-uri-inp');
          inp.type  = inp.type === 'password' ? 'text' : 'password';
          const ic  = revBtn.querySelector('i');
          if (ic) {
            ic.setAttribute('data-lucide', inp.type === 'password' ? 'eye' : 'eye-off');
            lucide.createIcons({ nodes: [ic] });
          }
        });

        // Mode radio
        document.querySelectorAll('input[name="bkp-mode"]').forEach(r => {
          r.addEventListener('change', () => _toggleIntervalField(r.value));
        });

        // Preset → custom
        const presetSel = document.getElementById('bkp-interval-preset');
        if (presetSel) presetSel.addEventListener('change', function() {
          const cr = document.getElementById('bkp-custom-row');
          if (cr) cr.style.display = this.value === 'custom' ? '' : 'none';
        });

        // Add webhook
        const whAddBtn = document.getElementById('bkp-wh-add-btn');
        const whInp    = document.getElementById('bkp-wh-inp');
        function _addWebhook() {
          const val = (whInp?.value||'').trim();
          if (!/^https:\/\/discord\.com\/api\/webhooks\/\d+\/.+/.test(val)) {
            showSysToast(_t.autoBackupWebhookInvalid||'Invalid Discord webhook URL', 'error'); return;
          }
          _bkpModalWebhooks.push({
            masked: val.replace(/(\/api\/webhooks\/\d+\/)(.+)$/, '$1***'),
            isNew:  true,
            rawUrl: val,
          });
          if (whInp) whInp.value = '';
          _renderModalWebhooks();
        }
        if (whAddBtn) whAddBtn.addEventListener('click', _addWebhook);
        if (whInp) whInp.addEventListener('keydown', e => { if (e.key === 'Enter') { e.preventDefault(); _addWebhook(); } });

        // Test connection
        const testBtn = document.getElementById('bkp-test-btn');
        if (testBtn) testBtn.addEventListener('click', async () => {
          const uri    = (document.getElementById('bkp-uri-inp')?.value || '').trim();
          const testId = _bkpEditId;
          if (!uri && !testId) { showSysToast(_t.autoBackupUriRequired||'Enter a URI first', 'error'); return; }
          if (uri && !/^mongodb(\+srv)?:\/\//i.test(uri)) {
            showSysToast(_t.autoBackupUriInvalid||'Invalid URI', 'error'); return;
          }
          const res = document.getElementById('bkp-test-result');
          testBtn.disabled = true;
          const origHtml = testBtn.innerHTML;
          testBtn.textContent = _t.autoBackupTesting || 'Testing…';
          if (res) res.style.display = 'none';
          try {
            const body = uri ? { uri } : { id: testId };
            const r = await fetch('/settings/backup/test', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(body),
            });
            const d = await r.json();
            if (!r.ok) throw new Error(d.error || 'Failed');
            if (res) {
              res.className     = 'bkp-test-result ok';
              res.textContent   = _tf(_t.autoBackupTestOk || '✅ Connected — {n} collections', { n: d.collections });
              res.style.display = '';
            }
          } catch (e) {
            if (res) {
              res.className     = 'bkp-test-result fail';
              res.textContent   = _tf(_t.autoBackupTestFail || '❌ {msg}', { msg: e.message });
              res.style.display = '';
            }
          }
          testBtn.disabled = false;
          testBtn.innerHTML = origHtml;
        });
      })();

      /* ── Initial load ── */
      _loadBackups();
    })(); // end Auto Backup IIFE

    /* ── Profile sidebar ── */
    const bannerSolid = document.querySelector('.prof-banner-solid');
    if (bannerSolid && bannerSolid.dataset.bg) bannerSolid.style.background = bannerSolid.dataset.bg;

    const profSidebar  = document.getElementById('prof-sidebar');
    const profBackdrop = document.getElementById('prof-backdrop');
    const openBtn      = document.getElementById('open-profile');
    const closeBtn     = document.getElementById('close-profile');
    const copyId       = document.getElementById('prof-copy-id');

    function openProfile()  { profSidebar.classList.add('open'); profBackdrop.classList.add('open'); profSidebar.setAttribute('aria-hidden','false'); document.body.style.overflow = 'hidden'; }
    function closeProfile() { profSidebar.classList.remove('open'); profBackdrop.classList.remove('open'); profSidebar.setAttribute('aria-hidden','true'); document.body.style.overflow = ''; }

    openBtn.addEventListener('click', openProfile);
    if (closeBtn) closeBtn.addEventListener('click', closeProfile);
    profBackdrop.addEventListener('click', closeProfile);
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeProfile(); });

    if (copyId) {
      copyId.addEventListener('click', () => {
        navigator.clipboard.writeText(copyId.textContent.trim()).then(() => {
          const orig = copyId.textContent;
          copyId.textContent = '<%= t.systemSettings.copied %>';
          copyId.style.color = 'var(--cyan-l)';
          setTimeout(() => { copyId.textContent = orig; copyId.style.color = ''; }, 1500);
        });
      });
    }

    /* ── Lang select ── */
    /* Custom dropdown wiring */
    (function () {
      var wrap=document.getElementById('lcs-wrap'),btn=document.getElementById('lcs-btn');
      var flag=document.getElementById('lcs-flag'),lbl=document.getElementById('lcs-label');
      var sel=document.getElementById('lang-select');
      if(!wrap||!btn||!sel)return;
      function openM(){wrap.classList.add('open');btn.setAttribute('aria-expanded','true');}
      function closeM(){wrap.classList.remove('open');btn.setAttribute('aria-expanded','false');}
      btn.addEventListener('click',function(e){e.stopPropagation();wrap.classList.contains('open')?closeM():openM();});
      document.addEventListener('click',closeM);
      document.addEventListener('keydown',function(e){if(e.key==='Escape')closeM();});
      wrap.querySelectorAll('.lcs-item').forEach(function(item){
        item.addEventListener('click',function(e){
          e.stopPropagation();var val=item.getAttribute('data-value');
          if(flag){var fi=flag.querySelector('.fi');if(fi){fi.className='fi fi-'+item.getAttribute('data-flag');}}
          if(lbl)lbl.textContent=item.getAttribute('data-label')||val;
          wrap.querySelectorAll('.lcs-item').forEach(function(i){i.classList.remove('lcs-active');});
          item.classList.add('lcs-active');closeM();
          sel.value=val;sel.dispatchEvent(new Event('change',{bubbles:true}));
        });
        item.addEventListener('keydown',function(e){if(e.key==='Enter'||e.key===' '){e.preventDefault();item.click();}});
      });
    })();
    document.getElementById('lang-select').addEventListener('change', function() {
      const u = new URL(window.location.href);
      u.searchParams.set('lang', this.value);
      window.location.href = u.toString();
    });
  </script>

  <!-- Page transition overlay -->
  <div id="ov" style="position:fixed;inset:0;z-index:9999;background:#040010;animation:pIn .45s cubic-bezier(.4,0,.2,1) forwards;pointer-events:none;"></div>
  <style>
    @keyframes pIn  { from { opacity:1 } to { opacity:0 } }
    @keyframes pOut { from { opacity:0 } to { opacity:1 } }
    #ov.leave { animation:pOut .35s cubic-bezier(.4,0,.2,1) forwards; pointer-events:all; }
  </style>
  <script>
    (function () {
      function fadeOut(href) { var ov=document.getElementById('ov'); ov.classList.add('leave'); setTimeout(function(){ window.location.href=href; },360); }
      document.querySelectorAll('a.nav-link, a#logout-link').forEach(function(a){
        a.addEventListener('click',function(e){ if(this.target==='_blank') return; e.preventDefault(); fadeOut(this.href); });
      });
    })();
  </script>

    /* ── Owners management ── */
    const _ownersCache = {};

    function _renderOwnersChips(owners) {
      const wrap = document.getElementById('owners-chips');
      wrap.innerHTML = '';
      (owners || []).forEach(oid => {
        const info = _ownersCache[oid];
        const av = info ? info.avatar : 'https://cdn.discordapp.com/embed/avatars/0.png';
        const name = info ? info.displayName : oid;
        const chip = document.createElement('div');
        chip.className = 'ships-chip';
        chip.dataset.id = oid;
        chip.innerHTML = `<img class="ships-chip-av" src="${av}" alt="" onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">`
          + `<div class="ships-chip-info"><span class="ships-chip-name">${name}</span><span class="ships-chip-id">${oid}</span></div>`
          + `<button class="ships-chip-remove" data-uid="${oid}" title="Remove"><i data-lucide="x" style="width:10px;height:10px;stroke:currentColor;"></i></button>`;
        wrap.appendChild(chip);
      });
      lucide.createIcons();
      wrap.querySelectorAll('.ships-chip-remove').forEach(btn => {
        btn.addEventListener('click', () => removeOwner(btn.dataset.uid));
      });
    }

    async function _hydrateOwners(ids) {
      await Promise.all((ids || []).map(async oid => {
        if (_ownersCache[oid]) return;
        try {
          const r = await fetch(`/api/user/${oid}`);
          if (r.ok) _ownersCache[oid] = await r.json();
        } catch (_) {}
      }));
      _renderOwnersChips(ids);
    }

    const _initialOwners = JSON.parse(document.getElementById('owners-server-data').textContent || '[]');
    _hydrateOwners(_initialOwners);

    async function removeOwner(uid) {
      const label = _ownersCache[uid]?.displayName || uid;
      if (!confirm(_tf(_sys_t.removeOwnerConfirm, {label}))) return;
      try {
        const r = await fetch(`/settings/owners/${uid}`, { method: 'DELETE' });
        const d = await r.json();
        if (!r.ok) { showSysToast(d.error || 'Failed', 'error'); return; }
        await _hydrateOwners(d.owners);
        showSysToast(_sys_t.removedToast, 'success');
      } catch (e) { showSysToast(e.message, 'error'); }
    }


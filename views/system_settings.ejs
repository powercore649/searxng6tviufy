          const fields   = document.getElementById('geo-fields');
          const ipField  = `<div class="geo-field full"><div class="geo-field-label">${_sys_t.geoIpAddress}</div><div class="geo-field-value mono">${entry.ip}</div></div>`;
          if (!geo) {
            fields.innerHTML = ipField + `<div class="geo-field full"><div class="geo-field-label">${_sys_t.geoLocation}</div><div class="geo-field-value" style="color:var(--muted);">${_sys_t.geoNotAvailable}</div></div>`;
          } else {
            fields.innerHTML = ipField +
              `<div class="geo-field"><div class="geo-field-label">${_sys_t.geoCountry}</div><div class="geo-field-value">${geo.country || '—'}</div></div>` +
              `<div class="geo-field"><div class="geo-field-label">${_sys_t.geoRegion}</div><div class="geo-field-value">${geo.region ? geo.region + (geo.city ? ` / ${geo.city}` : '') : '—'}</div></div>` +
              `<div class="geo-field"><div class="geo-field-label">${_sys_t.geoTimezone}</div><div class="geo-field-value">${geo.timezone || '—'}</div></div>` +
              `<div class="geo-field"><div class="geo-field-label">${_sys_t.geoIsp}</div><div class="geo-field-value">${geo.org || '—'}</div></div>` +
              (geo.ll ? `<div class="geo-field full"><div class="geo-field-label">${_sys_t.geoCoordinates}</div><div class="geo-field-value mono">${geo.ll[0]}, ${geo.ll[1]}</div></div>` : '');
          }
          lucide.createIcons();

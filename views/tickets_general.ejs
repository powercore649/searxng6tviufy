          </svg>
        </div>
        <h3><%= t.tickets.autoCloseSectionTitle %></h3>
      </div>
      <div class="card-body">

        <!-- Close on user leave -->
        <div class="form-row">
          <div class="form-row-left">
            <label class="form-label"><%= t.tickets.acLeaveLabel %></label>
            <p class="form-help"><%= t.tickets.acLeaveHelp %></p>
          </div>
          <%- include('partials/toggle_switch', { id: 'ticket-ac-leave', checked: ticketSettings.AUTO_CLOSE_ON_LEAVE }) %>
        </div>


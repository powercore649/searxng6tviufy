          </div>
          <%- include('partials/toggle_switch', { id: 'ticket-hide-close', checked: ticketSettings.HIDE_CLOSE_BTN }) %>
        </div>

        <!-- Hide Close With Reason Button -->
        <div class="form-row">
          <div class="form-row-left">
            <label class="form-label"><%= t.tickets.hideCloseReasonLabel %></label>
            <p class="form-help"><%= t.tickets.hideCloseReasonHelp %></p>
          </div>
          <%- include('partials/toggle_switch', { id: 'ticket-hide-close-reason', checked: ticketSettings.HIDE_CLOSE_REASON_BTN }) %>

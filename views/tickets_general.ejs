          <div class="ac-row-left">
            <div class="ac-row-toggle-line">
              <%- include('partials/toggle_switch', { id: 'ticket-ac-noresponse-enabled', checked: ticketSettings.AC_NO_RESPONSE_ENABLED }) %>

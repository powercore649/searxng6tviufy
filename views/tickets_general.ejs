          </div>
          <%- include('partials/toggle_switch', { id: 'ticket-add-msg-sender', checked: ticketSettings.ADD_MSG_SENDER }) %>
        </div>

        <!-- Ticket Channel Permissions sub-group -->
        <p class="form-row-group-label"><%= t.tickets.ticketPermsLabel %></p>

        <!-- Attach Files -->
        <div class="form-row">
          <div class="form-row-left">
            <label class="form-label"><%= t.tickets.permAttachLabel %></label>
            <p class="form-help"><%= t.tickets.permAttachHelp %></p>
          </div>
          <%- include('partials/toggle_switch', { id: 'ticket-perm-attach', checked: ticketSettings.PERM_ATTACH_FILES !== false }) %>
        </div>

        <!-- Embed Links -->
        <div class="form-row">
          <div class="form-row-left">
            <label class="form-label"><%= t.tickets.permEmbedLabel %></label>
            <p class="form-help"><%= t.tickets.permEmbedHelp %></p>
          </div>
          <%- include('partials/toggle_switch', { id: 'ticket-perm-embed', checked: ticketSettings.PERM_EMBED_LINKS !== false }) %>
        </div>

        <!-- Add Reactions -->
        <div class="form-row">
          <div class="form-row-left">
            <label class="form-label"><%= t.tickets.permReactLabel %></label>
            <p class="form-help"><%= t.tickets.permReactHelp %></p>
          </div>
          <%- include('partials/toggle_switch', { id: 'ticket-perm-reactions', checked: ticketSettings.PERM_ADD_REACTIONS !== false }) %>
        </div>


            <div class="esc-chips" id="esc-chips-box"></div>
          </div>
          <input type="hidden" id="ticket-escalate-cats-json" value="<%= JSON.stringify(ticketSettings.ESCALATE_CATEGORIES || []) %>" />
<% if (!guildCategories.length) { %>
            <p class="form-help" style="margin:0"><%= t.ticketsGeneral.noCategoriesFoundInThisServer %></p>
<% } %>
        </div>

        <!-- Escalation Roles -->
        <div class="form-row form-row-col" id="escalate-roles-row" <%- ticketSettings.ESCALATE_ENABLED ? '' : 'style="display:none"' %>>
          <div class="form-row-left" style="width:100%">
            <label class="form-label">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:-2px;margin-right:5px;"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              Allowed Roles
            </label>
            <p class="form-help">Only members with these roles can use the Escalate button. Leave empty to allow all users.</p>
          </div>
          <div class="esc-select-wrap">
            <select id="ticket-escalate-roles-sel" class="form-select">
              <option value="">-- Select a role --</option>
<% guildRoles.forEach(function(r) { %>
              <option value="<%= r.id %>"><%= r.name %></option>
<% }); %>
            </select>
            <div class="esc-chips" id="esc-roles-chips-box"></div>
          </div>
          <input type="hidden" id="ticket-escalate-roles-json" value="<%= JSON.stringify(ticketSettings.ESCALATE_ROLES || []) %>" />
        </div>

      </div>
    </div>
  </main>

  <input type="hidden" id="ticket-enable-val" value="<%= ticketSettings.ENABLE ? '1' : '0' %>" />

  <!-- Save Bar -->
  <div class="save-bar" id="save-bar">
    <span class="save-bar-text" id="save-bar-text"><%= t.ticketsGeneral.youHaveUnsavedChanges %></span>
    <div class="save-bar-actions">
      <button class="btn btn-ghost" id="reset-btn"><%= t.ticketsGeneral.reset %></button>
      <button class="btn btn-primary" id="save-btn"><%= t.tickets.saveBtn %></button>
    </div>
  </div>

  <%- include('partials/bg_stars') %>
  <script>

    // Nav links
    document.querySelectorAll('.nav-link').forEach(a => {
      a.addEventListener('click', e => { e.preventDefault(); window.location.href = a.href; });
    });

    // Mobile menu
    const menuBtn  = document.getElementById('menu-toggle');
    const sidebar  = document.getElementById('mgmt-sidebar');
    const overlay  = document.getElementById('nav-overlay');
    const navSidebar = document.querySelector('.nav-sidebar');
    function openSidebar()  { sidebar.classList.add('open');  overlay.classList.add('open');  document.body.style.overflow = 'hidden'; }
    function closeSidebar() { sidebar.classList.remove('open'); overlay.classList.remove('open'); document.body.style.overflow = ''; }
    function openNav()  { if (navSidebar) { navSidebar.classList.add('open');  overlay.classList.add('open');  document.body.style.overflow = 'hidden'; } }
    function closeNav() { if (navSidebar) { navSidebar.classList.remove('open'); overlay.classList.remove('open'); document.body.style.overflow = ''; } }
    if (menuBtn) menuBtn.addEventListener('click', () => sidebar.classList.contains('open') ? closeSidebar() : openSidebar());
    if (overlay) overlay.addEventListener('click', () => { closeSidebar(); closeNav(); closeFooterDrop(); });
    // Sort button → toggle server switcher
    const sortBtn = document.querySelector('.mgmt-sort-btn');
    if (sortBtn) sortBtn.addEventListener('click', () => {
      if (navSidebar && navSidebar.classList.contains('open')) { closeNav(); }
      else { closeSidebar(); openNav(); }
    });
    // Footer dots dropdown
    const footerDotsBtn = document.getElementById('footer-dots-btn');
    const footerDrop    = document.getElementById('footer-drop');
    function openFooterDrop()  { if (footerDrop) footerDrop.classList.add('open'); }
    function closeFooterDrop() { if (footerDrop) footerDrop.classList.remove('open'); }
    if (footerDotsBtn) footerDotsBtn.addEventListener('click', e => {
      e.stopPropagation();
      footerDrop.classList.toggle('open');
    });
    document.addEventListener('click', e => {
      if (footerDrop && !footerDrop.contains(e.target) && e.target !== footerDotsBtn) closeFooterDrop();
    });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') { closeSidebar(); closeNav(); closeFooterDrop(); } });

    // Section collapse
    document.querySelectorAll('.mgmt-section-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        btn.classList.toggle('open');
        btn.nextElementSibling.classList.toggle('open');
      });
    });

    // Naming scheme variable chip insertion
    document.querySelectorAll('#naming-chips .var-chip').forEach(chip => {
      chip.addEventListener('click', () => {
        const input = document.getElementById('ticket-naming');
        const val = chip.dataset.val;
        const start = input.selectionStart ?? input.value.length;
        const end   = input.selectionEnd   ?? input.value.length;
        input.value = input.value.slice(0, start) + val + input.value.slice(end);
        input.focus();
        input.setSelectionRange(start + val.length, start + val.length);
        checkDirty();
      });
    });

    // Language select
    document.getElementById('lang-select')?.addEventListener('change', function() {
      const url = new URL(window.location.href);
      url.searchParams.set('lang', this.value);
      window.location.href = url.toString();
    });

    // Save bar logic
    const saveBar = document.getElementById('save-bar');
    const saveBtn = document.getElementById('save-btn');
    const resetBtn = document.getElementById('reset-btn');

    // Original values snapshot
    const originals = {
      limit:        document.getElementById('ticket-limit').value,
      lang:         document.getElementById('ticket-lang').value,
      allowClose:   document.getElementById('ticket-allow-close').checked,
      closeConfirm: document.getElementById('ticket-close-confirm').checked,
      feedback:     document.getElementById('ticket-feedback').checked,
      anon:         document.getElementById('ticket-anon').checked,
      thread:       document.getElementById('ticket-thread').checked,
      disableOpen:       document.getElementById('ticket-disable-open').checked,
      notifChannel:      document.getElementById('ticket-notif-channel').value,
      transcriptChannel: document.getElementById('ticket-transcript-channel').value,
      channelCategory:   document.getElementById('ticket-channel-category').value,
      overflowCategory:  document.getElementById('ticket-overflow-category').value,
      namingScheme:      document.getElementById('ticket-naming').value,
      welcomeMsg:              document.getElementById('ticket-welcome').value,
      claimView:               document.getElementById('ticket-claim-view').checked,
      claimType:               document.getElementById('ticket-claim-type').checked,
      acLeave:                 document.getElementById('ticket-ac-leave').checked,
      acNoResponseEnabled:     document.getElementById('ticket-ac-noresponse-enabled').checked,
      acNoResponseDays:        document.getElementById('ticket-ac-noresponse-days').value,
      acNoResponseHours:       document.getElementById('ticket-ac-noresponse-hours').value,
      acNoResponseMins:        document.getElementById('ticket-ac-noresponse-mins').value,
      acLastMsgEnabled:        document.getElementById('ticket-ac-lastmsg-enabled').checked,
      acLastMsgDays:           document.getElementById('ticket-ac-lastmsg-days').value,
      acLastMsgHours:          document.getElementById('ticket-ac-lastmsg-hours').value,
      acLastMsgMins:           document.getElementById('ticket-ac-lastmsg-mins').value,
      openPerm:      document.getElementById('ticket-open-perm').value,
      openPermRole:  document.getElementById('ticket-open-perm-role').value,
      addMsgSender:  document.getElementById('ticket-add-msg-sender').checked,
      permAttach:    document.getElementById('ticket-perm-attach').checked,
      permEmbed:     document.getElementById('ticket-perm-embed').checked,
      permReact:     document.getElementById('ticket-perm-reactions').checked,
      colorSuccess:    document.getElementById('ticket-color-success').value,
      colorFailure:    document.getElementById('ticket-color-failure').value,
      hideClose:       document.getElementById('ticket-hide-close').checked,
      hideCloseReason: document.getElementById('ticket-hide-close-reason').checked,
      hideClaim:       document.getElementById('ticket-hide-claim').checked,
      rulesEnabled:    document.getElementById('ticket-rules-enabled').checked,
      rulesText:       document.getElementById('ticket-rules-text').value,
      rulesLabel:      document.getElementById('ticket-rules-label').value,
      rulesEmoji:      document.getElementById('ticket-rules-emoji').value,
      rulesBtnStyle:   document.getElementById('ticket-rules-style-val').value,
      escalateEnabled: document.getElementById('ticket-escalate-enabled').checked,
      escalateCats:    JSON.stringify(_getEscalateCats()),
      escalateRoles:   document.getElementById('ticket-escalate-roles-json')?.value || '[]',
    };

    function isDirty() {
      return (
        document.getElementById('ticket-limit').value           !== originals.limit        ||
        document.getElementById('ticket-lang').value            !== originals.lang         ||
        document.getElementById('ticket-allow-close').checked   !== originals.allowClose   ||
        document.getElementById('ticket-close-confirm').checked !== originals.closeConfirm ||
        document.getElementById('ticket-feedback').checked      !== originals.feedback      ||
        document.getElementById('ticket-anon').checked          !== originals.anon          ||
        document.getElementById('ticket-thread').checked        !== originals.thread        ||
        document.getElementById('ticket-disable-open').checked  !== originals.disableOpen       ||
        document.getElementById('ticket-notif-channel').value      !== originals.notifChannel      ||
        document.getElementById('ticket-transcript-channel').value !== originals.transcriptChannel ||
        document.getElementById('ticket-channel-category').value   !== originals.channelCategory   ||
        document.getElementById('ticket-overflow-category').value  !== originals.overflowCategory  ||
        document.getElementById('ticket-naming').value             !== originals.namingScheme      ||
        document.getElementById('ticket-welcome').value            !== originals.welcomeMsg              ||
        document.getElementById('ticket-claim-view').checked        !== originals.claimView              ||
        document.getElementById('ticket-claim-type').checked        !== originals.claimType              ||
        document.getElementById('ticket-ac-leave').checked          !== originals.acLeave                ||
        document.getElementById('ticket-ac-noresponse-enabled').checked !== originals.acNoResponseEnabled ||
        document.getElementById('ticket-ac-noresponse-days').value   !== originals.acNoResponseDays      ||
        document.getElementById('ticket-ac-noresponse-hours').value  !== originals.acNoResponseHours     ||
        document.getElementById('ticket-ac-noresponse-mins').value   !== originals.acNoResponseMins      ||
        document.getElementById('ticket-ac-lastmsg-enabled').checked !== originals.acLastMsgEnabled      ||
        document.getElementById('ticket-ac-lastmsg-days').value      !== originals.acLastMsgDays         ||
        document.getElementById('ticket-ac-lastmsg-hours').value     !== originals.acLastMsgHours        ||
        document.getElementById('ticket-ac-lastmsg-mins').value      !== originals.acLastMsgMins      ||
        document.getElementById('ticket-open-perm').value             !== originals.openPerm           ||
        document.getElementById('ticket-open-perm-role').value        !== originals.openPermRole       ||
        document.getElementById('ticket-add-msg-sender').checked      !== originals.addMsgSender       ||
        document.getElementById('ticket-perm-attach').checked         !== originals.permAttach         ||
        document.getElementById('ticket-perm-embed').checked          !== originals.permEmbed          ||
        document.getElementById('ticket-perm-reactions').checked      !== originals.permReact          ||
        document.getElementById('ticket-color-success').value          !== originals.colorSuccess       ||
        document.getElementById('ticket-color-failure').value          !== originals.colorFailure       ||
        document.getElementById('ticket-hide-close').checked           !== originals.hideClose          ||
        document.getElementById('ticket-hide-close-reason').checked    !== originals.hideCloseReason    ||
        document.getElementById('ticket-hide-claim').checked           !== originals.hideClaim          ||
        document.getElementById('ticket-rules-enabled').checked          !== originals.rulesEnabled        ||
        document.getElementById('ticket-rules-text').value               !== originals.rulesText           ||
        document.getElementById('ticket-rules-label').value              !== originals.rulesLabel          ||
        document.getElementById('ticket-rules-emoji').value              !== originals.rulesEmoji          ||
        document.getElementById('ticket-rules-style-val').value          !== originals.rulesBtnStyle       ||
        document.getElementById('ticket-escalate-enabled').checked       !== originals.escalateEnabled     ||
        JSON.stringify(_getEscalateCats())   !== originals.escalateCats                                    ||
        JSON.stringify(_getEscalateRoles())  !== originals.escalateRoles
      );
    }

    function checkDirty() {
      if (isDirty()) {
        saveBar.classList.add('visible');
      } else {
        saveBar.classList.remove('visible');
      }
    }

    const watchIds = ['ticket-limit','ticket-lang','ticket-allow-close','ticket-close-confirm','ticket-feedback','ticket-anon','ticket-thread','ticket-disable-open','ticket-notif-channel','ticket-transcript-channel','ticket-channel-category','ticket-overflow-category','ticket-naming','ticket-welcome','ticket-claim-view','ticket-claim-type','ticket-ac-leave','ticket-ac-noresponse-enabled','ticket-ac-noresponse-days','ticket-ac-noresponse-hours','ticket-ac-noresponse-mins','ticket-ac-lastmsg-enabled','ticket-ac-lastmsg-days','ticket-ac-lastmsg-hours','ticket-ac-lastmsg-mins','ticket-open-perm','ticket-open-perm-role','ticket-add-msg-sender','ticket-perm-attach','ticket-perm-embed','ticket-perm-reactions','ticket-color-success','ticket-color-failure','ticket-hide-close','ticket-hide-close-reason','ticket-hide-claim','ticket-rules-enabled','ticket-rules-text','ticket-rules-label','ticket-rules-emoji','ticket-escalate-enabled'];

    // Show/hide rules text row + appearance row
    document.getElementById('ticket-rules-enabled').addEventListener('change', function () {
      const show = this.checked;
      document.getElementById('rules-text-row').style.display     = show ? '' : 'none';
      document.getElementById('rules-btn-style-row').style.display = show ? '' : 'none';
    });
    // ── Escalate cats helpers ───────────────────────────────────────
    function _getEscalateCats() {
      return [...document.querySelectorAll('#esc-chips-box .esc-chip')].map(c => c.dataset.val).sort();
    }
    function _addEscChip(id, label) {
      const box = document.getElementById('esc-chips-box');
      if (box.querySelector(`.esc-chip[data-val="${id}"]`)) return;
      const chip = document.createElement('span');
      chip.className = 'esc-chip'; chip.dataset.val = id;
      chip.innerHTML = `${label}<button type="button" class="esc-chip-rm" title="Remove">&times;</button>`;
      chip.querySelector('.esc-chip-rm').addEventListener('click', () => {
        chip.remove();
        const opt = document.querySelector(`#ticket-escalate-cats-sel option[value="${id}"]`);
        if (opt) opt.disabled = false;
        checkDirty();
      });
      box.appendChild(chip);
      const opt = document.querySelector(`#ticket-escalate-cats-sel option[value="${id}"]`);
      if (opt) opt.disabled = true;
    }
    // Init existing cats as chips
    (function() {
      const saved = JSON.parse(document.getElementById('ticket-escalate-cats-json')?.value || '[]');
      const sel = document.getElementById('ticket-escalate-cats-sel');
      saved.forEach(id => {
        const opt = sel ? sel.querySelector(`option[value="${id}"]`) : null;
        if (opt) _addEscChip(id, opt.textContent);
      });
    })();
    // Select change → add chip
    document.getElementById('ticket-escalate-cats-sel')?.addEventListener('change', function() {
      const id = this.value;
      if (!id) return;
      const label = this.options[this.selectedIndex].textContent;
      _addEscChip(id, label);
      this.value = '';
      checkDirty();
    });
    // ── Escalate roles helpers ──────────────────────────────────────
    function _getEscalateRoles() {
      return [...document.querySelectorAll('#esc-roles-chips-box .esc-chip')].map(c => c.dataset.val).sort();
    }
    function _addEscRoleChip(id, label) {
      const box = document.getElementById('esc-roles-chips-box');
      if (box.querySelector(`.esc-chip[data-val="${id}"]`)) return;
      const chip = document.createElement('span');
      chip.className = 'esc-chip'; chip.dataset.val = id;
      chip.innerHTML = `${label}<button type="button" class="esc-chip-rm" title="Remove">&times;</button>`;
      chip.querySelector('.esc-chip-rm').addEventListener('click', () => {
        chip.remove();
        const opt = document.querySelector(`#ticket-escalate-roles-sel option[value="${id}"]`);
        if (opt) opt.disabled = false;
        checkDirty();
      });
      box.appendChild(chip);
      const opt = document.querySelector(`#ticket-escalate-roles-sel option[value="${id}"]`);
      if (opt) opt.disabled = true;
    }
    // Init existing roles as chips
    (function() {
      const saved = JSON.parse(document.getElementById('ticket-escalate-roles-json')?.value || '[]');
      const sel = document.getElementById('ticket-escalate-roles-sel');
      saved.forEach(id => {
        const opt = sel ? sel.querySelector(`option[value="${id}"]`) : null;
        if (opt) _addEscRoleChip(id, opt.textContent.trim());
      });
    })();
    document.getElementById('ticket-escalate-roles-sel')?.addEventListener('change', function() {
      const id = this.value;
      if (!id) return;
      const label = this.options[this.selectedIndex].textContent.trim();
      _addEscRoleChip(id, label);
      this.value = '';
      checkDirty();
    });
    watchIds.forEach(id => {
      const el = document.getElementById(id);
      if (!el) return;
      el.addEventListener('change', checkDirty);
      el.addEventListener('input', checkDirty);
    });

    // Rules btn style pills
    document.querySelectorAll('.rules-style-opt').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.rules-style-opt').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById('ticket-rules-style-val').value = btn.dataset.val;
        checkDirty();
      });
    });
    // Server emoji picker for rules button
    const _rEmojiBtn = document.getElementById('rules-emoji-picker-btn');
    const _rEmojiPop = document.getElementById('rules-emoji-picker-pop');
    if (_rEmojiBtn && _rEmojiPop) {
      document.body.appendChild(_rEmojiPop); // escape overflow:hidden ancestors
      _rEmojiBtn.addEventListener('click', e => {
        e.stopPropagation();
        if (_rEmojiPop.style.display !== 'none') { _rEmojiPop.style.display = 'none'; return; }
        const r = _rEmojiBtn.getBoundingClientRect();
        const popH = 220;
        const spaceBelow = window.innerHeight - r.bottom;
        _rEmojiPop.style.top  = (spaceBelow >= popH || spaceBelow >= r.top ? r.bottom + 4 : r.top - popH - 4) + 'px';
        _rEmojiPop.style.left = Math.min(r.left, window.innerWidth - 270) + 'px';
        _rEmojiPop.style.display = 'grid';
      });
      _rEmojiPop.querySelectorAll('.rules-emoji-item').forEach(item => {
        item.addEventListener('click', () => {
          document.getElementById('ticket-rules-emoji').value = item.dataset.val;
          _rEmojiPop.style.display = 'none';
          checkDirty();
        });
      });
      document.addEventListener('click', e => {
        if (!_rEmojiBtn.contains(e.target) && !_rEmojiPop.contains(e.target)) {
          _rEmojiPop.style.display = 'none';
        }
      });
    }
    // Show/hide escalate categories + roles rows
    document.getElementById('ticket-escalate-enabled').addEventListener('change', function () {
      document.getElementById('escalate-cats-row').style.display  = this.checked ? '' : 'none';
      document.getElementById('escalate-roles-row').style.display = this.checked ? '' : 'none';
    });
    // Show/hide required-role row when permission level changes
    document.getElementById('ticket-open-perm').addEventListener('change', function () {
      document.getElementById('perm-role-row').classList.toggle('perm-role-row-hidden', this.value !== 'role_required');
    });

    // Live color swatch update
    ['success', 'failure'].forEach(key => {
      const inp    = document.getElementById(`ticket-color-${key}`);
      const swatch = document.getElementById(`color-${key}-swatch`);
      const hex    = document.getElementById(`color-${key}-hex`);
      swatch.style.background = inp.value;  // init from input value
      inp.addEventListener('input', () => {
        swatch.style.background = inp.value;
        hex.textContent = inp.value;
      });
    });

    resetBtn.addEventListener('click', () => {
      document.getElementById('ticket-limit').value             = originals.limit;
      document.getElementById('ticket-lang').value              = originals.lang;
      document.getElementById('ticket-allow-close').checked     = originals.allowClose;
      document.getElementById('ticket-close-confirm').checked   = originals.closeConfirm;
      document.getElementById('ticket-feedback').checked        = originals.feedback;
      document.getElementById('ticket-anon').checked            = originals.anon;
      document.getElementById('ticket-thread').checked          = originals.thread;
      document.getElementById('ticket-disable-open').checked    = originals.disableOpen;
      document.getElementById('ticket-notif-channel').value      = originals.notifChannel;
      document.getElementById('ticket-transcript-channel').value = originals.transcriptChannel;
      document.getElementById('ticket-channel-category').value   = originals.channelCategory;
      document.getElementById('ticket-overflow-category').value  = originals.overflowCategory;
      document.getElementById('ticket-naming').value             = originals.namingScheme;
      document.getElementById('ticket-welcome').value            = originals.welcomeMsg;
      document.getElementById('ticket-claim-view').checked        = originals.claimView;
      document.getElementById('ticket-claim-type').checked        = originals.claimType;
      document.getElementById('ticket-ac-leave').checked          = originals.acLeave;
      document.getElementById('ticket-ac-noresponse-enabled').checked = originals.acNoResponseEnabled;
      document.getElementById('ticket-ac-noresponse-days').value   = originals.acNoResponseDays;
      document.getElementById('ticket-ac-noresponse-hours').value  = originals.acNoResponseHours;
      document.getElementById('ticket-ac-noresponse-mins').value   = originals.acNoResponseMins;
      document.getElementById('ticket-ac-lastmsg-enabled').checked = originals.acLastMsgEnabled;
      document.getElementById('ticket-ac-lastmsg-days').value      = originals.acLastMsgDays;
      document.getElementById('ticket-ac-lastmsg-hours').value     = originals.acLastMsgHours;
      document.getElementById('ticket-ac-lastmsg-mins').value      = originals.acLastMsgMins;
      document.getElementById('ticket-open-perm').value             = originals.openPerm;
      document.getElementById('ticket-open-perm-role').value        = originals.openPermRole;
      document.getElementById('ticket-add-msg-sender').checked      = originals.addMsgSender;
      document.getElementById('ticket-perm-attach').checked         = originals.permAttach;
      document.getElementById('ticket-perm-embed').checked          = originals.permEmbed;
      document.getElementById('ticket-perm-reactions').checked      = originals.permReact;
      document.getElementById('ticket-color-success').value          = originals.colorSuccess;
      document.getElementById('ticket-color-failure').value          = originals.colorFailure;
      document.getElementById('ticket-hide-close').checked           = originals.hideClose;
      document.getElementById('ticket-hide-close-reason').checked    = originals.hideCloseReason;
      document.getElementById('ticket-hide-claim').checked           = originals.hideClaim;
      document.getElementById('ticket-rules-enabled').checked          = originals.rulesEnabled;
      document.getElementById('ticket-rules-text').value               = originals.rulesText;
      document.getElementById('ticket-rules-label').value              = originals.rulesLabel;
      document.getElementById('ticket-rules-emoji').value              = originals.rulesEmoji;
      document.getElementById('ticket-rules-style-val').value          = originals.rulesBtnStyle;
      document.querySelectorAll('.rules-style-opt').forEach(b => b.classList.toggle('active', b.dataset.val === originals.rulesBtnStyle));
      document.getElementById('rules-text-row').style.display           = originals.rulesEnabled ? '' : 'none';
      document.getElementById('rules-btn-style-row').style.display      = originals.rulesEnabled ? '' : 'none';
      document.getElementById('ticket-escalate-enabled').checked        = originals.escalateEnabled;
      document.getElementById('escalate-cats-row').style.display        = originals.escalateEnabled ? '' : 'none';
      const _savedCats = JSON.parse(originals.escalateCats);
      const _chipsBox  = document.getElementById('esc-chips-box');
      const _escSel    = document.getElementById('ticket-escalate-cats-sel');
      _chipsBox.innerHTML = '';
      [..._escSel.options].forEach(o => { o.disabled = false; });
      _savedCats.forEach(id => {
        const opt = _escSel.querySelector(`option[value="${id}"]`);
        if (opt) _addEscChip(id, opt.textContent);
      });
      document.getElementById('escalate-roles-row').style.display = originals.escalateEnabled ? '' : 'none';
      const _savedRoles = JSON.parse(originals.escalateRoles);
      const _rolesBox   = document.getElementById('esc-roles-chips-box');
      const _rolesSel   = document.getElementById('ticket-escalate-roles-sel');
      _rolesBox.innerHTML = '';
      [..._rolesSel.options].forEach(o => { o.disabled = false; });
      _savedRoles.forEach(id => {
        const opt = _rolesSel.querySelector(`option[value="${id}"]`);
        if (opt) _addEscRoleChip(id, opt.textContent.trim());
      });
      document.getElementById('color-success-swatch').style.background = originals.colorSuccess;
      document.getElementById('color-failure-swatch').style.background = originals.colorFailure;
      document.getElementById('color-success-hex').textContent = originals.colorSuccess;
      document.getElementById('color-failure-hex').textContent = originals.colorFailure;
      document.getElementById('perm-role-row').classList.toggle('perm-role-row-hidden', originals.openPerm !== 'role_required');
      saveBar.classList.remove('visible');
    });

    saveBtn.addEventListener('click', async () => {
      saveBtn.disabled = true;
      const savingLabel = '<%= t.tickets.savingBtn %>';
      const savedLabel  = '<%= t.tickets.savedBtn %>';
      const saveLabel   = '<%= t.tickets.saveBtn %>';
      saveBtn.textContent = savingLabel;

      const payload = {
        ENABLE:                 document.getElementById('ticket-enable-val').value === '1',
        LANGUAGE:               document.getElementById('ticket-lang').value,
        TICKET_LIMIT_PER_USER:  parseInt(document.getElementById('ticket-limit').value, 10) || 1,
        ALLOW_USER_CLOSE:       document.getElementById('ticket-allow-close').checked,
        CLOSE_CONFIRMATION:     document.getElementById('ticket-close-confirm').checked,
        ENABLE_FEEDBACK:        document.getElementById('ticket-feedback').checked,
        ANONYMISE_RESPONSES:    document.getElementById('ticket-anon').checked,
        THREAD_MODE:            document.getElementById('ticket-thread').checked,
        DISABLE_OPEN_COMMAND:   document.getElementById('ticket-disable-open').checked,
        NOTIFICATION_CHANNEL:   document.getElementById('ticket-notif-channel').value || null,
        TRANSCRIPTS_CHANNEL:    document.getElementById('ticket-transcript-channel').value || null,
        CHANNEL_CATEGORY:       document.getElementById('ticket-channel-category').value || null,
        OVERFLOW_CATEGORY:      document.getElementById('ticket-overflow-category').value || null,
        NAMING_SCHEME:          document.getElementById('ticket-naming').value || 'ticket-{number}',
        WELCOME_MESSAGE:        document.getElementById('ticket-welcome').value,
        CLAIM_SUPPORT_VIEW:     document.getElementById('ticket-claim-view').checked,
        CLAIM_SUPPORT_TYPE:     document.getElementById('ticket-claim-type').checked,
        AUTO_CLOSE_ON_LEAVE:    document.getElementById('ticket-ac-leave').checked,
        AC_NO_RESPONSE_ENABLED: document.getElementById('ticket-ac-noresponse-enabled').checked,
        AC_NO_RESPONSE_DAYS:    parseInt(document.getElementById('ticket-ac-noresponse-days').value, 10)  || 0,
        AC_NO_RESPONSE_HOURS:   parseInt(document.getElementById('ticket-ac-noresponse-hours').value, 10) || 0,
        AC_NO_RESPONSE_MINS:    parseInt(document.getElementById('ticket-ac-noresponse-mins').value, 10)  || 0,
        AC_LAST_MSG_ENABLED:    document.getElementById('ticket-ac-lastmsg-enabled').checked,
        AC_LAST_MSG_DAYS:       parseInt(document.getElementById('ticket-ac-lastmsg-days').value, 10)  || 0,
        AC_LAST_MSG_HOURS:      parseInt(document.getElementById('ticket-ac-lastmsg-hours').value, 10) || 0,
        AC_LAST_MSG_MINS:       parseInt(document.getElementById('ticket-ac-lastmsg-mins').value, 10)  || 0,
        OPEN_PERMISSION:        document.getElementById('ticket-open-perm').value,
        OPEN_PERMISSION_ROLE:   document.getElementById('ticket-open-perm-role').value || null,
        ADD_MSG_SENDER:         document.getElementById('ticket-add-msg-sender').checked,
        PERM_ATTACH_FILES:      document.getElementById('ticket-perm-attach').checked,
        PERM_EMBED_LINKS:       document.getElementById('ticket-perm-embed').checked,
        PERM_ADD_REACTIONS:     document.getElementById('ticket-perm-reactions').checked,
        COLOR_SUCCESS:          document.getElementById('ticket-color-success').value,
        COLOR_FAILURE:          document.getElementById('ticket-color-failure').value,
        HIDE_CLOSE_BTN:         document.getElementById('ticket-hide-close').checked,
        HIDE_CLOSE_REASON_BTN:  document.getElementById('ticket-hide-close-reason').checked,
        HIDE_CLAIM_BTN:         document.getElementById('ticket-hide-claim').checked,
        RULES_BTN_ENABLED:      document.getElementById('ticket-rules-enabled').checked,
        RULES_BTN_TEXT:         document.getElementById('ticket-rules-text').value.trim(),
        RULES_BTN_LABEL:        document.getElementById('ticket-rules-label').value.trim(),
        RULES_BTN_EMOJI:        document.getElementById('ticket-rules-emoji').value.trim(),
        RULES_BTN_STYLE:        parseInt(document.getElementById('ticket-rules-style-val').value, 10) || 2,
        ESCALATE_ENABLED:       document.getElementById('ticket-escalate-enabled').checked,
        ESCALATE_CATEGORIES:    _getEscalateCats(),
        ESCALATE_ROLES:         _getEscalateRoles(),
      };

      try {
        const res = await fetch('/dashboard/<%= guildId %>/tickets/general/save', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        if (!res.ok) throw new Error('Save failed');

        // Update originals
        originals.limit        = String(payload.TICKET_LIMIT_PER_USER);
        originals.lang         = payload.LANGUAGE;
        originals.allowClose   = payload.ALLOW_USER_CLOSE;
        originals.closeConfirm = payload.CLOSE_CONFIRMATION;
        originals.feedback     = payload.ENABLE_FEEDBACK;
        originals.anon         = payload.ANONYMISE_RESPONSES;
        originals.thread       = payload.THREAD_MODE;
        originals.disableOpen       = payload.DISABLE_OPEN_COMMAND;
        originals.notifChannel      = document.getElementById('ticket-notif-channel').value;
        originals.transcriptChannel = document.getElementById('ticket-transcript-channel').value;
        originals.channelCategory   = document.getElementById('ticket-channel-category').value;
        originals.overflowCategory  = document.getElementById('ticket-overflow-category').value;
        originals.namingScheme      = document.getElementById('ticket-naming').value;
        originals.welcomeMsg        = document.getElementById('ticket-welcome').value;
        originals.claimView              = document.getElementById('ticket-claim-view').checked;
        originals.claimType              = document.getElementById('ticket-claim-type').checked;
        originals.acLeave                = document.getElementById('ticket-ac-leave').checked;
        originals.acNoResponseEnabled    = document.getElementById('ticket-ac-noresponse-enabled').checked;
        originals.acNoResponseDays       = document.getElementById('ticket-ac-noresponse-days').value;
        originals.acNoResponseHours      = document.getElementById('ticket-ac-noresponse-hours').value;
        originals.acNoResponseMins       = document.getElementById('ticket-ac-noresponse-mins').value;
        originals.acLastMsgEnabled       = document.getElementById('ticket-ac-lastmsg-enabled').checked;
        originals.acLastMsgDays          = document.getElementById('ticket-ac-lastmsg-days').value;
        originals.acLastMsgHours         = document.getElementById('ticket-ac-lastmsg-hours').value;
        originals.acLastMsgMins          = document.getElementById('ticket-ac-lastmsg-mins').value;
        originals.openPerm     = document.getElementById('ticket-open-perm').value;
        originals.openPermRole = document.getElementById('ticket-open-perm-role').value;
        originals.addMsgSender = document.getElementById('ticket-add-msg-sender').checked;
        originals.permAttach   = document.getElementById('ticket-perm-attach').checked;
        originals.permEmbed    = document.getElementById('ticket-perm-embed').checked;
        originals.permReact    = document.getElementById('ticket-perm-reactions').checked;
        originals.colorSuccess    = document.getElementById('ticket-color-success').value;
        originals.colorFailure    = document.getElementById('ticket-color-failure').value;
        originals.hideClose       = document.getElementById('ticket-hide-close').checked;
        originals.hideCloseReason = document.getElementById('ticket-hide-close-reason').checked;
        originals.hideClaim       = document.getElementById('ticket-hide-claim').checked;
        originals.rulesEnabled    = document.getElementById('ticket-rules-enabled').checked;
        originals.rulesText       = document.getElementById('ticket-rules-text').value;
        originals.rulesLabel      = document.getElementById('ticket-rules-label').value;
        originals.rulesEmoji      = document.getElementById('ticket-rules-emoji').value;
        originals.rulesBtnStyle   = document.getElementById('ticket-rules-style-val').value;
        originals.escalateEnabled = document.getElementById('ticket-escalate-enabled').checked;
        originals.escalateCats    = JSON.stringify(_getEscalateCats());
        originals.escalateRoles   = JSON.stringify(_getEscalateRoles());

        saveBtn.textContent = savedLabel;
        saveBtn.classList.remove('btn-primary');
        saveBtn.classList.add('btn-success');
        setTimeout(() => {
          saveBar.classList.remove('visible');
          saveBtn.textContent = saveLabel;
          saveBtn.classList.remove('btn-success');
          saveBtn.classList.add('btn-primary');
          saveBtn.disabled = false;
        }, 1800);
      } catch (err) {
        console.error(err);
        saveBtn.textContent = saveLabel;
        saveBtn.disabled = false;
        alert('<%= t.ticketsGeneral.saveFailedPleaseTryAgain %>');
      }
    });
  </script>

  <script>
    /* ── Profile sidebar ── */
    const profSidebar  = document.getElementById('prof-sidebar');
    const profBackdrop = document.getElementById('prof-backdrop');
    const openBtn      = document.getElementById('open-profile');
    const closeBtn     = document.getElementById('close-profile');
    const copyId       = document.getElementById('prof-copy-id');
    const bannerSolid  = document.querySelector('.prof-banner-solid');
    if (bannerSolid && bannerSolid.dataset.bg) bannerSolid.style.background = bannerSolid.dataset.bg;
    function openProfile()  { if (!profSidebar) return; profSidebar.classList.add('open'); profBackdrop.classList.add('open'); profSidebar.setAttribute('aria-hidden','false'); document.body.style.overflow='hidden'; }
    function closeProfile() { if (!profSidebar) return; profSidebar.classList.remove('open'); profBackdrop.classList.remove('open'); profSidebar.setAttribute('aria-hidden','true'); document.body.style.overflow=''; }
    if (openBtn)  openBtn.addEventListener('click', openProfile);
    document.querySelectorAll('.open-profile-btn').forEach(b => b.addEventListener('click', openProfile));
    if (closeBtn) closeBtn.addEventListener('click', closeProfile);
    if (profBackdrop) profBackdrop.addEventListener('click', closeProfile);
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeProfile(); });
    if (copyId) {
      copyId.addEventListener('click', () => {
        navigator.clipboard.writeText(copyId.textContent.trim()).then(() => {
          const orig = copyId.textContent;
          copyId.textContent = '✓ Copied!'; copyId.style.color = 'var(--cyan-l)';
          setTimeout(() => { copyId.textContent = orig; copyId.style.color = ''; }, 1500);
        });
      });
    }
  </script>
  <!-- Lucide -->
  <script src="/js/lucide.min.js"></script>
  <script>lucide.createIcons();</script>

  <!-- Page transition overlay -->
  <div id="ov" style="position:fixed;inset:0;z-index:9999;background:#040010;animation:pIn .45s cubic-bezier(.4,0,.2,1) forwards;pointer-events:none;"></div>
  <style>
    @keyframes pIn  { from { opacity:1 } to { opacity:0 } }
    @keyframes pOut { from { opacity:0 } to { opacity:1 } }
    #ov.leave { animation:pOut .35s cubic-bezier(.4,0,.2,1) forwards; pointer-events:all; }
  </style>
  <script>
    (function () {
      function fadeOut(href) { var ov=document.getElementById('ov'); ov.classList.add('leave'); setTimeout(function(){ window.location.href=href; },360); }
      document.querySelectorAll('a.nav-link, a#logout-link').forEach(function(a){
        a.addEventListener('click',function(e){ if(this.target==='_blank') return; e.preventDefault(); fadeOut(this.href); });
      });
    })();
  </script>
  <%- include('partials/promo_card') %>
  <%- include('partials/footer') %>
</body>

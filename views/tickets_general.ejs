            <option value="everyone"      <%= ticketSettings.OPEN_PERMISSION === 'everyone'      || !ticketSettings.OPEN_PERMISSION ? 'selected' : '' %>><%= t.tickets.openPermEveryone %></option>
            <option value="role_required" <%= ticketSettings.OPEN_PERMISSION === 'role_required' ? 'selected' : '' %>><%= t.tickets.openPermRole %></option>
            <option value="admin_only"    <%= ticketSettings.OPEN_PERMISSION === 'admin_only'    ? 'selected' : '' %>><%= t.tickets.openPermAdmin %></option>
          </select>

              <span class="ac-time-label"><%= t.tickets.acDays %></span>
            </div>
            <div class="ac-time-inp">
              <input type="number" id="ticket-ac-noresponse-hours" class="form-input" min="0" max="23" value="<%= ticketSettings.AC_NO_RESPONSE_HOURS || 0 %>" />
              <span class="ac-time-label"><%= t.tickets.acHours %></span>
            </div>
            <div class="ac-time-inp">
              <input type="number" id="ticket-ac-noresponse-mins" class="form-input" min="0" max="59" value="<%= ticketSettings.AC_NO_RESPONSE_MINS || 0 %>" />
              <span class="ac-time-label"><%= t.tickets.acMins %></span>
            </div>
          </div>
        </div>

        <!-- Since last message -->
        <div class="form-row ac-row">
          <div class="ac-row-left">
            <div class="ac-row-toggle-line">
              <%- include('partials/toggle_switch', { id: 'ticket-ac-lastmsg-enabled', checked: ticketSettings.AC_LAST_MSG_ENABLED }) %>
              <label class="form-label"><%= t.tickets.acLastMsgLabel %></label>
            </div>
            <p class="form-help"><%= t.tickets.acLastMsgHelp %></p>
          </div>
          <div class="ac-time-group">
            <div class="ac-time-inp">
              <input type="number" id="ticket-ac-lastmsg-days" class="form-input" min="0" max="365" value="<%= ticketSettings.AC_LAST_MSG_DAYS || 0 %>" />
              <span class="ac-time-label"><%= t.tickets.acDays %></span>
            </div>
            <div class="ac-time-inp">
              <input type="number" id="ticket-ac-lastmsg-hours" class="form-input" min="0" max="23" value="<%= ticketSettings.AC_LAST_MSG_HOURS || 0 %>" />
              <span class="ac-time-label"><%= t.tickets.acHours %></span>
            </div>
            <div class="ac-time-inp">
              <input type="number" id="ticket-ac-lastmsg-mins" class="form-input" min="0" max="59" value="<%= ticketSettings.AC_LAST_MSG_MINS || 0 %>" />
              <span class="ac-time-label"><%= t.tickets.acMins %></span>
            </div>
          </div>
        </div>

      </div>
    </div>


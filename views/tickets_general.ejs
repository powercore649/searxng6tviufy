    <!-- Rules Button Card -->
    <div class="card card-mt">
      <div class="card-header">
        <div class="card-header-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" fill="currentColor" fill-opacity="0.12"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
            <line x1="10" y1="9" x2="8" y2="9"/>
          </svg>
        </div>
        <h3><%= t.ticketsGeneral.rulesButton %></h3>
      </div>
      <div class="card-body">

        <!-- Enable Rules Button -->
        <div class="form-row">
          <div class="form-row-left">
            <label class="form-label"><%= t.ticketsGeneral.enableRulesButton %></label>
            <p class="form-help"><%= t.ticketsGeneral.addsARulesButtonToThe %></p>
          </div>
          <%- include('partials/toggle_switch', { id: 'ticket-rules-enabled', checked: ticketSettings.RULES_BTN_ENABLED }) %>
        </div>

        <!-- Rules Text -->
        <div class="form-row form-row-col" id="rules-text-row" <%- ticketSettings.RULES_BTN_ENABLED ? '' : 'style="display:none"' %>>
          <div class="form-row-left" style="width:100%">
            <label class="form-label"><%= t.ticketsGeneral.rulesText %></label>
            <p class="form-help"><%= t.ticketsGeneral.textShownToTheUserWhen %></p>
          </div>
          <textarea id="ticket-rules-text" class="form-textarea" rows="6" maxlength="3000" placeholder="<%= t.ticketsGeneral.writeYourServerRulesHere %>"><%= ticketSettings.RULES_BTN_TEXT || '' %></textarea>
        </div>

        <!-- Rules Button Appearance -->
        <div class="form-row" id="rules-btn-style-row" <%- ticketSettings.RULES_BTN_ENABLED ? '' : 'style="display:none"' %>>
          <div class="form-row-left">
            <label class="form-label"><%= t.ticketsGeneral.rulesButtonAppearance %></label>
            <p class="form-help"><%= t.ticketsGeneral.buttonLabelEmojiAndColorShown %></p>
          </div>
          <div class="rules-btn-cfg">
            <div class="rules-btn-cfg-row">
              <label class="rules-cfg-lbl"><%= t.ticketsGeneral.label %></label>
              <input type="text" id="ticket-rules-label" class="form-input" style="width:180px" maxlength="40"
                     placeholder="Rules" value="<%= ticketSettings.RULES_BTN_LABEL || '' %>" />
            </div>
            <div class="rules-btn-cfg-row">
              <label class="rules-cfg-lbl"><%= t.ticketsGeneral.emoji %></label>
              <div style="position:relative;display:inline-flex;align-items:center;gap:6px">
                <input type="text" id="ticket-rules-emoji" class="form-input" style="width:170px"
                       maxlength="64" placeholder="📜 or &lt;:name:id&gt;"
                       value="<%= ticketSettings.RULES_BTN_EMOJI || '' %>" />
<% if (typeof guildEmojis !== 'undefined' && guildEmojis && guildEmojis.length) { %>
                <button type="button" id="rules-emoji-picker-btn" class="rules-emoji-picker-btn" title="<%= t.ticketsGeneral.serverEmojis %>">
                  <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 13s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/><path d="M16 5c0-1.1.9-1 2-1"/></svg>
                </button>
                <div id="rules-emoji-picker-pop" class="rules-emoji-pop" style="display:none">
<% guildEmojis.forEach(function(em) { %>
                  <button type="button" class="rules-emoji-item" data-val="<:<%=em.name%>:<%=em.id%>>" title=":<%=em.name%>:">
                    <img src="<%=em.url%>" alt="<%=em.name%>" loading="lazy" />
                  </button>
<% }); %>
                </div>
<% } %>
              </div>
            </div>
            <div class="rules-btn-cfg-row">
              <label class="rules-cfg-lbl"><%= t.ticketsGeneral.style %></label>
              <div class="rules-style-group" id="ticket-rules-style-group">
                <button type="button" class="rules-style-opt<%= (ticketSettings.RULES_BTN_STYLE||2)==1?' active':'' %>" data-val="1">Primary</button>
                <button type="button" class="rules-style-opt<%= (ticketSettings.RULES_BTN_STYLE||2)==2?' active':'' %>" data-val="2">Secondary</button>
                <button type="button" class="rules-style-opt<%= (ticketSettings.RULES_BTN_STYLE||2)==3?' active':'' %>" data-val="3">Success</button>
                <button type="button" class="rules-style-opt<%= (ticketSettings.RULES_BTN_STYLE||2)==4?' active':'' %>" data-val="4">Danger</button>
              </div>
              <input type="hidden" id="ticket-rules-style-val" value="<%= ticketSettings.RULES_BTN_STYLE || 2 %>" />
            </div>
          </div>
        </div>

      </div>
    </div>


  <!-- Lucide -->
  <script src="/js/lucide.min.js"></script>
  <script>lucide.createIcons();</script>

  <%- include('partials/bg_stars') %>

  <!-- Page in overlay -->
  <div id="ov"
    style="position:fixed;inset:0;z-index:9999;background:#040010;animation:pIn .45s cubic-bezier(.4,0,.2,1) forwards;pointer-events:none;">
  </div>
  <style>
    @keyframes pIn {
      from {
        opacity: 1
      }

      to {
        opacity: 0
      }
    }

    @keyframes pOut {
      from {
        opacity: 0
      }

      to {
        opacity: 1
      }
    }

    #ov.leave {
      animation: pOut .35s cubic-bezier(.4, 0, .2, 1) forwards;
      pointer-events: all;
    }
  </style>

  <script>
    /* ── Banner solid color ── */
    const bannerSolid = document.querySelector('.prof-banner-solid');
    if (bannerSolid && bannerSolid.dataset.bg) bannerSolid.style.background = bannerSolid.dataset.bg;

    /* ── Profile sidebar ── */
    const profSidebar = document.getElementById('prof-sidebar');
    const profBackdrop = document.getElementById('prof-backdrop');
    const openBtn = document.getElementById('open-profile');
    const closeBtn = document.getElementById('close-profile');
    const copyId = document.getElementById('prof-copy-id');

    function openProfile() { profSidebar.classList.add('open'); profBackdrop.classList.add('open'); profSidebar.setAttribute('aria-hidden', 'false'); document.body.style.overflow = 'hidden'; }
    function closeProfile() { profSidebar.classList.remove('open'); profBackdrop.classList.remove('open'); profSidebar.setAttribute('aria-hidden', 'true'); document.body.style.overflow = ''; }

    openBtn.addEventListener('click', openProfile);
    document.querySelectorAll('.open-profile-btn').forEach(b => b.addEventListener('click', openProfile));
    if (closeBtn) closeBtn.addEventListener('click', closeProfile);
    profBackdrop.addEventListener('click', closeProfile);
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeProfile(); });

    if (copyId) {
      copyId.addEventListener('click', () => {
        const uid = copyId.dataset.uid || copyId.textContent.trim();
        const lbl = document.getElementById('prof-copy-label');
        navigator.clipboard.writeText(uid).then(() => {
          if (lbl) { const orig = lbl.textContent; lbl.textContent = '✓ Copied!'; lbl.style.color = 'var(--cyan-l)'; setTimeout(() => { lbl.textContent = orig; lbl.style.color = ''; }, 1500); }
        });
      });
    }

    /* ── Language select ── */
    const langSelectEl = document.getElementById('lang-select');
    if (langSelectEl) {
      langSelectEl.addEventListener('change', function () {
        const u = new URL(window.location.href);
        u.searchParams.set('lang', this.value);
        window.location.href = u.toString();
      });
    }

    /* ── Mobile nav toggle (mgmt sidebar) ── */
    const menuToggle  = document.getElementById('menu-toggle');
    const mgmtSidebar = document.getElementById('mgmt-sidebar');
    const navSidebar  = document.querySelector('.nav-sidebar');
    const navOverlay  = document.getElementById('nav-overlay');

    function openMgmt()  { mgmtSidebar.classList.add('open'); navOverlay.classList.add('open'); document.body.style.overflow = 'hidden'; }
    function closeMgmt() { mgmtSidebar.classList.remove('open'); navOverlay.classList.remove('open'); document.body.style.overflow = ''; }
    function openNav()   { if (navSidebar) { navSidebar.classList.add('open'); navOverlay.classList.add('open'); document.body.style.overflow = 'hidden'; } }
    function closeNav()  { if (navSidebar) { navSidebar.classList.remove('open'); navOverlay.classList.remove('open'); document.body.style.overflow = ''; } }

    if (menuToggle) menuToggle.addEventListener('click', () => mgmtSidebar.classList.contains('open') ? closeMgmt() : openMgmt());
    if (navOverlay) navOverlay.addEventListener('click', () => { closeMgmt(); closeNav(); });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') { closeMgmt(); closeNav(); closeProfile(); } });

    /* Sort button in mgmt header = toggle server switcher panel */
    const sortBtn = document.querySelector('.mgmt-sort-btn');
    if (sortBtn) {
      sortBtn.addEventListener('click', function () {
        if (navSidebar && navSidebar.classList.contains('open')) {
          closeNav();
        } else {
          closeMgmt();
          openNav();
        }
      });
    }

    /* ── Mgmt section collapse ── */
    document.querySelectorAll('.mgmt-section-btn').forEach(btn => {
      btn.addEventListener('click', function () {
        const body = this.nextElementSibling;
        const isOpen = body.classList.contains('open');
        body.classList.toggle('open', !isOpen);
        this.classList.toggle('open', !isOpen);
      });
    });

    /* ── Page transitions ── */
    function fadeOut(href) {
      const ov = document.getElementById('ov');
      ov.classList.add('leave');
      setTimeout(() => { window.location.href = href; }, 360);
    }
    document.querySelectorAll('a.nav-link, a#logout-link').forEach(a => {
      a.addEventListener('click', function (e) {
        if (this.target === '_blank') return;
        e.preventDefault(); fadeOut(this.href);
      });
    });
  </script>

  <!-- ── Activity sparkline charts ────────────────────────────────────── -->
  <script>
  (function () {
    const guildId = '<%= guildId %>';

    function changeEl(el, cur, prev) {
      if (prev === 0 && cur === 0) {
        el.textContent = 'No data yet';
        el.className = 'act-card-change flat';
        return;
      }
      if (prev === 0) {
        el.innerHTML = '&#9650; +100% Vs Last 24h';
        el.className = 'act-card-change up';
        return;
      }
      const p = ((cur - prev) / prev * 100).toFixed(1);
      if (parseFloat(p) > 0) {
        el.innerHTML = '&#9650; +' + p + '% Vs Last 24h';
        el.className = 'act-card-change up';
      } else if (parseFloat(p) < 0) {
        el.innerHTML = '&#9660; ' + p + '% Vs Last 24h';
        el.className = 'act-card-change down';
      } else {
        el.innerHTML = '&#9679; 0% Vs Last 24h';
        el.className = 'act-card-change flat';
      }
    }

    function sparkOpts(data, color) {
      return {
        chart: { type: 'area', height: 55, sparkline: { enabled: true }, animations: { enabled: true, speed: 700 }, background: 'transparent' },
        stroke: { curve: 'smooth', width: 2 },
        fill: { type: 'gradient', gradient: { shade: 'dark', type: 'vertical', shadeIntensity: 0.5, opacityFrom: 0.35, opacityTo: 0.02, stops: [0, 100] } },
        colors: [color],
        series: [{ name: '', data: data }],
        tooltip: { enabled: false },
        grid: { show: false },
        xaxis: { labels: { show: false }, axisBorder: { show: false }, axisTicks: { show: false } },
        yaxis: { show: false, min: 0 },
      };
    }

    function render(d) {
      const half = Math.floor(d.joins.length / 2);
      const sum  = (arr) => arr.reduce((a, b) => a + b, 0);

      const totals  = { joins: sum(d.joins),    leaves: sum(d.leaves),    messages: sum(d.messages),    voice: sum(d.voice) };
      const prevHalf = { joins: sum(d.joins.slice(0,half)),   leaves: sum(d.leaves.slice(0,half)),   messages: sum(d.messages.slice(0,half)),   voice: sum(d.voice.slice(0,half)) };
      const curHalf  = { joins: sum(d.joins.slice(half)),     leaves: sum(d.leaves.slice(half)),     messages: sum(d.messages.slice(half)),     voice: sum(d.voice.slice(half)) };

      document.getElementById('actJoinsVal').textContent    = totals.joins;
      document.getElementById('actLeavesVal').textContent   = totals.leaves;
      document.getElementById('actMessagesVal').textContent = totals.messages;
      document.getElementById('actVoiceVal').textContent    = totals.voice;

      changeEl(document.getElementById('actJoinsChange'),    curHalf.joins,    prevHalf.joins);
      changeEl(document.getElementById('actLeavesChange'),   curHalf.leaves,   prevHalf.leaves);
      changeEl(document.getElementById('actMessagesChange'), curHalf.messages, prevHalf.messages);
      changeEl(document.getElementById('actVoiceChange'),    curHalf.voice,    prevHalf.voice);

      new ApexCharts(document.getElementById('actJoinsChart'),    sparkOpts(d.joins,    '#4ade80')).render();
      new ApexCharts(document.getElementById('actLeavesChart'),   sparkOpts(d.leaves,   '#f87171')).render();
      new ApexCharts(document.getElementById('actMessagesChart'), sparkOpts(d.messages, '#a78bfa')).render();
      new ApexCharts(document.getElementById('actVoiceChart'),    sparkOpts(d.voice,    '#38bdf8')).render();
    }

    function boot() {
      if (window.ApexCharts) { loadData(); return; }
      const s = document.createElement('script');
      s.src = '/apexcharts.js';
      s.onerror = () => {
        const cdn = document.createElement('script');
        cdn.src = 'https://cdn.jsdelivr.net/npm/apexcharts@3/dist/apexcharts.min.js';
        cdn.onload = loadData;
        document.head.appendChild(cdn);
      };
      s.onload = loadData;
      document.head.appendChild(s);
    }

    function loadData() {
      fetch('/dashboard/' + guildId + '/stats/activity')
        .then(r => r.json())
        .then(render)
        .catch(() => {
          ['actJoinsVal','actLeavesVal','actMessagesVal','actVoiceVal'].forEach(id => {
            document.getElementById(id).textContent = '—';
          });
          ['actJoinsChange','actLeavesChange','actMessagesChange','actVoiceChange'].forEach(id => {
            const el = document.getElementById(id);
            el.textContent = 'No data';
            el.className = 'act-card-change flat';
          });
        });
    }

    boot();
  })();
  </script>
</body>


  html[data-theme="light"] .btn:disabled,html[data-theme="light"] button:disabled,html[data-theme="light"] .btn[disabled] { background: rgba(124,58,237,.08) !important; border-color: rgba(124,58,237,.12) !important; color: rgba(80,40,160,.38) !important; opacity: 1 !important; cursor: not-allowed; }
  html[data-theme="light"] .status-badge     { border-color: rgba(124,58,237,.12); }
  html[data-theme="light"] .status-badge.on  { background: rgba(34,197,94,.12); color: #15803d; border-color: rgba(34,197,94,.25); }
  html[data-theme="light"] .status-badge.off { background: rgba(239,68,68,.10); color: #b91c1c; border-color: rgba(239,68,68,.22); }
  /* ── Selects ── */

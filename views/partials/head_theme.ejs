  html[data-theme="light"] .role-tag-rm { color: rgba(80,40,160,.55); }
  /* ── csel custom multi-select ── */
  html[data-theme="light"] .csel-display { background: rgba(255,255,255,.8) !important; border-color: rgba(124,58,237,.22) !important; color: #16063b !important; }

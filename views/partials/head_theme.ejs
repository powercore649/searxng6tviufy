  html[data-theme="light"] .prot-select,html[data-theme="light"] .invite-select,html[data-theme="light"] .form-select { background: rgba(255,255,255,.82) !important; border-color: rgba(124,58,237,.22) !important; color: #16063b !important; }
  html[data-theme="light"] .prot-select option,html[data-theme="light"] .invite-select option,html[data-theme="light"] .form-select option { background: #f0ebff !important; color: #16063b !important; }

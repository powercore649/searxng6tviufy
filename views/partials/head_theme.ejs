  /* ── Invite input ── */
  html[data-theme="light"] .invite-input { background: rgba(255,255,255,.82) !important; border-color: rgba(124,58,237,.22) !important; color: #16063b !important; }
  /* ── Site footer ── */
  html[data-theme="light"] .site-footer { border-top-color: rgba(124,58,237,.12); }
  html[data-theme="light"] .site-footer p { color: rgba(80,40,160,.45); }
  /* ── Guild welcome overlay ── */
  html[data-theme="light"] .gwo-wrap { background: rgba(237,233,255,.6); }
  html[data-theme="light"] .gwo-card { background: rgba(255,255,255,.95); border-color: rgba(124,58,237,.2); box-shadow: 0 24px 80px rgba(80,40,160,.18), 0 0 0 1px rgba(124,58,237,.08); }
  html[data-theme="light"] .gwo-name { color: #16063b; }
  html[data-theme="light"] .gwo-sub  { color: rgba(80,40,160,.55); }
  /* ── Home guild card stats ── */
  html[data-theme="light"] .guild-card-stats { color: rgba(80,40,160,.6); }
  /* ── Page Loader ── */
  #page-loader {
    position: fixed; inset: 0; z-index: 99999;
    display: flex; align-items: center; justify-content: center;
    background: #07000f;
    transition: opacity .55s cubic-bezier(.4,0,.2,1), visibility .55s cubic-bezier(.4,0,.2,1);
    overflow: hidden;
  }
  html[data-theme="light"] #page-loader { background: #ede9ff; }
  #page-loader.pl-done { opacity: 0; visibility: hidden; pointer-events: none; }

  /* Aurora background */
  .pl-aurora { position: absolute; inset: 0; pointer-events: none; }
  .pl-aurora::before, .pl-aurora::after {
    content: ''; position: absolute; border-radius: 50%;
    filter: blur(90px); opacity: .28;
    animation: pl-aurora 7s ease-in-out infinite alternate;
  }
  .pl-aurora::before {
    width: 560px; height: 560px;
    background: radial-gradient(circle, #7c3aed 0%, transparent 70%);
    top: -160px; left: -160px;
  }
  .pl-aurora::after {
    width: 420px; height: 420px;
    background: radial-gradient(circle, #06b6d4 0%, transparent 70%);
    bottom: -120px; right: -120px;
    animation-delay: -3.5s;
  }
  html[data-theme="light"] .pl-aurora::before { opacity: .14; }
  html[data-theme="light"] .pl-aurora::after  { opacity: .12; }
  @keyframes pl-aurora {
    from { transform: scale(1) translate(0,0); }
    to   { transform: scale(1.25) translate(24px,18px); }
  }

  /* Center layout */
  .pl-center {
    position: relative; display: flex; flex-direction: column;
    align-items: center; gap: 28px;
  }

  /* Orb wrap — 96 × 96 container */
  .pl-orb-wrap {
    position: relative; width: 96px; height: 96px;
    display: flex; align-items: center; justify-content: center;
  }

  /* Conic gradient ring */
  .pl-ring-conic {
    position: absolute; inset: 0; border-radius: 50%;
    background: conic-gradient(
      from 0deg,
      transparent   0deg,
      rgba(124,58,237,.06) 40deg,
      #a78bfa 190deg,
      #06b6d4 280deg,
      transparent  360deg
    );
    -webkit-mask: radial-gradient(circle, transparent 36px, black 37px);
    mask:         radial-gradient(circle, transparent 36px, black 37px);
    animation: pl-spin 1.35s linear infinite;
  }

  /* Outer faint track ring */
  .pl-ring-track {
    position: absolute; inset: 0; border-radius: 50%;
    border: 1.5px solid rgba(124,58,237,.1);
  }

  /* Inner glowing card */
  .pl-orb-inner {
    position: relative; z-index: 2;
    width: 56px; height: 56px; border-radius: 18px;
    background: linear-gradient(145deg, rgba(124,58,237,.22), rgba(6,182,212,.12));
    border: 1px solid rgba(167,139,250,.35);
    box-shadow:
      0 0 0 6px rgba(124,58,237,.06),
      0 0 24px rgba(124,58,237,.3),
      0 0 56px rgba(124,58,237,.12),
      inset 0 1px 0 rgba(255,255,255,.12);
    display: flex; align-items: center; justify-content: center;
    animation: pl-breathe 2.4s ease-in-out infinite;
  }
  html[data-theme="light"] .pl-orb-inner {
    background: linear-gradient(145deg, rgba(124,58,237,.15), rgba(6,182,212,.08));
    border-color: rgba(124,58,237,.3);
    box-shadow: 0 0 0 6px rgba(124,58,237,.04), 0 0 20px rgba(124,58,237,.2), inset 0 1px 0 rgba(255,255,255,.5);
  }
  @keyframes pl-breathe {
    0%,100% { box-shadow: 0 0 0 6px rgba(124,58,237,.06), 0 0 24px rgba(124,58,237,.30), 0 0 56px rgba(124,58,237,.12), inset 0 1px 0 rgba(255,255,255,.12); }
    50%      { box-shadow: 0 0 0 8px rgba(124,58,237,.10), 0 0 36px rgba(124,58,237,.50), 0 0 72px rgba(124,58,237,.20), inset 0 1px 0 rgba(255,255,255,.16); }
  }

  /* Orbiting dot */
  .pl-orbit-dot {
    position: absolute; width: 8px; height: 8px; border-radius: 50%;
    top: 4px; left: calc(50% - 4px);
    background: #c4b5fd;
    box-shadow: 0 0 8px #a78bfa, 0 0 20px rgba(167,139,250,.6);
    z-index: 3;
    transform-origin: 4px 44px;
    animation: pl-spin 1.35s linear infinite;
  }

  /* Loading label */
  .pl-label {
    font-size: .68rem; font-weight: 700; letter-spacing: .18em;
    text-transform: uppercase;
    background: linear-gradient(90deg, #a78bfa, #67e8f9, #a78bfa);
    background-size: 200% 100%;
    -webkit-background-clip: text; background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: pl-label-shimmer 2.5s linear infinite;
  }
  html[data-theme="light"] .pl-label {
    background: linear-gradient(90deg, #7c3aed, #0891b2, #7c3aed);
    background-size: 200% 100%;
    -webkit-background-clip: text; background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: pl-label-shimmer 2.5s linear infinite;
  }
  @keyframes pl-label-shimmer { to { background-position: -200% center; } }

  /* Progress bar */
  .pl-bar {
    position: absolute; bottom: 0; left: 0; right: 0;
    height: 2px; overflow: hidden;
    background: rgba(124,58,237,.08);
  }
  .pl-bar-fill {
    position: absolute; height: 100%; width: 35%;
    left: -35%;
    background: linear-gradient(90deg, transparent, #a78bfa, #67e8f9, #a78bfa, transparent);
    animation: pl-bar-slide 1.9s cubic-bezier(.4,0,.6,1) infinite;
    border-radius: 999px;
  }
  @keyframes pl-spin       { to { transform: rotate(360deg); } }
  @keyframes pl-bar-slide  { 0% { left: -35%; } 100% { left: 110%; } }

  @media (prefers-reduced-motion: reduce) {
    .pl-ring-conic, .pl-orbit-dot, .pl-aurora::before, .pl-aurora::after { animation: none !important; }
    .pl-bar-fill { animation: none !important; left: 0; width: 100%; background: rgba(124,58,237,.25); }
  }
</style>
<script>
/* ── Page Loader ── */
(function () {
  var l = document.createElement('div');
  l.id = 'page-loader';
  l.innerHTML = [
    '<div class="pl-aurora"></div>',
    '<div class="pl-center">',
      '<div class="pl-orb-wrap">',
        '<div class="pl-ring-track"></div>',
        '<div class="pl-ring-conic"></div>',
        '<div class="pl-orb-inner">',
          '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">',
            '<path opacity=".5" d="M12 2L2 7l10 5 10-5-10-5z" stroke="#a78bfa" stroke-width="1.6" stroke-linejoin="round"/>',
            '<path d="M2 12l10 5 10-5" stroke="#67e8f9" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>',
            '<path opacity=".7" d="M2 17l10 5 10-5" stroke="#a78bfa" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>',
          '</svg>',
        '</div>',
        '<div class="pl-orbit-dot"></div>',
      '</div>',
      '<div class="pl-label">Loading</div>',
    '</div>',
    '<div class="pl-bar"><div class="pl-bar-fill"></div></div>'
  ].join('');
  document.documentElement.appendChild(l);
  function moveToBdy() {
    if (document.body && l.parentNode !== document.body) document.body.appendChild(l);
  }
  document.addEventListener('DOMContentLoaded', moveToBdy);
  function done() { l.classList.add('pl-done'); setTimeout(function () { if (l.parentNode) l.parentNode.removeChild(l); }, 560); }
  window.addEventListener('load', function () { setTimeout(done, 120); });
  setTimeout(done, 8000);
})();
</script>

<style>
/* ── Scroll-to-top button ── */
#cn-stt {
  position: fixed; bottom: 28px; right: 28px; z-index: 9000;
  width: 40px; height: 40px; border-radius: 12px;
  background: rgba(124,58,237,.18);
  border: 1px solid rgba(167,139,250,.3);
  color: #a78bfa; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 4px 20px rgba(124,58,237,.25);
  opacity: 0; visibility: hidden; pointer-events: none;
  transform: translateY(12px);
  transition: opacity .28s, visibility .28s, transform .28s cubic-bezier(.22,1,.36,1), background .18s, border-color .18s;
  backdrop-filter: blur(12px);
}
#cn-stt.visible { opacity: 1; visibility: visible; pointer-events: auto; transform: translateY(0); }
#cn-stt:hover { background: rgba(124,58,237,.32); border-color: rgba(167,139,250,.55); }
#cn-stt:active { transform: scale(.92); }
[dir="rtl"] #cn-stt { right: auto; left: 28px; }
html[data-theme="light"] #cn-stt { background: rgba(255,255,255,.85); border-color: rgba(124,58,237,.3); box-shadow: 0 4px 20px rgba(124,58,237,.15); }

/* ── Ripple effect ── */
.btn, .mgmt-item:not(.disabled), .nav-item, .lcs-btn, .lcs-item {
  position: relative; overflow: hidden;
}
.cn-ripple {
  position: absolute; border-radius: 50%;
  background: rgba(167,139,250,.25);
  transform: scale(0);
  animation: cn-ripple-anim .55s cubic-bezier(.22,1,.36,1) forwards;
  pointer-events: none;
}
@keyframes cn-ripple-anim {
  to { transform: scale(4); opacity: 0; }
}

/* ── Ctrl+S hint on save-bar ── */
.cn-ks-hint {
  font-size: .68rem; font-weight: 600; letter-spacing: .06em;
  color: var(--muted); opacity: .7; flex-shrink: 0; white-space: nowrap;
}
kbd.cn-kbd {
  display: inline-flex; align-items: center; justify-content: center;
  padding: 1px 5px; border-radius: 4px;
  background: rgba(255,255,255,.07); border: 1px solid rgba(255,255,255,.12);
  font-size: .65rem; font-family: inherit; color: var(--muted);
  vertical-align: middle; margin: 0 2px;
  box-shadow: inset 0 -1px 0 rgba(255,255,255,.08);
}
html[data-theme="light"] kbd.cn-kbd { background: rgba(0,0,0,.06); border-color: rgba(0,0,0,.15); }

/* ── Active mgmt-item pulse on load ── */
@keyframes cn-active-pulse {
  0%   { box-shadow: inset 3px 0 0 var(--purple-l), 0 0 0 0 rgba(167,139,250,.35); }
  60%  { box-shadow: inset 3px 0 0 var(--purple-l), 0 0 0 6px rgba(167,139,250,.0); }
  100% { box-shadow: none; }
}
.mgmt-item.active { animation: cn-active-pulse .7s .3s ease-out both; }
</style>

<script>
/* ── Universal UX enhancements ── */
(function () {
  document.addEventListener('DOMContentLoaded', function () {

    /* 1 — Scroll-to-top ─────────────────────────────────────────── */
    var stt = document.createElement('button');
    stt.id = 'cn-stt';
    stt.setAttribute('aria-label', 'Back to top');
    stt.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V5"/><path d="M5 12l7-7 7 7"/></svg>';
    document.body.appendChild(stt);
    var _sttTimer;
    window.addEventListener('scroll', function () {
      clearTimeout(_sttTimer);
      _sttTimer = setTimeout(function () {
        stt.classList.toggle('visible', window.scrollY > 320);
      }, 60);
    }, { passive: true });
    stt.addEventListener('click', function () {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    /* 2 — Ctrl + S / Cmd + S to save ───────────────────────────── */
    document.addEventListener('keydown', function (e) {
      if ((e.ctrlKey || e.metaKey) && e.key === 's') {
        var bar = document.getElementById('save-bar');
        var btn = document.getElementById('save-btn');
        if (bar && bar.classList.contains('visible') && btn && !btn.disabled) {
          e.preventDefault();
          btn.click();
        }
      }
    });

    /* Inject Ctrl+S hint into save-bar if none exists */
    var saveBar = document.getElementById('save-bar');
    if (saveBar && !saveBar.querySelector('.cn-ks-hint')) {
      var isMac = /Mac|iPhone|iPad/.test(navigator.platform || navigator.userAgent);
      var hint  = document.createElement('span');
      hint.className = 'cn-ks-hint';
      hint.innerHTML = '<kbd class="cn-kbd">' + (isMac ? '⌘' : 'Ctrl') + '</kbd>+<kbd class="cn-kbd">S</kbd>';
      hint.title = 'Keyboard shortcut to save';
      var actions = saveBar.querySelector('.save-bar-actions');
      if (actions) actions.before(hint);
    }

    /* 3 — Auto-scroll active sidebar item into view ─────────────── */
    var activeItem = document.querySelector('.mgmt-item.active');
    if (activeItem) {
      var mgmtBody = document.querySelector('.mgmt-body');
      if (mgmtBody) {
        setTimeout(function () {
          var itemTop  = activeItem.offsetTop;
          var itemH    = activeItem.offsetHeight;
          var bodyH    = mgmtBody.clientHeight;
          var scrollTo = itemTop - (bodyH / 2) + (itemH / 2);
          mgmtBody.scrollTo({ top: scrollTo, behavior: 'smooth' });
        }, 200);
      }
    }

    /* 4 — Ripple on interactive elements ────────────────────────── */
    function addRipple(e) {
      var el   = e.currentTarget;
      var rect = el.getBoundingClientRect();
      var size = Math.max(rect.width, rect.height) * 1.4;
      var x    = e.clientX - rect.left - size / 2;
      var y    = e.clientY - rect.top  - size / 2;
      var rip  = document.createElement('span');
      rip.className = 'cn-ripple';
      rip.style.cssText = 'width:' + size + 'px;height:' + size + 'px;left:' + x + 'px;top:' + y + 'px;';
      el.appendChild(rip);
      rip.addEventListener('animationend', function () { rip.remove(); });
    }

    function bindRipples() {
      document.querySelectorAll('.btn, .mgmt-item:not(.disabled), .lcs-btn, .lcs-item').forEach(function (el) {
        if (!el.dataset.cnRipple) {
          el.dataset.cnRipple = '1';
          el.addEventListener('click', addRipple);
        }
      });
    }
    bindRipples();

    /* Re-bind if new elements appear (e.g. dynamically added buttons) */
    if (window.MutationObserver) {
      var mo = new MutationObserver(function () { bindRipples(); });
      mo.observe(document.body, { childList: true, subtree: true });
    }

  });
})();
</script>

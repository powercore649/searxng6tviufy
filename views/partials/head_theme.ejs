  html[data-theme="light"] .csel-dropdown { background: #f4f0ff !important; border-color: rgba(124,58,237,.22) !important; box-shadow: 0 8px 32px rgba(80,40,160,.14) !important; }
  html[data-theme="light"] .csel-option { color: #16063b; }
  html[data-theme="light"] .csel-option:hover { background: rgba(124,58,237,.09) !important; }
  html[data-theme="light"] .csel-chip { background: rgba(124,58,237,.12); color: #16063b; }
  /* ── Save bar ── */
  html[data-theme="light"] .save-bar { background: rgba(237,233,255,.97) !important; border-top: 1px solid rgba(124,58,237,.15) !important; box-shadow: 0 -4px 24px rgba(80,40,160,.1) !important; }
  html[data-theme="light"] .save-bar-text,html[data-theme="light"] .save-bar-hint { color: rgba(80,40,160,.7) !important; }

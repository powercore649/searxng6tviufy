<style>
  /* ── Discord-style profile redesign ── */
  .prof-avatar-row {
    display: flex; align-items: flex-end; justify-content: space-between;
    padding: 0 16px 0 0; margin-top: -44px; margin-bottom: 0; position: relative; z-index: 2;
  }
  [dir="rtl"] .prof-avatar-row { padding: 0 0 0 16px; }
  .prof-avatar-wrap { position: relative; margin: 0 0 0 16px; width: 80px; height: 80px; flex-shrink: 0; }
  [dir="rtl"] .prof-avatar-wrap { margin: 0 16px 0 0; }
  .prof-avatar { width: 80px; height: 80px; border-radius: 50%; object-fit: cover; display: block; border: 4px solid rgba(8,2,22,.97); }
  .prof-avatar-fallback { width: 80px; height: 80px; border-radius: 50%; background: linear-gradient(135deg,rgba(124,58,237,.4),rgba(6,182,212,.2)); border: 4px solid rgba(8,2,22,.97); display: flex; align-items: center; justify-content: center; font-size: 1.6rem; font-weight: 800; color: var(--purple-l); }
  .prof-online-dot { position: absolute; bottom: 3px; right: 3px; width: 16px; height: 16px; border-radius: 50%; background: #23a55a; border: 3px solid rgba(8,2,22,.97); box-shadow: 0 0 6px rgba(35,165,90,.7); z-index: 4; transition: background .3s, box-shadow .3s; }
  [dir="rtl"] .prof-online-dot { right: auto; left: 3px; }
  .prof-badges-right { display: flex; flex-wrap: wrap; gap: 5px; justify-content: flex-end; align-self: flex-end; padding-bottom: 6px; max-width: 160px; }
  .prof-badge { display: flex; align-items: center; justify-content: center; width: 26px; height: 26px; border-radius: 6px; background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.09); position: relative; cursor: default; transition: transform .12s, background .12s; }
  .prof-badge:hover { transform: translateY(-2px) scale(1.1); background: rgba(255,255,255,.11); }
  .prof-badge img { width: 18px; height: 18px; object-fit: contain; }
  .prof-badge-tip { position: absolute; bottom: calc(100% + 7px); left: 50%; transform: translateX(-50%); background: rgba(10,3,30,.97); border: 1px solid rgba(124,58,237,.3); border-radius: 7px; padding: 4px 9px; font-size: .65rem; white-space: nowrap; color: var(--white); opacity: 0; pointer-events: none; transition: opacity .15s; z-index: 20; box-shadow: 0 4px 14px rgba(0,0,0,.5); }
  .prof-badge:hover .prof-badge-tip { opacity: 1; }
  .prof-body { flex: 1; overflow-y: auto; padding: 10px 16px 16px; scrollbar-width: thin; scrollbar-color: rgba(124,58,237,.3) transparent; }
  .prof-display-name { font-size: 1.1rem; font-weight: 700; color: var(--white); letter-spacing: -.01em; line-height: 1.3; margin-top: 6px; }
  .prof-username { font-size: .74rem; color: var(--muted); margin-bottom: 4px; }
  .prof-custom-status { font-size: .76rem; color: rgba(203,194,255,.65); margin-bottom: 4px; margin-top: 2px; line-height: 1.4; }
  .prof-divider { height: 1px; background: rgba(255,255,255,.08); margin: 10px 0 6px; }
  .prof-actrow { display: flex; align-items: center; gap: 10px; padding: 8px 10px; border-radius: 8px; font-size: .83rem; color: var(--white); cursor: pointer; transition: background .14s; user-select: none; }
  .prof-actrow:hover { background: rgba(255,255,255,.07); }
  .prof-actdot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; background: #80848e; transition: background .3s; }

  /* ── Guild stats row (replaces guild-meta-id plain text) ── */
  .guild-stats-row { display: flex; align-items: center; gap: 6px; }
  @media (max-width: 768px) { .guild-stats-row { display: none !important; } }
  .gms-item   { display: inline-flex; align-items: center; gap: 3px; }
  .gms-sep    { opacity: .35; line-height: 1; }
  .gms-online svg { border-radius: 50%; box-shadow: 0 0 4px rgba(34,197,94,.5); }

  /* ── Custom lang dropdown ── */
  .lcs-wrap { position: relative; display: inline-block; }
  .lcs-btn {
    display: inline-flex; align-items: center; gap: 5px;
    background: var(--surface); border: 1px solid rgba(255,255,255,.12);
    border-radius: 10px; color: var(--white);
    font-size: .8rem; font-weight: 600; padding: 6px 10px;
    cursor: pointer; outline: none; font-family: inherit;
    transition: border-color .18s, background-color .18s; min-width: 100px;
  }
  .lcs-btn:hover { border-color: rgba(124,58,237,.5); background-color: rgba(124,58,237,.08); }
  .lcs-wrap.open .lcs-btn { border-color: rgba(124,58,237,.6); }
  .lcs-flag { display:inline-flex; align-items:center; }
  .lcs-flag .fi, .lcs-item .fi { width:20px; height:15px; border-radius:2px; background-size:cover; flex-shrink:0; }
  .lcs-arrow { flex-shrink: 0; transition: transform .18s; }
  .lcs-wrap.open .lcs-arrow { transform: rotate(180deg); }
  .lcs-menu {
    display: none; position: absolute; top: calc(100% + 5px); right: 0;
    background: var(--surface, #1a0a3e); border: 1px solid rgba(124,58,237,.3);
    border-radius: 10px; padding: 4px; list-style: none; margin: 0;
    min-width: 130px; z-index: 9000; box-shadow: 0 8px 24px rgba(4,0,16,.55);
  }
  .lcs-wrap.open .lcs-menu { display: block; }
  .lcs-item {
    display: flex; align-items: center; gap: 7px;
    padding: 7px 10px; border-radius: 7px; cursor: pointer;
    font-size: .8rem; font-weight: 600; color: var(--white);
    transition: background .15s;
  }
  .lcs-item:hover, .lcs-item:focus { background: rgba(124,58,237,.18); outline: none; }
  .lcs-item.lcs-active { background: rgba(124,58,237,.25); }

  /* Light mode overrides */
  html[data-theme="light"] .lcs-btn { color: #16063b; }
  html[data-theme="light"] .lcs-menu { background: #f0ebff; border-color: rgba(124,58,237,.3); }
  html[data-theme="light"] .lcs-item { color: #16063b; }
  html[data-theme="light"] .lcs-item:hover { background: rgba(124,58,237,.12); }
  html[data-theme="light"] .lcs-item.lcs-active { background: rgba(124,58,237,.2); }
</style>

<script>
/* ── Custom lang dropdown wiring ── */
(function () {
  var wrap  = document.getElementById('lcs-wrap');
  var btn   = document.getElementById('lcs-btn');
  var flag  = document.getElementById('lcs-flag');
  var lbl   = document.getElementById('lcs-label');
  var sel   = document.getElementById('lang-select');
  if (!wrap || !btn || !sel) return;
  function openMenu()  { wrap.classList.add('open');    btn.setAttribute('aria-expanded','true'); }
  function closeMenu() { wrap.classList.remove('open'); btn.setAttribute('aria-expanded','false'); }
  btn.addEventListener('click', function (e) { e.stopPropagation(); wrap.classList.contains('open') ? closeMenu() : openMenu(); });
  document.addEventListener('click', closeMenu);
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeMenu(); });
  wrap.querySelectorAll('.lcs-item').forEach(function (item) {
    item.addEventListener('click', function (e) {
      e.stopPropagation();
      var val = item.getAttribute('data-value');
      if (flag) { var fi=flag.querySelector('.fi'); if(fi){ fi.className='fi fi-'+item.getAttribute('data-flag'); } }
      if (lbl)  lbl.textContent   = item.getAttribute('data-label') || val;
      wrap.querySelectorAll('.lcs-item').forEach(function (i) { i.classList.remove('lcs-active'); });
      item.classList.add('lcs-active');
      closeMenu();
      sel.value = val;
      sel.dispatchEvent(new Event('change', { bubbles: true }));
    });
    item.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); item.click(); }
    });
  });
})();

/* ── Guild stats fetch (member count + online) ── */
(function () {
  var el = document.getElementById('gmeta-stats');
  if (!el) return;
  var gid = el.getAttribute('data-guild');
  fetch('/api/guild-stats/' + gid)
    .then(function (r) { return r.ok ? r.json() : null; })
    .then(function (d) {
      if (!d) return;
      var tot = document.getElementById('gms-total-val');
      var onl = document.getElementById('gms-online-val');
      if (tot && d.memberCount != null) tot.textContent = Number(d.memberCount).toLocaleString();
      if (onl && d.onlineCount  != null) onl.textContent = Number(d.onlineCount).toLocaleString();
      if (typeof lucide !== 'undefined') lucide.createIcons();
    })
    .catch(function () {});
})();

/* ── Profile presence fetch ── */
(function () {
  var STATUS_COLORS = { online: '#23a55a', idle: '#f0b232', dnd: '#f23f43', offline: '#80848e', invisible: '#80848e' };
  var STATUS_LABELS = {
    online:    (document.documentElement.lang === 'ar') ? 'متصل' : 'Online',
    idle:      (document.documentElement.lang === 'ar') ? 'بعيد' : 'Away',
    dnd:       (document.documentElement.lang === 'ar') ? 'لا تزعجني' : 'Do Not Disturb',
    offline:   (document.documentElement.lang === 'ar') ? 'غير متصل' : 'Offline',
    invisible: (document.documentElement.lang === 'ar') ? 'غير مرئي' : 'Invisible',
  };
  function applyPresence(data) {
    var status  = data.status || 'offline';
    var color   = STATUS_COLORS[status] || STATUS_COLORS.offline;
    var dot     = document.getElementById('prof-online-dot');
    var actDot  = document.getElementById('prof-actdot');
    var lbl     = document.getElementById('prof-status-label');
    var cust    = document.getElementById('prof-custom-status');
    if (dot)    { dot.style.background = color; dot.style.boxShadow = '0 0 6px ' + color + 'cc'; }
    if (actDot) { actDot.style.background = color; actDot.className = 'prof-actdot'; }
    if (lbl)    lbl.textContent = STATUS_LABELS[status] || STATUS_LABELS.offline;
    if (cust)   {
      if (data.customStatus) { cust.textContent = data.customStatus; cust.style.display = ''; }
      else                   { cust.style.display = 'none'; }
    }
  }
  fetch('/api/me/presence')
    .then(function (r) { return r.ok ? r.json() : null; })
    .then(function (d) { if (d) applyPresence(d); })
    .catch(function () {});
})();
</script>

<!-- ── Guild Welcome Overlay ─────────────────────────────────────────── -->
<div id="guild-welcome-ov" class="gwo-wrap gwo-hidden" aria-hidden="true" style="display:none;">
  <div class="gwo-card">

          src="https://cdn.discordapp.com/icons/<%= guildInfo.id %>/<%= guildInfo.icon %>.png?size=128"
          alt="<%= guildInfo.name %>" />
      <% } else { %>
        <div class="gwo-icon-fallback"><%= guildInfo.name.charAt(0).toUpperCase() %></div>
      <% } %>
    </div>
    <p class="gwo-title"><%= t.guild.welcomeTitle %></p>
    <h2 class="gwo-name"><%= guildInfo.name %></h2>
    <p class="gwo-sub"><%= t.guild.welcomeSub %></p>

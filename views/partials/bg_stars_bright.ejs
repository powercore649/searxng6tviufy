<%
  /* Bright variant — login / verify pages */
%><script>
(function () {
  'use strict';
  var canvas = document.getElementById('c');
  if (!canvas) return;
  var ctx = canvas.getContext('2d');
  if (!ctx) return;

  if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    canvas.style.display = 'none';
    return;
  }

  var isMobile = window.innerWidth <= 768;
  var N = isMobile ? 900 : 3200;
  var OP = 0.65, SZ = 0.75, SP = 0.00028 * 0.65;
  var DEPTH = 240, FOV = 320;
  var W, H, stars = [], mx = 0, my = 0, t = 0, raf;

  function resize() {
    W = canvas.width  = window.innerWidth;
    H = canvas.height = window.innerHeight;
  }
  function init() {
    stars = [];
    for (var i = 0; i < N; i++) stars.push({
      x: (Math.random() - 0.5) * DEPTH,
      y: (Math.random() - 0.5) * DEPTH,
      z: Math.random() * DEPTH,
      r: Math.random() * SZ + 0.3,
    });
  }
  function draw() {
    ctx.fillStyle = '#040010';
    ctx.fillRect(0, 0, W, H);
    t += SP;
    var cos = Math.cos(t), sin = Math.sin(t);
    for (var i = 0; i < N; i++) {
      var s = stars[i];
      var rx = s.x * cos - s.z * sin + mx * 24;
      var rz = s.x * sin + s.z * cos;
      var d  = FOV / (FOV + rz);
      var sx = rx * d + W * 0.5;
      var sy = (s.y + my * 12) * d + H * 0.5;
      if (sx < 0 || sx > W || sy < 0 || sy > H) continue;
      var a = Math.min(d * OP * 1.5, 1);
      ctx.beginPath();
      ctx.arc(sx, sy, Math.max(s.r * d, 0.3), 0, 6.2832);
      ctx.fillStyle = 'rgba(184,176,255,' + a.toFixed(2) + ')';
      ctx.fill();
    }
    raf = requestAnimationFrame(draw);
  }

  resize(); init(); draw();
  window.addEventListener('resize', function () { resize(); init(); });
  document.addEventListener('mousemove', function (e) {
    mx = (e.clientX / W - 0.5) * 0.3;
    my = (e.clientY / H - 0.5) * 0.15;
  });
  document.addEventListener('visibilitychange', function () {
    if (document.hidden) cancelAnimationFrame(raf); else draw();
  });
})();
</script>

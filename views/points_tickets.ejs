              </span>
              <% } %>
              <input class="picker-search" id="logs-search" type="text" placeholder="<%= lang === 'ar' ? 'ابحث عن قناة...' : 'Search channel...' %>" autocomplete="off">
            </div>
            <input type="hidden" id="logs-channel-val" class="cfg-field" data-path="logsChannelId" value="<%= staffPointsConfig.logsChannelId || '' %>">
            <div class="picker-dropdown" id="logs-dropdown">
              <% if (guildChannels.length === 0) { %>
              <div class="picker-empty"><%= lang === 'ar' ? 'لا توجد قنوات' : 'No channels found' %></div>
              <% } else { guildChannels.forEach(ch => { %>
              <div class="picker-opt" data-id="<%= ch.id %>" data-name="#<%= ch.name %>">#<%= ch.name %></div>
              <% }); } %>

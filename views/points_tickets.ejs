            <div class="toggle-row-label"><%= lang === 'ar' ? 'تفعيل الحماية' : 'Enable Anti-Abuse' %></div>
            <div class="toggle-row-sub"><%= lang === 'ar' ? 'تفعيل/إيقاف جميع حمايات الغش' : 'Master toggle for all abuse protections' %></div>
          </div>
          <label class="sw-wrap">
            <input type="checkbox" class="sw-input cfg-field" data-path="antiAbuse.enabled" <%= staffPointsConfig.antiAbuse.enabled ? 'checked' : '' %>>
            <div class="sw-track"><div class="sw-thumb"></div></div>
          </label>
        </div>
        <div class="toggle-row">
          <div>
            <div class="toggle-row-label"><%= lang === 'ar' ? 'منع الاستلام الذاتي' : 'No Self-Claim' %></div>
            <div class="toggle-row-sub"><%= lang === 'ar' ? 'لا نقاط إذا كان الإداري هو مفتح التذكرة' : 'No points if staff claims their own ticket' %></div>
          </div>
          <label class="sw-wrap">
            <input type="checkbox" class="sw-input cfg-field" data-path="antiAbuse.noSelfClaim" <%= staffPointsConfig.antiAbuse.noSelfClaim ? 'checked' : '' %>>
            <div class="sw-track"><div class="sw-thumb"></div></div>
          </label>
        </div>
        <div class="toggle-row">
          <div>
            <div class="toggle-row-label"><%= lang === 'ar' ? 'منع التقييم الذاتي' : 'No Self-Rate' %></div>
            <div class="toggle-row-sub"><%= lang === 'ar' ? 'لا نقاط إذا قيّم الإداري تذكرته بنفسه' : 'No points if staff rates their own ticket' %></div>
          </div>
          <label class="sw-wrap">
            <input type="checkbox" class="sw-input cfg-field" data-path="antiAbuse.noSelfRate" <%= staffPointsConfig.antiAbuse.noSelfRate ? 'checked' : '' %>>
            <div class="sw-track"><div class="sw-thumb"></div></div>
          </label>
        </div>
        <div class="toggle-row">
          <div>
            <div class="toggle-row-label"><%= lang === 'ar' ? 'منع تكرار النقاط' : 'No Duplicate Points' %></div>
            <div class="toggle-row-sub"><%= lang === 'ar' ? 'نقطة واحدة لكل تذكرة/أمر (منع التكرار)' : 'One-time points per ticket/action (no repeats)' %></div>
          </div>
          <label class="sw-wrap">
            <input type="checkbox" class="sw-input cfg-field" data-path="antiAbuse.noDuplicatePoints" <%= staffPointsConfig.antiAbuse.noDuplicatePoints ? 'checked' : '' %>>
            <div class="sw-track"><div class="sw-thumb"></div></div>
          </label>
        </div>
      </div>
    </div>

    <%# ── Section 5: Rewards ──────────────────────────────────────── %>
    <div class="sec-card" id="sec-rewards">
      <div class="sec-head" onclick="toggleSec('sec-rewards')">
        <div class="sec-head-left">
          <div class="sec-icon red"><i data-lucide="gift" style="width:18px;height:18px;stroke:currentColor;fill:none;"></i></div>
          <div>
            <div class="sec-title"><%= lang === 'ar' ? 'نظام المكافآت' : 'Rewards System' %></div>
            <div class="sec-sub"><%= lang === 'ar' ? 'منح رتب عند الوصول لعدد معين من النقاط' : 'Grant roles when staff reach a point threshold' %></div>
          </div>
        </div>
        <div style="display:flex;align-items:center;gap:14px;">
          <label class="sw-wrap" onclick="event.stopPropagation()">
            <input type="checkbox" class="sw-input cfg-field" data-path="rewards.enabled" <%= staffPointsConfig.rewards.enabled ? 'checked' : '' %>>
            <div class="sw-track"><div class="sw-thumb"></div></div>
          </label>
          <i data-lucide="chevron-down" class="sec-chevron" style="width:18px;height:18px;stroke:currentColor;fill:none;"></i>
        </div>
      </div>
      <div class="sec-body">
        <div class="tip">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <%= lang === 'ar' ? 'عند وصول الإداري لعدد النقاط المحدد، تمنح الرتبة تلقائياً.' : 'When staff reach the set point threshold, the role is auto-granted.' %>
        </div>
        <div id="rewards-list">
          <% (staffPointsConfig.rewards.list || []).forEach(function(reward, idx) { %>
          <div class="reward-row" data-rid="<%= reward.id || idx %>">
            <input type="number" class="reward-pts-input" placeholder="100" value="<%= reward.points %>" min="1" max="99999">
            <span class="reward-sep"><%= lang === 'ar' ? 'نقطة →' : 'pts →' %></span>
            <select class="reward-role-sel">
              <option value=""><%= lang === 'ar' ? 'رتبة (اختياري)' : 'Role (optional)' %></option>
              <% guildRoles.forEach(function(r) { %>
              <option value="<%= r.id %>" <%= reward.roleId === r.id ? 'selected' : '' %>>@<%= r.name %></option>
              <% }); %>
            </select>
            <input type="text" class="reward-label-input" placeholder="<%= lang === 'ar' ? 'وصف المكافأة (اختياري)' : 'Reward label (optional)' %>" value="<%= reward.label || '' %>" maxlength="80">
            <button class="btn-del-reward" type="button" onclick="delReward(this)">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M3 6h18"/><path d="M19 6l-1 14H6L5 6"/><path d="M9 6V4h6v2"/></svg>
            </button>
          </div>
          <% }); %>
        </div>
        <button class="btn-add-reward" type="button" onclick="addReward()">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>

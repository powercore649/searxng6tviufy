  <%# ── Save bar ──────────────────────────────────────────────────── %>
  <div class="save-bar" id="save-bar">
    <span class="save-bar-text"><%= lang === 'ar' ? 'لديك تغييرات غير محفوظة' : 'You have unsaved changes' %></span>
    <div class="save-bar-actions">
      <button class="btn-discard" onclick="discardChanges()"><%= lang === 'ar' ? 'إلغاء' : 'Discard' %></button>
      <button class="btn-save-main" id="btn-save" onclick="saveConfig()">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13"/><polyline points="7 3 7 8 15 8"/></svg>
        <%= lang === 'ar' ? 'حفظ' : 'Save' %>
      </button>
    </div>
  </div>

  <div class="toast" id="toast"></div>

  <%- include('partials/bg_stars') %>
  <script type="application/json" id="_channels"><%- JSON.stringify(guildChannels) %></script>
  <script type="application/json" id="_roles"><%- JSON.stringify(guildRoles) %></script>
  <script type="application/json" id="_cmds"><%- JSON.stringify(guildCommands) %></script>
  <script>
    const IS_AR = '<%= lang %>' === 'ar';
    const GUILD_ID = '<%= guildId %>';

    /* ── Server data ─────────────────────────────── */
    const GUILD_CHANNELS = JSON.parse(document.getElementById('_channels').textContent);
    const GUILD_ROLES     = JSON.parse(document.getElementById('_roles').textContent);
    const GUILD_COMMANDS  = JSON.parse(document.getElementById('_cmds').textContent);

    /* ── Language select ─────────────────────────── */
    document.getElementById('lang-select').addEventListener('change', function () {
      const u = new URL(window.location.href);
      u.searchParams.set('lang', this.value);
      window.location.href = u.toString();
    });

    /* ── Mobile nav ──────────────────────────────── */
    const menuToggle  = document.getElementById('menu-toggle');
    const mgmtSidebar = document.getElementById('mgmt-sidebar');
    const navSidebar  = document.querySelector('.nav-sidebar');
    const navOverlay  = document.getElementById('nav-overlay');
    const sortBtn     = document.getElementById('mgmt-sort-btn');
    function openMgmt()  { mgmtSidebar.classList.add('open'); navOverlay.classList.add('open'); document.body.style.overflow='hidden'; }
    function closeMgmt() { mgmtSidebar.classList.remove('open'); navOverlay.classList.remove('open'); document.body.style.overflow=''; }
    function openNav()   { if (navSidebar) { navSidebar.classList.add('open'); navOverlay.classList.add('open'); document.body.style.overflow='hidden'; } }
    function closeNav()  { if (navSidebar) { navSidebar.classList.remove('open'); navOverlay.classList.remove('open'); document.body.style.overflow=''; } }
    if (menuToggle) menuToggle.addEventListener('click', function(e) { e.stopPropagation(); mgmtSidebar.classList.contains('open') ? closeMgmt() : openMgmt(); });
    if (navOverlay) navOverlay.addEventListener('click', function() { closeMgmt(); closeNav(); });
    if (sortBtn)    sortBtn.addEventListener('click', function(e) { e.stopPropagation(); if (navSidebar && navSidebar.classList.contains('open')) { closeNav(); } else { closeMgmt(); openNav(); } });
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape') { closeMgmt(); closeNav(); } });

    /* ── Mgmt section collapse ───────────────────── */
    document.querySelectorAll('.mgmt-section-btn').forEach(function(btn) {
      btn.addEventListener('click', function () {
        const body = this.nextElementSibling;
        const isOpen = body.classList.contains('open');
        body.classList.toggle('open', !isOpen);
        this.classList.toggle('open', !isOpen);
      });
    });

    /* ── Page transitions ────────────────────────── */
    function fadeOut(href) {
      const ov = document.getElementById('ov');
      ov.classList.add('leave');
      setTimeout(function() { window.location.href = href; }, 360);
    }
    document.querySelectorAll('a.nav-link').forEach(function(a) {
      a.addEventListener('click', function (e) {
        if (this.target === '_blank') return;
        e.preventDefault(); fadeOut(this.href);
      });
    });

    /* ── Toast ───────────────────────────────────── */
    function showToast(msg, type) {
      type = type || 'success';
      const el = document.getElementById('toast');
      const icon = type === 'success'
        ? '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>'
        : '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>';
      el.className = 'toast ' + type;
      el.innerHTML = icon + ' ' + msg;
      el.classList.add('show');
      setTimeout(function(){ el.classList.remove('show'); }, 3500);
    }

    /* ── Profile sidebar ─────────────────────────── */
    const profSidebar  = document.getElementById('prof-sidebar');
    const profBackdrop = document.getElementById('prof-backdrop');
    const openBtn      = document.getElementById('open-profile');
    const closeBtn     = document.getElementById('close-profile');
    const copyId       = document.getElementById('prof-copy-id');
    const bannerSolid  = document.querySelector('.prof-banner-solid');
    if (bannerSolid && bannerSolid.dataset.bg) bannerSolid.style.background = bannerSolid.dataset.bg;
    function openProfile()  { if (!profSidebar) return; profSidebar.classList.add('open'); profBackdrop.classList.add('open'); profSidebar.setAttribute('aria-hidden','false'); document.body.style.overflow='hidden'; }
    function closeProfile() { if (!profSidebar) return; profSidebar.classList.remove('open'); profBackdrop.classList.remove('open'); profSidebar.setAttribute('aria-hidden','true'); document.body.style.overflow=''; }
    if (openBtn)  openBtn.addEventListener('click', openProfile);
    document.querySelectorAll('.open-profile-btn').forEach(function(b){ b.addEventListener('click', openProfile); });
    if (closeBtn) closeBtn.addEventListener('click', closeProfile);
    if (profBackdrop) profBackdrop.addEventListener('click', closeProfile);
    document.addEventListener('keydown', function(e){ if (e.key === 'Escape') closeProfile(); });
    if (copyId) {
      copyId.addEventListener('click', function() {
        navigator.clipboard.writeText(copyId.textContent.trim()).then(function() {
          const orig = copyId.textContent;
          copyId.textContent = 'Copied!'; copyId.style.color = 'var(--cyan-l)';
          setTimeout(function(){ copyId.textContent = orig; copyId.style.color = ''; }, 1500);
        });
      });
    }

    /* ── Section accordion ───────────────────────── */
    function toggleSec(id) {
      const el = document.getElementById(id);
      if (el) el.classList.toggle('open');
    }

    /* ── Change tracking ─────────────────────────── */
    let dirty = false;
    function markDirty() {
      dirty = true;
      document.getElementById('save-bar').classList.add('visible');
    }
    function clearDirty() {
      dirty = false;
      document.getElementById('save-bar').classList.remove('visible');
    }
    document.querySelectorAll('.cfg-field').forEach(function(el) {
      el.addEventListener('change', markDirty);
      el.addEventListener('input', markDirty);
    });

    /* ── Logs channel picker ─────────────────────── */
    (function initLogsPicker() {
      const picker   = document.getElementById('logs-picker');
      const search   = document.getElementById('logs-search');
      const dropdown = document.getElementById('logs-dropdown');
      const hiddenVal= document.getElementById('logs-channel-val');
      const inputRow = document.getElementById('logs-input-row');

      function renderDropdown(query) {
        const q = (query || '').toLowerCase();
        const filtered = GUILD_CHANNELS.filter(function(c){ return c.name.toLowerCase().includes(q); });
        dropdown.innerHTML = filtered.length
          ? filtered.map(function(c){ return '<div class="picker-opt" data-id="'+c.id+'" data-name="#'+c.name+'">#'+c.name+'</div>'; }).join('')
          : '<div class="picker-empty">' + (IS_AR ? 'لا توجد نتائج' : 'No results') + '</div>';
        dropdown.querySelectorAll('.picker-opt').forEach(function(opt){
          opt.addEventListener('click', function(){ selectChannel(opt.dataset.id, opt.dataset.name); });
        });
      }

      function selectChannel(id, name) {
        hiddenVal.value = id;
        inputRow.querySelectorAll('.picker-chip').forEach(function(c){ c.remove(); });
        const chip = document.createElement('span');
        chip.className = 'picker-chip';
        chip.dataset.id = id;
        chip.innerHTML = name + ' <button class="picker-chip-del" type="button">✕</button>';
        chip.querySelector('.picker-chip-del').addEventListener('click', function(e){
          e.stopPropagation(); chip.remove(); hiddenVal.value = ''; search.value = ''; markDirty();
        });
        inputRow.insertBefore(chip, search);
        search.value = '';
        dropdown.classList.remove('open');
        markDirty();
      }

      inputRow.querySelectorAll('.picker-chip .picker-chip-del').forEach(function(btn){
        btn.addEventListener('click', function(e){ e.stopPropagation(); btn.closest('.picker-chip').remove(); hiddenVal.value = ''; markDirty(); });
      });

      search.addEventListener('focus', function(){ renderDropdown(search.value); dropdown.classList.add('open'); });
      search.addEventListener('input', function(){ renderDropdown(search.value); });
      document.addEventListener('click', function(e){ if (!picker.contains(e.target)) dropdown.classList.remove('open'); });
    })();

    /* ── Commands list ─────────────────────────────── */
    function addCmd() {
      const list = document.getElementById('cmd-list');
      const id   = Date.now();
      const row  = document.createElement('div');
      row.className = 'cmd-row'; row.dataset.cid = id;
      const termSvg = '<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" style="color:var(--cyan-l);flex-shrink:0;"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>';
      const cmdOpts = GUILD_COMMANDS.map(function(c){ return '<option value="'+c+'">'+c.replace(/</g,'&lt;')+'</option>'; }).join('');
      row.innerHTML =
        '<div class="cmd-name">' +
          termSvg +
          '<select class="cmd-name-sel"><option value="">'+(IS_AR?'اختر أمراً...':'Pick command...')+'</option>'+cmdOpts+'</select>' +
        '</div>' +
        '<div style="display:flex;align-items:center;gap:6px;flex-shrink:0;">' +
          '<input type="number" class="cmd-pts-input" value="1" min="-9999" max="9999" placeholder="1">' +
          '<span class="pts-unit">'+(IS_AR?'نقطة':'pts')+'</span>' +
        '</div>' +
        '<button class="btn-del-cmd" type="button" onclick="delCmd(this)">' +
          '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M3 6h18"/><path d="M19 6l-1 14H6L5 6"/><path d="M9 6V4h6v2"/></svg>' +
        '</button>';
      list.appendChild(row);
      row.querySelector('.cmd-name-sel').addEventListener('change', markDirty);
      row.querySelector('.cmd-pts-input').addEventListener('input', markDirty);
      markDirty();
    }
    function delCmd(btn) { btn.closest('.cmd-row').remove(); markDirty(); }
    document.querySelectorAll('#cmd-list .cmd-name-sel, #cmd-list .cmd-pts-input').forEach(function(el){
      el.addEventListener('change', markDirty); el.addEventListener('input', markDirty);
    });

    /* ── Rewards list ─────────────────────────────── */
    function addReward() {
      const list = document.getElementById('rewards-list');
      const id   = Date.now();
      const row  = document.createElement('div');
      row.className = 'reward-row'; row.dataset.rid = id;
      const roleOpts = GUILD_ROLES.map(function(r){ return '<option value="'+r.id+'">@'+r.name.replace(/</g,'&lt;')+'</option>'; }).join('');
      row.innerHTML =
        '<input type="number" class="reward-pts-input" placeholder="100" min="1" max="99999">' +
        '<span class="reward-sep">'+(IS_AR?'نقطة →':'pts →')+'</span>' +
        '<select class="reward-role-sel">' +
          '<option value="">'+(IS_AR?'رتبة (اختياري)':'Role (optional)')+'</option>' +
          roleOpts +
        '</select>' +
        '<input type="text" class="reward-label-input" placeholder="'+(IS_AR?'وصف المكافأة (اختياري)':'Reward label (optional)')+'" maxlength="80">' +
        '<button class="btn-del-reward" type="button" onclick="delReward(this)">' +
          '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M3 6h18"/><path d="M19 6l-1 14H6L5 6"/><path d="M9 6V4h6v2"/></svg>' +
        '</button>';
      list.appendChild(row);
      row.querySelector('.reward-pts-input').addEventListener('input', markDirty);
      row.querySelector('.reward-role-sel').addEventListener('change', markDirty);
      row.querySelector('.reward-label-input').addEventListener('input', markDirty);
      markDirty();
    }
    function delReward(btn) { btn.closest('.reward-row').remove(); markDirty(); }
    document.querySelectorAll('.reward-row .reward-pts-input, .reward-row .reward-role-sel, .reward-row .reward-label-input').forEach(function(el){
      el.addEventListener('change', markDirty); el.addEventListener('input', markDirty);
    });

    /* ── Build config object from DOM ────────────── */
    function buildConfig() {
      function field(path) {
        const el = document.querySelector('.cfg-field[data-path="' + path + '"]');
        if (!el) return undefined;
        if (el.type === 'checkbox') return el.checked;
        return el.value;
      }
      function numField(path, def) {
        const v = parseInt(field(path), 10);
        return isNaN(v) ? def : v;
      }
      const rewards = [];
      document.querySelectorAll('#rewards-list .reward-row').forEach(function(row){
        const pts = parseInt(row.querySelector('.reward-pts-input').value, 10);
        if (isNaN(pts) || pts <= 0) return;
        rewards.push({
          id:     row.dataset.rid,
          points: pts,
          roleId: row.querySelector('.reward-role-sel').value,
          label:  (row.querySelector('.reward-label-input')?.value || '').slice(0, 80),
        });
      });
      const commands = [];
      document.querySelectorAll('#cmd-list .cmd-row').forEach(function(row){
        const name = row.querySelector('.cmd-name-sel').value;
        if (!name) return;
        commands.push({ id: row.dataset.cid, name: name, points: parseInt(row.querySelector('.cmd-pts-input').value, 10) || 1 });
      });
      return {
        enabled: field('enabled'),
        ticketPoints: {
          enabled: field('ticketPoints.enabled'),
          claim: { enabled: field('ticketPoints.claim.enabled'), points: numField('ticketPoints.claim.points', 5) },
          close: { enabled: field('ticketPoints.close.enabled'), points: numField('ticketPoints.close.points', 3) },
        },
        ratingPoints: {
          enabled: field('ratingPoints.enabled'),
          stars: {
            5: numField('ratingPoints.stars.5', 10),
            4: numField('ratingPoints.stars.4', 5),
            3: numField('ratingPoints.stars.3', 0),
            2: numField('ratingPoints.stars.2', -2),
            1: numField('ratingPoints.stars.1', -5),
          },
        },
        commandPoints: { enabled: field('commandPoints.enabled'), commands: commands },
        logsChannelId: document.getElementById('logs-channel-val').value || null,
        antiAbuse: {
          enabled:           field('antiAbuse.enabled'),
          noSelfClaim:       field('antiAbuse.noSelfClaim'),
          noSelfRate:        field('antiAbuse.noSelfRate'),
          noDuplicatePoints: field('antiAbuse.noDuplicatePoints'),
          cooldownMinutes:   60,
        },
        rewards: { enabled: field('rewards.enabled'), list: rewards },
      };
    }

    /* ── Save ────────────────────────────────────── */
    async function saveConfig() {
      const btn = document.getElementById('btn-save');
      btn.classList.add('loading');
      btn.textContent = IS_AR ? 'جاري الحفظ...' : 'Saving...';
      try {
        const cfg  = buildConfig();
        const resp = await fetch('/dashboard/' + GUILD_ID + '/points/tickets/save', {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify(cfg),
        });
        const data = await resp.json();
        if (data.ok) {
          clearDirty();
          showToast(IS_AR ? '✅ تم الحفظ بنجاح' : '✅ Saved successfully', 'success');
        } else {
          showToast(IS_AR ? '❌ فشل الحفظ' : '❌ Failed to save', 'error');
        }
      } catch (_) {
        showToast(IS_AR ? '❌ خطأ في الاتصال' : '❌ Connection error', 'error');
      } finally {
        btn.classList.remove('loading');
        btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13"/><polyline points="7 3 7 8 15 8"/></svg> ' + (IS_AR ? 'حفظ' : 'Save');
      }
    }

    function discardChanges() { window.location.reload(); }

    window.addEventListener('beforeunload', function(e){ if (dirty) { e.preventDefault(); e.returnValue = ''; } });
  </script>
  <script src="/js/lucide.min.js"></script>
  <script>lucide.createIcons();</script>
  <%- include('partials/promo_card') %>
  <%- include('partials/footer') %>
</body>
</html>


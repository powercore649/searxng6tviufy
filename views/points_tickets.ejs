      <div class="sec-head" onclick="toggleSec('sec-general')">
        <div class="sec-head-left">
          <div class="sec-icon green"><i data-lucide="settings-2" style="width:18px;height:18px;stroke:currentColor;fill:none;"></i></div>
          <div>
            <div class="sec-title"><%= lang === 'ar' ? 'الإعدادات العامة' : 'General Settings' %></div>
            <div class="sec-sub"><%= lang === 'ar' ? 'قناة الـ Logs وحماية من الغش' : 'Logs channel & anti-abuse' %></div>
          </div>
        </div>
        <i data-lucide="chevron-down" class="sec-chevron" style="width:18px;height:18px;stroke:currentColor;fill:none;"></i>
      </div>
      <div class="sec-body">
        <%# Logs channel picker %>
        <div class="field" style="margin-bottom:18px;">
          <label class="field-label"><%= lang === 'ar' ? '📋 قناة سجل النقاط' : '📋 Points Log Channel' %></label>
          <div class="picker-wrap" id="logs-picker">
            <div class="picker-input-row" id="logs-input-row">
              <% if (staffPointsConfig.logsChannelId) {
                const foundCh = guildChannels.find(c => c.id === staffPointsConfig.logsChannelId);
              %>
              <span class="picker-chip" data-id="<%= staffPointsConfig.logsChannelId %>">

  <!-- ═══ SELECT OPTION EDIT MODAL ═══ -->
  <div class="modal-overlay" id="optEditModal">
    <div class="modal">
      <h3><%= lang === 'ar' ? 'تعديل خيار' : 'Edit Option' %></h3>
      <div class="bld-field">
        <label class="bld-label"><%= lang === 'ar' ? 'النص' : 'Label' %></label>

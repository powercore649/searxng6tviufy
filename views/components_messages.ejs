        closeEditor();
      });

      // ═══ SMART TRIGGERS MODAL ═══
      // providesChannel: true  → trigger supplies the Discord channel at runtime (no explicit channel needed)
      // providesChannel: false → trigger fires but relies on the configured Primary Channel to know where to send
      // Generate a cryptographically-random 32-hex-char webhook token
      function _genWebhookToken() {
        if (window.crypto?.getRandomValues) {
          const arr = new Uint8Array(16);
          window.crypto.getRandomValues(arr);
          return Array.from(arr).map(b => b.toString(16).padStart(2, '0')).join('');
        }
        return Date.now().toString(36) + Math.random().toString(36).slice(2) + Math.random().toString(36).slice(2);
      }

      const TRIGGER_TYPES = [
        { value: 'slash_command',    label: isAR ? 'أمر Slash'       : 'Slash Command',           icon: 'terminal',       providesChannel: true,  params: [{ key: 'name',       label: isAR ? 'اسم الأمر'      : 'Command name',    placeholder: '/menu'    }] },
        { value: 'on_join',          label: isAR ? 'انضمام عضو'     : 'Member Joins',             icon: 'user-plus',      providesChannel: false, params: [] },
        { value: 'member_leave',     label: isAR ? 'مغادرة عضو'     : 'Member Leaves',            icon: 'user-minus',     providesChannel: false, params: [] },
        { value: 'role_add',         label: isAR ? 'حصل على رتبة'   : 'Role Assigned',            icon: 'shield-plus',    providesChannel: false, params: [{ key: 'roleId', label: isAR ? 'الرتبة (اختياري)' : 'Role (optional)', type: 'select', getOptions: () => roles.map(r => ({ id: r.id, name: r.name })) }] },
        { value: 'role_remove',      label: isAR ? 'أُزيلت رتبته'   : 'Role Removed',             icon: 'shield-minus',   providesChannel: false, params: [{ key: 'roleId', label: isAR ? 'الرتبة (اختياري)' : 'Role (optional)', type: 'select', getOptions: () => roles.map(r => ({ id: r.id, name: r.name })) }] },
        { value: 'on_reaction',      label: isAR ? 'تفاعل'           : 'Reaction Added',           icon: 'smile-plus',     providesChannel: true,  params: [{ key: 'emoji',      label: isAR ? 'الإيموجي'       : 'Emoji',           placeholder: '👍'     }] },
        { value: 'scheduled',        label: isAR ? 'مجدول'            : 'Scheduled',                icon: 'clock',          providesChannel: false, params: [{ key: 'cron',       label: isAR ? 'Cron'           : 'Cron expression', placeholder: '0 9 * * *' }] },
        { value: 'webhook',          label: isAR ? 'Webhook'          : 'Webhook',                  icon: 'webhook',        providesChannel: false, params: [{ key: 'token', label: isAR ? 'رابط الـ Webhook' : 'Webhook URL', type: 'webhook_url' }] },
        { value: 'on_message',       label: isAR ? 'رسالة تطابق'     : 'Message Pattern',          icon: 'message-square', providesChannel: true,  params: [{ key: 'pattern',    label: isAR ? 'النمط (regex)' : 'Pattern (regex)', placeholder: '^!start' }] },
        { value: 'on_channel_create',label: isAR ? 'قناة جديدة'      : 'New Channel in Category',  icon: 'folder-plus',    providesChannel: true,  params: [{ key: 'categoryId', label: isAR ? 'الكاتيغوري'    : 'Category',        type: 'select', getOptions: () => categories }] },
      ];

      /**
       * Returns the channel-context status based on active triggers:
       *  'all_provided'  — every active trigger provides its own channel at runtime
       *  'some_provided' — mixed: some need an explicit channel, some don't
       *  'none_provided' — all active triggers need an explicit channel
       *  'no_triggers'   — no triggers at all (optional immediate send)
       */
      function _triggerChannelCtx() {
        if (!flowTriggers.length) return 'no_triggers';
        const provided = flowTriggers.filter(t => {
          const def = TRIGGER_TYPES.find(tt => tt.value === t.type);
          return def?.providesChannel === true;
        });
        if (provided.length === flowTriggers.length) return 'all_provided';
        if (provided.length > 0)                     return 'some_provided';
        return 'none_provided';
      }

      function renderTriggersModal() {
        const picker = document.getElementById('trgTypePicker');
        const list   = document.getElementById('trgList');
        if (!picker || !list) return;
        // Type add buttons
        picker.innerHTML = TRIGGER_TYPES.map(t =>
          '<button class="fl-trg-type-btn _add-trg" data-ttype="' + t.value + '" type="button"><i data-lucide="' + t.icon + '" style="width:13px;height:13px;stroke:currentColor;flex-shrink:0;vertical-align:-2px;"></i> ' + t.label + '</button>'
        ).join('');
        picker.querySelectorAll('._add-trg').forEach(btn => {
          btn.addEventListener('click', () => {
            const tt = TRIGGER_TYPES.find(t => t.value === btn.dataset.ttype);
            if (!tt) return;
            const defaultParams = {};
            if (tt.value === 'webhook') defaultParams.token = _genWebhookToken();
            flowTriggers.push({ id: uid(), type: tt.value, params: defaultParams });
            renderTriggersModal();
          });
        });
        lucide.createIcons();
        // Render trigger items
        list.innerHTML = '';
        if (!flowTriggers.length) {
          list.innerHTML = '<div style="text-align:center;color:var(--muted);font-size:.79rem;padding:24px 0;">' + (isAR ? 'لا مُشغِّلات بعد — اختر واحداً أعلاه' : 'No triggers yet — pick one above') + '</div>';
          return;
        }
        flowTriggers.forEach((trg, ti) => {
          const tt = TRIGGER_TYPES.find(t => t.value === trg.type) || { icon: '⚡', label: trg.type, params: [] };
          const item = document.createElement('div');
          item.className = 'fl-trg-item';
          let paramsHtml = '';
          tt.params.forEach(p => {
            if (p.type === 'webhook_url') {
              // Auto-generate token if missing (e.g. loaded from old save)
              if (!trg.params[p.key]) trg.params[p.key] = _genWebhookToken();
              const token = trg.params[p.key];
              const webhookUrl = window.location.origin + '/api/webhook/components/' + GUILD_ID + '/' + trg.id + '?token=' + encodeURIComponent(token);
              paramsHtml +=
                '<label>' + esc(p.label) + '</label>' +
                '<div style="display:flex;gap:6px;align-items:center;margin-top:4px;">' +
                  '<input type="text" readonly value="' + esc(webhookUrl) + '" class="_wh-url" data-trgid="' + trg.id + '" style="flex:1;font-size:.65rem;background:rgba(255,255,255,.04);color:var(--muted);cursor:text;">' +
                  '<button type="button" class="btn btn-ghost btn-sm _copy-webhook" data-url="' + esc(webhookUrl) + '" style="flex-shrink:0;font-size:.68rem;padding:3px 10px;white-space:nowrap;">' + (isAR ? 'نسخ' : 'Copy') + '</button>' +
                '</div>';
            } else if (p.type === 'select') {
              const opts = (typeof p.getOptions === 'function' ? p.getOptions() : [])
                .map(o => '<option value="' + esc(o.id) + '"' + (trg.params[p.key] === o.id ? ' selected' : '') + '>' + esc(o.name) + '</option>')
                .join('');
              paramsHtml +=
                '<label>' + esc(p.label) + '</label>' +
                '<select data-trgid="' + trg.id + '" data-key="' + esc(p.key) + '" class="bld-select" style="font-size:.74rem;width:100%;margin-top:4px;">' +
                  '<option value="">' + (isAR ? '— اختر —' : '— Any —') + '</option>' + opts +
                '</select>';
            } else {
              paramsHtml +=
                '<label>' + esc(p.label) + '</label>' +
                '<input type="text" data-trgid="' + trg.id + '" data-key="' + esc(p.key) + '" value="' + esc(trg.params[p.key] || '') + '" placeholder="' + esc(p.placeholder || '') + '">';
            }
          });
          item.innerHTML =
            '<div class="fl-trg-item-head">' +
              '<span class="fl-trg-icon"><i data-lucide="' + tt.icon + '" style="width:16px;height:16px;stroke:currentColor;"></i></span>' +
              '<span class="fl-trg-label">' + esc(tt.label) + '</span>' +
              '<span class="fl-trg-badge active">active</span>' +
              '<button class="fl-trg-del-btn _del-trg" data-ti="' + ti + '" type="button">×</button>' +
            '</div>' +
            (paramsHtml ? '<div class="fl-trg-params">' + paramsHtml + '</div>' : '');
          item.querySelectorAll('.fl-trg-params input').forEach(inp => {
            inp.addEventListener('input', () => {
              const trgItem = flowTriggers.find(t => t.id === inp.dataset.trgid);
              if (trgItem) trgItem.params[inp.dataset.key] = inp.value;
            });
          });
          item.querySelectorAll('.fl-trg-params select').forEach(sel => {
            sel.addEventListener('change', () => {
              const trgItem = flowTriggers.find(t => t.id === sel.dataset.trgid);
              if (trgItem) trgItem.params[sel.dataset.key] = sel.value;
            });
          });
          item.querySelectorAll('._copy-webhook').forEach(copyBtn => {
            copyBtn.addEventListener('click', () => {
              navigator.clipboard.writeText(copyBtn.dataset.url || '').catch(() => {
                // Fallback for non-secure contexts
                const ta = document.createElement('textarea');
                ta.value = copyBtn.dataset.url || '';
                document.body.appendChild(ta); ta.select(); document.execCommand('copy'); ta.remove();
              });
              const orig = copyBtn.textContent;
              copyBtn.textContent = isAR ? '✓ تم' : '✓ Copied';
              setTimeout(() => { copyBtn.textContent = orig; }, 2000);
            });
          });
          item.querySelector('._del-trg')?.addEventListener('click', () => {
            flowTriggers.splice(ti, 1);
            renderTriggersModal();
          });
          list.appendChild(item);
        });
        lucide.createIcons();
      }


  <!-- ═══ IF / THEN LOGIC BUILDER MODAL ═══ -->
  <div class="modal-overlay" id="actionModal">
    <div class="modal if-modal">
      <!-- Header -->
      <div class="if-modal-head">
        <div class="if-modal-head-left">
          <span class="if-modal-icon">⚡</span>
          <div>
            <div class="if-modal-title" id="actionModalTitle"><%= lang === 'ar' ? 'منطق التفاعل' : 'Interaction Logic' %></div>
            <div class="if-modal-sub" id="actionModalSub"></div>
          </div>
        </div>
        <button class="icon-btn" id="actionCancel" title="Close" style="font-size:.9rem;">✕</button>
      </div>
      <!-- Rule list -->
      <div class="if-rule-list" id="ifRuleList"></div>
      <!-- Add Rule Block -->
      <button class="if-add-rule-btn" id="addRuleBlock" type="button">
        <span>+</span>
        <%= lang === 'ar' ? 'إضافة كتلة شرطية جديدة' : 'Add Rule Block' %>
      </button>
      <!-- Footer -->
      <div class="modal-actions if-modal-footer">
        <button class="btn btn-ghost btn-sm" id="actionCancel2"><%= lang === 'ar' ? 'إلغاء' : 'Cancel' %></button>
        <button class="btn btn-primary btn-sm" id="actionSave">
          <%= lang === 'ar' ? '💾 حفظ المنطق' : '💾 Save Logic' %>
        </button>
      </div>
    </div>
  </div>

  <!-- ═══ DELETE CONFIRM MODAL ═══ -->
  <div class="modal-overlay" id="deleteModal">
    <div class="modal" style="min-width:340px;text-align:center;">
      <h3><%= lang === 'ar' ? 'تأكيد الحذف' : 'Confirm Delete' %></h3>
      <p style="font-size:.82rem;color:var(--muted);margin-bottom:16px;" id="deleteText"></p>
      <div class="modal-actions" style="justify-content:center;">
        <button class="btn btn-ghost btn-sm" id="deleteCancelBtn"><%= lang === 'ar' ? 'إلغاء' : 'Cancel' %></button>
        <button class="btn btn-danger btn-sm" id="deleteConfirmBtn"><%= lang === 'ar' ? 'حذف' : 'Delete' %></button>
      </div>
    </div>

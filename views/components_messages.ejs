            const contColor = card.querySelector('._cont-color');
            if (contColor) contColor.addEventListener('input', () => { compRows[ri].accentColor = contColor.value; markDirty(); renderCompRows(); });
            card.querySelector('._cont-clear')?.addEventListener('click', () => { compRows[ri].accentColor = ''; markDirty(); renderCompRows(); });

            // Delete child

      /* ═══ SLASH QUICK-ADD ═══ */
      (function initSlashCmd() {
        const CMDS = [
          { key: '/text', label: isAR ? 'نص'           : 'Text Display',  desc: isAR ? 'كتلة نص حر'       : 'Free-text markdown block',  fn: () => addTextDisplayRow() },
          { key: '/btn',  label: isAR ? 'أزرار'         : 'Buttons',       desc: isAR ? 'صف أزرار تفاعلية' : 'Interactive button row',     fn: () => addButtonRow()      },
          { key: '/sel',  label: isAR ? 'قائمة منسدلة' : 'Select Menu',   desc: isAR ? 'قائمة اختيار'     : 'Dropdown selection menu',   fn: () => addSelectRow()      },
          { key: '/sep',  label: isAR ? 'فاصل'          : 'Separator',     desc: isAR ? 'خط أو مسافة فارغة': 'Divider line or spacing',    fn: () => addSeparatorRow()   },
          { key: '/img',  label: isAR ? 'صورة'          : 'Image',         desc: isAR ? 'عرض صورة'         : 'Display an image',           fn: () => addImageRow()       },
          { key: '/cnt',  label: isAR ? 'حاوية'         : 'Container',     desc: isAR ? 'حاوية بلون حد'    : 'Accent-border container',    fn: () => addContainerRow()   },
        ];
        const inp  = document.getElementById('slashInput');
        const menu = document.getElementById('slashMenu');
        if (!inp || !menu) return;
        let activeIdx = 0;

        function filtered() {
          const q = inp.value.toLowerCase().replace(/^\//, '');
          return q === '' ? CMDS : CMDS.filter(c => c.key.slice(1).startsWith(q) || c.label.toLowerCase().includes(q));
        }
        function renderMenu() {
          if (!inp.value.startsWith('/')) { menu.classList.remove('open'); return; }
          const items = filtered();
          if (!items.length) { menu.classList.remove('open'); return; }
          activeIdx = Math.min(activeIdx, items.length - 1);
          menu.innerHTML = items.map((c, i) =>
            '<div class="bld-slash-item' + (i === activeIdx ? ' slash-active' : '') + '" data-i="' + i + '">' +
              '<span class="bld-slash-item-key">' + c.key + '</span>' +
              '<div class="bld-slash-item-text">' +
                '<div class="bld-slash-item-label">' + c.label + '</div>' +
                '<div class="bld-slash-item-desc">'  + c.desc  + '</div>' +
              '</div></div>'
          ).join('');
          menu.classList.add('open');
          menu.querySelectorAll('.bld-slash-item').forEach(el => {
            el.addEventListener('mousedown', e => {
              e.preventDefault();
              const cmd = filtered()[parseInt(el.dataset.i)];
              if (cmd) { cmd.fn(); inp.value = ''; menu.classList.remove('open'); inp.blur(); }
            });
          });
        }
        function pick() {
          const cmd = filtered()[activeIdx];
          if (cmd) { cmd.fn(); inp.value = ''; menu.classList.remove('open'); inp.blur(); }
        }
        inp.addEventListener('input', () => { activeIdx = 0; renderMenu(); });
        inp.addEventListener('keydown', e => {
          const items = filtered();
          if (!menu.classList.contains('open')) return;
          if (e.key === 'ArrowDown') { e.preventDefault(); activeIdx = (activeIdx + 1) % items.length; renderMenu(); }
          if (e.key === 'ArrowUp')   { e.preventDefault(); activeIdx = (activeIdx - 1 + items.length) % items.length; renderMenu(); }
          if (e.key === 'Enter')     { e.preventDefault(); pick(); }
          if (e.key === 'Escape')    { menu.classList.remove('open'); inp.value = ''; inp.blur(); }
        });
        inp.addEventListener('blur',  () => setTimeout(() => menu.classList.remove('open'), 160));
        inp.addEventListener('focus', () => { if (inp.value.startsWith('/')) renderMenu(); });
      })();

      /* ═══ ADD COMPONENT MENU ═══ */
      const addCompMenuEl = document.getElementById('addCompMenu');
      document.getElementById('addCompBtn')?.addEventListener('click', e => {
        e.stopPropagation();
        addCompMenuEl && addCompMenuEl.classList.toggle('open');
      });
      document.addEventListener('click', () => { addCompMenuEl && addCompMenuEl.classList.remove('open'); });

      function addButtonRow() {
        if (compRows.length >= 5) { toast(isAR ? 'الحد الأقصى 5 صفوف' : 'Max 5 rows'); return; }
        const id = 'row_' + (nextRowId++);
        compRows.push({ id, type: 'buttons', buttons: [{ customId: uid(), label: isAR ? 'زر' : 'Button', style: 'Primary', emoji: '', url: '', disabled: false }], select: null });
        markDirty(); renderCompRows(); renderActions();
      }
      function addSelectRow() {
        if (compRows.length >= 5) { toast(isAR ? 'الحد الأقصى 5 صفوف' : 'Max 5 rows'); return; }
        const id = 'row_' + (nextRowId++);
        compRows.push({ id, type: 'select', buttons: [], select: { customId: uid(), placeholder: isAR ? 'اختر خياراً...' : 'Select an option…', minValues: 1, maxValues: 1, disabled: false, options: [{ label: isAR ? 'خيار 1' : 'Option 1', value: uid(), description: '', emoji: '', default: false }] } });
        markDirty(); renderCompRows(); renderActions();
      }
      function addTextDisplayRow() {
        const id = 'row_' + (nextRowId++);
        compRows.push({ id, type: 'text_display', text: '' });
        markDirty(); renderCompRows();
      }
      function addSeparatorRow() {
        const id = 'row_' + (nextRowId++);
        compRows.push({ id, type: 'separator', divider: true, spacing: 'Small' });
        markDirty(); renderCompRows();
      }
      function addContainerRow() {
        const id = 'row_' + (nextRowId++);
        compRows.push({ id, type: 'container', accentColor: '', children: [] });
        markDirty(); renderCompRows();
      }
      function addImageRow() {
        const id = 'row_' + (nextRowId++);
        compRows.push({ id, type: 'image', url: '', description: '' });
        markDirty(); renderCompRows();
      }
      document.getElementById('menuAddContent')?.addEventListener('click',    () => { addCompMenuEl.classList.remove('open'); addTextDisplayRow(); });
      document.getElementById('menuAddSeparator')?.addEventListener('click',  () => { addCompMenuEl.classList.remove('open'); addSeparatorRow(); });
      document.getElementById('menuAddContainer')?.addEventListener('click',  () => { addCompMenuEl.classList.remove('open'); addContainerRow(); });
      document.getElementById('menuAddImage')?.addEventListener('click',      () => { addCompMenuEl.classList.remove('open'); addImageRow(); });
      document.getElementById('menuAddBtnRow')?.addEventListener('click',     () => { addCompMenuEl.classList.remove('open'); addButtonRow(); });
      document.getElementById('menuAddSelectRow')?.addEventListener('click',  () => { addCompMenuEl.classList.remove('open'); addSelectRow(); });

      /* ═══ ACTIONS SECTION TOGGLE ═══ */
      document.getElementById('actionsToggle')?.addEventListener('click', () => {
        const btn = document.getElementById('actionsToggle');
        btn.classList.toggle('open');
        actionsPanel.classList.toggle('open');
      });

      /* ═══ ACTIONS PANEL ═══ */
      function renderActions() {
        const allIds = getAllCustomIds();
        actionsSection.style.display = allIds.length ? '' : 'none';
        actionsPanel.innerHTML = '';
        if (!allIds.length) return;

        allIds.forEach(({ customId, label }) => {
          const entry   = actionsMap[customId];
          // Support both old (steps[]) and new (rules[]) format
          const rules   = entry?.rules || (entry?.steps?.length ? [{ conditions: [], steps: entry.steps }] : []);
          const ruleCount = rules.length;
          const totalSteps = rules.reduce((s, r) => s + (r.steps?.length || 0), 0);

          const item = document.createElement('div');
          item.className = 'bld-action-item';

          // Build rule chips (show IF/ELSE IF/ELSE badges)
          let chipsHtml = '';
          if (ruleCount) {
            chipsHtml = '<div class="bld-action-item-rules">';
            rules.forEach((r, ri) => {
              const bl = ri === 0 ? 'IF' : (ri === rules.length - 1 && !r.conditions?.length ? 'ELSE' : 'ELSE IF');
              const stc = r.steps?.length || 0;
              chipsHtml += '<span class="bld-action-rule-chip">' + bl + (stc ? ' \u2192 ' + stc + (isAR ? ' إجراء' : ' action' + (stc > 1 ? 's' : '')) : '') + '</span>';
            });
            chipsHtml += '</div>';
          }

          item.innerHTML =
            '<div class="bld-action-item-icon">⚡</div>' +
            '<div class="bld-action-item-body">' +
              '<div class="bld-action-item-label">' + esc(label) + '</div>' +
              (ruleCount
                ? '<div class="bld-action-item-count">' + ruleCount + ' ' + (isAR ? 'كتلة' : 'block' + (ruleCount > 1 ? 's' : '')) + ' · ' + totalSteps + ' ' + (isAR ? 'إجراء' : 'action' + (totalSteps !== 1 ? 's' : '')) + '</div>' + chipsHtml
                : '<div class="bld-action-item-count" style="color:rgba(255,200,100,.7);">' + (isAR ? '⚡ انقر لبناء المنطق' : '⚡ Click to build logic') + '</div>'
              ) +
            '</div>' +
            '<div style="font-size:.7rem;color:var(--muted);margin-left:auto;flex-shrink:0;">' + (isAR ? 'تعديل &rsaquo;' : 'Edit &rsaquo;') + '</div>';
          item.addEventListener('click', () => openActionEditor(customId));
          actionsPanel.appendChild(item);
        });
      }

      function getAllCustomIds() {
        const ids = [];
        function collectFromRow(row) {
          if (row.type === 'buttons') {
            (row.buttons || []).forEach(b => {
              if (b.style !== 'Link' && b.customId) ids.push({ customId: b.customId, label: b.emoji ? b.emoji + ' ' + b.label : b.label || 'Button' });
            });
          } else if (row.type === 'select' && row.select?.customId) {
            ids.push({ customId: row.select.customId, label: row.select.placeholder || 'Select Menu' });
          } else if (row.type === 'container') {
            (row.children || []).forEach(collectFromRow);
          }
        }
        compRows.forEach(collectFromRow);
        return ids;
      }

      /* ═══ LIVE PREVIEW ═══ */
      function dcMarkdown(raw) {
        if (!raw) return '';
        let s = raw.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
        s = s.replace(/\*\*\*(.+?)\*\*\*/g,'<strong><em>$1</em></strong>');
        s = s.replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>');
        s = s.replace(/__(.+?)__/g,'<u>$1</u>');
        s = s.replace(/\*(.+?)\*/g,'<em>$1</em>');
        s = s.replace(/_([^_]+)_/g,'<em>$1</em>');
        s = s.replace(/~~(.+?)~~/g,'<del>$1</del>');
        s = s.replace(/\|\|(.+?)\|\|/g,'<span style="background:#202225;color:#202225;border-radius:2px;padding:0 2px;">$1</span>');
        s = s.replace(/`([^`]+)`/g,'<code>$1</code>');
        s = s.replace(/\n/g,'<br>');
        return s;
      }

      function renderDcRow(row) {
        if (!row) return '';
        if (row.type === 'text_display') {
          return '<div class="dc-text-display">' + dcMarkdown(row.text || '') + '</div>';
        }
        if (row.type === 'separator') {
          const cls = row.spacing === 'Large' ? 'dc-sep-wrap-l' : 'dc-sep-wrap-s';
          return row.divider !== false
            ? '<div class="' + cls + '"><hr class="dc-separator"></div>'
            : '<div class="' + cls + '"></div>';
        }
        if (row.type === 'container') {
          const ac = row.accentColor || '#5865f2';
          const inner = (row.children || []).map(renderDcRow).join('') ||
            '<div style="color:#949ba4;font-size:.8rem;font-style:italic;padding:4px 0;">' + (isAR ? '(فارغ)' : '(empty)') + '</div>';
          return '<div class="dc-container" style="border-left-color:' + esc(ac) + ';">' + inner + '</div>';
        }
        if (row.type === 'image') {
          if (!row.url) return '<div class="dc-image-placeholder">' + (isAR ? '🖼 لم يتم تعيين رابط الصورة' : '🖼 Image URL not set') + '</div>';
          return '<div class="dc-image-wrap"><img src="' + esc(row.url) + '" class="dc-image" alt="' + esc(row.description || '') + '" onerror="this.style.display=\'none\'"></div>';
        }
        if (row.type === 'buttons') {
          const styleMap = { Primary:'dc-btn-primary', Secondary:'dc-btn-secondary', Success:'dc-btn-success', Danger:'dc-btn-danger', Link:'dc-btn-link' };
          const btnsHtml = (row.buttons || []).map(b =>
            '<button class="dc-btn ' + (styleMap[b.style] || 'dc-btn-secondary') + '"' + (b.disabled ? ' disabled' : '') + '>' +
              (b.emoji ? esc(b.emoji) + ' ' : '') + esc(b.label || 'Button') +
              (b.style === 'Link' ? ' <svg viewBox="0 0 24 24" width="11" height="11" fill="currentColor"><path d="M10 6v2H5v11h11v-5h2v6a1 1 0 01-1 1H4a1 1 0 01-1-1V7a1 1 0 011-1h6zm11-3v8h-2V6.413l-7.293 7.294-1.414-1.414L17.585 5H13V3h8z"/></svg>' : '') +
            '</button>'
          ).join('');
          return '<div class="dc-action-row">' + (btnsHtml || '') + '</div>';
        }
        if (row.type === 'select') {
          const s = row.select || {};
          return '<div class="dc-select-wrap"><div class="dc-select">' +
            '<span>' + esc(s.placeholder || (isAR ? 'اختر...' : 'Select an option\u2026')) + '</span>' +
            '<svg viewBox="0 0 24 24" width="16" height="16" fill="#949ba4"><path d="M16.59 8.59L12 13.17 7.41 8.59 6 10l6 6 6-6z"/></svg>' +
            '</div></div>';
        }
        return '';
      }

      function renderPreview() {
        const previewEl = document.getElementById('previewContent');
        if (!previewEl) return;
        let html = '';
        let txt, rows;
        // Allow pinning preview to a different state without switching editor
        if (previewStateId && previewStateId !== currentStateId) {
          const pst = flowStates.find(s => s.id === previewStateId);
          if (pst) { txt = pst.content; rows = pst.components || []; }
          else { previewStateId = null; }
        }
        if (!previewStateId || previewStateId === currentStateId) {
          txt  = msgContent.value;
          rows = compRows;
        }
        if (txt?.trim()) html += '<div class="dc-text-display">' + dcMarkdown(txt.trim()) + '</div>';
        rows.forEach(row => { html += renderDcRow(row); });
        previewEl.innerHTML = html ||
          '<div class="dc-empty-prev">' + (isAR ? 'ابدأ الكتابة أو أضف مكونات...' : 'Start typing or add components...') + '</div>';
      }

      function renderPreviewTabs() {
        const previewCol = document.getElementById('previewCol');
        const dcMock = previewCol?.querySelector('.dc-mock');
        if (!previewCol || !dcMock) return;
        let tabsEl = document.getElementById('previewStateTabs');
        if (flowStates.length <= 1) { if (tabsEl) tabsEl.style.display = 'none'; return; }
        if (!tabsEl) {
          tabsEl = document.createElement('div');
          tabsEl.id = 'previewStateTabs';
          previewCol.insertBefore(tabsEl, dcMock);
        }
        tabsEl.style.display = '';
        const activeId = previewStateId || currentStateId;
        tabsEl.innerHTML = flowStates.map(st =>
          '<button class="bld-prev-tab' + (activeId === st.id ? ' active' : '') + '" data-psid="' + esc(st.id) + '" type="button">' +
            '<span style="display:inline-block;width:7px;height:7px;border-radius:50%;background:' + esc(st.color) + ';flex-shrink:0;"></span>' +
            esc(st.label) +
          '</button>'
        ).join('');
        tabsEl.querySelectorAll('.bld-prev-tab').forEach(btn => {
          btn.addEventListener('click', () => {
            previewStateId = btn.dataset.psid === currentStateId ? null : btn.dataset.psid;
            renderPreviewTabs();
            renderPreview();
          });
        });
      }

      /* ═══ BUTTON EDIT MODAL ═══ */
      function openBtnEdit(rowId, bi) {
        const ri = compRows.findIndex(r => r.id === rowId);
        if (ri < 0) return;
        const btn = compRows[ri].buttons[bi];
        if (!btn) return;
        _btnEditCtx = { rowId, bi };
        document.getElementById('btnEditLabel').value      = btn.label || '';
        document.getElementById('btnEditStyle').value      = btn.style || 'Primary';
        document.getElementById('btnEditUrl').value        = btn.url || '';
        document.getElementById('btnEditEmoji').value      = btn.emoji || '';
        document.getElementById('btnEditCustomId').value   = btn.customId || '';
        document.getElementById('btnEditDisabled').checked = !!btn.disabled;
        toggleUrlField();
        btnEditModal.classList.add('open');
      }
      function toggleUrlField() {
        const isLink = document.getElementById('btnEditStyle').value === 'Link';
        document.getElementById('btnEditUrlWrap').style.display      = isLink ? '' : 'none';
        document.getElementById('btnEditCustomIdWrap').style.display = isLink ? 'none' : '';
      }
      document.getElementById('btnEditStyle').addEventListener('change', toggleUrlField);
      document.getElementById('btnEditCancel').addEventListener('click', () => { btnEditModal.classList.remove('open'); _btnEditCtx = null; });
      document.getElementById('btnEditSave').addEventListener('click', () => {
        if (!_btnEditCtx) return;
        const ri = compRows.findIndex(r => r.id === _btnEditCtx.rowId);
        if (ri < 0) return;
        const btn = compRows[ri].buttons[_btnEditCtx.bi];
        if (!btn) return;
        btn.label    = document.getElementById('btnEditLabel').value.trim() || 'Button';
        btn.style    = document.getElementById('btnEditStyle').value;
        btn.url      = document.getElementById('btnEditUrl').value.trim();
        btn.emoji    = document.getElementById('btnEditEmoji').value.trim();
        btn.disabled = document.getElementById('btnEditDisabled').checked;
        if (btn.style === 'Link') {
          if (btn.customId) { delete actionsMap[btn.customId]; btn.customId = ''; }
        } else {
          const newCid = document.getElementById('btnEditCustomId').value.trim() || btn.customId || uid();
          if (btn.customId && btn.customId !== newCid && actionsMap[btn.customId]) {
            actionsMap[newCid] = { ...actionsMap[btn.customId], customId: newCid };
            delete actionsMap[btn.customId];
          }
          btn.customId = newCid;
        }
        markDirty(); renderCompRows(); renderActions(); renderPreview();
        btnEditModal.classList.remove('open'); _btnEditCtx = null;
      });

      /* ═══ OPTION EDIT MODAL ═══ */
      function openOptEdit(rowId, oi) {
        const ri = compRows.findIndex(r => r.id === rowId);
        if (ri < 0) return;
        const opt = compRows[ri].select?.options?.[oi];
        if (!opt) return;
        _optEditCtx = { rowId, oi };
        document.getElementById('optEditLabel').value = opt.label || '';
        document.getElementById('optEditValue').value = opt.value || '';
        document.getElementById('optEditDesc').value  = opt.description || '';
        document.getElementById('optEditEmoji').value = opt.emoji || '';
        optEditModal.classList.add('open');
      }
      document.getElementById('optEditCancel').addEventListener('click', () => { optEditModal.classList.remove('open'); _optEditCtx = null; });
      document.getElementById('optEditSave').addEventListener('click', () => {
        if (!_optEditCtx) return;
        const ri = compRows.findIndex(r => r.id === _optEditCtx.rowId);
        if (ri < 0) return;
        const opt = compRows[ri].select?.options?.[_optEditCtx.oi];
        if (!opt) return;
        opt.label       = document.getElementById('optEditLabel').value.trim() || 'Option';
        opt.value       = document.getElementById('optEditValue').value.trim() || uid();
        opt.description = document.getElementById('optEditDesc').value.trim();
        opt.emoji       = document.getElementById('optEditEmoji').value.trim();
        markDirty(); renderCompRows(); renderPreview();
        optEditModal.classList.remove('open'); _optEditCtx = null;
      });

      /* ═══ IF / THEN INTERACTION LOGIC BUILDER ═══ */

      const ACTION_TYPES = [
        // Flow / Automation
        { value: 'go_to_state',       label: isAR ? '🔀 الانتقال إلى حالة'  : '🔀 Go to State',        group: isAR ? 'أتمتة' : 'Automation' },
        { value: 'update_message',    label: isAR ? '🔄 تحديث الرسالة'      : '🔄 Update Message',     group: isAR ? 'أتمتة' : 'Automation' },
        // Messaging
        { value: 'reply',             label: isAR ? '💬 رد في القناة'       : '💬 Reply in Channel',   group: isAR ? 'رسائل' : 'Messaging' },
        { value: 'send_dm',           label: isAR ? '📨 رسالة خاصة'         : '📨 Send DM',            group: isAR ? 'رسائل' : 'Messaging' },
        { value: 'send_to_channel',   label: isAR ? '📢 إرسال إلى قناة'     : '📢 Send to Channel',    group: isAR ? 'رسائل' : 'Messaging' },
        { value: 'send_webhook',      label: isAR ? '🔗 إرسال Webhook'      : '🔗 Send Webhook',       group: isAR ? 'رسائل' : 'Messaging' },
        { value: 'edit_message',      label: isAR ? '✏️ تعديل الرسالة'      : '✏️ Edit Message',       group: isAR ? 'رسائل' : 'Messaging' },
        // Roles
        { value: 'add_role',          label: isAR ? '🏷 إضافة رتبة'         : '🏷 Add Role',           group: isAR ? 'رتب' : 'Roles' },
        { value: 'remove_role',       label: isAR ? '🗑 إزالة رتبة'         : '🗑 Remove Role',        group: isAR ? 'رتب' : 'Roles' },
        { value: 'toggle_role',       label: isAR ? '🔄 تبديل رتبة'         : '🔄 Toggle Role',        group: isAR ? 'رتب' : 'Roles' },
        // Tickets
        { value: 'open_ticket',       label: isAR ? '🎫 فتح تذكرة'          : '🎫 Open Ticket',        group: isAR ? 'تذاكر' : 'Tickets' },
        { value: 'close_ticket',      label: isAR ? '🔒 إغلاق التذكرة'      : '🔒 Close Ticket',       group: isAR ? 'تذاكر' : 'Tickets' },
        // Components
        { value: 'disable_component', label: isAR ? '🚫 تعطيل مكوّن'        : '🚫 Disable Component',  group: isAR ? 'مكونات' : 'Components' },
        { value: 'enable_component',  label: isAR ? '✅ تفعيل مكوّن'        : '✅ Enable Component',   group: isAR ? 'مكونات' : 'Components' },
        // Other
        { value: 'create_thread',     label: isAR ? '🧵 إنشاء ثريد'         : '🧵 Create Thread',      group: isAR ? 'أخرى' : 'Other' },
        { value: 'award_points',      label: isAR ? '⭐ منح نقاط'           : '⭐ Award Points',       group: isAR ? 'أخرى' : 'Other' },
        { value: 'kick_member',       label: isAR ? '👢 طرد العضو'          : '👢 Kick Member',        group: isAR ? 'أخرى' : 'Other' },
        { value: 'timeout_member',    label: isAR ? '⏱ إيقاف مؤقت (10 دق)' : '⏱ Timeout Member (10m)', group: isAR ? 'أخرى' : 'Other' },
      ];

      const COND_TYPES = [
        { value: 'user_has_role',     label: isAR ? 'العضو يملك رتبة'   : 'User has role',     needs: 'role' },
        { value: 'user_missing_role', label: isAR ? 'العضو لا يملك رتبة': 'User missing role', needs: 'role' },
        { value: 'channel_is',        label: isAR ? 'القناة هي'          : 'Channel is',        needs: 'channel' },
        { value: 'channel_is_not',    label: isAR ? 'القناة ليست'        : 'Channel is not',    needs: 'channel' },
        { value: 'selected_option',   label: isAR ? 'الخيار المختار يساوي': 'Selected option =', needs: 'text' },
      ];

      /* ── Migrate old steps→rules format ── */
      function ensureRules(customId) {
        if (!actionsMap[customId]) actionsMap[customId] = { customId, rules: [] };
        const entry = actionsMap[customId];
        // Old format had `steps` array instead of `rules`
        if (entry.steps && !entry.rules) {
          entry.rules = entry.steps.length
            ? [{ id: uid(), conditions: [], conditionOp: 'AND', steps: entry.steps }]
            : [];
          delete entry.steps;
        }
        if (!entry.rules) entry.rules = [];
        return entry;
      }

      function openActionEditor(customId) {
        if (!customId) return;
        saveCurrentStateData(); // ensure current editor data is flushed before reading flowStates
        _actionCtx = { customId };
        ensureRules(customId);
        document.getElementById('actionModalTitle').textContent = isAR ? 'منطق التفاعل' : 'Interaction Logic';
        document.getElementById('actionModalSub').textContent = customId;
        renderRuleList();
        actionModal.classList.add('open');
      }

      function closeActionModal() { actionModal.classList.remove('open'); _actionCtx = null; }
      document.getElementById('actionCancel').addEventListener('click', closeActionModal);
      document.getElementById('actionCancel2').addEventListener('click', closeActionModal);
      document.getElementById('actionSave').addEventListener('click', () => {
        if (!_actionCtx) return;
        markDirty(); renderActions();
        closeActionModal();
      });
      document.getElementById('addRuleBlock').addEventListener('click', () => {
        if (!_actionCtx) return;
        const entry = actionsMap[_actionCtx.customId];
        entry.rules.push({ id: uid(), conditions: [], conditionOp: 'AND', steps: [] });
        renderRuleList();
      });

      /* ─── Render all rule blocks ─── */
      function renderRuleList() {
        const listEl = document.getElementById('ifRuleList');
        listEl.innerHTML = '';
        if (!_actionCtx) return;
        const rules = actionsMap[_actionCtx.customId]?.rules || [];
        rules.forEach((rule, ri) => renderRuleBlock(listEl, rule, ri, rules));
      }

      function ruleLabel(rule, ri, total) {
        if (ri === 0) return 'IF';
        if (ri === total - 1 && !rule.conditions.length) return 'ELSE';
        return 'ELSE IF';
      }
      function ruleBadgeClass(rule, ri, total) {
        if (ri === 0) return 'if';
        if (ri === total - 1 && !rule.conditions.length) return 'else';
        return 'elif';
      }

      function renderRuleBlock(listEl, rule, ri, allRules) {
        const wrap = document.createElement('div');
        wrap.className = 'if-rule';
        wrap.dataset.ri = ri;

        const rl   = ruleLabel(rule, ri, allRules.length);
        const rbc  = ruleBadgeClass(rule, ri, allRules.length);
        const isElse = rl === 'ELSE';
        const condSummary = rule.conditions.length
          ? rule.conditions.map(c => {
              const ct = COND_TYPES.find(x => x.value === c.type);
              return ct ? ct.label : c.type;
            }).join(' ' + rule.conditionOp + ' ')
          : (isElse ? (isAR ? 'تنفيذ دائمًا (افتراضي)' : 'Always executes (default)') : (isAR ? 'لا شروط' : 'No conditions'));

        // ── Header ──
        const head = document.createElement('div');
        head.className = 'if-rule-head';
        head.innerHTML =
          '<span class="if-badge ' + rbc + '">' + rl + '</span>' +
          '<span class="if-rule-head-label">' + esc(condSummary) + '</span>' +
          '<div class="if-rule-head-btns">' +
            (ri > 0 ? '<button class="icon-btn _mv-up" title="' + (isAR?'تحريك لأعلى':'Move up') + '" style="font-size:.7rem;">↑</button>' : '') +
            (ri < allRules.length - 1 ? '<button class="icon-btn _mv-dn" title="' + (isAR?'تحريك لأسفل':'Move down') + '" style="font-size:.7rem;">↓</button>' : '') +
            '<button class="icon-btn danger _del-rule" title="' + (isAR?'حذف الكتلة':'Delete block') + '" style="font-size:.7rem;">✕</button>' +
          '</div>';
        wrap.appendChild(head);

        // ── Body ──
        const body = document.createElement('div');
        body.className = 'if-rule-body';

        // Conditions section
        const condSec = document.createElement('div');
        condSec.className = 'if-cond-section';
        condSec.innerHTML = '<div class="if-cond-section-label">' + (isAR ? 'الشروط' : 'CONDITIONS') + '</div>';

        if (isElse && !rule.conditions.length) {
          condSec.innerHTML += '<span class="if-else-label">' + (isAR ? '✓ يُنفَّذ إذا لم تتحقق أي كتلة سابقة' : '✓ Runs if no previous block matched') + '</span>';
        } else {
          rule.conditions.forEach((cond, ci) => {
            const ct = COND_TYPES.find(x => x.value === cond.type);
            const condRow = document.createElement('div');
            condRow.className = 'if-cond-row';
            if (ci > 0) {
              condRow.innerHTML += '<button class="if-cond-op-badge _op-toggle" title="' + (isAR?'انقر للتبديل':'Click to toggle') + '">' + rule.conditionOp + '</button>';
            }
            condRow.innerHTML +=
              '<select class="bld-select if-cond-type _cond-type" data-ci="' + ci + '">' +
                COND_TYPES.map(x => '<option value="' + x.value + '"' + (cond.type === x.value ? ' selected' : '') + '>' + esc(x.label) + '</option>').join('') +
              '</select>' +
              buildCondValField(cond, ci) +
              '<button class="icon-btn danger _del-cond" data-ci="' + ci + '" title="Remove" style="flex-shrink:0;">✕</button>';
            condSec.appendChild(condRow);
          });
          const addCondBtn = document.createElement('button');
          addCondBtn.className = 'if-add-cond _add-cond';
          addCondBtn.textContent = (isAR ? '+ إضافة شرط' : '+ Add Condition');
          condSec.appendChild(addCondBtn);
        }
        body.appendChild(condSec);

        // Steps section
        const stepSec = document.createElement('div');
        stepSec.className = 'if-steps-section';
        stepSec.innerHTML = '<div class="if-steps-label">' + (isAR ? '▶ الإجراءات' : '▶ THEN DO') + '</div>';
        rule.steps.forEach((step, si) => buildStepEl(stepSec, step, si, rule.steps));
        const addStepBtn = document.createElement('button');
        addStepBtn.className = 'if-add-step _add-step';
        addStepBtn.textContent = (isAR ? '+ إضافة إجراء' : '+ Add Action');
        stepSec.appendChild(addStepBtn);
        body.appendChild(stepSec);
        wrap.appendChild(body);
        listEl.appendChild(wrap);

        // ── Bind rule-level events ──
        head.querySelector('._del-rule')?.addEventListener('click', () => {
          allRules.splice(ri, 1); renderRuleList();
        });
        head.querySelector('._mv-up')?.addEventListener('click', () => {
          if (ri > 0) { [allRules[ri - 1], allRules[ri]] = [allRules[ri], allRules[ri - 1]]; renderRuleList(); }
        });
        head.querySelector('._mv-dn')?.addEventListener('click', () => {
          if (ri < allRules.length - 1) { [allRules[ri], allRules[ri + 1]] = [allRules[ri + 1], allRules[ri]]; renderRuleList(); }
        });

        // Condition events
        condSec.querySelectorAll('._cond-type').forEach(sel => {
          sel.addEventListener('change', () => {
            const ci = parseInt(sel.dataset.ci);
            rule.conditions[ci].type = sel.value;
            rule.conditions[ci].value = '';
            renderRuleList();
          });
        });
        condSec.querySelectorAll('._cond-val-role').forEach(sel => {
          sel.addEventListener('change', () => { rule.conditions[parseInt(sel.dataset.ci)].value = sel.value; });
        });
        condSec.querySelectorAll('._cond-val-channel').forEach(sel => {
          sel.addEventListener('change', () => { rule.conditions[parseInt(sel.dataset.ci)].value = sel.value; });
        });
        condSec.querySelectorAll('._cond-val-text').forEach(inp => {
          inp.addEventListener('input', () => { rule.conditions[parseInt(inp.dataset.ci)].value = inp.value; });
        });
        condSec.querySelectorAll('._del-cond').forEach(btn => {
          btn.addEventListener('click', () => { rule.conditions.splice(parseInt(btn.dataset.ci), 1); renderRuleList(); });
        });
        condSec.querySelectorAll('._op-toggle').forEach(btn => {
          btn.addEventListener('click', () => { rule.conditionOp = rule.conditionOp === 'AND' ? 'OR' : 'AND'; renderRuleList(); });
        });
        condSec.querySelector('._add-cond')?.addEventListener('click', () => {
          rule.conditions.push({ type: 'user_has_role', value: '' }); renderRuleList();
        });

        // Step events
        stepSec.querySelector('._add-step')?.addEventListener('click', () => {
          rule.steps.push({ type: 'reply', content: '', ephemeral: true, channelId: '', roleId: '', targetId: '', webhookUrl: '' });
          renderRuleList();
        });
      }

      function buildCondValField(cond, ci) {
        const ct = COND_TYPES.find(x => x.value === cond.type);
        if (!ct) return '';
        if (ct.needs === 'role') {
          return '<select class="bld-select if-cond-val _cond-val-role" data-ci="' + ci + '">' +
            '<option value="">' + (isAR ? 'اختر رتبة...' : 'Select role...') + '</option>' +
            roles.map(r => '<option value="' + r.id + '"' + (cond.value === r.id ? ' selected' : '') + '>' + esc(r.name) + '</option>').join('') +
            '</select>';
        }
        if (ct.needs === 'channel') {
          return '<select class="bld-select if-cond-val _cond-val-channel" data-ci="' + ci + '">' +
            '<option value="">' + (isAR ? 'اختر قناة...' : 'Select channel...') + '</option>' +
            channels.map(c => '<option value="' + c.id + '"' + (cond.value === c.id ? ' selected' : '') + '>#' + esc(c.name) + '</option>').join('') +
            '</select>';
        }
        return '<input class="bld-input if-cond-val _cond-val-text" data-ci="' + ci + '" value="' + esc(cond.value || '') + '" placeholder="value" style="font-size:.72rem;">';
      }

      function buildStepEl(parent, step, si, stepsArr) {
        const div = document.createElement('div');
        div.className = 'if-step';
        div.innerHTML =
          '<div class="if-step-num">' + (si + 1) + '</div>' +
          '<div class="if-step-body">' +
            '<select class="bld-select if-step-type _step-type" data-si="' + si + '">' +
              ACTION_TYPES.map(t => '<option value="' + t.value + '"' + (step.type === t.value ? ' selected' : '') + '>' + esc(t.label) + '</option>').join('') +
            '</select>' +
            buildStepFields(step, si) +
          '</div>' +
          '<button class="icon-btn danger _del-step" data-si="' + si + '" title="Delete" style="flex-shrink:0;margin-top:1px;">✕</button>';
        parent.insertBefore(div, parent.querySelector('._add-step'));

        div.querySelector('._step-type').addEventListener('change', function() {
          stepsArr[si].type = this.value;
          renderRuleList();
        });
        const bindField = (sel, prop, evtType) => {
          div.querySelectorAll(sel).forEach(el => {
            el.addEventListener(evtType || 'input', () => { stepsArr[si][prop] = el.value; });
          });
        };
        div.querySelectorAll('._step-content').forEach(el => el.addEventListener('input', () => { stepsArr[si].content = el.value; }));
        div.querySelectorAll('._step-ephemeral').forEach(el => el.addEventListener('change', () => { stepsArr[si].ephemeral = el.checked; }));
        div.querySelectorAll('._step-channel').forEach(el => el.addEventListener('change', () => { stepsArr[si].channelId = el.value; }));
        div.querySelectorAll('._step-role').forEach(el => el.addEventListener('change', () => { stepsArr[si].roleId = el.value; }));
        div.querySelectorAll('._step-target').forEach(el => el.addEventListener('input', () => { stepsArr[si].targetId = el.value; }));
        div.querySelectorAll('._step-webhook').forEach(el => el.addEventListener('input', () => { stepsArr[si].webhookUrl = el.value; }));
        div.querySelectorAll('._step-points').forEach(el => el.addEventListener('input', () => { stepsArr[si].points = parseInt(el.value) || 0; }));
        div.querySelectorAll('._step-duration').forEach(el => el.addEventListener('input', () => { stepsArr[si].duration = parseInt(el.value) || 10; }));
        div.querySelector('._del-step').addEventListener('click', () => { stepsArr.splice(si, 1); renderRuleList(); });
      }

      function buildStepFields(step, si) {
        let h = '';
        const t = step.type;
        const content = '<div class="bld-field"><label class="bld-label">' + (isAR ? 'المحتوى' : 'Content') + '</label>' +
          '<textarea class="bld-textarea _step-content" data-si="' + si + '" style="min-height:52px;" maxlength="2000">' + esc(step.content || '') + '</textarea></div>';
        const ephem = '<div class="bld-field" style="display:flex;align-items:center;gap:8px;">' +
          '<input type="checkbox" class="_step-ephemeral" data-si="' + si + '" style="accent-color:var(--purple);width:14px;height:14px;"' + (step.ephemeral !== false ? ' checked' : '') + '>' +
          '<label style="font-size:.72rem;color:var(--muted);">' + (isAR ? 'مخفي (Ephemeral)' : 'Ephemeral — only visible to user') + '</label></div>';
        const roleField = '<div class="bld-field"><label class="bld-label">' + (isAR ? 'الرتبة' : 'Role') + '</label>' +
          '<select class="bld-select _step-role" data-si="' + si + '"><option value="">' + (isAR ? 'اختر...' : 'Select...') + '</option>' +
          roles.map(r => '<option value="' + r.id + '"' + (step.roleId === r.id ? ' selected' : '') + '>' + esc(r.name) + '</option>').join('') +
          '</select></div>';
        const channelField = '<div class="bld-field"><label class="bld-label">' + (isAR ? 'القناة' : 'Channel') + '</label>' +
          '<select class="bld-select _step-channel" data-si="' + si + '"><option value="">' + (isAR ? 'اختر...' : 'Select...') + '</option>' +
          channels.map(c => '<option value="' + c.id + '"' + (step.channelId === c.id ? ' selected' : '') + '>#' + esc(c.name) + '</option>').join('') +
          '</select></div>';

        if (t === 'reply')           { h += content + ephem; }
        if (t === 'send_dm')         { h += content; }
        if (t === 'edit_message')    { h += content; }
        if (t === 'update_message')  { h += content; }
        if (t === 'send_to_channel') { h += content + channelField; }
        if (t === 'go_to_state') {
          const stateOptions = flowStates.map(s =>
            '<option value="' + esc(s.id) + '"' + (step.targetId === s.id ? ' selected' : '') + '>' + esc(s.label) + (s.id === initialStateId ? ' ★' : '') + '</option>'
          ).join('');
          h += '<div class="bld-field"><label class="bld-label">' + (isAR ? 'الحالة المستهدفة' : 'Target State') + '</label>' +
            '<select class="bld-select _step-target" data-si="' + si + '">' +
              '<option value="">' + (isAR ? 'اختر حالة...' : 'Select state...') + '</option>' + stateOptions +
            '</select></div>' +
            '<div style="font-size:.65rem;color:var(--muted);margin-top:2px;">' + (isAR ? 'ينتقل المستخدم إلى هذه الحالة من الأتمتة' : 'Transitions the user to this flow state') + '</div>';
        }
        if (t === 'send_webhook') {
          h += '<div class="bld-field"><label class="bld-label">Webhook URL</label>' +
            '<input type="url" class="bld-input _step-webhook" data-si="' + si + '" value="' + esc(step.webhookUrl || '') + '" placeholder="https://discord.com/api/webhooks/..."></div>';
          h += content;
        }
        if (t === 'add_role' || t === 'remove_role' || t === 'toggle_role') { h += roleField; }
        if (t === 'disable_component' || t === 'enable_component') {
          h += '<div class="bld-field"><label class="bld-label">' + (isAR ? 'معرف المكوّن' : 'Component Custom ID') + '</label>' +
            '<input type="text" class="bld-input _step-target" data-si="' + si + '" value="' + esc(step.targetId || '') + '" placeholder="customId" style="font-family:monospace;"></div>';
        }
        if (t === 'award_points') {
          h += '<div class="bld-field"><label class="bld-label">' + (isAR ? 'عدد النقاط' : 'Points') + '</label>' +
            '<input type="number" class="bld-input _step-points" data-si="' + si + '" value="' + (step.points || 10) + '" min="1" max="10000"></div>';
        }
        if (t === 'timeout_member') {
          h += '<div class="bld-field"><label class="bld-label">' + (isAR ? 'المدة (دقائق)' : 'Duration (minutes)') + '</label>' +
            '<input type="number" class="bld-input _step-duration" data-si="' + si + '" value="' + (step.duration || 10) + '" min="1" max="40320"></div>';
        }
        if (t === 'create_thread') {
          h += '<div class="bld-field"><label class="bld-label">' + (isAR ? 'اسم الثريد' : 'Thread Name') + '</label>' +
            '<input type="text" class="bld-input _step-target" data-si="' + si + '" value="' + esc(step.targetId || '') + '" placeholder="Support Thread" maxlength="100"></div>';
        }
        return h;
      }

      /* ═══ DELETE MODAL ═══ */
      function confirmDelete(id, name) {
        _deleteCtx = { id, name };
        document.getElementById('deleteText').textContent = (isAR ? 'هل تريد حذف "' + name + '"؟ لا يمكن التراجع.' : 'Delete "' + name + '"? This cannot be undone.');
        deleteModal.classList.add('open');
      }
      document.getElementById('deleteCancelBtn').addEventListener('click', () => { deleteModal.classList.remove('open'); _deleteCtx = null; });
      document.getElementById('deleteConfirmBtn').addEventListener('click', async () => {
        if (!_deleteCtx) return;
        deleteModal.classList.remove('open');
        try {
          const res = await fetch(API + '/' + _deleteCtx.id, { method: 'DELETE' });
          const data = await res.json();
          if (data.success) {
            saved = saved.filter(m => m._id !== _deleteCtx.id);
            toast(isAR ? 'تم الحذف' : 'Deleted');
            renderList();
          } else { toast(data.error || 'Error', 4000); }
        } catch (e) { toast('Network error', 4000); }
        _deleteCtx = null;
      });

      /* ═══ SAVE ═══ */
      const saveConfirmModal = document.getElementById('saveConfirmModal');
      const modalName        = document.getElementById('modalName');
      const modalChannel     = document.getElementById('modalChannel');
      const sendModeGroup    = document.getElementById('sendModeGroup');

      // Validation helper — only enforces constraints that Discord itself would reject.
      // Nothing about channels, content, or empty states is forced here.
      function _validateBeforeSave() {
        const name = mgName.value.trim();
        if (!name) { toast(isAR ? 'أدخل اسم الأتمتة' : 'Enter an automation name'); mgName.focus(); return false; }
        saveCurrentStateData();
        // Validate Discord API constraints only (duplicate customIds + Link URLs)
        for (const st of flowStates) {
          const seenIds = new Set();
          function checkRows(rows) {
            for (const row of (rows || [])) {
              if (row.type === 'buttons') {
                for (const btn of (row.buttons || [])) {
                  if (btn.style === 'Link' && !btn.url?.trim()) {
                    toast(isAR ? 'زر Link في "' + st.label + '" يحتاج رابطاً' : 'Link button in "' + st.label + '" needs a URL');
                    return false;
                  }
                  if (btn.customId && btn.style !== 'Link') {
                    if (seenIds.has(btn.customId)) {
                      toast(isAR ? 'معرف مكرر في "' + st.label + '": ' + btn.customId : 'Duplicate customId in "' + st.label + '": ' + btn.customId);
                      return false;
                    }
                    seenIds.add(btn.customId);
                  }
                }
              }
              if (row.type === 'select' && row.select?.customId) {
                if (seenIds.has(row.select.customId)) {
                  toast(isAR ? 'معرف مكرر في "' + st.label + '": ' + row.select.customId : 'Duplicate customId in "' + st.label + '": ' + row.select.customId);
                  return false;
                }
                seenIds.add(row.select.customId);
              }
              if (row.type === 'container') {
                const ok = checkRows(row.children || []);
                if (ok === false) return false;
              }
            }
            return true;
          }
          if (checkRows(st.components || []) === false) return false;
        }
        return true;
      }
      const mgName = msgName; // alias used inside _validateBeforeSave

      async function _doActualSave(sendMode) {
        const smBtn = document.getElementById('smSave');
        if (smBtn) { smBtn.disabled = true; smBtn.textContent = isAR ? 'جاري الحفظ...' : 'Saving...'; }
        saveBtn.disabled = true;

        // Apply any name / channel overrides from the modal
        const finalName = (modalName?.value.trim()) || msgName.value.trim();
        msgName.value = finalName;
        // Only promote the modal channel value if one was actually chosen
        const modalChVal = modalChannel?.value;
        if (modalChVal && flowChannelIds[0] !== modalChVal) {
          // Move selected channel to front, preserving the rest
          flowChannelIds = [modalChVal, ...flowChannelIds.filter(id => id !== modalChVal)];
        }

        const serializedStates = flowStates.map(st => ({
          id: st.id, label: st.label, color: st.color,
          content: st.content || '',
          components: st.components || [],
          actions: (st.actions || []).map(a => {
            const rules = a.rules || (a.steps?.length ? [{ conditions:[], conditionOp:'AND', steps:a.steps }] : []);
            return { customId: a.customId, rules };
          })
        }));

        try {
          const body = {
            name: finalName,
            channelId:  flowChannelIds[0] || '',
            channelIds: flowChannelIds,
            scheduledAt: flowScheduledAt || null,
            preMentions: flowPreMentions,
            sendMode: sendMode || 'new',
            states:        serializedStates,
            initialStateId,
            multiUser:     flowMultiUser,
            timeout:       flowTimeout,
            triggers:      flowTriggers,
            content:    (flowStates.find(s => s.id === initialStateId) || flowStates[0])?.content || '',
            components: (flowStates.find(s => s.id === initialStateId) || flowStates[0])?.components || [],
            actions:    (flowStates.find(s => s.id === initialStateId) || flowStates[0])?.actions   || [],
          };
          if (editingId) body._id = editingId;

          const res  = await fetch(API + '/save', {
            method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body)
          });
          const data = await res.json();
          if (data.success) {
            if (editingId) {
              const idx = saved.findIndex(m => m._id === editingId);
              if (idx >= 0) saved[idx] = data.data; else saved.unshift(data.data);
            } else {
              saved.unshift(data.data);
              editingId = data.data._id;
            }
            dirty = false;
            saveBtn.classList.remove('dirty');
            try { localStorage.removeItem('draft_cm_' + GUILD_ID); } catch(e) {}
            saveConfirmModal?.classList.remove('open');
            toast(isAR ? 'تم حفظ الأتمتة وإطلاقها!' : 'Flow automation saved & sent!');
          } else {
            toast(data.error || 'Error', 4000);
          }
        } catch(e) {
          toast('Network error', 4000);
        }

        saveBtn.disabled = false;
        saveBtn.innerHTML = '<i data-lucide="save" style="width:14px;height:14px;stroke:currentColor;"></i> ' + (isAR ? 'حفظ وإرسال' : 'Save & Send');
        if (smBtn) { smBtn.disabled = false; smBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15.2 3a2 2 0 0 1 1.4.6l3.8 3.8a2 2 0 0 1 .6 1.4V19a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/><path d="M17 21v-7a1 1 0 0 0-1-1H8a1 1 0 0 0-1 1v7"/><path d="M7 3v4a1 1 0 0 0 1 1h7"/></svg> ' + (isAR ? 'حفظ وإرسال' : 'Save & Send'); }
        lucide.createIcons();
      }

      saveBtn.addEventListener('click', () => {
        if (!_validateBeforeSave()) return;
        // Pre-fill modal
        if (modalName)    modalName.value = msgName.value.trim();
        if (modalChannel) modalChannel.value = flowChannelIds[0] || '';
        // Show send-mode group always (edit vs new choice)
        if (sendModeGroup) {
          sendModeGroup.classList.add('visible');
          const modeEdit = document.getElementById('modeEdit');
          const modeNew  = document.getElementById('modeNew');
          if (editingId && modeEdit) modeEdit.checked = true;
          else if (modeNew) modeNew.checked = true;
        }
        // Smart channel context hint
        const ctx        = _triggerChannelCtx();
        const hintEl     = document.getElementById('smChannelHint');
        const chLabelEl  = document.getElementById('smChannelLabel');
        const baseLabel  = isAR ? 'القناة الأساسية' : 'Primary Channel';
        if (hintEl) {
          if (ctx === 'all_provided') {
            hintEl.className = 'sm-channel-hint hint-ok';
            hintEl.textContent = (isAR
              ? '✓ جميع المُشغِّلات النشطة توفر قناة تلقائياً — اختيارية'
              : '✓ All active triggers auto-provide a channel — field is optional');
          } else if (ctx === 'some_provided') {
            hintEl.className = 'sm-channel-hint hint-warn';
            hintEl.textContent = (isAR
              ? '⚠ بعض المُشغِّلات تحتاج قناة محددة (scheduled / webhook / on_join)'
              : '⚠ Some triggers (scheduled / webhook / on_join) need an explicit channel');
          } else if (ctx === 'none_provided') {
            hintEl.className = 'sm-channel-hint hint-warn';
            hintEl.textContent = (isAR
              ? '⚠ المُشغِّلات النشطة لا توفر قناة — حدد قناة لتفعيلها'
              : '⚠ Active triggers rely on an explicit channel to know where to send');
          } else {
            hintEl.className = 'sm-channel-hint hint-info';
            hintEl.textContent = (isAR
              ? 'ℹ اتركها فارغة واستخدم المُشغِّلات، أو اختر قناة للإرسال الفوري'
              : 'ℹ Leave empty and rely on triggers, or select a channel for an immediate send');
          }
        }
        if (chLabelEl) {
          const suffix = ctx === 'all_provided'
            ? (isAR ? ' (اختياري)' : ' (optional)')
            : ctx === 'no_triggers'
              ? (isAR ? ' (للإرسال الفوري)' : ' (for immediate send)')
              : '';
          chLabelEl.textContent = baseLabel + suffix;
        }
        const titleEl = document.getElementById('saveModalTitle');
        const descEl  = document.getElementById('saveModalDesc');
        if (titleEl) titleEl.textContent = editingId
          ? (isAR ? 'تحديث الأتمتة' : 'Update Automation')
          : (isAR ? 'إطلاق الأتمتة'  : 'Launch Automation');
        if (descEl) descEl.textContent = editingId
          ? (isAR ? 'راجع الإعدادات ثم اختر طريقة الإرسال.' : 'Review settings and choose how to send.')
          : (isAR ? 'راجع الإعدادات قبل الإطلاق — كل شيء اختياري.' : 'Review settings before launching — everything except the name is optional.');
        saveConfirmModal?.classList.add('open');
        lucide.createIcons();
      });

      /* ═══ EVENTS ═══ */
      let _prevTimer;

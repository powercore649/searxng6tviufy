      <div class="bld-field" style="display:flex;align-items:center;gap:8px;">
        <input type="checkbox" id="btnEditDisabled" style="accent-color:var(--purple);width:16px;height:16px;">
        <label for="btnEditDisabled" style="font-size:.78rem;color:var(--muted);cursor:pointer;"><%= lang === 'ar' ? 'معطل' : 'Disabled' %></label>
      </div>
      <div class="modal-actions">
        <button class="btn btn-ghost btn-sm" id="btnEditCancel"><%= lang === 'ar' ? 'إلغاء' : 'Cancel' %></button>
        <button class="btn btn-primary btn-sm" id="btnEditSave"><%= lang === 'ar' ? 'حفظ' : 'Save' %></button>

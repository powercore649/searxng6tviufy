      <div class="modal-actions">
        <button class="btn btn-ghost btn-sm" id="optEditCancel"><%= lang === 'ar' ? 'إلغاء' : 'Cancel' %></button>
        <button class="btn btn-primary btn-sm" id="optEditSave"><%= lang === 'ar' ? 'حفظ' : 'Save' %></button>
      </div>
    </div>

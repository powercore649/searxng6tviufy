        picker.style.width = pw + 'px';
        picker.style.left = left + 'px';
        if (r.top > 310) {
          picker.style.top = 'auto';
          picker.style.bottom = (window.innerHeight - r.top + 6) + 'px';
        } else {
          picker.style.top = (r.bottom + 6) + 'px';
          picker.style.bottom = 'auto';
        }
        let activePanel = 'unicode';
        function _renderEpkGrid(q) {
          const grid = picker.querySelector('#_epk-grid');
          grid.innerHTML = '';
          q = (q || '').toLowerCase();
          if (activePanel === 'unicode') {
            _EMOJI_GROUPS.forEach(arr => arr.forEach(em => {
              const b = document.createElement('button');
              b.type = 'button'; b.className = 'epk-btn'; b.textContent = em;
              b.addEventListener('mousedown', ev => { ev.preventDefault(); _epkInsert(em, targetId); });
              grid.appendChild(b);
            }));
          } else {
            const list = emojis.filter(e => !q || e.name.toLowerCase().includes(q));
            if (!list.length) { grid.innerHTML = '<span class="epk-empty">' + (isAR ? 'لا يوجد' : 'No custom emojis') + '</span>'; return; }
            list.forEach(e => {
              const b = document.createElement('button');
              b.type = 'button'; b.className = 'epk-btn custom-e'; b.title = ':' + e.name + ':';
              b.innerHTML = '<img src="' + e.url + '" alt=":' + e.name + ':" />';
              b.addEventListener('mousedown', ev => { ev.preventDefault(); _epkInsert('<:' + e.name + ':' + e.id + '>', targetId); });
              grid.appendChild(b);
            });
          }
        }
        picker.querySelectorAll('.epk-tab').forEach(tab => {
          tab.addEventListener('click', e => { e.stopPropagation(); picker.querySelectorAll('.epk-tab').forEach(t => t.classList.remove('active')); tab.classList.add('active'); activePanel = tab.dataset.ep; picker.querySelector('.epk-search input').value = ''; _renderEpkGrid(''); });
        });
        picker.querySelector('.epk-search input').addEventListener('input', e => { e.stopPropagation(); _renderEpkGrid(e.target.value); });
        picker.addEventListener('click', e => e.stopPropagation());
        _renderEpkGrid('');
      }
      function _epkInsert(emoji, targetId) {
        const ta = document.getElementById(targetId);
        if (!ta) return;
        const s = ta.selectionStart || 0, e2 = ta.selectionEnd || 0;
        ta.value = ta.value.slice(0, s) + emoji + ta.value.slice(e2);
        ta.selectionStart = ta.selectionEnd = s + emoji.length;
        ta.focus(); ta.dispatchEvent(new Event('input'));
        const epk = document.getElementById('_bld-epk');
        if (epk) { epk.remove(); _epkTarget = null; }
      }
      // Wire the emoji smiley button (not the @ mention one)
      document.querySelector('.bld-emoji-btn:not(#mentionBtn)')?.addEventListener('click', function(e) {
        e.stopPropagation();
        _buildEmojiPicker('msgContent', this);
      });
      document.addEventListener('click', () => { const epk = document.getElementById('_bld-epk'); if (epk) { epk.remove(); _epkTarget = null; } });

      /* ═══ MENTION POPOVER ═══ */
      document.getElementById('mentionBtn')?.addEventListener('click', e => {
        e.stopPropagation();
        if (mentionPop?.classList.contains('open')) { mentionPop.classList.remove('open'); return; }
        renderMentionList('');
        // Position using fixed coords to escape any overflow:hidden parent
        const r = e.currentTarget.getBoundingClientRect();
        const popW = 260;
        const left = Math.max(8, Math.min(r.right - popW, window.innerWidth - popW - 8));
        const spaceAbove = r.top - 8;
        const spaceBelow = window.innerHeight - r.bottom - 8;
        if (mentionPop) {
          mentionPop.style.left = left + 'px';
          if (spaceAbove >= 280 || spaceAbove > spaceBelow) {
            mentionPop.style.bottom = (window.innerHeight - r.top + 6) + 'px';
            mentionPop.style.top = 'auto';
          } else {
            mentionPop.style.top = (r.bottom + 6) + 'px';
            mentionPop.style.bottom = 'auto';
          }
          mentionPop.classList.add('open');
        }
      });
      document.getElementById('mentionSearch')?.addEventListener('input', e => renderMentionList(e.target.value));
      document.querySelectorAll('.mention-mode-tab').forEach(btn => {
        btn.addEventListener('click', () => {
          _mentionMode = btn.dataset.mode;
          document.querySelectorAll('.mention-mode-tab').forEach(b => b.classList.toggle('active', b === btn));
        });
      });
      document.addEventListener('click', e => {
        if (!e.target.closest('#mentionAnchor')) mentionPop?.classList.remove('open');
      });

      /* ═══ SEND LOG MODAL ═══ */
      document.getElementById('sendLogClose')?.addEventListener('click', () => {
        sendLogModal?.classList.remove('open'); _sendLogCtx = null;
      });
      sendLogModal?.addEventListener('click', e => {
        if (e.target === sendLogModal) { sendLogModal.classList.remove('open'); _sendLogCtx = null; }
      });

      /* ═══ SAVE CONFIRM MODAL ═══ */
      document.getElementById('smCancel')?.addEventListener('click', () => saveConfirmModal?.classList.remove('open'));
      saveConfirmModal?.addEventListener('click', e => { if (e.target === saveConfirmModal) saveConfirmModal.classList.remove('open'); });
      document.getElementById('smSave')?.addEventListener('click', () => {
        const mode = document.querySelector('input[name="sendMode"]:checked')?.value || 'new';
        _doActualSave(mode);
      });

      // Close modals on escape / Ctrl+S to save
      document.addEventListener('keydown', e => {
        if ((e.ctrlKey || e.metaKey) && e.key === 's' && builderView.classList.contains('active')) {
          e.preventDefault(); saveBtn.click(); return;
        }
        if (e.key === 'Escape') {
          if (saveConfirmModal?.classList.contains('open')) { saveConfirmModal.classList.remove('open'); return; }
          if (sendLogModal?.classList.contains('open')) { sendLogModal.classList.remove('open'); _sendLogCtx = null; return; }
          if (mentionPop?.classList.contains('open'))  { mentionPop.classList.remove('open'); return; }
          if (btnEditModal.classList.contains('open')) { btnEditModal.classList.remove('open'); _btnEditCtx = null; }
          if (optEditModal.classList.contains('open')) { optEditModal.classList.remove('open'); _optEditCtx = null; }
          if (actionModal.classList.contains('open')) { actionModal.classList.remove('open'); _actionCtx = null; }
          if (deleteModal.classList.contains('open')) { deleteModal.classList.remove('open'); _deleteCtx = null; }
          if (triggersModal?.classList.contains('open')) { triggersModal.classList.remove('open'); renderStatesSidebar(); }
        }
      });

      // Close modals on backdrop click
      [btnEditModal, optEditModal, actionModal, deleteModal, triggersModal].forEach(modal => {
        modal.addEventListener('click', e => { if (e.target === modal) modal.classList.remove('open'); });
      });

      /* ═══ INIT ═══ */
      renderList();

    })();
  </script>
</body>
</html>
